      select: { id: true, status: true },\r\n  39:       });\r\n  40:       if (!space || space.status !== \"ACTIVE\") {\r\n  41:         socket.emit(\"space:error\", {\r\n  42:           code: \"SPACE_NOT_FOUND\",\r\n  43:           message: \"ê³µê°„??ì°¾ì„ ???†ê±°??ë¹„í™œ???íƒœ?…ë‹ˆ??\",\r\n  44:         });\r\n  45:         return;\r\n  46:       }\r\n  47: \r\n  48:       const member = await prisma.spaceMember.findUnique({\r\n  49:         where: { spaceId_userId: { spaceId, userId } },\r\n  50:         select: { id: true, role: true, restriction: true },\r\n  51:       });\r\n  52:       if (!member) {\r\n  53:         socket.emit(\"space:error\", {\r\n  54:           code: \"NOT_A_MEMBER\",\r\n  55:           message: \"??ê³µê°„??ë©¤ë²„ê°€ ?„ë‹™?ˆë‹¤.\",\r\n  56:         });\r\n  57:         return;\r\n  58:       }\r\n  59:       if (member.restriction === \"BANNED\") {\r\n  60:         socket.emit(\"space:error\", {\r\n  61:           code: \"BANNED\",\r\n  62:           message: \"??ê³µê°„?ì„œ ì°¨ë‹¨?˜ì—ˆ?µë‹ˆ??\",\r\n  63:         });\r\n  64:         return;\r\n  65:       }\r\n  66: \r\n  67:       memberId = member.id;\r\n  68:       role = member.role as \"OWNER\" | \"STAFF\" | \"PARTICIPANT\";\r\n  69:       restriction = member.restriction as \"NONE\" | \"MUTED\" | \"BANNED\";\r\n  70:     } catch (err) {\r\n  71:       console.error(\"[Room] join authorization failed:\", err);\r\n  72:       socket.emit(\"space:error\", {\r\n  73:         code: \"JOIN_FAILED\",\r\n  74:         message: \"?…ìž¥ ì²˜ë¦¬ ì¤??¤ë¥˜ê°€ ë°œìƒ?ˆìŠµ?ˆë‹¤.\",\r\n  75:       });\r\n  76:       return;\r\n  77:     }\r\n  78: \r\n  79:     // ?¸ê? ?µê³¼ ?„ì—ë§?room ì°¸ê? + ê²€ì¦ëœ ê¶Œí•œ ?•ë³´ ?¤ì •\r\n  80:     socket.join(spaceId);\r\n  81:     socket.data.spaceId = spaceId;\r\n  82:     socket.data.memberId = memberId;\r\n  83:     socket.data.role = role;\r\n  84:     socket.data.restriction = restriction;\r\n  85: \r\n  86:     const player: PlayerData = {\r\n  87:       userId,\r\n  88:       nickname,\r\n  89:       avatar,\r\n  90:       position: { x: 400, y: 300 }, // ê¸°ë³¸ ?¤í° ?„ì¹˜\r\n  91:     };\r\n  92: \r\n  93:     const players = getSpacePlayers(spaceId);\r\n  94:     players.set(userId, player);\r\n  95: \r\n  96:     // ê¸°ì¡´ ?Œë ˆ?´ì–´ ëª©ë¡ ?„ì†¡\r\n  97:     socket.emit(\"players:list\", {\r\n  98:       players: Array.from(players.values()),\r\n  99:     });\r\n 100: \r\n 101:     // ?¤ë¥¸ ?Œë ˆ?´ì–´?ê²Œ ?…ìž¥ ?Œë¦¼\r\n 102:     socket.to(spaceId).emit(\"player:joined\", player);\r\n 103: \r\n 104:     console.log(\r\n 105:       `[Room] ${nickname} joined ${spaceId} (${players.size} players)`\r\n 106:     );\r\n 107:   });\r\n 108: \r\n 109:   socket.on(\"leave:space\", ({ spaceId }) => {\r\n 110:     leaveSpace(io, socket, spaceId);\r\n 111:   });\r\n 112: \r\n 113:   // ?°ê²° ?´ì œ ???ë™ ?´ìž¥\r\n 114:   socket.on(\"disconnect\", () => {\r\n 115:     const spaceId = socket.data.spaceId;\r\n 116:     if (spaceId) {\r\n 117:       leaveSpace(io, socket, spaceId);\r\n 118:     }\r\n 119:   });\r\n 120: }\r\n 121: \r\n 122: function leaveSpace(io: IO, socket: TypedSocket, spaceId: string) {\r\n 123:   const userId = socket.data.userId;\r\n 124:   const players = getSpacePlayers(spaceId);\r\n 125: \r\n 126:   players.delete(userId);\r\n 127:   socket.leave(spaceId);\r\n 128: \r\n 129:   // ?¤ë¥¸ ?Œë ˆ?´ì–´?ê²Œ ?´ìž¥ ?Œë¦¼\r\n 130:   io.to(spaceId).emit(\"player:left\", { userId });\r\n 131: \r\n 132:   // ë¹?ê³µê°„ ?•ë¦¬\r\n 133:   if (players.size === 0) {\r\n 134:     spacePlayersMap.delete(spaceId);\r\n 135:   }\r\n 136: \r\n 137:   console.log(`[Room] ${userId} left ${spaceId} (${players.size} players)`);\r\n 138: }\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_13","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=1; Get-Content -LiteralPath '\"'server/handlers/chat.ts' | ForEach-Object { '{0,4}: {1}' -f \"'$i, $_; $i++ }'","aggregated_output":"   1: import type { Server, Socket } from \"socket.io\";\r\n   2: import type {\r\n   3:   ClientToServerEvents,\r\n   4:   ServerToClientEvents,\r\n   5: } from \"../../src/features/space/socket/internal/types\";\r\n   6: import { spacePlayersMap } from \"./room\";\r\n   7: import { getPrisma } from \"../lib/prisma\";\r\n   8: import {\r\n   9:   MAX_CONTENT_LENGTH,\r\n  10:   RATE_LIMIT_MS,\r\n  11:   DEFAULT_NICKNAME,\r\n  12: } from \"../../src/features/space/chat/internal/chat-constants\";\r\n  13: \r\n  14: type IO = Server<ClientToServerEvents, ServerToClientEvents>;\r\n  15: type TypedSocket = Socket<ClientToServerEvents, ServerToClientEvents>;\r\n  16: \r\n  17: // Rate limiting: userId ??last message timestamp\r\n  18: const rateLimitMap = new Map<string, number>();\r\n  19: \r\n  20: // In-memory reaction store: messageId ??reactions[]\r\n  21: const messageReactionsMap = new Map<\r\n  22:   string,\r\n  23:   Array<{ type: \"thumbsup\" | \"heart\" | \"check\"; userId: string; userNickname: string }>\r\n  24: >();\r\n  25: \r\n  26: let tempIdCounter = 0;\r\n  27: \r\n  28: function sanitizeContent(raw: string): string {\r\n  29:   const trimmed = raw.trim().slice(0, MAX_CONTENT_LENGTH);\r\n  30:   return trimmed.replace(/[<>]/g, \"\");\r\n  31: }\r\n  32: \r\n  33: function checkRateLimit(userId: string): boolean {\r\n  34:   const now = Date.now();\r\n  35:   const last = rateLimitMap.get(userId) || 0;\r\n  36:   if (now - last < RATE_LIMIT_MS) return false;\r\n  37:   rateLimitMap.set(userId, now);\r\n  38:   return true;\r\n  39: }\r\n  40: \r\n  41: function isMuted(socket: TypedSocket): boolean {\r\n  42:   return socket.data.restriction === \"MUTED\";\r\n  43: }\r\n  44: \r\n  45: function isAdmin(socket: TypedSocket): boolean {\r\n  46:   return socket.data.role === \"OWNER\" || socket.data.role === \"STAFF\";\r\n  47: }\r\n  48: \r\n  49: /** ?‰ë„¤?„ìœ¼ë¡??€ê²??Œì¼“ ì°¾ê¸° */\r\n  50: function findSocketsByNickname(io: IO, spaceId: string, nickname: string): TypedSocket[] {\r\n  51:   const sockets = io.sockets.adapter.rooms.get(spaceId);\r\n  52:   if (!sockets) return [];\r\n  53: \r\n  54:   const result: TypedSocket[] = [];\r\n  55:   const spacePlayers = spacePlayersMap.get(spaceId);\r\n  56: \r\n  57:   for (const socketId of sockets) {\r\n  58:     const s = io.sockets.sockets.get(socketId) as TypedSocket | undefined;\r\n  59:     if (!s) continue;\r\n  60:     const player = spacePlayers?.get(s.data.userId);\r\n  61:     if (player?.nickname === nickname) {\r\n  62:       result.push(s);\r\n  63:     }\r\n  64:   }\r\n  65:   return result;\r\n  66: }\r\n  67: \r\n  68: export function handleChat(io: IO, socket: TypedSocket) {\r\n  69:   // ?€?€ ?¼ë°˜/ê·¸ë£¹ ë©”ì‹œì§€ ?€?€\r\n  70:   socket.on(\"chat:send\", ({ content, type, replyTo }) => {\r\n  71:     const spaceId = socket.data.spaceId;\r\n  72:     const userId = socket.data.userId;\r\n  73:     if (!spaceId || !userId) return;\r\n  74:     if (isMuted(socket)) {\r\n  75:       socket.emit(\"chat:error\", { code: \"MUTED\", message: \"You are muted\" });\r\n  76:       return;\r\n  77:     }\r\n  78:     if (!checkRateLimit(userId)) return;\r\n  79: \r\n  80:     const sanitized = sanitizeContent(content);\r\n  81:     if (sanitized.length === 0) return;\r\n  82: \r\n  83:     const spacePlayers = spacePlayersMap.get(spaceId);\r\n  84:     const player = spacePlayers?.get(userId);\r\n  85:     const nickname = player?.nickname ?? DEFAULT_NICKNAME;\r\n  86: \r\n  87:     const tempId = `srv-${Date.now()}-${++tempIdCounter}`;\r\n  88:     const timestamp = new Date().toISOString();\r\n  89: \r\n  90:     // party ?€?…ì? chat:sendê°€ ?„ë‹Œ party:message ?„ìš© ?¸ë“¤???¬ìš©\r\n  91:     if (type === \"party\") {\r\n  92:       socket.emit(\"chat:error\", { code: \"INVALID_TYPE\", message: \"Use party:message for party chat\" });\r\n  93:       return;\r\n  94:     }\r\n  95: \r\n  96:     const message = {\r\n  97:       tempId,\r\n  98:       userId,\r\n  99:       nickname,\r\n 100:       content: sanitized,\r\n 101:       type: type === \"whisper\" ? \"whisper\" : \"message\",\r\n 102:       timestamp,\r\n 103:       replyTo,\r\n 104:     };\r\n 105: \r\n 106:     // Optimistic broadcast\r\n 107:     io.to(spaceId).emit(\"chat:message\", message);\r\n 108: \r\n 109:     // DB ë¹„ë™ê¸??€??(fire-and-forget, import ?†ì´ ë¡œê·¸ë§?\r\n 110:     saveChatMessageAsync(spaceId, userId, nickname, sanitized, message.type, tempId, replyTo).catch(\r\n 111:       (err) => {\r\n 112:         console.error(\"[Chat] DB save failed:\", err);\r\n 113:         socket.emit(\"chat:messageFailed\", { tempId, error: \"Failed to save message\" });\r\n 114:       }\r\n 115:     );\r\n 116: \r\n 117:     console.log(`[Chat] ${nickname} (${type}): ${sanitized.slice(0, 50)}`);\r\n 118:   });\r\n 119: \r\n 120:   // ?€?€ ê·“ì†ë§??€?€\r\n 121:   socket.on(\"whisper:send\", ({ targetNickname, content }) => {\r\n 122:     const spaceId = socket.data.spaceId;\r\n 123:     const userId = socket.data.userId;\r\n 124:     if (!spaceId || !userId) return;\r\n 125:     if (isMuted(socket)) {\r\n 126:       socket.emit(\"whisper:error\", { code: \"MUTED\", message: \"You are muted\" });\r\n 127:       return;\r\n 128:     }\r\n 129:     if (!checkRateLimit(userId)) return;\r\n 130: \r\n 131:     const sanitized = sanitizeContent(content);\r\n 132:     if (sanitized.length === 0) return;\r\n 133: \r\n 134:     const spacePlayers = spacePlayersMap.get(spaceId);\r\n 135:     const player = spacePlayers?.get(userId);\r\n 136:     const senderNickname = player?.nickname ?? DEFAULT_NICKNAME;\r\n 137: \r\n 138:     const timestamp = new Date().toISOString();\r\n 139: \r\n 140:     // ?€ê²??Œì¼“ ì°¾ê¸°\r\n 141:     const targetSockets = findSocketsByNickname(io, spaceId, targetNickname);\r\n 142:     if (targetSockets.length === 0) {\r\n 143:       socket.emit(\"whisper:error\", { code: \"TARGET_NOT_FOUND\", message: `User \"${targetNickname}\" not found` });\r\n 144:       return;\r\n 145:     }\r\n 146: \r\n 147:     // ?˜ì‹ ?ì—ê²??„ì†¡\r\n 148:     for (const ts of targetSockets) {\r\n 149:       ts.emit(\"whisper:receive\", {\r\n 150:         senderId: userId,\r\n 151:         senderNickname,\r\n 152:         content: sanitized,\r\n 153:         timestamp,\r\n 154:       });\r\n 155:     }\r\n 156: \r\n 157:     // ë°œì‹ ?ì—ê²??•ì¸\r\n 158:     socket.emit(\"whisper:sent\", {\r\n 159:       targetNickname,\r\n 160:       content: sanitized,\r\n 161:       timestamp,\r\n 162:     });\r\n 163: \r\n 164:     console.log(`[Chat] Whisper: ${senderNickname} ??${targetNickname}`);\r\n 165:   });\r\n 166: \r\n 167:   // ?€?€ ë¦¬ì•¡??? ê? ?€?€\r\n 168:   socket.on(\"reaction:toggle\", ({ messageId, reactionType }) => {\r\n 169:     const spaceId = socket.data.spaceId;\r\n 170:     const userId = socket.data.userId;\r\n 171:     if (!spaceId || !userId) return;\r\n 172: \r\n 173:     const spacePlayers = spacePlayersMap.get(spaceId);\r\n 174:     const player = spacePlayers?.get(userId);\r\n 175:     const userNickname = player?.nickname ?? DEFAULT_NICKNAME;\r\n 176: \r\n 177:     let reactions = messageReactionsMap.get(messageId) || [];\r\n 178:     const existing = reactions.findIndex((r) => r.userId === userId && r.type === reactionType);\r\n 179: \r\n 180:     if (existing >= 0) {\r\n 181:       reactions.splice(existing, 1);\r\n 182:     } else {\r\n 183:       reactions.push({ type: reactionType, userId, userNickname });\r\n 184:     }\r\n 185: \r\n 186:     messageReactionsMap.set(messageId, reactions);\r\n 187: \r\n 188:     io.to(spaceId).emit(\"reaction:updated\", {\r\n 189:       messageId,\r\n 190:       reactions: [...reactions],\r\n 191:     });\r\n 192:   });\r\n 193: \r\n 194:   // ?€?€ ë©”ì‹œì§€ ?? œ ?€?€\r\n 195:   socket.on(\"chat:delete\", ({ messageId }) => {\r\n 196:     const spaceId = socket.data.spaceId;\r\n 197:     const userId = socket.data.userId;\r\n 198:     if (!spaceId || !userId) return;\r\n 199:     if (!isAdmin(socket)) {\r\n 200:       socket.emit(\"admin:error\", { code: \"FORBIDDEN\", message: \"Insufficient permissions\" });\r\n 201:       return;\r\n 202:     }\r\n 203: \r\n 204:     const spacePlayers = spacePlayersMap.get(spaceId);\r\n 205:     const player = spacePlayers?.get(userId);\r\n 206:     const deletedBy = player?.nickname ?? \"Admin\";\r\n 207: \r\n 208:     io.to(spaceId).emit(\"chat:messageDeleted\", { messageId, deletedBy });\r\n 209: \r\n 210:     // DB soft delete (ë¹„ë™ê¸?\r\n 211:     softDeleteMessageAsync(messageId, userId).catch((err) =>\r\n 212:       console.error(\"[Chat] DB soft delete failed:\", err)\r\n 213:     );\r\n 214: \r\n 215:     console.log(`[Chat] Message ${messageId} deleted by ${deletedBy}`);\r\n 216:   });\r\n 217: \r\n 218:   // ?€?€ ê´€ë¦?ëª…ë ¹: mute ?€?€\r\n 219:   socket.on(\"admin:mute\", ({ targetNickname, duration }) => {\r\n 220:     const spaceId = socket.data.spaceId;\r\n 221:     if (!spaceId || !isAdmin(socket)) {\r\n 222:       socket.emit(\"admin:error\", { code: \"FORBIDDEN\", message: \"Insufficient permissions\" });\r\n 223:       return;\r\n 224:     }\r\n 225: \r\n 226:     const targetSockets = findSocketsByNickname(io, spaceId, targetNickname);\r\n 227:     for (const ts of targetSockets) {\r\n 228:       ts.data.restriction = \"MUTED\";\r\n 229:     }\r\n 230: \r\n 231:     const spacePlayers = spacePlayersMap.get(spaceId);\r\n 232:     const mutedBy = spacePlayers?.get(socket.data.userId)?.nickname ?? \"Admin\";\r\n 233: \r\n 234:     io.to(spaceId).emit(\"member:muted\", {\r\n 235:       memberId: targetSockets[0]?.data.userId ?? \"\",\r\n 236:       nickname: tar