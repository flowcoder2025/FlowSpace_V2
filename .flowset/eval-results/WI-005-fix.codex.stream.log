r\n 337:     };\r\n 338: \r\n 339:     await prisma.chatMessage.create({\r\n 340:       data: {\r\n 341:         spaceId,\r\n 342:         senderId,\r\n 343:         senderType: \"USER\",\r\n 344:         senderName,\r\n 345:         content,\r\n 346:         type: (messageTypeMap[type] ?? \"MESSAGE\") as \"MESSAGE\" | \"WHISPER\" | \"PARTY\" | \"SYSTEM\" | \"ANNOUNCEMENT\",\r\n 347:       },\r\n 348:     });\r\n 349:   } catch (err) {\r\n 350:     console.error(\"[Chat] DB save error:\", err);\r\n 351:   }\r\n 352: }\r\n 353: \r\n 354: /** DB soft delete (?Œì¼“ ê²½ë¡œ?? */\r\n 355: async function softDeleteMessageAsync(messageId: string, deletedBy: string): Promise<void> {\r\n 356:   try {\r\n 357:     const prisma = await getPrisma();\r\n 358: \r\n 359:     await prisma.chatMessage.update({\r\n 360:       where: { id: messageId },\r\n 361:       data: {\r\n 362:         isDeleted: true,\r\n 363:         deletedBy,\r\n 364:         deletedAt: new Date(),\r\n 365:       },\r\n 366:     });\r\n 367:   } catch (err) {\r\n 368:     console.error(\"[Chat] DB soft delete error:\", err);\r\n 369:   }\r\n 370: }\r\n","exit_code":0,"status":"completed"}}
