erId, action, role }),\r\n  43:       });\r\n  44:       if (!res.ok) {\r\n  45:         const data = await res.json();\r\n  46:         alert(data.error || \"Action failed\");\r\n  47:       }\r\n  48:       onRefresh();\r\n  49:     } catch {\r\n  50:       alert(\"Network error\");\r\n  51:     } finally {\r\n  52:       setActionLoading(null);\r\n  53:     }\r\n  54:   }\r\n  55: \r\n  56:   return (\r\n  57:     <div className=\"overflow-x-auto\">\r\n  58:       <table className=\"w-full text-sm\">\r\n  59:         <thead>\r\n  60:           <tr className=\"border-b border-line text-left text-ink-muted\">\r\n  61:             <th className=\"pb-3 font-medium\">Name</th>\r\n  62:             <th className=\"pb-3 font-medium\">Role</th>\r\n  63:             <th className=\"pb-3 font-medium\">Status</th>\r\n  64:             <th className=\"pb-3 font-medium\">Joined</th>\r\n  65:             <th className=\"pb-3 font-medium text-right\">Actions</th>\r\n  66:           </tr>\r\n  67:         </thead>\r\n  68:         <tbody>\r\n  69:           {members.map((m) => {\r\n  70:             const name = m.user?.name || m.guestSession?.nickname || m.displayName || \"Unknown\";\r\n  71:             const isOwner = m.role === \"OWNER\";\r\n  72:             const isLoading = actionLoading === m.id;\r\n  73: \r\n  74:             return (\r\n  75:               <tr key={m.id} className=\"border-b border-line\">\r\n  76:                 <td className=\"py-3\">\r\n  77:                   <div className=\"font-medium text-ink\">{name}</div>\r\n  78:                   {m.user?.email && (\r\n  79:                     <div className=\"text-xs text-ink-light\">{m.user.email}</div>\r\n  80:                   )}\r\n  81:                   {m.guestSession && (\r\n  82:                     <div className=\"text-xs text-ink-light\">Guest</div>\r\n  83:                   )}\r\n  84:                 </td>\r\n  85:                 <td className=\"py-3\">\r\n  86:                   <span className={`inline-block px-2 py-0.5 rounded text-xs font-medium ${ROLE_COLORS[m.role]}`}>\r\n  87:                     {m.role}\r\n  88:                   </span>\r\n  89:                 </td>\r\n  90:                 <td className=\"py-3\">\r\n  91:                   {m.restriction !== \"NONE\" && (\r\n  92:                     <span className={`inline-block px-2 py-0.5 rounded text-xs font-medium ${RESTRICTION_COLORS[m.restriction]}`}>\r\n  93:                       {m.restriction}\r\n  94:                     </span>\r\n  95:                   )}\r\n  96:                 </td>\r\n  97:                 <td className=\"py-3 text-ink-muted\">\r\n  98:                   {new Date(m.createdAt).toLocaleDateString(\"ko-KR\")}\r\n  99:                 </td>\r\n 100:                 <td className=\"py-3 text-right\">\r\n 101:                   {!isOwner && (\r\n 102:                     <div className=\"relative inline-block\">\r\n 103:                       <select\r\n 104:                         disabled={isLoading}\r\n 105:                         defaultValue=\"\"\r\n 106:                         onChange={(e) => {\r\n 107:                           const val = e.target.value;\r\n 108:                           e.target.value = \"\";\r\n 109:                           if (!val) return;\r\n 110:                           if (val === \"mute\" || val === \"unmute\" || val === \"kick\" || val === \"ban\") {\r\n 111:                             handleAction(m.id, val);\r\n 112:                           } else if (val.startsWith(\"role:\")) {\r\n 113:                             handleAction(m.id, \"changeRole\", val.replace(\"role:\", \"\"));\r\n 114:                           }\r\n 115:                         }}\r\n 116:                         className=\"text-xs border border-line rounded px-2 py-1 bg-white disabled:opacity-50\"\r\n 117:                       >\r\n 118:                         <option value=\"\">Actions...</option>\r\n 119:                         {