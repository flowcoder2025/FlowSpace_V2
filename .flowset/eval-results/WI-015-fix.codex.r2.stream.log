ess\", (value: number) => {\r\n  49:       progressBar.clear();\r\n  50:       progressBar.fillStyle(0x4488ff, 1);\r\n  51:       progressBar.fillRect(x + 2, y + 2, (barWidth - 4) * value, barHeight - 4);\r\n  52: \r\n  53:       eventBridge.emit(GameEvents.ASSET_PROCESSING_PROGRESS, {\r\n  54:         assetId: \"boot\",\r\n  55:         progress: Math.round(value * 100),\r\n  56:       });\r\n  57:     });\r\n  58: \r\n  59:     this.load.on(\"complete\", () => {\r\n  60:       bgBar.destroy();\r\n  61:       progressBar.destroy();\r\n  62:       loadingText.destroy();\r\n  63:     });\r\n  64:   }\r\n  65: \r\n  66:   private loadAPIAssets(): void {\r\n  67:     // API ?愳厠 搿滊摐??牍勲彊旮办澊氙€搿? ?措? 旌愳嫓???愳厠毵?搿滊摐\r\n  68:     // ?れ牅 API ?愳厠?€ ???勴櫂 ??氚标犯?检毚??搿滊摐\r\n  69:     fetchGeneratedAssets().then((assets) => {\r\n  70:       if (assets.length > 0 && this.scene.isActive(SCENE_KEYS.BOOT)) {\r\n  71:         loadAssetsInScene(this, assets);\r\n  72:         this.load.start();\r\n  73:       }\r\n  74:     });\r\n  75:   }\r\n  76: }\r\n","exit_code":0,"status":"completed"}}
