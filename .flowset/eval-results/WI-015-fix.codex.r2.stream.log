y = generateAvatarSpriteFromConfig(scene, avatarConfig);\r\n  44: \r\n  45:     // ?ろ攧?检澊???濎劚 (氍茧Μ ?嗢潓 - 氤搓皠 ?措彊)\r\n  46:     this.sprite = scene.add.sprite(info.x, info.y, textureKey, 0);\r\n  47:     this.sprite.setDepth(DEPTH.PLAYER);\r\n  48:     this.sprite.setScale(PLAYER_SCALE);\r\n  49: \r\n  50:     // ?夒劋??    this.nameText = scene.add.text(info.x, info.y + NAME_OFFSET_Y, info.nickname, {\r\n  51:       fontSize: \"12px\",\r\n  52:       fontStyle: \"bold\",\r\n  53:       color: \"#ffffff\",\r\n  54:       fontFamily: \"Arial, 'Malgun Gothic', sans-serif\",\r\n  55:       backgroundColor: \"#00000088\",\r\n  56:       padding: { x: 4, y: 2 },\r\n  57:     });\r\n  58:     this.nameText.setOrigin(0.5);\r\n  59:     this.nameText.setDepth(DEPTH.PLAYER_NAME);\r\n  60: \r\n  61:     // ?犽媹氅旍澊???濎劚\r\n  62:     this.createAnimations(textureKey);\r\n  63: \r\n  64:     if (info.direction) {\r\n  65:       this.currentDirection = info.direction as Direction;\r\n  66:     }\r\n  67:   }\r\n  68: \r\n  69:   /** Tween 氤搓皠 ?措彊 */\r\n  70:   moveTo(x: number, y: number, direction: string): void {\r\n  71:     this.targetX = x;\r\n  72:     this.targetY = y;\r\n  73:     this.isMoving = true;\r\n  74: \r\n  75:     if (direction) {\r\n  76:       this.currentDirection = direction as Direction;\r\n  77:     }\r\n  78: \r\n  79:     // 瓯逢赴 ?犽媹氅旍澊??    const animKey = `remote-walk-${this.userId}-${this.currentDirection}`;\r\n  80:     if (this.scene.anims.exists(animKey) || this.tryCreateAnim(animKey)) {\r\n  81:       this.sprite.anims.play(animKey, true);\r\n  82:     }\r\n  83: \r\n  84:     // Tween?茧 攵€?滊煬???措彊\r\n  85:     this.scene.tweens.add({\r\n  86:       targets: [this.sprite, this.nameText],\r\n  87:       x: x,\r\n  88:       duration: LERP_DURATION,\r\n  89:       ease: \"Linear\",\r\n  90:     });\r\n  91: \r\n  92:     this.scene.tweens.add({\r\n  93:       targets: this.sprite,\r\n  94:       y: y,\r\n  95:       duration: LERP_DURATION,\r\n  96:  