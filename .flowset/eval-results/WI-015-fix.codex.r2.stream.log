{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -Path '\"'src\\\\features\\\\space\\\\game\\\\internal\\\\remote\\\\remote-player-manager.ts' -Encoding UTF8 | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: /**\r\n   2:  * Remote Player Manager\r\n   3:  *\r\n   4:  * 원격 플레이어 Map 관리 + pending 이벤트 큐\r\n   5:  * EventBridge에서 REMOTE_* 이벤트를 수신하여 처리\r\n   6:  */\r\n   7: \r\n   8: import { eventBridge, GameEvents, type RemotePlayerData } from \"../../events\";\r\n   9: import { RemotePlayerSprite, type RemotePlayerInfo } from \"./remote-player-sprite\";\r\n  10: \r\n  11: interface AvatarUpdateData {\r\n  12:   userId: string;\r\n  13:   avatar: string;\r\n  14: }\r\n  15: \r\n  16: interface PendingEvent {\r\n  17:   type: \"joined\" | \"moved\" | \"left\" | \"avatarUpdated\";\r\n  18:   data: unknown;\r\n  19: }\r\n  20: \r\n  21: export class RemotePlayerManager {\r\n  22:   private players = new Map<string, RemotePlayerSprite>();\r\n  23:   private pendingEvents: PendingEvent[] = [];\r\n  24:   private ready = false;\r\n  25: \r\n  26:   private onRemoteJoined = (payload: unknown) => {\r\n  27:     if (!this.ready) {\r\n  28:       this.pendingEvents.push({ type: \"joined\", data: payload });\r\n  29:       return;\r\n  30:     }\r\n  31:     this.handleJoined(payload as RemotePlayerData);\r\n  32:   };\r\n  33: \r\n  34:   private onRemoteMoved = (payload: unknown) => {\r\n  35:     if (!this.ready) {\r\n  36:       this.pendingEvents.push({ type: \"moved\", data: payload });\r\n  37:       return;\r\n  38:     }\r\n  39:     this.handleMoved(payload as RemotePlayerData);\r\n  40:   };\r\n  41: \r\n  42:   private onRemoteLeft = (payload: unknown) => {\r\n  43:     if (!this.ready) {\r\n  44:       this.pendingEvents.push({ type: \"left\", data: payload });\r\n  45:       return;\r\n  46:     }\r\n  47:     const { userId } = payload as { userId: string };\r\n  48:     this.handleLeft(userId);\r\n  49:   };\r\n  50: \r\n  51:   private onRemoteAvatarUpdated = (payload: unknown) => {\r\n  52:     if (!this.ready) {\r\n  53:       this.pendingEvents.push({ type: \"avatarUpdated\", data: payload });\r\n  54:       return;\r\n  55:     }\r\n  56:     this.handleAvatarUpdated(payload as AvatarUpdateData);\r\n  57:   };\r\n  58: \r\n  59:   constructor(private scene: Phaser.Scene) {\r\n  60:     eventBridge.on(GameEvents.REMOTE_PLAYER_JOINED, this.onRemoteJoined);\r\n  61:     eventBridge.on(GameEvents.REMOTE_PLAYER_MOVED, this.onRemoteMoved);\r\n  62:     eventBridge.on(GameEvents.REMOTE_PLAYER_LEFT, this.onRemoteLeft);\r\n  63:     eventBridge.on(GameEvents.REMOTE_PLAYER_AVATAR_UPDATED, this.onRemoteAvatarUpdated);\r\n  64: \r\n  65:     // 씬 준비 후 pending 이벤트 처리\r\n  66:     this.setReady();\r\n  67:   }\r\n  68: \r\n  69:   /** 준비 완료 → pending 이벤트 처리 */\r\n  70:   setReady(): void {\r\n  71:     this.ready = true;\r\n  72:     for (const event of this.pendingEvents) {\r\n  73:       switch (event.type) {\r\n  74:         case \"joined\":\r\n  75:           this.handleJoined(event.data as RemotePlayerData);\r\n  76:           break;\r\n  77:         case \"moved\":\r\n  78:           this.handleMoved(event.data as RemotePlayerData);\r\n  79:           break;\r\n  80:         case \"left\":\r\n  81:           this.handleLeft((event.data as { userId: string }).userId);\r\n  82:           break;\r\n  83:         case \"avatarUpdated\":\r\n  84:           this.handleAvatarUpdated(event.data as AvatarUpdateData);\r\n  85:           break;\r\n  86:       }\r\n  87:     }\r\n  88:     this.pendingEvents = [];\r\n  89:   }\r\n  90: \r\n  91:   /** 매 프레임 보간 업데이트 */\r\n  92:   update(): void {\r\n  93:     for (const player of this.players.values()) {\r\n  94:       player.update();\r\n  95:     }\r\n  96:   }\r\n  97: \r\n  98:   private handleAvatarUpdated(data: AvatarUpdateData): void {\r\n  99:     const player = this.players.get(data.userId);\r\n 100:     if (player) {\r\n 101:       player.updateAvatar(data.avatar);\r\n 102:     }\r\n 103:   }\r\n 104: \r\n 105:   /** 리소스 정리 */\r\n 106:   destroy(): void {\r\n 107:     eventBridge.off(GameEvents.REMOTE_PLAYER_JOINED, this.onRemoteJoined);\r\n 108:     eventBridge.off(GameEvents.REMOTE_PLAYER_MOVED, this.onRemoteMoved);\r\n 109:     eventBridge.off(GameEvents.REMOTE_PLAYER_LEFT, this.onRemoteLeft);\r\n 110:     eventBridge.off(GameEvents.REMOTE_PLAYER_AVATAR_UPDATED, this.onRemoteAvatarUpdated);\r\n 111: \r\n 112:     for (const player of this.players.values()) {\r\n 113:       player.destroy();\r\n 114:     }\r\n 115:     this.players.clear();\r\n 116:   }\r\n 117: \r\n 118:   private handleJoined(data: RemotePlayerData): void {\r\n 119:     // 이미 존재하면 스킵\r\n 120:     if (this.players.has(data.userId)) return;\r\n 121: \r\n 122:     const info: RemotePlayerInfo = {\r\n 123:       userId: data.userId,\r\n 124:       nickname: data.nickname ?? \"Unknown\",\r\n 125:       avatar: data.avatar ?? \"default\",\r\n 126:       x: data.x,\r\n 127:       y: data.y,\r\n 128:       direction: data.direction,\r\n 129:     };\r\n 130: \r\n 131:     const sprite = new RemotePlayerSprite(this.scene, info);\r\n 132:     this.players.set(data.userId, sprite);\r\n 133:   }\r\n 134: \r\n 135:   private handleMoved(data: RemotePlayerData): void {\r\n 136:     const player = this.players.get(data.userId);\r\n 137:     if (player) {\r\n 138:       player.moveTo(data.x, data.y, data.direction);\r\n 139:     } else {\r\n 140:       // 아직 joined 안 됐으면 자동 추가\r\n 141:       this.handleJoined(data);\r\n 142:     }\r\n 143:   }\r\n 144: \r\n 145:   private handleLeft(userId: string): void {\r\n 146:     const player = this.players.get(userId);\r\n 147:     if (player) {\r\n 148:       player.destroy();\r\n 149:       this.players.delete(userId);\r\n 150:     }\r\n 151:   }\r\n 152: }\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -Path '\"'src\\\\features\\\\space\\\\game\\\\internal\\\\objects\\\\interactive-object.ts' -Encoding UTF8 | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: /**\r\n   2:  * Interactive Object - 인터랙티브 오브젝트\r\n   3:  *\r\n   4:  * 타입별 색상, 글로우 애니메이션, [E] 인디케이터\r\n   5:  */\r\n   6: \r\n   7: import { TILE_SIZE, DEPTH } from \"@/constants/game-constants\";\r\n   8: \r\n   9: export interface InteractiveObjectConfig {\r\n  10:   id: string;\r\n  11:   type: string;\r\n  12:   x: number;\r\n  13:   y: number;\r\n  14:   label?: string;\r\n  15: }\r\n  16: \r\n  17: /** 타입별 색상 */\r\n  18: const TYPE_COLORS: Record<string, number> = {\r\n  19:   portal: 0x8050c0,\r\n  20:   spawn: 0x40c070,\r\n  21:   chest: 0xd4a030,\r\n  22:   npc: 0x4060c0,\r\n  23:   default: 0x808080,\r\n  24: };\r\n  25: \r\n  26: export class InteractiveObject {\r\n  27:   private graphics: Phaser.GameObjects.Graphics;\r\n  28:   private indicator: Phaser.GameObjects.Text;\r\n  29:   private glowTween: Phaser.Tweens.Tween | null = null;\r\n  30:   private isNearby = false;\r\n  31:   readonly id: string;\r\n  32:   readonly type: string;\r\n  33:   readonly worldX: number;\r\n  34:   readonly worldY: number;\r\n  35: \r\n  36:   constructor(private scene: Phaser.Scene, config: InteractiveObjectConfig) {\r\n  37:     this.id = config.id;\r\n  38:     this.type = config.type;\r\n  39:     this.worldX = config.x;\r\n  40:     this.worldY = config.y;\r\n  41: \r\n  42:     const color = TYPE_COLORS[config.type] ?? TYPE_COLORS.default;\r\n  43: \r\n  44:     // 글로우 그래픽\r\n  45:     this.graphics = scene.add.graphics();\r\n  46:     this.graphics.setDepth(DEPTH.OBJECTS - 1);\r\n  47:     this.graphics.setPosition(config.x, config.y);\r\n  48:     this.graphics.setAlpha(0);\r\n  49: \r\n  50:     this.drawGlow(color);\r\n  51: \r\n  52:     // [E] 인디케이터\r\n  53:     const label = config.label ?? \"[E]\";\r\n  54:     this.indicator = scene.add.text(config.x, config.y - TILE_SIZE, label, {\r\n  55:       fontSize: \"12px\",\r\n  56:       color: \"#ffffff\",\r\n  57:       fontFamily: \"monospace\",\r\n  58:       backgroundColor: \"#000000aa\",\r\n  59:       padding: { x: 4, y: 2 },\r\n  60:     });\r\n  61:     this.indicator.setOrigin(0.5);\r\n  62:     this.indicator.setDepth(DEPTH.UI);\r\n  63:     this.indicator.setVisible(false);\r\n  64:   }\r\n  65: \r\n  66:   /** 근접 상태 설정 */\r\n  67:   setNearby(nearby: boolean): void {\r\n  68:     if (this.isNearby === nearby) return;\r\n  69:     this.isNearby = nearby;\r\n  70: \r\n  71:     if (nearby) {\r\n  72:       this.showIndicator();\r\n  73:       this.startGlow();\r\n  74:     } else {\r\n  75:       this.hideIndicator();\r\n  76:       this.stopGlow();\r\n  77:     }\r\n  78:   }\r\n  79: \r\n  80:   /** 리소스 정리 */\r\n  81:   destroy(): void {\r\n  82:     this.glowTween?.destroy();\r\n  83:     this.graphics.destroy();\r\n  84:     this.indicator.destroy();\r\n  85:   }\r\n  86: \r\n  87:   private drawGlow(color: number): void {\r\n  88:     this.graphics.fillStyle(color, 0.3);\r\n  89:     this.graphics.fillCircle(0, 0, TILE_SIZE * 0.8);\r\n  90:   }\r\n  91: \r\n  92:   private showIndicator(): void {\r\n  93:     this.indicator.setVisible(true);\r\n  94: \r\n  95:     // 떠다니는 애니메이션\r\n  96:     this.scene.tweens.add({\r\n  97:       targets: this.indicator,\r\n  98:       y: this.worldY - TILE_SIZE - 4,\r\n  99:       duration: 600,\r\n 100:       yoyo: true,\r\n 101:       repeat: -1,\r\n 102:       ease: \"Sine.easeInOut\",\r\n 103:     });\r\n 104:   }\r\n 105: \r\n 106:   private hideIndicator(): void {\r\n 107:     this.indicator.setVisible(false);\r\n 108:     this.scene.tweens.killTweensOf(this.indicator);\r\n 109:     this.indicator.setPosition(this.worldX, this.worldY - TILE_SIZE);\r\n 110:   }\r\n 111: \r\n 112:   private startGlow(): void {\r\n 113:     this.graphics.setAlpha(0.4);\r\n 114:     this.glowTween = this.scene.tweens.add({\r\n 115:       targets: this.graphics,\r\n 116:       alpha: 0.8,\r\n 117:       duration: 800,\r\n 118:       yoyo: true,\r\n 119:       repeat: -1,\r\n 120:       ease: \"Sine.easeInOut\",\r\n 121:     });\r\n 122:   }\r\n 123: \r\n 124:   private stopGlow(): void {\r\n 125:     if (this.glowTween) {\r\n 126:       this.glowTween.destroy();\r\n 127:       this.glowTween = null;\r\n 128:     }\r\n 129:     this.graphics.setAlpha(0);\r\n 130:   }\r\n 131: }\r\n","exit_code":0,"status":"completed"}}
