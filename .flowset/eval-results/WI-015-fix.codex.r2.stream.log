{"type":"item.completed","item":{"id":"item_18","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -Path '\"'src\\\\features\\\\space\\\\game\\\\internal\\\\objects\\\\object-manager.ts' -Encoding UTF8 | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: /**\r\n   2:  * Object Manager - 인터랙티브 오브젝트 레지스트리 + 근접 체크\r\n   3:  *\r\n   4:  * OBJECT_INTERACT 이벤트를 EventBridge로 발행\r\n   5:  * EDITOR_MAP_LOADED 이벤트로 동적 오브젝트 로딩 지원\r\n   6:  */\r\n   7: \r\n   8: import { TILE_SIZE, INTERACT_DISTANCE } from \"@/constants/game-constants\";\r\n   9: import { eventBridge, GameEvents } from \"../../events\";\r\n  10: import type { EditorMapLoadedPayload, EditorObjectPlacedPayload, EditorObjectMovedPayload, EditorObjectDeletedPayload } from \"../../events\";\r\n  11: import { InteractiveObject, type InteractiveObjectConfig } from \"./interactive-object\";\r\n  12: \r\n  13: export class ObjectManager {\r\n  14:   private objects = new Map<string, InteractiveObject>();\r\n  15:   private nearestObject: InteractiveObject | null = null;\r\n  16:   private interactKey: Phaser.Input.Keyboard.Key;\r\n  17: \r\n  18:   constructor(private scene: Phaser.Scene) {\r\n  19:     this.interactKey = scene.input.keyboard!.addKey(\r\n  20:       Phaser.Input.Keyboard.KeyCodes.E\r\n  21:     );\r\n  22:     this.interactKey.on(\"down\", this.onInteract);\r\n  23: \r\n  24:     // EventBridge 리스너: 동적 오브젝트 로딩\r\n  25:     eventBridge.on(GameEvents.EDITOR_MAP_LOADED, this.onMapLoaded);\r\n  26:     eventBridge.on(GameEvents.EDITOR_OBJECT_PLACED, this.onObjectPlaced);\r\n  27:     eventBridge.on(GameEvents.EDITOR_OBJECT_MOVED, this.onObjectMoved);\r\n  28:     eventBridge.on(GameEvents.EDITOR_OBJECT_DELETED, this.onObjectDeleted);\r\n  29: \r\n  30:     this.registerMapObjects();\r\n  31:   }\r\n  32: \r\n  33:   /** 근접 체크 (매 프레임) */\r\n  34:   checkProximity(playerX: number, playerY: number): void {\r\n  35:     let nearest: InteractiveObject | null = null;\r\n  36:     let nearestDist = Infinity;\r\n  37: \r\n  38:     for (const obj of this.objects.values()) {\r\n  39:       const dx = playerX - obj.worldX;\r\n  40:       const dy = playerY - obj.worldY;\r\n  41:       const dist = Math.sqrt(dx * dx + dy * dy);\r\n  42: \r\n  43:       if (dist < INTERACT_DISTANCE && dist < nearestDist) {\r\n  44:         nearest = obj;\r\n  45:         nearestDist = dist;\r\n  46:       }\r\n  47: \r\n  48:       obj.setNearby(false);\r\n  49:     }\r\n  50: \r\n  51:     if (nearest) {\r\n  52:       nearest.setNearby(true);\r\n  53:     }\r\n  54:     this.nearestObject = nearest;\r\n  55:   }\r\n  56: \r\n  57:   /** 리소스 정리 */\r\n  58:   destroy(): void {\r\n  59:     this.interactKey.off(\"down\", this.onInteract);\r\n  60:     eventBridge.off(GameEvents.EDITOR_MAP_LOADED, this.onMapLoaded);\r\n  61:     eventBridge.off(GameEvents.EDITOR_OBJECT_PLACED, this.onObjectPlaced);\r\n  62:     eventBridge.off(GameEvents.EDITOR_OBJECT_MOVED, this.onObjectMoved);\r\n  63:     eventBridge.off(GameEvents.EDITOR_OBJECT_DELETED, this.onObjectDeleted);\r\n  64:     for (const obj of this.objects.values()) {\r\n  65:       obj.destroy();\r\n  66:     }\r\n  67:     this.objects.clear();\r\n  68:   }\r\n  69: \r\n  70:   /** [E] 키 입력 시 가장 가까운 오브젝트와 상호작용 */\r\n  71:   private onInteract = (): void => {\r\n  72:     if (!this.nearestObject) return;\r\n  73: \r\n  74:     eventBridge.emit(GameEvents.OBJECT_INTERACT, {\r\n  75:       objectId: this.nearestObject.id,\r\n  76:       type: this.nearestObject.type,\r\n  77:     });\r\n  78:   };\r\n  79: \r\n  80:   /** 맵 데이터에서 인터랙티브 오브젝트 자동 등록 */\r\n  81:   private registerMapObjects(): void {\r\n  82:     // 포털 (고정 위치 - map-data.ts 참조)\r\n  83:     this.addObject({\r\n  84:       id: \"portal-1\",\r\n  85:       type: \"portal\",\r\n  86:       x: 3 * TILE_SIZE + TILE_SIZE / 2,\r\n  87:       y: 14 * TILE_SIZE + TILE_SIZ