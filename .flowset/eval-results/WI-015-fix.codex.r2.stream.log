ing(avatarString);\r\n 155:     const newKey = generateAvatarSpriteFromConfig(this.scene, config);\r\n 156: \r\n 157:     // 旮办〈 ?犽媹氅旍澊???滉卑\r\n 158:     const directions: Direction[] = [\"down\", \"left\", \"right\", \"up\"];\r\n 159:     for (const dir of directions) {\r\n 160:       const key = `remote-walk-${this.userId}-${dir}`;\r\n 161:       if (this.scene.anims.exists(key)) {\r\n 162:         this.scene.anims.remove(key);\r\n 163:       }\r\n 164:     }\r\n 165: \r\n 166:     // ?嶌姢觳?甑愳泊\r\n 167:     this.sprite.setTexture(newKey);\r\n 168: \r\n 169:     // ???犽媹氅旍澊???濎劚\r\n 170:     this.createAnimations(newKey);\r\n 171:     this.sprite.setFrame(IDLE_FRAMES[this.currentDirection]);\r\n 172:   }\r\n 173: \r\n 174:   /** 毽唽???曤Μ */\r\n 175:   destroy(): void {\r\n 176:     // Phaser??GameObject destroy ??攴??€?侅潉 臧€毽偆??tween???愲彊 ?滉卑?橃? ?婋姅??\r\n 177:     // jump tween?€ this(?茧皹 臧濎泊)毳? moveTo tween?€ sprite/nameText毳?target?茧 ?橂?搿?    // 氇憪 氇呾嫓?侅溂搿??滉卑?滊嫟 ???岅创 ??stale tween??onComplete?愳劀 ?岅创??sprite.anims毳?    // 毵岇?瓯半倶(crash) jumpOffsetY毳?臧膘嫚?橂┌ ?胳姢?挫姢毳??§晞?愲姅(leak) 瓴冹潉 彀嫧.\r\n 178:     this.scene.tweens.killTweensOf(this);\r\n 179:     this.scene.tweens.killTweensOf(this.sprite);\r\n 180:     this.scene.tweens.killTweensOf(this.nameText);\r\n 181:     this.sprite.destroy();\r\n 182:     this.nameText.destroy();\r\n 183:   }\r\n 184: \r\n 185:   private createAnimations(textureKey: string): void {\r\n 186:     const directions: Direction[] = [\"down\", \"left\", \"right\", \"up\"];\r\n 187:     for (const dir of directions) {\r\n 188:       const key = `remote-walk-${this.userId}-${dir}`;\r\n 189:       if (!this.scene.anims.exists(key)) {\r\n 190:         this.scene.anims.create({\r\n 191:           key,\r\n 192:           frames: this.scene.anims.generateFrameNumbers(textureKey, {\r\n 193:             start: DIRECTION_FRAMES[dir].start,\r\n 194:             end: DIRECTION_FRAMES[dir].end,\r\n 195:           }),\r\n 196:           frameRate: 8,\r\n 