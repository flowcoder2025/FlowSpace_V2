t.count({ where }),\r\n    ]);\r\n\r\n    return NextResponse.json({\r\n      assets,\r\n      pagination: {\r\n        page,\r\n        limit,\r\n        total,\r\n        totalPages: Math.ceil(total / limit),\r\n      },\r\n    });\r\n  } catch (error) {\r\n    return NextResponse.json(\r\n      {\r\n        error: \"Failed to fetch assets\",\r\n        details: error instanceof Error ? error.message : undefined,\r\n      },\r\n      { status: 500 }\r\n    );\r\n  }\r\n}\r\n","exit_code":0,"status":"completed"}}
