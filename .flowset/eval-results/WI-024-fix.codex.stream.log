{"type":"item.completed","item":{"id":"item_22","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"Get-Content -Path src\\\\features\\\\assets\\\\internal\\\\game-loader.ts\"","aggregated_output":"import { eventBridge, GameEvents } from \"@/features/space/game\";\r\n\r\ninterface AssetMetadata {\r\n  id: string;\r\n  type: string;\r\n  filePath: string;\r\n  name: string;\r\n  metadata?: Record<string, unknown>;\r\n}\r\n\r\n/**\r\n * DB?愳劀 ?愳厠 氅旐??办澊??臁绊殞 ??Phaser texture 搿滊摐毳??勴暅 ?措菠??氚滍枆\r\n */\r\nexport async function loadAssetToPhaser(assetId: string): Promise<void> {\r\n  try {\r\n    const res = await fetch(`/api/assets/${assetId}`);\r\n    if (!res.ok) {\r\n      throw new Error(`Failed to fetch asset: ${res.statusText}`);\r\n    }\r\n\r\n    const asset: AssetMetadata = await res.json();\r\n\r\n    if (!asset.filePath) {\r\n      throw new Error(\"Asset has no file path\");\r\n    }\r\n\r\n    // EventBridge搿?ASSET_GENERATED ?措菠??氚滍枆 ??Phaser?愳劀 ?橃嫚\r\n    eventBridge.emit(GameEvents.ASSET_GENERATED, {\r\n      assetId: asset.id,\r\n      type: asset.type,\r\n      metadata: {\r\n        filePath: asset.filePath,\r\n        name: asset.name,\r\n        ...(asset.metadata || {}),\r\n      },\r\n    });\r\n  } catch (error) {\r\n    eventBridge.emit(GameEvents.ASSET_GENERATION_FAILED, {\r\n      error: error instanceof Error ? error.message : \"Unknown error\",\r\n      params: { assetId },\r\n    });\r\n  }\r\n}\r\n\r\n/**\r\n * ?煬 ?愳厠??Phaser??搿滊摐\r\n */\r\nexport async function loadAssetsToPhaser(assetIds: string[]): Promise<void> {\r\n  await Promise.allSettled(assetIds.map(loadAssetToPhaser));\r\n}\r\n","exit_code":0,"status":"completed"}}
