{"type":"item.completed","item":{"id":"item_53","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"Get-Content -Raw src\\\\__tests__\\\\helpers\\\\api-route.ts\"","aggregated_output":"/**\n * API ?检毎???岇姢???橂媹?????滌垬 牍岆崝 (WI-011)\n *\n * Next.js Route Handler(GET/POST ??毳?vitest?愳劀 歆侅爲 ?胳稖?橁赴 ?勴暅 瓿奠毄 ?犿嫺.\n * ???岇澕?€ mock wiring???橃? ?婈碃 ?旍箔 ?濎劚 路 ?胳厴/??fixture 路 ?戨嫷 ?岇嫳毵??滉车?滊嫟.\n * (auth()/prisma 甑愳泊??vitest??vi.hoisted + vi.mock ?胳澊?ろ寘???岇澕 搿滌滑?措澕\n *  臧??检毎???岇姢???岇澕 ?侂嫧?愳劀 歆侅爲 ?犾柛?挫暭 ?滊嫟 ??欷戩暀??攵堦?.)\n *\n * ?岇姢???岇澕 ?勲Μ?半笖 ?劥 (?检毎??import ?勳棎 ?犾柛):\n *   const { mockAuth, mockPrisma } = vi.hoisted(() => ({\n *     mockAuth: vi.fn(),\n *     mockPrisma: { space: { findMany: vi.fn() } },\n *   }));\n *   vi.mock(\"@/lib/auth\", () => ({ auth: mockAuth }));\n *   vi.mock(\"@/lib/prisma\", () => ({ prisma: mockPrisma }));\n */\nimport { NextRequest } from \"next/server\";\n\nconst TEST_ORIGIN = \"http://localhost\";\n\nexport interface MockSessionUser {\n  id: string;\n  isSuperAdmin?: boolean;\n  name?: string | null;\n  email?: string | null;\n}\n\nexport type MockSession = { user: MockSessionUser } | null;\n\n/** auth()臧€ 氚橅櫂???胳厴 臧濎泊(?愲姅 氙胳澑歃?null)毳?毵岆摖?? */\nexport function makeSession(user: MockSessionUser | null): MockSession {\n  return user ? { user } : null;\n}\n\n/** 炜茧Μ ?岆澕氙疙劙毳?攵欖澑 GET??NextRequest毳?毵岆摖?? */\nexport function buildGetRequest(\n  path: string,\n  params?: Record<string, string>\n): NextRequest {\n  const url = new URL(path, TEST_ORIGIN);\n  if (params) {\n    for (const [key, value] of Object.entries(params)) {\n      url.searchParams.set(key, value);\n    }\n  }\n  return new NextRequest(url);\n}\n\n/** JSON body臧€ ?堧姅 ?旍箔(POST/PATCH ????NextRequest毳?毵岆摖?? */\nexport function buildJsonRequest(\n  path: string,\n  method: string,\n  body: unknown\n): NextRequest {\n  return new NextRequest(new URL(path, TEST_ORIGIN), {\n    method,\n    headers: { \"content-type\": \"application/json\" },\n    body: JSON.stringify(body),\n  });\n}\n\n/** makeSpaceRow ?る矂?检澊??(?愳＜ 氚旉靖???勲摐毵??胳稖) */\nexport interface SpaceRowOverrides {\n  id?: string;\n  name?: string;\n  /** ?胳稖??氤胳澑 氅る矂????暊. null?措┐ 牍勲─氩?members: []) */\n  role?: string | null;\n  memberCount?: number;\n  status?: string;\n}\n\n/**\n * prisma.space.findMany臧€ 氚橅櫂?橂姅 ???曧儨??fixture.\n * route??include({ template, _count, members })毳?氚橃榿?橂┌,\n * ?戨嫷 allowlist ?岅?毳??勴暣 \"?戨嫷???胳稖?橂┐ ???橂姅\" 氙缄皭/?措? ?勲摐\n * (inviteCode/accessSecret/ownerId)???橂弰?侅溂搿??暔?滊嫟.\n */\nexport function makeSpaceRow(overrides: SpaceRowOverrides = {}) {\n  const {\n    id = \"space-1\",\n    name = \"?岇姢??瓿店皠\",\n    role = \"MEMBER\",\n    memberCount = 3,\n    status = \"ACTIVE\",\n  } = overrides;\n\n  return {\n    id,\n    name,\n    description: \"?る獏\",\n    accessType: \"PUBLIC\",\n    maxUsers: 50,\n    logoUrl: null,\n    primaryColor: \"#000000\",\n    createdAt: \"2026-01-01T00:00:00.000Z\",\n    updatedAt: \"2026-01-02T00:00:00.000Z\",\n    status,\n    templateId: \"tpl-1\",\n    // ?戨嫷 allowlist?愳劀 ?滌櫢?橃柎???橂姅 氙缄皭/?措? ?勲摐 (?岅? 臧€??\n    ownerId: \"owner-1\",\n    inviteCode: \"SECRET-INVITE\",\n    accessSecret: \"hashed-secret\",\n    template: { key: \"OFFICE\", name: \"?ろ敿?? },\n    _count: { members: memberCount },\n    members: role === null ? [] : [{ role }],\n  };\n}\n\n/** Response??JSON body毳??€?呹臣 ?粯 ?诫姅?? */\nexport async function readJson<T = unknown>(res: Response): Promise<T> {\n  return (await res.json()) as T;\n}\n\r\n","exit_code":0,"status":"completed"}}
