{"type":"item.completed","item":{"id":"item_5","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"Get-Content -Raw -Path src\\\\lib\\\\csv.ts\"","aggregated_output":"/**\n * CSV ì§ë ¬??ê³µìš© ?¬í¼ (?œìˆ˜ ?¨ìˆ˜ ??DOM/React/?„ë©”??ë¬´ì˜ì¡? WI-031 CSV ?´ë³´?´ê¸°).\n *\n * - RFC 4180 ?´ìŠ¤ì¼€?´í”„: êµ¬ë¶„??`,`)/?°ì˜´??`\"`)/ê°œí–‰(CRÂ·LF) ?¬í•¨ ?€?€ ?°ë”°?´í‘œë¡? *   ê°ì‹¸ê³??´ë? `\"`???´ì¤‘?? ?ˆì½”??êµ¬ë¶„?ëŠ” CRLF.\n * - CSV/?˜ì‹ ?¸ì ??ì¤‘í™”: ?€???„í—˜ ë¬¸ìž(`= + - @` ?ëŠ” ??CR)ë¡??œìž‘?˜ë©´ ?‘ì??°ì˜´?? *   prefixë¡??ìŠ¤??ê°•ì œ(OWASP CSV Injection ??Excel/Sheetsê°€ ?€???˜ì‹?¼ë¡œ ?¤í–‰?˜ëŠ”\n *   ê²?ì°¨ë‹¨). ëª¨ë“  ?€???¼ë¥  ?ìš©(? ë¢° ê°€?¥í•œ ?«ìž/? ì§œ/enum ì»¬ëŸ¼?€ ? ë‘ ?„í—˜ ë¬¸ìžê°€\n *   ?†ì–´ ë¬´ì˜?? ?¬ìš©???œì–´ ?ìŠ¤?¸ë§Œ ?¤ì œë¡?ì¤‘í™”??.\n * - BOM?€ ì§ë ¬??ê²°ê³¼???¬í•¨?˜ì? ?ŠëŠ”???œìˆ˜ ?ìŠ¤??? ì?) ???¤ìš´ë¡œë“œ ê³„ì¸µ??`CSV_BOM`?? *   ?žì— ë¶™ì—¬ Excel ?œê? ?¸ì½”??ê¹¨ì§??ë§‰ëŠ”??\n */\n\n/** Excel??UTF-8 CSVë¥??¬ë°”ë¥??¸ì½”?©ìœ¼ë¡??´ë„ë¡??˜ëŠ” BOM (?¤ìš´ë¡œë“œ ???žì— ë¶™ìž„). */\nexport const CSV_BOM = \"ï»?;\n\n/** RFC 4180 ?ˆì½”??êµ¬ë¶„??(CRLF). */\nconst CSV_LINE_BREAK = \"\\r\\n\";\n\n/** ?€ ? ë‘???¤ë©´ ?˜ì‹?¼ë¡œ ?´ì„?????ˆëŠ” ë¬¸ìž (OWASP CSV Injection). */\nconst FORMULA_INJECTION_PREFIXES = new Set([\"=\", \"+\", \"-\", \"@\", \"\\t\", \"\\r\"]);\n\n/** ?°ì˜´??ê°ì‹¸ê¸°ê? ?„ìš”??ë¬¸ìž (êµ¬ë¶„?Â·ë”°?´í‘œÂ·ê°œí–‰). */\nconst NEEDS_QUOTING_RE = /[\",\\r\\n]/;\n\nfunction escapeCell(value: string): string {\n  let cell = value;\n  // 1) ?˜ì‹ ?¸ì ??ì¤‘í™” ??? ë‘ ?„í—˜ ë¬¸ìžë©??‘ì??°ì˜´??prefix(?ìŠ¤??ê°•ì œ).\n  if (cell.length > 0 && FORMULA_INJECTION_PREFIXES.has(cell[0])) {\n    cell = `'${cell}`;\n  }\n  // 2) RFC 4180 ??êµ¬ë¶„???°ì˜´??ê°œí–‰ ?¬í•¨ ???°ë”°?´í‘œë¡?ê°ì‹¸ê³??´ë? ?°ì˜´???´ì¤‘??\n  if (NEEDS_QUOTING_RE.test(cell)) {\n    cell = `\"${cell.replace(/\"/g, '\"\"')}\"`;\n  }\n  return cell;\n}\n\n/**\n * ?¤ë” + ?‰ë“¤??RFC 4180 CSV ë¬¸