        resolveSpaceRoleDecision({\n          memberRole: \"PARTICIPANT\",\n          restriction: \"MUTED\",\n          isOwner: false,\n          accessType: \"PUBLIC\",\n        })\n      ).toEqual({ action: \"use\", role: \"PARTICIPANT\" });\n    });\n  });\n\n  describe(\"BANNED 氅る矂 ??redirect (role 氍搓?, ?岇紦 join:space ?曧暕)\", () => {\n    it.each([\"OWNER\", \"STAFF\", \"PARTICIPANT\"] as const)(\n      \"BANNED %s ??redirect (admin?挫柎???愲敂??甏€毽?UI 氙鸽吀於?\",\n      (role) => {\n        // 毵??胳 HTTP ?检毎?戈? BANNED 氙戈??澊氙€搿? role??欤茧┐ BANNED admin??        // ?愲敂?半 毵奠潉 ?胳?????堧嫟 ??role氤措嫟 BANNED毳?毹检? 彀嫧?挫暭 ?滊嫟.\n        expect(\n          resolveSpaceRoleDecision({\n            memberRole: role,\n            restriction: \"BANNED\",\n            isOwner: role === \"OWNER\",\n            accessType: \"PUBLIC\",\n          })\n        ).toEqual({ action: \"redirect\" });\n      }\n    );\n  });\n\n  describe(\"氅る矂 ???嗢潓 ??臧€??瓯半? 瓴办爼\", () => {\n    it(\"?る剤?鸽嵃 氅る矂 ???嗢潓 ??create OWNER (self-heal, ?╈劚 ?勲嫎)\", () => {\n      expect(\n        resolveSpaceRoleDecision({\n          memberRole: null,\n          restriction: null,\n          isOwner: true,\n          accessType: \"PRIVATE\",\n        })\n      ).toEqual({ action: \"create\", role: \"OWNER\" });\n    });\n\n    it(\"PUBLIC 牍勲─氩???create PARTICIPANT (?愲彊 臧€??\", () => {\n      expect(\n        resolveSpaceRoleDecision({\n          memberRole: null,\n          restriction: null,\n          isOwner: false,\n          accessType: \"PUBLIC\",\n        })\n      ).toEqual({ action: \"create\", role: \"PARTICIPANT\" });\n    });\n\n    it.each([\"PRIVATE\", \"PASSWORD\"] as const)(\n      \"%s 牍勲─氩???redirect (齑堧? 旖旊摐搿滊 臧€??\",\n      (accessType) => {\n        expect(\n          resolveSpaceRoleDecision({\n            memberRole: null,\n            restriction: null,\n            isOwner: false,\n            accessType,\n          })\n        ).toEqual({ action: \"redirect\" });\n      }\n    );\n  });\n\n