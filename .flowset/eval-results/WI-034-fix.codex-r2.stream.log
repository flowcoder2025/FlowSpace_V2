": \"^4.8.1\",\n    \"tailwind-merge\": \"^2.5.0\",\n    \"tsx\": \"^4.0.0\",\n    \"zustand\": \"^5.0.9\"\n  },\n  \"devDependencies\": {\n    \"@tailwindcss/postcss\": \"^4.0.15\",\n    \"@testing-library/jest-dom\": \"^6.9.1\",\n    \"@testing-library/react\": \"^16.3.2\",\n    \"@types/dompurify\": \"3.0.5\",\n    \"@types/node\": \"^20.0.0\",\n    \"@types/react\": \"^19.0.0\",\n    \"@types/react-dom\": \"^19.0.0\",\n    \"concurrently\": \"^9.2.1\",\n    \"cross-env\": \"^10.1.0\",\n    \"eslint\": \"^9.39.1\",\n    \"eslint-config-next\": \"^16.0.8\",\n    \"jsdom\": \"^28.1.0\",\n    \"playwright\": \"^1.58.2\",\n    \"prisma\": \"^6.0.0\",\n    \"tailwindcss\": \"^4.0.15\",\n    \"typescript\": \"^5.0.0\",\n    \"vitest\": \"^4.0.18\"\n  }\n}\n\r\n","exit_code":0,"status":"completed"}}
