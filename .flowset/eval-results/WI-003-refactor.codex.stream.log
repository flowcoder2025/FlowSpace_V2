{"type":"item.completed","item":{"id":"item_24","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"Get-Content -Raw src\\\\features\\\\space\\\\game\\\\internal\\\\tilemap\\\\map-data.ts\"","aggregated_output":"/**\n * Map Data - 40x30 ê·¸ë¦¬???ˆì´???°ì´?? *\n * 6ê°??ˆì´?? ground, walls, furniture, furniture_top, decorations, collision\n * -1 = ë¹??€?? */\n\nimport { MAP_COLS, MAP_ROWS } from \"@/constants/game-constants\";\nimport { TILE_INDEX } from \"./tileset-generator\";\n\ntype LayerData = number[][];\n\n/** ë¹??ˆì´???ì„± (MAP_ROWS x MAP_COLS, -1 ì±„ì?) */\nexport function createEmptyLayer(): LayerData {\n  return Array.from({ length: MAP_ROWS }, () =>\n    Array.from({ length: MAP_COLS }, () => -1)\n  );\n}\n\n/** ë²”ìœ„ ì±„ìš°ê¸?? í‹¸ */\nfunction fillArea(\n  layer: LayerData,\n  startCol: number,\n  startRow: number,\n  width: number,\n  height: number,\n  tileIndex: number\n): void {\n  for (let r = startRow; r < startRow + height && r < MAP_ROWS; r++) {\n    for (let c = startCol; c < startCol + width && c < MAP_COLS; c++) {\n      layer[r][c] = tileIndex;\n    }\n  }\n}\n\n/** Ground ?ˆì´?? ?ì—­ë³?ë°”ë‹¥ */\nfunction createGroundLayer(): LayerData {\n  const layer = createEmptyLayer();\n  // ?„ì²´ ?˜ë¬´ ë°”ë‹¥\n  fillArea(layer, 0, 0, MAP_COLS, MAP_ROWS, TILE_INDEX.WOOD_FLOOR);\n  // ?°ì¸¡ ?¼ìš´ì§€ ?ì—­: ì¹´íŽ« (col 23~38, row 3~15)\n  fillArea(layer, 23, 3, 16, 13, TILE_INDEX.CARPET);\n  return layer;\n}\n\n/** Walls ?ˆì´?? ?ë‹¨/ì¢Œìš° ë²?+ ?ì—­ ?Œí‹°??*/\nfunction createWallsLayer(): LayerData {\n  const layer = createEmptyLayer();\n  // ?ë‹¨ ë²?  fillArea(layer, 1, 1, MAP_COLS - 2, 1, TILE_INDEX.WALL_TOP);\n  // ì¢Œì¸¡ ë²?  fillArea(layer, 1, 2, 1, MAP_ROWS - 3, TILE_INDEX.WALL_LEFT);\n  // ?°ì¸¡ ë²?  fillArea(layer, MAP_COLS - 2, 2, 1, MAP_ROWS - 3, TILE_INDEX.WALL_RIGHT);\n  // ?ì—­ êµ¬ë¶„ ?Œí‹°??(?…ë¬´-?¼ìš´ì§€ ?¬ì´, col 22, row 3~15)\n  fillArea(layer, 22, 3, 1, 13, TILE_INDEX.WALL_INNER);\n  return layer;\n}\n\n/** Furniture ?ˆì´?? ê°€êµ?ë°°ì¹˜ (?„ìž¬ ë¹„ì–´ ?ˆìŒ ???¤ë¸Œ?íŠ¸ ?œìŠ¤?œìœ¼ë¡??´ì „ ?ˆì •) */\nfunction createFurnitureLayer(): LayerData {\n  return createEmptyLayer();\n}\n\n/** Furniture Top ?ˆì´?? ê°€êµ????Œí’ˆ (?„ìž¬ ë¹„ì–´ ?ˆìŒ) */\nfunction createFurnitureTopLayer(): LayerData {\n  return createEmptyLayer();\n}\n\n/** Decorations ?ˆì´?? ?¸ë? ?¥ì‹ (?„ìž¬ ë¹„ì–´ ?ˆìŒ) */\nfunction createDecorationsLayer(): LayerData {\n  return createEmptyLayer();\n}\n\n/** Collision ?ˆì´?? ë§?ê²½ê³„ë§?*/\nfunction createCollisionLayer(): LayerData {\n  const layer = createEmptyLayer();\n  const C = TILE_INDEX.COLLISION;\n\n  // ë§??¸ê³½ ê²½ê³„ (?Œë ˆ?´ì–´ê°€ ë§?ë°–ìœ¼ë¡??˜ê?ì§€ ?Šë„ë¡?\n  fillArea(layer, 0, 0, MAP_COLS, 1, C); // ?ë‹¨\n  fillArea(layer, 0, MAP_ROWS - 1, MAP_COLS, 1, C); // ?˜ë‹¨\n  fillArea(layer, 0, 0, 1, MAP_ROWS, C); // ì¢Œì¸¡\n  fillArea(layer, MAP_COLS - 1, 0, 1, MAP_ROWS, C); // ?°ì¸¡\n\n  return layer;\n}\n\n/** ?ˆì´???´ë¦„ */\nexport const LAYER_NAMES = {\n  GROUND: \"ground\",\n  WALLS: \"walls\",\n  FURNITURE: \"furniture\",\n  FURNITURE_TOP: \"furniture_top\",\n  DECORATIONS: \"decorations\",\n  COLLISION: \"collision\",\n} as const;\n\n/** ì¶©ëŒ ?ˆì´???´ë¦„ ëª©ë¡ */\nexport const COLLISION_LAYER_NAMES = [\n  LAYER_NAMES.WALLS,\n  LAYER_NAMES.FURNITURE,\n  LAYER_NAMES.COLLISION,\n] as const;\n\nexport interface MapLayerDefinition {\n  name: string;\n  data: LayerData;\n  depth: number;\n  hasCollision: boolean;\n}\n\n/** ëª¨ë“  ?ˆì´???°ì´???ì„± (ê¸°ë³¸ ë§? */\nexport function createMapLayers(): MapLayerDefinition[] {\n  return [\n    { name: LAYER_NAMES.GROUND, data: createGroundLayer(), depth: 0, hasCollision: false },\n    { name: LAYER_NAMES.WALLS, data: createWallsLayer(), depth: 10, hasCollision: true },\n    { name: LAYER_NAMES.FURNITURE, data: createFurnitureLayer(), depth: 20, hasCollision: true },\n    { name: LAYER_NAMES.FURNITURE_TOP, data: createFurnitureTopLayer(), depth: 25, hasCollision: false },\n    { name: LAYER_NAMES.DECORATIONS, data: createDecorationsLayer(), depth: 30, hasCollision: false },\n    { name: LAYER_NAMES.COLLISION, data: createCollisionLayer(), depth: -1, hasCollision: true },\n  ];\n}\n\n/** ?ˆì´???´ë¦„ ??depth/collision ë§¤í•‘ */\nconst LAYER_META: Record<string, { depth: number; hasCollision: boolean }> = {\n  [LAYER_NAMES.GROUND]: { depth: 0, hasCollision: false },\n  [LAYER_NAMES.WALLS]: { depth: 10, hasCollision: true },\n  [LAYER_NAMES.FURNITURE]: { depth: 20, hasCollision: true },\n  [LAYER_NAMES.FURNITURE_TOP]: { depth: 25, hasCollision: false },\n  [LAYER_NAMES.DECORATIONS]: { depth: 30, hasCollision: false },\n  [LAYER_NAMES.COLLISION]: { depth: -1, hasCollision: true },\n};\n\n/** ?€?¥ëœ ë§??°ì´?°ì—???ˆì´???ì„± (DB ?°ì´????MapLayerDefinition[]) */\nexport function createMapLayersFromStored(\n  stored: Record<string, number[][]>\n): MapLayerDefinition[] {\n  const layerOrder = [\n    LAYER_NAMES.GROUND,\n    LAYER_NAMES.WALLS,\n    LAYER_NAMES.FURNITURE,\n    LAYER_NAMES.FURNITURE_TOP,\n    LAYER_NAMES.DECORATIONS,\n    LAYER_NAMES.COLLISION,\n  ] as string[];\n\n  return layerOrder.map((name) => {\n    const meta = LAYER_META[name] ?? { depth: 0, hasCollision: false };\n    const data = stored[name] ?? createEmptyLayer();\n    return { name, data, depth: meta.depth, hasCollision: meta.hasCollision };\n  });\n}\n\n/** ?„ìž¬ ê¸°ë³¸ ë§µì„ ?€??ê°€?¥í•œ ?•ì‹?¼ë¡œ ì¶”ì¶œ */\nexport function extractDefaultMapData(): Record<string, number[][]> {\n  const layers = createMapLayers();\n  const result: Record<string, number[][]> = {};\n  for (const layer of layers) {\n    result[layer.name] = layer.data;\n  }\n  return result;\n}\n\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_22","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"Get-Content -Raw src\\\\features\\\\space\\\\game\\\\internal\\\\tilemap\\\\tilemap-system.ts\"","aggregated_output":"/**\n * Tilemap System\n *\n * Phaser Tilemap ?ì„± + ?ˆì´??êµ¬ì„± + ì¶©ëŒ ?¤ì •\n */\n\nimport { TILE_SIZE, MAP_COLS, MAP_ROWS, MAP_WIDTH, MAP_HEIGHT } from \"@/constants/game-constants\";\nimport { generateTileset, TILESET_KEY } from \"./tileset-generator\";\nimport {\n  createMapLayers,\n  createMapLayersFromStored,\n  COLLISION_LAYER_NAMES,\n  type MapLayerDefinition,\n} from \"./map-data\";\n\nconst TILEMAP_KEY = \"main-map\";\nconst TILESET_NAME = \"main-tileset\";\n\nexport interface TilemapResult {\n  tilemap: Phaser.Tilemaps.Tilemap;\n  layers: Map<string, Phaser.Tilemaps.TilemapLayer>;\n  collisionLayers: Phaser.Tilemaps.TilemapLayer[];\n}\n\n/**\n * Tilemap ?œìŠ¤??ì´ˆê¸°?? *\n * 1. ?„ë¡œ?œì????€?¼ì…‹ ?ì„±\n * 2. Tilemap ?ì„± (make.tilemap)\n * 3. ?ˆì´???ì„± + ?°ì´??ì±„ìš°ê¸? * 4. ì¶©ëŒ ?ˆì´???¤ì •\n *\n * @param externalLayers - DB?ì„œ ê°€?¸ì˜¨ ?ˆì´???°ì´??(?†ìœ¼ë©?ê¸°ë³¸ ë§??¬ìš©)\n */\nexport function createTilemapSystem(\n  scene: Phaser.Scene,\n  externalLayers?: Record<string, number[][]>\n): TilemapResult {\n  // 1. ?€?¼ì…‹ ?ìŠ¤ì²??ì„±\n  generateTileset(scene);\n\n  // 2. Tilemap ?ì„±\n  const tilemap = scene.make.tilemap({\n    key: TILEMAP_KEY,\n    tileWidth: TILE_SIZE,\n    tileHeight: TILE_SIZE,\n    width: MAP_COLS,\n    height: MAP_ROWS,\n    insertNull: true,\n  });\n\n  // 3. ?€?¼ì…‹ ?´ë?ì§€ ?°ê²°\n  const tileset = tilemap.addTilesetImage(TILESET_NAME, TILESET_KEY, TILE_SIZE, TILE_SIZE, 0, 0);\n  if (!tileset) {\n    throw new Error(\"Failed to add tileset image\");\n  }\n\n  // 4. ?ˆì´???ì„± (?¸ë? ?°ì´???°ì„ , ?†ìœ¼ë©?ê¸°ë³¸ ë§?\n  const layerDefs = externalLayers\n    ? createMapLayersFromStored(externalLayers)\n    : createMapLayers();\n  const layers = new Map<string, Phaser.Tilemaps.TilemapLayer>();\n  const collisionLayers: Phaser.Tilemaps.TilemapLayer[] = [];\n\n  for (const def of layerDefs) {\n    const layer = createLayer(tilemap, tileset, def);\n    if (layer) {\n      layers.set(def.name, layer);\n\n      if (def.hasCollision) {\n        collisionLayers.push(layer);\n      }\n    }\n  }\n\n  return { tilemap, layers, collisionLayers };\n}\n\n/** ?¨ì¼ ?ˆì´???ì„± + ?°ì´??ì±„ìš°ê¸?*/\nfunction createLayer(\n  tilemap: Phaser.Tilemaps.Tilemap,\n  tileset: Phaser.Tilemaps.Tileset,\n  def: MapLayerDefinition\n): Phaser.Tilemaps.TilemapLayer | null {\n  const layer = tilemap.createBlankLayer(def.name, tileset, 0, 0, MAP_COLS, MAP_ROWS, TILE_SIZE, TILE_SIZE);\n  if (!layer) return null;\n\n  // ?°ì´??ì±„ìš°ê¸?  for (let row = 0; row < MAP_ROWS; row++) {\n    for (let col = 0; col < MAP_COLS; col++) {\n      const tileIndex = def.data[row][col];\n      if (tileIndex >= 0) {\n        layer.putTileAt(tileIndex, col, row);\n      }\n    }\n  }\n\n  // ê¹Šì´ ?¤ì • (collision ?ˆì´?´ëŠ” ?¨ê?)\n  if (def.depth < 0) {\n    layer.setVisible(false);\n  } else {\n    layer.setDepth(def.depth);\n  }\n\n  // ì¶©ëŒ ?¤ì •\n  if (def.hasCollision) {\n    layer.setCollisionByExclusion([-1]);\n  }\n\n  return layer;\n}\n\n/** ?”ë“œ ë°”ìš´??ë°˜í™˜ */\nexport function getWorldBounds(): { width: number; height: number } {\n  return { width: MAP_WIDTH, height: MAP_HEIGHT };\n}\n\n/** ì¶©ëŒ ?ˆì´???´ë¦„ ëª©ë¡ (?¸ë? ì°¸ì¡°?? */\nexport { COLLISION_LAYER_NAMES };\n\r\n","exit_code":0,"status":"completed"}}
