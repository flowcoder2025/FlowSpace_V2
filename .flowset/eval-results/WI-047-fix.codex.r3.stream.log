{"type":"item.completed","item":{"id":"item_18","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"node -e \\\"const fs=require('fs'); const p='src/features/space/socket/internal/kick-guard.ts'; const s=fs.readFileSync(p,'utf8'); s.split(/\\\\r?\\\\n/).forEach((l,i)=>console.log(String(i+1).padStart(4)+': '+l));\\\"\"","aggregated_output":"   1: /**\n   2:  * 클라이언트 kick 가드(WI-047) — space 단위 자동 재입장 차단.\n   3:  *\n   4:  * 강퇴(`space:error` code=\"KICKED\") 수신 시 해당 space를 짧게 기록해, effect 리마운트/\n   5:  * 소켓 재연결로 join:space가 자동 재발송되는 루프를 끊는다. **최종 강제력은 서버 join:space\n   6:  * 쿨다운**이며 이 가드는 UX 보조다(다중 탭은 모듈 메모리를 공유하지 않으므로 — codex).\n   7:  *\n   8:  * 모듈 레벨 싱글턴이라 use-socket effect가 리마운트돼도 가드 상태가 유지된다.\n   9:  */\n  10: import { createKickCooldown, KICK_COOLDOWN_MS } from \"@/lib/kick-cooldown\";\n  11: \n  12: const guard = createKickCooldown(KICK_COOLDOWN_MS);\n  13: \n  14: /** space를 kick 가드에 등록(KICKED 수신 시). */\n  15: export function markSpaceKicked(spaceId: string): void {\n  16:   guard.mark(spaceId, Date.now());\n  17: }\n  18: \n  19: /** space가 kick 가드 쿨다운 중인지(join 재발송 차단 판정). */\n  20: export function isSpaceKicked(spaceId: string): boolean {\n  21:   return guard.isActive(spaceId, Date.now());\n  22: }\n  23: \n  24: /** space의 kick 가드를 즉시 해제(테스트/재입장 허용). */\n  25: export function clearSpaceKicked(spaceId: string): void {\n  26:   guard.clear(spaceId);\n  27: }\n  28: \n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_17","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"node -e \\\"const fs=require('fs'); const p='server/handlers/room.ts'; const s=fs.readFileSync(p,'utf8'); s.split(/\\\\r?\\\\n/).forEach((l,i)=>{ if(i<220) console.log(String(i+1).padStart(4)+': '+l); });\\\"\"","aggregated_output":"   1: import type { Server, Socket } from \"socket.io\";\n   2: import type {\n   3:   ClientToServerEvents,\n   4:   ServerToClientEvents,\n   5:   PlayerData,\n   6: } from \"../../src/features/space/protocol/internal/socket-events\";\n   7: import { getPrisma } from \"../lib/prisma\";\n   8: import { recordingStates, spotlightStates, proximityStates } from \"../state\";\n   9: import { createKickCooldown, KICK_COOLDOWN_MS } from \"../../src/lib/kick-cooldown\";\n  10: \n  11: type IO = Server<ClientToServerEvents, ServerToClientEvents>;\n  12: type TypedSocket = Socket<ClientToServerEvents, ServerToClientEvents>;\n  13: \n  14: // spaceId → Map<userId, PlayerData>\n  15: export const spacePlayersMap = new Map<string, Map<string, PlayerData>>();\n  16: \n  17: /**\n  18:  * kick 쿨다운(WI-047). 강퇴된 (space,user)를 짧게 기록해, DB 무변경인 kick 직후\n  19:  * 클라가 소켓을 재생성/재연결해 join:space를 자동 재발송해도 즉시 복귀하지 못하게 막는다.\n  20:  * **이 게이트가 최종 강제력** — 클라 가드는 UX 보조이며 다중 탭/구버전 번들은 클라 메모리를\n  21:  * 공유하지 않으므로 서버에서 막아야 한다(codex). 단일 OCI 인스턴스·Redis 없음 → in-memory.\n  22:  * 서버 재시작 시 비워지나 kick은 임시(~30s)라 재시작=재입장 허용이 시맨틱과 무모순.\n  23:  */\n  24: const kickCooldown = createKickCooldown(KICK_COOLDOWN_MS);\n  25: \n  26: function kickKey(spaceId: string, userId: string): string {\n  27:   return `${spaceId}:${userId}`;\n  28: }\n  29: \n  30: /** (space,user)를 kick 쿨다운에 등록(enforce kick 적용 시). */\n  31: export function markUserKicked(spaceId: string, userId: string): void {\n  32:   kickCooldown.mark(kickKey(spaceId, userId), Date.now());\n  33: }\n  34: \n  35: /** (space,user)가 kick 쿨다운 중인지(join 즉시 거부 판정). */\n  36: export function isUserKicked(spaceId: string, userId: string): boolean {\n  37:   return kickCooldown.isActive(kickKey(spaceId, userId), Date.now());\n  38: }\n  39: \n  40: /**\n  41:  * archive 된 공간 deny cache(WI-036, TOCTOU 보강).\n  42:  * archive enforce 적용 시 추가되며, join:space 가 DB 조회와 별개로 즉시 입장을 거부한다.\n  43:  * archive 직전 status=ACTIVE 를 읽고 진행 중이던 in-flight join 이 archive 스냅샷 이후 room 에\n  44:  * 합류해 추방을 놓치는 좁은 창을 닫는다. **근본 방어는 join:space 의 DB status 게이트**이며\n  45:  * 이건 best-effort 보강 — 서버 재시작 시 비워지고 DB 게이트가 최종 방어다.\n  46:  * 공간은 ARCHIVED 단방향(되돌리는 API 없음)이라 항목은 제거하지 않으며, 누적 크기는\n  47:  * 서버 가동 중 archive 된 공간 수로 제한된다.\n  48:  */\n  49: const archivedSpaces = new Set<string>();\n  50: \n  51: /** 공간을 archived deny cache 에 추가한다(archive enforce 적용 시). */\n  52: export function markSpaceArchived(spaceId: string): void {\n  53:   archivedSpaces.add(spaceId);\n  54: }\n  55: \n  56: /** 공간이 archived deny cache 에 있는지(입장 즉시 거부 판정). */\n  57: export function isSpaceArchived(spaceId: string): boolean {\n  58:   return archivedSpaces.has(spaceId);\n  59: }\n  60: \n  61: /**\n  62:  * 공간의 모든 인메모리 인덱스를 일괄 제거(WI-036 archive). spaceId 로 키된 상태는\n  63:  * presence(spacePlayersMap) + media(recording/spotlight/proximity) 가 전부다\n  64:  * (chat 의 rate-limit/reaction 맵은 userId/messageId 키라 공간 범위 아님).\n  65:  * archive 는 공간을 영구 종료시키므로 잔존 상태가 새지 않도록 직접 정리한다.\n  66:  */\n  67: export function purgeSpaceState(spaceId: string): void {\n  68:   spacePlayersMap.delete(spaceId);\n  69:   recordingStates.delete(spaceId);\n  70:   spotlightStates.delete(spaceId);\n  71:   proximityStates.delete(spaceId);\n  72: }\n  73: \n  74: function getSpacePlayers(spaceId: string): Map<string, PlayerData> {\n  75:   if (!spacePlayersMap.has(spaceId)) {\n  76:     spacePlayersMap.set(spaceId, new Map());\n  77:   }\n  78:   return spacePlayersMap.get(spaceId)!;\n  79: }\n  80: \n  81: /** WI-047: 강퇴 쿨다운 중 join 거부 통지(early 체크 + post-await TOCTOU 재확인 공용). */\n  82: const KICKED_JOIN_ERROR = {\n  83:   code: \"KICKED\",\n  84:   message: \"강퇴되어 잠시 후 다시 입장할 수 있습니다.\",\n  85: } as const;\n  86: \n  87: export function handleRoom(io: IO, socket: TypedSocket) {\n  88:   socket.on(\"join:space\", async ({ spaceId, nickname, avatar }) => {\n  89:     // 인증된 userId 사용 (클라이언트 값 무시)\n  90:     const userId = socket.data.userId;\n  91:     if (!userId) return;\n  92: \n  93:     // WI-047: 최근 강퇴(kick) 쿨다운 중이면 즉시 거부. kick은 DB를 바꾸지 않으므로\n  94:     // 이 게이트가 없으면 클라 소켓 재생성/재연결의 자동 join 재발송으로 즉시 복귀한다.\n  95:     // 여기 early 체크는 효율(DB 조회 전 빠른 거부)용 — **권위 검증은 아래 모든 await 이후\n  96:     // socket.join 직전의 재확인**이다(그 사이 kick이 일어나는 TOCTOU를 닫는다).\n  97:     if (isUserKicked(spaceId, userId)) {\n  98:       socket.emit(\"space:error\", KICKED_JOIN_ERROR);\n  99:       return;\n 100:     }\n 101: \n 102:     // join 전 동기 인가 검증: 공간 존재/활성 + 멤버십 + BANNED 차단.\n 103:     // 통과하기 전에는 socket.join / role / presence 등록을 하지 않는다.\n 104:     let role: \"OWNER\" | \"STAFF\" | \"PARTICIPANT\";\n 105:     let restriction: \"NONE\" | \"MUTED\" | \"BANNED\";\n 106:     let memberId: string;\n 107:     try {\n 108:       const prisma = await getPrisma();\n 109: \n 110:       const space = await prisma.space.findUnique({\n 111:         where: { id: spaceId },\n 112:         select: { id: true, status: true },\n 113:       });\n 114:       if (!space || space.status !== \"ACTIVE\") {\n 115:         socket.emit(\"space:error\", {\n 116:           code: \"SPACE_NOT_FOUND\",\n 117:           message: \"공간을 찾을 수 없거나 비활성 상태입니다.\",\n 118:         });\n 119:         return;\n 120:       }\n 121: \n 122:       const member = await prisma.spaceMember.findUnique({\n 123:         where: { spaceId_userId: { spaceId, userId } },\n 124:         select: { id: true, role: true, restriction: true },\n 125:       });\n 126:       if (!member) {\n 127:         socket.emit(\"space:error\", {\n 128:           code: \"NOT_A_MEMBER\",\n 129:           message: \"이 공간의 멤버가 아닙니다.\",\n 130:         });\n 131:         return;\n 132:       }\n 133:       if (member.restriction === \"BANNED\") {\n 134:         socket.emit(\"space:error\", {\n 135:           code: \"BANNED\",\n 136:           message: \"이 공간에서 차단되었습니다.\",\n 137:         });\n 138:         return;\n 139:       }\n 140: \n 141:       memberId = member.id;\n 142:       role = member.role as \"OWNER\" | \"STAFF\" | \"PARTICIPANT\";\n 143:       restriction = member.restriction as \"NONE\" | \"MUTED\" | \"BANNED\";\n 144:     } catch (err) {\n 145:       console.error(\"[Room] join authorization failed:\", err);\n 146:       socket.emit(\"space:error\", {\n 147:         code: \"JOIN_FAILED\",\n 148:         message: \"입장 처리 중 오류가 발생했습니다.\",\n 149:       });\n 150:       return;\n 151:     }\n 152: \n 153:     // TOCTOU 보강(WI-036): DB status 를 읽은 뒤 archive 가 일어났을 수 있다.\n 154:     // 모든 await 이후·room 합류 직전에 deny cache 를 재확인해, in-flight join 이\n 155:     // archive 추방 스냅샷 이후 합류해 살아남는 좁은 창을 닫는다.\n 156:     if (isSpaceArchived(spaceId)) {\n 157:       socket.emit(\"space:error\", {\n 158:         code: \"SPACE_NOT_FOUND\",\n 159:         message: \"공간을 찾을 수 없거나 비활성 상태입니다.\",\n 160:       });\n 161:       return;\n 162:     }\n 163: \n 164:     // TOCTOU 보강(WI-047): DB 조회(await) 동안 이 사용자가 kick 됐을 수 있다. 그 경우\n 165:     // applyEnforcement 의 markUserKicked 는 아직 room 미합류인 이 소켓을 socketsForUser 로\n 166:     // 잡지 못하므로, archive 와 동일하게 socket.join 직전 쿨다운을 재확인해 강퇴 직후\n 167:     // in-flight join 이 살아남는 창을 닫는다(서버 게이트=최종 강제력).\n 168:     if (isUserKicked(spaceId, userId)) {\n 169:       socket.emit(\"space:error\", KICKED_JOIN_ERROR);\n 170:       return;\n 171:     }\n 172: \n 173:     // 인가 통과 후에만 room 참가 + 검증된 권한 정보 설정\n 174:     socket.join(spaceId);\n 175:     socket.data.spaceId = spaceId;\n 176:     socket.data.memberId = memberId;\n 177:     socket.data.role = role;\n 178:     socket.data.restriction = restriction;\n 179: \n 180:     const player: PlayerData = {\n 181:       userId,\n 182:       nickname,\n 183:       avatar,\n 184:       position: { x: 400, y: 300 }, // 기본 스폰 위치\n 185:     };\n 186: \n 187:     const players = getSpacePlayers(spaceId);\n 188:     players.set(userId, player);\n 189: \n 190:     // 기존 플레이어 목록 전송\n 191:     socket.emit(\"players:list\", {\n 192:       players: Array.from(players.values()),\n 193:     });\n 194: \n 195:     // 다른 플레이어에게 입장 알림\n 196:     socket.to(spaceId).emit(\"player:joined\", player);\n 197: \n 198:     console.log(\n 199:       `[Room] ${nickname} joined ${spaceId} (${players.size} players)`\n 200:     );\n 201:   });\n 202: \n 203:   socket.on(\"leave:space\", () => {\n 204:     // 클라이언트가 보낸 spaceId 는 신뢰하지 않는다(communication invariant #3) —\n 205:     // 서버가 인가한 socket.data.spaceId 만 사용.\n 206:     const spaceId = socket.data.spaceId;\n 207:     if (spaceId) leaveSpace(io, socket, spaceId);\n 208:   });\n 209: \n 210:   // 연결 해제 시 자동 퇴장\n 211:   socket.on(\"disconnect\", () => {\n 212:     const spaceId = socket.data.spaceId;\n 213:     if (spaceId) {\n 214:       leaveSpace(io, socket, spaceId);\n 215:     }\n 216:   });\n 217: }\n 218: \n 219: /**\n 220:  * 소켓을 공간에서 물리적으로 분리: 자기 id 를 제외한 모든 room(공간 + 파티) 이탈 +\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_19","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"node -e \\\"const fs=require('fs'); const p='src/features/space/socket/internal/kick-guard.test.ts'; const s=fs.readFileSync(p,'utf8'); s.split(/\\\\r?\\\\n/).forEach((l,i)=>console.log(String(i+1).padStart(4)+': '+l));\\\"\"","aggregated_output":"   1: import { describe, it, expect, beforeEach, afterEach, vi } from \"vitest\";\n   2: import { markSpaceKicked, isSpaceKicked, clearSpaceKicked } from \"./kick-guard\";\n   3: import { KICK_COOLDOWN_MS } from \"@/lib/kick-cooldown\";\n   4: \n   5: // ============================================================\n   6: // WI-047: 클라 kick 가드(모듈 싱글턴). Date.now() 기반이라 fake timer로 검증한다.\n   7: // 싱글턴 상태가 테스트 간 누수되지 않도록 afterEach에서 clear한다.\n   8: // ============================================================\n   9: \n  10: const SPACE = \"space-guard-1\";\n  11: \n  12: beforeEach(() => {\n  13:   vi.useFakeTimers();\n  14:   vi.setSystemTime(0);\n  15:   clearSpaceKicked(SPACE);\n  16: });\n  17: \n  18: afterEach(() => {\n  19:   clearSpaceKicked(SPACE);\n  20:   vi.useRealTimers();\n  21: });\n  22: \n  23: describe(\"kick-guard (WI-047)\", () => {\n  24:   it(\"markSpaceKicked 후 쿨다운 이내는 isSpaceKicked=true\", () => {\n  25:     expect(isSpaceKicked(SPACE)).toBe(false);\n  26:     markSpaceKicked(SPACE);\n  27:     expect(isSpaceKicked(SPACE)).toBe(true);\n  28:     vi.advanceTimersByTime(KICK_COOLDOWN_MS - 1);\n  29:     expect(isSpaceKicked(SPACE)).toBe(true);\n  30:   });\n  31: \n  32:   it(\"쿨다운 경과 후 isSpaceKicked=false\", () => {\n  33:     markSpaceKicked(SPACE);\n  34:     vi.advanceTimersByTime(KICK_COOLDOWN_MS);\n  35:     expect(isSpaceKicked(SPACE)).toBe(false);\n  36:   });\n  37: \n  38:   it(\"clearSpaceKicked는 즉시 해제\", () => {\n  39:     markSpaceKicked(SPACE);\n  40:     expect(isSpaceKicked(SPACE)).toBe(true);\n  41:     clearSpaceKi