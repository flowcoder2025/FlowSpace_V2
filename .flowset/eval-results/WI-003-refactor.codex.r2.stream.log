{"type":"item.completed","item":{"id":"item_23","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"Get-Content -Path src\\\\features\\\\space\\\\game\\\\internal\\\\tilemap\\\\tilemap-system.ts\"","aggregated_output":"/**\r\n * Tilemap System\r\n *\r\n * Phaser Tilemap ?ì„± + ?ˆì´??êµ¬ì„± + ì¶©ëŒ ?¤ì •\r\n */\r\n\r\nimport { TILE_SIZE, MAP_COLS, MAP_ROWS, MAP_WIDTH, MAP_HEIGHT } from \"@/constants/game-constants\";\r\nimport { generateTileset, TILESET_KEY } from \"./tileset-generator\";\r\nimport {\r\n  createMapLayers,\r\n  createMapLayersFromStored,\r\n  COLLISION_LAYER_NAMES,\r\n  type MapLayerDefinition,\r\n} from \"./map-data\";\r\n\r\nconst TILEMAP_KEY = \"main-map\";\r\nconst TILESET_NAME = \"main-tileset\";\r\n\r\nexport interface TilemapResult {\r\n  tilemap: Phaser.Tilemaps.Tilemap;\r\n  layers: Map<string, Phaser.Tilemaps.TilemapLayer>;\r\n  collisionLayers: Phaser.Tilemaps.TilemapLayer[];\r\n}\r\n\r\n/**\r\n * Tilemap ?œìŠ¤??ì´ˆê¸°?? *\r\n * 1. ?„ë¡œ?œì????€?¼ì…‹ ?ì„±\r\n * 2. Tilemap ?ì„± (make.tilemap)\r\n * 3. ?ˆì´???ì„± + ?°ì´??ì±„ìš°ê¸? * 4. ì¶©ëŒ ?ˆì´???¤ì •\r\n *\r\n * @param externalLayers - DB?ì„œ ê°€?¸ì˜¨ ?ˆì´???°ì´??(?†ìœ¼ë©?ê¸°ë³¸ ë§??¬ìš©)\r\n */\r\nexport function createTilemapSystem(\r\n  scene: Phaser.Scene,\r\n  externalLayers?: Record<string, number[][]>\r\n): TilemapResult {\r\n  // 1. ?€?¼ì…‹ ?ìŠ¤ì²??ì„±\r\n  generateTileset(scene);\r\n\r\n  // 2. Tilemap ?ì„±\r\n  const tilemap = scene.make.tilemap({\r\n    key: TILEMAP_KEY,\r\n    tileWidth: TILE_SIZE,\r\n    tileHeight: TILE_SIZE,\r\n    width: MAP_COLS,\r\n    height: MAP_ROWS,\r\n    insertNull: true,\r\n  });\r\n\r\n  // 3. ?€?¼ì…‹ ?´ë?ì§€ ?°ê²°\r\n  const tileset = tilemap.addTilesetImage(TILESET_NAME, TILESET_KEY, TILE_SIZE, TILE_SIZE, 0, 0);\r\n  if (!tileset) {\r\n    throw new Error(\"Failed to add tileset image\");\r\n  }\r\n\r\n  // 4. ?ˆì´???ì„± (?¸ë? ?°ì´???°ì„ , ?†ìœ¼ë©?ê¸°ë³¸ ë§?\r\n  const layerDefs = externalLayers\r\n    ? createMapLayersFromStored(externalLayers)\r\n    : createMapLayers();\r\n  const layers = new Map<string, Phaser.Tilemaps.TilemapLayer>();\r\n  const collisionLayers: Phaser.Tilemaps.TilemapLayer[] = [];\r\n\r\n  for (const def of layerDefs) {\r\n    const layer = createLayer(tilemap, tileset, def);\r\n    if (layer) {\r\n      layers.set(def.name, layer);\r\n\r\n      if (def.hasCollision) {\r\n        collisionLayers.push(layer);\r\n      }\r\n    }\r\n  }\r\n\r\n  return { tilemap, layers, collisionLayers };\r\n}\r\n\r\n/** ?¨ì¼ ?ˆì´???ì„± + ?°ì´??ì±„ìš°ê¸?*/\r\nfunction createLayer(\r\n  tilemap: Phaser.Tilemaps.Tilemap,\r\n  tileset: Phaser.Tilemaps.Tileset,\r\n  def: MapLayerDefinition\r\n): Phaser.Tilemaps.TilemapLayer | null {\r\n  const layer = tilemap.createBlankLayer(def.name, tileset, 0, 0, MAP_COLS, MAP_ROWS, TILE_SIZE, TILE_SIZE);\r\n  if (!layer) return null;\r\n\r\n  // ?°ì´??ì±„ìš°ê¸?  for (let row = 0; row < MAP_ROWS; row++) {\r\n    for (let col = 0; col < MAP_COLS; col++) {\r\n      const tileIndex = def.data[row][col];\r\n      if (tileIndex >= 0) {\r\n        layer.putTileAt(tileIndex, col, row);\r\n      }\r\n    }\r\n  }\r\n\r\n  // ê¹Šì´ ?¤ì • (collision ?ˆì´?´ëŠ” ?¨ê?)\r\n  if (def.depth < 0) {\r\n    layer.setVisible(false);\r\n  } else {\r\n    layer.setDepth(def.depth);\r\n  }\r\n\r\n  // ì¶©ëŒ ?¤ì •\r\n  if (def.hasCollision) {\r\n    layer.setCollisionByExclusion([-1]);\r\n  }\r\n\r\n  return layer;\r\n}\r\n\r\n/** ?”ë“œ ë°”ìš´??ë°˜í™˜ */\r\nexport function getWorldBounds(): { width: number; height: number } {\r\n  return { width: MAP_WIDTH, height: MAP_HEIGHT };\r\n}\r\n\r\n/** ì¶©ëŒ ?ˆì´???´ë¦„ ëª©ë¡ (?¸ë? ì°¸ì¡°?? */\r\nexport { COLLISION_LAYER_NAMES };\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_21","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"Get-Content -Path src\\\\features\\\\space\\\\game\\\\internal\\\\tilemap\\\\map-data.ts\"","aggregated_output":"/**\r\n * Map Data - 40x30 ê·¸ë¦¬???ˆì´???°ì´?? *\r\n * 6ê°??ˆì´?? ground, walls, furniture, furniture_top, decorations, collision\r\n * -1 = ë¹??€?? */\r\n\r\nimport { MAP_COLS, MAP_ROWS } from \"@/constants/game-constants\";\r\nimport { TILE_INDEX } from \"./tileset-generator\";\r\n\r\ntype LayerData = number[][];\r\n\r\n/** ë¹??ˆì´???ì„± (MAP_ROWS x MAP_COLS, -1 ì±„ì?) */\r\nexport function createEmptyLayer(): LayerData {\r\n  return Array.from({ length: MAP_ROWS }, () =>\r\n    Array.from({ length: MAP_COLS }, () => -1)\r\n  );\r\n}\r\n\r\n/** ë²”ìœ„ ì±„ìš°ê¸?? í‹¸ */\r\nfunction fillArea(\r\n  layer: LayerData,\r\n  startCol: number,\r\n  startRow: number,\r\n  width: number,\r\n  height: number,\r\n  tileIndex: number\r\n): void {\r\n  for (let r = startRow; r < startRow + height && r < MAP_ROWS; r++) {\r\n    for (let c = startCol; c < startCol + width && c < MAP_COLS; c++) {\r\n      layer[r][c] = tileIndex;\r\n    }\r\n  }\r\n}\r\n\r\n/** Ground ?ˆì´?? ?ì—­ë³?ë°”ë‹¥ */\r\nfunction createGroundLayer(): LayerData {\r\n  const layer = createEmptyLayer();\r\n  // ?„ì²´ ?˜ë¬´ ë°”ë‹¥\r\n  fillArea(layer, 0, 0, MAP_COLS, MAP_ROWS, TILE_INDEX.WOOD_FLOOR);\r\n  // ?°ì¸¡ ?¼ìš´ì§€ ?ì—­: ì¹´íŽ« (col 23~38, row 3~15)\r\n  fillArea(layer, 23, 3, 16, 13, TILE_INDEX.CARPET);\r\n  return layer;\r\n}\r\n\r\n/** Walls ?ˆì´?? ?ë‹¨/ì¢Œìš° ë²?+ ?ì—­ ?Œí‹°??*/\r\nfunction createWallsLayer(): LayerData {\r\n  const layer = createEmptyLayer();\r\n  // ?ë‹¨ ë²?  fillArea(layer, 1, 1, MAP_COLS - 2, 1, TILE_INDEX.WALL_TOP);\r\n  // ì¢Œì¸¡ ë²?  fillArea(layer, 1, 2, 1, MAP_ROWS - 3, TILE_INDEX.WALL_LEFT);\r\n  // ?°ì¸¡ ë²?  fillArea(layer, MAP_COLS - 2, 2, 1, MAP_ROWS - 3, TILE_INDEX.WALL_RIGHT);\r\n  // ?ì—­ êµ¬ë¶„ ?Œí‹°??(?…ë¬´-?¼ìš´ì§€ ?¬ì´, col 22, row 3~15)\r\n  fillArea(layer, 22, 3, 1, 13, TILE_INDEX.WALL_INNER);\r\n  return layer;\r\n}\r\n\r\n/** Furniture ?ˆì´?? ê°€êµ?ë°°ì¹˜ (?„ìž¬ ë¹„ì–´ ?ˆìŒ ???¤ë¸Œ?íŠ¸ ?œìŠ¤?œìœ¼ë¡??´ì „ ?ˆì •) */\r\nfunction createFurnitureLayer(): LayerData {\r\n  return createEmptyLayer();\r\n}\r\n\r\n/** Furniture Top ?ˆì´?? ê°€êµ????Œí’ˆ (?„ìž¬ ë¹„ì–´ ?ˆìŒ) */\r\nfunction createFurnitureTopLayer(): LayerData {\r\n  return createEmptyLayer();\r\n}\r\n\r\n/** Decorations ?ˆì´?? ?¸ë? ?¥ì‹ (?„ìž¬ ë¹„ì–´ ?ˆìŒ) */\r\nfunction createDecorationsLayer(): LayerData {\r\n  return createEmptyLayer();\r\n}\r\n\r\n/** Collision ?ˆì´?? ë§?ê²½ê³„ë§?*/\r\nfunction createCollisionLayer(): LayerData {\r\n  const layer = createEmptyLayer();\r\n  const C = TILE_INDEX.COLLISION;\r\n\r\n  // ë§??¸ê³½ ê²½ê³„ (?Œë ˆ?´ì–´ê°€ ë§?ë°–ìœ¼ë¡??˜ê?ì§€ ?Šë„ë¡?\r\n  fillArea(layer, 0, 0, MAP_COLS, 1, C); // ?ë‹¨\r\n  fillArea(layer, 0, MAP_ROWS - 1, MAP_COLS, 1, C); // ?˜ë‹¨\r\n  fillArea(layer, 0, 0, 1, MAP_ROWS, C); // ì¢Œì¸¡\r\n  fillArea(layer, MAP_COLS - 1, 0, 1, MAP_ROWS, C); // ?°ì¸¡\r\n\r\n  return layer;\r\n}\r\n\r\n/** ?ˆì´???´ë¦„ */\r\nexport const LAYER_NAMES = {\r\n  GROUND: \"ground\",\r\n  WALLS: \"walls\",\r\n  FURNITURE: \"furniture\",\r\n  FURNITURE_TOP: \"furniture_top\",\r\n  DECORATIONS: \"decorations\",\r\n  COLLISION: \"collision\",\r\n} as const;\r\n\r\n/** ì¶©ëŒ ?ˆì´???´ë¦„ ëª©ë¡ */\r\nexport const COLLISION_LAYER_NAMES = [\r\n  LAYER_NAMES.WALLS,\r\n  LAYER_NAMES.FURNITURE,\r\n  LAYER_NAMES.COLLISION,\r\n] as const;\r\n\r\nexport interface MapLayerDefinition {\r\n  name: string;\r\n  data: LayerData;\r\n  depth: number;\r\n  hasCollision: boolean;\r\n}\r\n\r\n/** ëª¨ë“  ?ˆì´???°ì´???ì„± (ê¸°ë³¸ ë§? */\r\nexport function createMapLayers(): MapLayerDefinition[] {\r\n  return [\r\n    { name: LAYER_NAMES.GROUND, data: createGroundLayer(), depth: 0, hasCollision: false },\r\n    { name: LAYER_NAMES.WALLS, data: createWallsLayer(), depth: 10, hasCollision: true },\r\n    { name: LAYER_NAMES.FURNITURE, data: createFurnitureLayer(), depth: 20, hasCollision: true },\r\n    { name: LAYER_NAMES.FURNITURE_TOP, data: createFurnitureTopLayer(), depth: 25, hasCollision: false },\r\n    { name: LAYER_NAMES.DECORATIONS, data: createDecorationsLayer(), depth: 30, hasCollision: false },\r\n    { name: LAYER_NAMES.COLLISION, data: createCollisionLayer(), depth: -1, hasCollision: true },\r\n  ];\r\n}\r\n\r\n/** ?ˆì´???´ë¦„ ??depth/collision ë§¤í•‘ */\r\nconst LAYER_META: Record<string, { depth: number; hasCollision: boolean }> = {\r\n  [LAYER_NAMES.GROUND]: { depth: 0, hasCollision: false },\r\n  [LAYER_NAMES.WALLS]: { depth: 10, hasCollision: true },\r\n  [LAYER_NAMES.FURNITURE]: { depth: 20, hasCollision: true },\r\n  [LAYER_NAMES.FURNITURE_TOP]: { depth: 25, hasCollision: false },\r\n  [LAYER_NAMES.DECORATIONS]: { depth: 30, hasCollision: false },\r\n  [LAYER_NAMES.COLLISION]: { depth: -1, hasCollision: true },\r\n};\r\n\r\n/** ?€?¥ëœ ë§??°ì´?°ì—???ˆì´???ì„± (DB ?°ì´????MapLayerDefinition[]) */\r\nexport function createMapLayersFromStored(\r\n  stored: Record<string, number[][]>\r\n): MapLayerDefinition[] {\r\n  const layerOrder = [\r\n    LAYER_NAMES.GROUND,\r\n    LAYER_NAMES.WALLS,\r\n    LAYER_NAMES.FURNITURE,\r\n    LAYER_NAMES.FURNITURE_TOP,\r\n    LAYER_NAMES.DECORATIONS,\r\n    LAYER_NAMES.COLLISION,\r\n  ] as string[];\r\n\r\n  return layerOrder.map((name) => {\r\n    const meta = LAYER_META[name] ?? { depth: 0, hasCollision: false };\r\n    const data = stored[name] ?? createEmptyLayer();\r\n    return { name, data, depth: meta.depth, hasCollision: meta.hasCollision };\r\n  });\r\n}\r\n\r\n/** ?„ìž¬ ê¸°ë³¸ ë§µì„ ?€??ê°€?¥í•œ ?•ì‹?¼ë¡œ ì¶”ì¶œ */\r\nexport function extractDefaultMapData(): Record<string, number[][]> {\r\n  const layers = createMapLayers();\r\n  const result: Record<string, number[][]> = {};\r\n  for (const layer of layers) {\r\n    result[layer.name] = layer.data;\r\n  }\r\n  return result;\r\n}\r\n","exit_code":0,"status":"completed"}}
