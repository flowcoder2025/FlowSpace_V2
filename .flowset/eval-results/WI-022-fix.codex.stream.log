{"type":"item.completed","item":{"id":"item_5","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'git diff develop...HEAD -- src/app/api/assets/route.ts'","aggregated_output":"diff --git a/src/app/api/assets/route.ts b/src/app/api/assets/route.ts\nindex 898a9e6..5ec2560 100644\n--- a/src/app/api/assets/route.ts\n+++ b/src/app/api/assets/route.ts\n@@ -1,8 +1,34 @@\n import { NextRequest, NextResponse } from \"next/server\";\n+import { AssetType, AssetStatus } from \"@prisma/client\";\n import { auth } from \"@/lib/auth\";\n import { prisma } from \"@/lib/prisma\";\n+import { parsePageLimit, parsePageNumber } from \"@/lib/pagination\";\n import { toPublicAssetListItem } from \"@/features/assets\";\n \n+/** limit лҜём§Җм • мӢң кё°ліё нҺҳмқҙм§Җ нҒ¬кё° (WI-022 мқҙм „ лҸҷмһ‘ ліҙмЎҙ). */\n+const ASSETS_DEFAULT_LIMIT = 20;\n+/**\n+ * н•„н„° enum allowlist вҖ” Prisma лҹ°нғҖмһ„ enumм—җм„ң лҸ„м¶ң(н•ҳл“ңмҪ”л”© л°°м—ҙ нҡҢн”ј, enum\n+ * м¶”к°Җ мӢң мһҗлҸҷ лҸҷкё°нҷ”). к°’мқҖ лӘЁл‘җ лҢҖл¬ёмһҗлқј мһ…л Ҙмқ„ м •к·ңнҷ”(trim+лҢҖл¬ёмһҗ)н•ң л’Ө кІҖмҰқн•ңлӢӨ.\n+ */\n+const ASSET_TYPE_VALUES = new Set<string>(Object.values(AssetType));\n+const ASSET_STATUS_VALUES = new Set<string>(Object.values(AssetStatus));\n+\n+/**\n+ * мҝјлҰ¬ enum н•„н„°лҘј м •к·ңнҷ”(trim+лҢҖл¬ёмһҗ)В·кІҖмҰқн•ңлӢӨ.\n+ * - null/л№Ҳк°’ вҶ’ undefined (н•„н„° лҜём Ғмҡ©)\n+ * - allowlist л¶Ҳмқјм№ҳ вҶ’ null (нҳём¶ңл¶Җк°Җ 400 INVALID_FILTERлЎң мІҳлҰ¬)\n+ * - мң нҡЁ вҶ’ м •к·ңнҷ”лҗң лҢҖл¬ёмһҗ enum к°’\n+ */\n+function normalizeEnumFilter(\n+  raw: string | null,\n+  allowed: Set<string>\n+): string | undefined | null {\n+  if (!raw) return undefined;\n+  const value = raw.trim().toUpperCase();\n+  return allowed.has(value) ? value : null;\n+}\n+\n /** GET /api/assets - м—җм…Ӣ лӘ©лЎқ (н•„н„°л§Ғ) */\n export async function GET(request: NextRequest) {\n   try {\n@@ -12,11 +38,25 @@ export async function GET(request: NextRequest) {\n     }\n \n     const searchParams = request.nextUrl.searchParams;\n-    const type = searchParams.get(\"type\");\n-    const status = searchParams.get(\"status\");\n     const shared = searchParams.get(\"shared\");\n-    const page = parseInt(searchParams.get(\"page\") || \"1\", 10);\n-    const limit = parseInt(searchParams.get(\"limit\") || \"20\", 10);\n+\n+    // мһ…л Ҙ кІҖмҰқ(WI-022): type/statusлҘј AssetType/AssetStatus allowlistлЎң кІҖмҰқ.\n+    // мһҳлӘ»лҗң enumмқҖ мЎ°мҡ©нһҲ л¬ҙмӢң(м „мІҙ лӘ©лЎқ мқ‘лӢө)н•ҳм§Җ м•Ҡкі  400мңјлЎң кұ°м Ҳ(WI-009 м •н•©).\n+    const type = normalizeEnumFilter(searchParams.get(\"type\"), ASSET_TYPE_VALUES);\n+    const status = normalizeEnumFilter(\n+      searchParams.get(\"status\"),\n+      ASSET_STATUS_VALUES\n+    );\n+    if (type === null || status === null) {\n+      return NextResponse.json(\n+        { error: \"Invalid asset filter\", code: \"INVALID_FILTER\" },\n+        { status: 400 }\n+      );\n+    }\n+\n+    // page/limit м •к·ңнҷ”(WI-022): NaN/0/мқҢмҲҳ вҶ’ мқҢмҲҳ skip(500) л°©м§Җ, limit мғҒн•ң 100.\n+    const page = parsePageNumber(searchParams.get(\"page\"));\n+    const limit = parsePageLimit(searchParams.get(\"limit\"), ASSETS_DEFAULT_LIMIT);\n \n     const where: Record<string, unknown> = {};\n \n@@ -29,10 +69,10 @@ export async function GET(request: NextRequest) {\n     }\n \n     if (type) {\n-      where.type = type.toUpperCase();\n+      where.type = type;\n     }\n     if (status) {\n-      where.status = status.toUpperCase();\n+      where.status = status;\n     }\n \n     // мқ‘лӢө allowlist (WI-021): лӘ©лЎқмқҖ lean DTOл§Ң л°ҳнҷҳн•ңлӢӨ.\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_6","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'git diff develop...HEAD -- src/lib/pagination.test.ts'","aggregated_output":"diff --git a/src/lib/pagination.test.ts b/src/lib/pagination.test.ts\nindex 7956789..edeb2ab 100644\n--- a/src/lib/pagination.test.ts\n+++ b/src/lib/pagination.test.ts\n@@ -3,6 +3,7 @@ import {\n   DEFAULT_PAGE_LIMIT,\n   MAX_PAGE_LIMIT,\n   parsePageLimit,\n+  parsePageNumber,\n   buildCursorPage,\n } from \"./pagination\";\n \n@@ -34,6 +35,61 @@ describe(\"parsePageLimit\", () => {\n     // parseInt(\"12.9\") === 12 (мҶҢмҲҳм җ м ҲмӮӯмқҖ JS parseInt лҸҷмһ‘ вҖ” н—Ҳмҡ©)\n     expect(parsePageLimit(\"12.9\")).toBe(12);\n   });\n+\n+  // WI-022: лқјмҡ°нҠёлі„ кё°ліё нҺҳмқҙм§Җ нҒ¬кё° ліҙмЎҙмқ„ мң„н•ң optional defaultLimit\n+  describe(\"defaultLimit мқёмһҗ (WI-022)\", () => {\n+    it(\"null/л№Ҳк°’/мқҙмғҒм№ҳ вҶ’ м „лӢ¬н•ң defaultLimit\", () => {\n+      expect(parsePageLimit(null, 20)).toBe(20);\n+      expect(parsePageLimit(\"\", 20)).toBe(20);\n+      expect(parsePageLimit(\"0\", 20)).toBe(20);\n+      expect(parsePageLimit(\"-5\", 20)).toBe(20);\n+      expect(parsePageLimit(\"abc\", 20)).toBe(20);\n+    });\n+\n+    it(\"мң нҡЁ м •мҲҳлҠ” defaultLimitкіј л¬ҙкҙҖн•ҳкІҢ к·ёлҢҖлЎң\", () => {\n+      expect(parsePageLimit(\"10\", 20)).toBe(10);\n+      expect(parsePageLimit(\"75\", 20)).toBe(75);\n+    });\n+\n+    it(\"MAX capмқҖ defaultLimitкіј л¬ҙкҙҖн•ҳкІҢ м Ғмҡ©\", () => {\n+      expect(parsePageLimit(\"100000\", 20)).toBe(MAX_PAGE_LIMIT);\n+    });\n+\n+    it(\"мқёмһҗ лҜём§Җм • мӢң DEFAULT_PAGE_LIMIT (кё°мЎҙ нҳём¶ңл¶Җ л¬ҙмҳҒн–Ҙ)\", () => {\n+      expect(parsePageLimit(null)).toBe(DEFAULT_PAGE_LIMIT);\n+    });\n+  });\n+});\n+\n+describe(\"parsePageNumber (WI-022)\", () => {\n+  it(\"null/л№Ҳк°’ вҶ’ 1\", () => {\n+    expect(parsePageNumber(null)).toBe(1);\n+    expect(parsePageNumber(\"\")).toBe(1);\n+  });\n+\n+  it(\"м •мғҒ м–‘мқҳ м •мҲҳ вҶ’ к·ёлҢҖлЎң\", () => {\n+    expect(parsePageNumber(\"1\")).toBe(1);\n+    expect(parsePageNumber(\"2\")).toBe(2);\n+    expect(parsePageNumber(\"999\")).toBe(999);\n+  });\n+\n+  it(\"0/мқҢмҲҳ вҶ’ 1 (мқҢмҲҳ skip л°©м§Җ)\", () => {\n+    expect(parsePageNumber(\"0\")).toBe(1);\n+    expect(parsePageNumber(\"-5\")).toBe(1);\n+  });\n+\n+  it(\"л№„м •мҲҳ/NaN мң л°ң мһ…л Ҙ вҶ’ 1\", () => {\n+    expect(parsePageNumber(\"abc\")).toBe(1);\n+    expect(parsePageNumber(\"NaN\")).toBe(1);\n+  });\n+\n+  it(\"мғҒн•ң м—ҶмқҢ (offset лІ”мң„лҠ” лҚ°мқҙн„° нҒ¬кё°м—җ мқҳмЎҙ)\", () => {\n+    expect(parsePageNumber(\"100000\")).toBe(100000);\n+  });\n+\n+  it(\"мҶҢмҲҳм җ м ҲмӮӯмқҖ parsePageLimitкіј лҸҷмқј мӢңл§ЁнӢұ (parseInt мқјкҙҖм„ұ)\", () => {\n+    expect(parsePageNumber(\"2.9\")).toBe(2);\n+  });\n });\n \n describe(\"buildCursorPage\", () => {\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_4","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'git diff develop...HEAD -- src/lib/pagination.ts'","aggregated_output":"diff --git a/src/lib/pagination.ts b/src/lib/pagination.ts\nindex bb39eff..c90b3e5 100644\n--- a/src/lib/pagination.ts\n+++ b/src/lib/pagination.ts\n@@ -1,9 +1,13 @@\n /**\n- * Cursor кё°л°ҳ нҺҳмқҙм§Җл„Өмқҙм…ҳ кіөмҡ© н—¬нҚј (мҲңмҲҳ н•ЁмҲҳ вҖ” Prisma/React л¬ҙмқҳмЎҙ).\n+ * нҺҳмқҙм§Җл„Өмқҙм…ҳ мҝјлҰ¬ нҢҢмӢұ + ліҖнҷҳ кіөмҡ© н—¬нҚј (мҲңмҲҳ н•ЁмҲҳ вҖ” Prisma/React л¬ҙмқҳмЎҙ).\n  *\n- * мҪ”л“ңлІ мқҙмҠӨ кҙҖлЎҖ(`src/app/api/spaces/[id]/messages/route.ts`)мҷҖ лҸҷмқјн•ң\n- * `take: limit + 1` нҢЁн„ҙмқ„ мәЎмҠҗнҷ”н•ңлӢӨ. мҝјлҰ¬м—җм„ң limitліҙлӢӨ 1кұҙ лҚ” к°Җм ёмҳЁ л’Ө\n- * `buildCursorPage`лЎң мһҳлқј `hasMore`/`nextCursor`лҘј лҸ„м¶ңн•ңлӢӨ.\n+ * - `parsePageLimit`/`parsePageNumber`: мҝјлҰ¬мҠӨнҠёл§Ғ limit/pageлҘј м•Ҳм „н•ң м •мҲҳлЎң м •к·ңнҷ”.\n+ * - `buildCursorPage`: cursor нҺҳмқҙм§Җл„Өмқҙм…ҳмқҳ `take: limit + 1` нҢЁн„ҙ\n+ *   (`src/app/api/spaces/[id]/messages/route.ts` кҙҖлЎҖ)мқ„ мәЎмҠҗнҷ” вҖ” limitліҙлӢӨ 1кұҙ лҚ”\n+ *   к°Җм ёмҳЁ н–үмқ„ мһҳлқј `hasMore`/`nextCursor`лҘј лҸ„м¶ңн•ңлӢӨ.\n+ *\n+ * offset нҺҳмқҙм§Җл„Өмқҙм…ҳ(`skip`/`take`) лқјмҡ°нҠёлҠ” `parsePageNumber`+`parsePageLimit`л§Ң,\n+ * cursor нҺҳмқҙм§Җл„Өмқҙм…ҳ лқјмҡ°нҠёлҠ” `parsePageLimit`+`buildCursorPage`лҘј мӮ¬мҡ©н•ңлӢӨ.\n  */\n \n /** limit лҜём§Җм •/мқҙмғҒм№ҳ мӢң кё°ліё нҺҳмқҙм§Җ нҒ¬кё° */\n@@ -13,15 +17,35 @@ export const MAX_PAGE_LIMIT = 100;\n \n /**\n  * мҝјлҰ¬мҠӨнҠёл§Ғ `limit` к°’мқ„ м•Ҳм „н•ң м •мҲҳ нҺҳмқҙм§Җ нҒ¬кё°лЎң м •к·ңнҷ”н•ңлӢӨ.\n- * - null/л№Ҳк°’/л№„м •мҲҳ/0 мқҙн•ҳ вҶ’ DEFAULT_PAGE_LIMIT\n+ * - null/л№Ҳк°’/л№„м •мҲҳ/0 мқҙн•ҳ вҶ’ `defaultLimit`\n  * - MAX_PAGE_LIMIT мҙҲкіј вҶ’ MAX_PAGE_LIMITлЎң м ҲмғҒ(cap)\n+ *\n+ * @param defaultLimit limit лҜём§Җм •/мқҙмғҒм№ҳ мӢң кё°ліёк°’(лқјмҡ°нҠёлі„ кё°ліё нҺҳмқҙм§Җ нҒ¬кё°лҘј\n+ *   ліҙмЎҙн•ҳкё° мң„н•ң м„ нғқ мқёмһҗ, лҜём§Җм • мӢң DEFAULT_PAGE_LIMIT).\n  */\n-export function parsePageLimit(raw: string | null): number {\n+export function parsePageLimit(\n+  raw: string | null,\n+  defaultLimit: number = DEFAULT_PAGE_LIMIT\n+): number {\n   const n = parseInt(raw ?? \"\", 10);\n-  if (!Number.isFinite(n) || n <= 0) return DEFAULT_PAGE_LIMIT;\n+  if (!Number.isFinite(n) || n <= 0) return defaultLimit;\n   return Math.min(n, MAX_PAGE_LIMIT);\n }\n \n+/**\n+ * мҝјлҰ¬мҠӨнҠёл§Ғ `page`(1-base offset нҺҳмқҙм§Җ лІҲнҳё)лҘј м•Ҳм „н•ң м–‘мқҳ м •мҲҳлЎң м •к·ңнҷ”н•ңлӢӨ.\n+ * - null/л№Ҳк°’/л№„м •мҲҳ/1 лҜёл§Ң вҶ’ 1\n+ * - мғҒн•ң м—ҶмқҢ (offset нҺҳмқҙм§Җ лІ”мң„лҠ” лҚ°мқҙн„° нҒ¬кё°м—җ мқҳмЎҙ)\n+ *\n+ * offset лқјмҡ°нҠём—җм„ң `skip: (page - 1) * limit` кі„мӮ° мӢң pageк°Җ NaN/0/мқҢмҲҳл©ҙ\n+ * мқҢмҲҳ skipмқҙ лҗҳм–ҙ Prismaк°Җ throw(вҶ’500)н•ҳлҚҳ кІғмқ„ л°©м§Җн•ңлӢӨ.\n+ */\n+export function parsePageNumber(raw: string | null): number {\n+  const n = parseInt(raw ?? \"\", 10);\n+  if (!Number.isFinite(n) || n < 1) return 1;\n+  return n;\n+}\n+\n export interface CursorPage<T> {\n   items: T[];\n   nextCursor: string | null;\n","exit_code":0,"status":"completed"}}
