{"type":"item.completed","item":{"id":"item_10","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"Get-Content -Path src\\\\lib\\\\pagination.ts\"","aggregated_output":"/**\r\n * ?ЛңГ¬ВқВҙГ¬В§вӮ¬?ВӨГ¬ВқВҙ??Г¬ВҝВјГ«ВҰВ¬ ?Е’Г¬вҖ№Вұ + Г«ВівӮ¬??ГӘВіВөГ¬ЕЎВ© ?В¬ГӯВҚВј (?Е“Г¬ЛҶЛң ?ВЁГ¬ЛҶЛң ??Prisma/React Г«В¬ВҙГ¬ВқЛңГ¬ВЎ?.\r\n *\r\n * - `parsePageLimit`/`parsePageNumber`: Г¬ВҝВјГ«ВҰВ¬?ВӨГӯЕ ВёГ«В§?limit/pageГ«ВҘ??ЛҶГ¬В вҖһ???вҖўГ¬ЛҶЛңГ«ВЎ??вҖўГӘВ·Е“??\r\n * - `buildCursorPage`: cursor ?ЛңГ¬ВқВҙГ¬В§вӮ¬?ВӨГ¬ВқВҙ?ЛңГ¬ВқЛң `take: limit + 1` ?ВЁГӯвҖһВҙ\r\n *   (`src/app/api/spaces/[id]/messages/route.ts` ГӘВҙвӮ¬Г«ВЎвӮ¬)??Г¬ВәВЎГ¬Е Вҗ????limitГ«ВіВҙГ«вҖ№ВӨ 1ГӘВұ??? *   ГӘВ°вӮ¬?ВёГ¬ЛңВЁ ?вҖ°Г¬ВқвҖһ ?ЛңГ«ВқВј `hasMore`/`nextCursor`Г«ВҘ??вҖһГ¬В¶Е“?Е“Г«вҖ№ВӨ.\r\n *\r\n * offset ?ЛңГ¬ВқВҙГ¬В§вӮ¬?ВӨГ¬ВқВҙ??`skip`/`take`) ?ВјГ¬ЕЎВ°?ВёГ«Е вҖқ `parsePageNumber`+`parsePageLimit`Г«В§?\r\n * cursor ?ЛңГ¬ВқВҙГ¬В§вӮ¬?ВӨГ¬ВқВҙ???ВјГ¬ЕЎВ°?ВёГ«Е вҖқ `parsePageLimit`+`buildCursorPage`Г«ВҘ??В¬Г¬ЕЎВ©?Е“Г«вҖ№ВӨ.\r\n */\r\n\r\n/** limit Г«ВҜВёГ¬????ВҙГ¬Ж’ВҒГ¬В№???ГӘВёВ°Г«ВіВё ?ЛңГ¬ВқВҙГ¬В§вӮ¬ ?В¬ГӘВёВ° */\r\nexport const DEFAULT_PAGE_LIMIT = 50;\r\n/** ?ВҙГ«ВқВј?ВҙГ¬вҖ“Вё?ВёГӘ? ?вҖқГ¬ВІВӯ ГӘВ°вӮ¬?ВҘГӯвҖўЕ“ Г¬ВөЕ“Г«? ?ЛңГ¬ВқВҙГ¬В§вӮ¬ ?В¬ГӘВёВ° (?вҖһГ¬вҖ”Вӯ Г«ВӘВ©Г«ВЎВқ ??ВЈВј Г«В°В©Г¬?) */\r\nexport const MAX_PAGE_LIMIT = 100;\r\n\r\n/**\r\n * Г¬ВҝВјГ«ВҰВ¬?ВӨГӯЕ ВёГ«В§?`limit` ГӘВ°вҖҷГ¬ВқвҖһ ?ЛҶГ¬В вҖһ???вҖўГ¬ЛҶЛң ?ЛңГ¬ВқВҙГ¬В§вӮ¬ ?В¬ГӘВёВ°Г«ВЎ??вҖўГӘВ·Е“?вҖқГӯвҖўЕ“??\r\n * - null/Г«В№ЛҶГӘВ°вҖҷ/Г«В№вҖһГ¬В вҖў??0 ?ВҙГӯвҖўЛң ??`defaultLimit`\r\n * - MAX_PAGE_LIMIT Г¬ВҙЛҶГӘВіВј ??MAX_PAGE_LIMITГ«ВЎ??ЛҶГ¬Ж’ВҒ(cap)\r\n *\r\n * @param defaultLimit limit Г«ВҜВёГ¬????ВҙГ¬Ж’ВҒГ¬В№???ГӘВёВ°Г«ВіВёГӘВ°??ВјГ¬ЕЎВ°?ВёГ«ВівҖһ ГӘВёВ°Г«ВіВё ?ЛңГ¬ВқВҙГ¬В§вӮ¬ ?В¬ГӘВёВ°Г«ВҘ? *   Г«ВіВҙГ¬ВЎВҙ?ЛңГӘВёВ° ?вҖһГӯвҖўЕ“ ?В ГӯЖ’Вқ ?ВёГ¬ЕҫВҗ, Г«ВҜВёГ¬?????DEFAULT_PAGE_LIMIT).\r\n */\r\nexport function parsePageLimit(\r\n  raw: string | null,\r\n  defaultLimit: number = DEFAULT_PAGE_LIMIT\r\n): number {\r\n  const n = parseInt(raw ?? \"\", 10);\r\n  if (!Number.isFinite(n) || n <= 0) return defaultLimit;\r\n  return Math.min(n, MAX_PAGE_LIMIT);\r\n}\r\n\r\n/**\r\n * Г¬ВҝВјГ«ВҰВ¬?ВӨГӯЕ ВёГ«В§?`page`(1-base offset ?ЛңГ¬ВқВҙГ¬В§вӮ¬ Г«ВІЛҶГӯЛңВё)Г«ВҘ??ЛҶГ¬В вҖһ???вҖҳГ¬ВқЛң ?вҖўГ¬ЛҶЛңГ«ВЎ??вҖўГӘВ·Е“?вҖқГӯвҖўЕ“??\r\n * - null/Г«В№ЛҶГӘВ°вҖҷ/Г«В№вҖһГ¬В вҖў??1 Г«ВҜВёГ«В§Е’ ??1\r\n * - ?ВҒГӯвҖўЕ“ ?вҖ Г¬ВқЕ’ (offset ?ЛңГ¬ВқВҙГ¬В§вӮ¬ Г«ВІвҖқГ¬Е“вҖһ???В°Г¬ВқВҙ???В¬ГӘВёВ°???ЛңГ¬ВЎВҙ)\r\n *\r\n * offset ?ВјГ¬ЕЎВ°?ВёГ¬вҖ”Вҗ??`skip: (page - 1) * limit` ГӘВівҖһГ¬вҖҡВ° ??pageГӘВ°вӮ¬ NaN/0/?Е’Г¬ЛҶЛңГ«В©? * ?Е’Г¬ЛҶЛң skip???ЛңГ¬вҖ“Вҙ PrismaГӘВ°вӮ¬ throw(??00)?ЛңГ«ВҚЛң ГӘВІЖ’Г¬ВқвҖһ Г«В°В©Г¬??Е“Г«вҖ№ВӨ.\r\n */\r\nexport function parsePageNumber(raw: string | null): number {\r\n  const n = parseInt(raw ?? \"\", 10);\r\n  if (!Number.isFinite(n) || n < 1) return 1;\r\n  return n;\r\n}\r\n\r\nexport interface CursorPage<T> {\r\n  items: T[];\r\n  nextCursor: string | null;\r\n  hasMore: boolean;\r\n}\r\n\r\n/**\r\n * `take: limit + 1`Г«ВЎ?Г¬ВЎВ°ГӯЕЎЕ’????Г«В°В°Г¬вҖ”Вҙ???ЛңГ¬ВқВҙГ¬В§вӮ¬Г«ВЎ?Г«ВівӮ¬?ЛңГӯвҖўЕ“??\r\n * ?вҖ°Г¬ВқВҙ limitГ«ВіВҙГ«вҖ№ВӨ Г«В§ЕҪГ¬Е“ВјГ«В©?Г«В§ЛҶГ¬?Г«В§??В¬Г«В¶вҖһ) 1ГӘВұВҙГ¬ВқвҖһ ?ЛңГ«ВқВј?ВҙГӘВіВ  ГӘВ·?Г¬В§ВҒГ¬В вҖһ ?вҖ°Г¬ВқЛң idГ«ВҘ? * ?ВӨГ¬ВқЕ’ cursorГ«ВЎ??В¬Г¬ЕЎВ©?Е“Г«вҖ№ВӨ.\r\n *\r\n * @param rows  limit + 1 Г«В§Е’ГӯВҒВј Г¬ВЎВ°ГӯЕЎЕ’?????вҖўГ«В В¬ ?вҖһГ«ВЈЕ’ ?ВҒГӯЖ’Е“, ГӘВ°??вҖ°Г¬? ГӘВіВ Г¬Е“В  `id` Г«ВіВҙГ¬Е“В )\r\n * @param limit ?ЛңГ¬ВқВҙГ¬В§вӮ¬ ?В¬ГӘВёВ°\r\n */\r\nexport function buildCursorPage<T extends { id: string }>(\r\n  rows: T[],\r\n  limit: number\r\n): CursorPage<T> {\r\n  const hasMore = rows.length > limit;\r\n  const items = hasMore ? rows.slice(0, limit) : rows;\r\n  const nextCursor = hasMore ? items[items.length - 1]?.id ?? null : null;\r\n  return { items, nextCursor, hasMore };\r\n}\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_8","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"Get-Content -Path src\\\\app\\\\api\\\\assets\\\\route.ts\"","aggregated_output":"import { NextRequest, NextResponse } from \"next/server\";\r\nimport { AssetType, AssetStatus } from \"@prisma/client\";\r\nimport { auth } from \"@/lib/auth\";\r\nimport { prisma } from \"@/lib/prisma\";\r\nimport { parsePageLimit, parsePageNumber } from \"@/lib/pagination\";\r\nimport { toPublicAssetListItem } from \"@/features/assets\";\r\n\r\n/** limit Г«ВҜВёГ¬?????ГӘВёВ°Г«ВіВё ?ЛңГ¬ВқВҙГ¬В§вӮ¬ ?В¬ГӘВёВ° (WI-022 ?ВҙГ¬В вҖһ ?в„ўГ¬ЕҫвҖҳ Г«ВіВҙГ¬ВЎВҙ). */\r\nconst ASSETS_DEFAULT_LIMIT = 20;\r\n/**\r\n * ?вҖһГӯвҖһВ° enum allowlist ??Prisma ?В°Гӯ???enum?ВҗГ¬вҖһЕ“ ?вҖһГ¬В¶Е“(?ЛңГ«вҖңЕ“Г¬ВҪвҖқГ«вҖқВ© Г«В°В°Г¬вҖ”Вҙ ?Е’ГӯвҖқВј, enum\r\n * Г¬В¶вҖқГӘ? ???ВҗГ«ВҸв„ў ?в„ўГӘВёВ°??. ГӘВ°вҖҷГ¬? Г«ВӘВЁГ«вҖҳВҗ ?вӮ¬Г«В¬ВёГ¬ЕҫВҗ???вҖҰГ«В ВҘ???вҖўГӘВ·Е“??trim+?вӮ¬Г«В¬ВёГ¬ЕҫВҗ)????ГӘВІвӮ¬Г¬ВҰВқГӯвҖўЕ“??\r\n */\r\nconst ASSET_TYPE_VALUES = new Set<string>(Object.values(AssetType));\r\nconst ASSET_STATUS_VALUES = new Set<string>(Object.values(AssetStatus));\r\n\r\n/**\r\n * Г¬ВҝВјГ«ВҰВ¬ enum ?вҖһГӯвҖһВ°Г«ВҘ??вҖўГӘВ·Е“??trim+?вӮ¬Г«В¬ВёГ¬ЕҫВҗ)ГӮВ·ГӘВІвӮ¬Г¬ВҰВқГӯвҖўЕ“??\r\n * - null/Г«В№ЛҶГӘВ°вҖҷ ??undefined (?вҖһГӯвҖһВ° Г«ВҜВёГ¬В ВҒ??\r\n * - allowlist Г«В¶ЛҶГ¬ВқВјГ¬В№???null (?ВёГ¬В¶Е“Г«В¶вӮ¬ГӘВ°вӮ¬ 400 INVALID_FILTERГ«ВЎ?Г¬ВІЛңГ«ВҰВ¬)\r\n * - ?В ГӯЕЎВЁ ???вҖўГӘВ·Е“?вҖқГ«ВҗЕ“ ?вӮ¬Г«В¬ВёГ¬ЕҫВҗ enum ГӘВ°? */\r\nfunction normalizeEnumFilter(\r\n  raw: string | null,\r\n  allowed: Set<string>\r\n): string | undefined | null {\r\n  if (!raw) return undefined;\r\n  const value = raw.trim().toUpperCase();\r\n  return allowed.has(value) ? value : null;\r\n}\r\n\r\n/** GET /api/assets - ?ВҗГ¬вҖҰвҖ№ Г«ВӘВ©Г«ВЎВқ (?вҖһГӯвҖһВ°Г«В§? */\r\nexport async function GET(request: NextRequest) {\r\n  try {\r\n    const session = await auth();\r\n    if (!session?.user?.id) {\r\n      return NextResponse.json({ error: \"Unauthorized\" }, { status: 401 });\r\n    }\r\n\r\n    const searchParams = request.nextUrl.searchParams;\r\n    const shared = searchParams.get(\"shared\");\r\n\r\n    // ?вҖҰГ«В ВҘ ГӘВІвӮ¬Г¬ВҰ?WI-022): type/statusГ«ВҘ?AssetType/AssetStatus allowlistГ«ВЎ?ГӘВІвӮ¬Г¬ВҰ?\r\n    // ?ЛңГ«ВӘВ»??enum?вӮ¬ Г¬ВЎВ°Г¬ЕЎВ©??Г«В¬ВҙГ¬вҖ№Е“(?вҖһГ¬ВІВҙ Г«ВӘВ©Г«ВЎВқ ?вҖҳГ«вҖ№Вө)?ЛңГ¬? ?Е ГӘВіВ  400?ВјГ«ВЎЕ“ ГӘВұВ°Г¬В ЛҶ(WI-009 ?вҖўГӯвҖўВ©).\r\n    const type = normalizeEnumFilter(searchParams.get(\"type\"), ASSET_TYPE_VALUES);\r\n    const status = normalizeEnumFilter(\r\n      searchParams.get(\"status\"),\r\n      ASSET_STATUS_VALUES\r\n    );\r\n    if (type === null || status === null) {\r\n      return NextResponse.json(\r\n        { error: \"Invalid asset filter\", code: \"INVALID_FILTER\" },\r\n        { status: 400 }\r\n      );\r\n    }\r\n\r\n    // page/limit ?вҖўГӘВ·Е“??WI-022): NaN/0/?Е’Г¬ЛҶЛң ???Е’Г¬ЛҶЛң skip(500) Г«В°В©Г¬?, limit ?ВҒГӯвҖўЕ“ 100.\r\n    const page = parsePageNumber(searchParams.get(\"page\"));\r\n    const limit = parsePageLimit(searchParams.get(\"limit\"), ASSETS_DEFAULT_LIMIT);\r\n\r\n    const where: Record<string, unknown> = {};\r\n\r\n    if (shared === \"true\") {\r\n      // ГӘВіВөГ¬ЕЎВ© ?ВҗГ¬вҖҰвҖ№ Г¬ВЎВ°ГӯЕЎЕ’ (?вҖһГ«В°вҖқ?вӮ¬ ?В ГӯЖ’Вқ ??\r\n      where.isShared = true;\r\n    } else {\r\n      // Г«ВіВёГ¬ВқВё ?ВҗГ¬вҖҰвҖ№Г«В§?Г¬ВЎВ°ГӯЕЎЕ’ (IDOR Г«В°В©Г¬?)\r\n      where.userId = session.user.id;\r\n    }\r\n\r\n    if (type) {\r\n      where.type = type;\r\n    }\r\n    if (status) {\r\n      where.status = status;\r\n    }\r\n\r\n    // ?вҖҳГ«вҖ№Вө allowlist (WI-021): Г«ВӘВ©Г«ВЎВқ?вӮ¬ lean DTOГ«В§?Г«В°ЛңГӯв„ўЛң?Е“Г«вҖ№ВӨ.\r\n    // shared=true Г«В¶вҖһГӘВёВ°??owner ГӘВІЕ’Г¬ВқВҙ???вҖ Г¬ВқВҙ ?вӮ¬??ГӘВіВөГ¬Е“В  ?ВҗГ¬вҖҡВ°??Г«В°ЛңГӯв„ўЛң?ЛңГ«?Г«ВЎ??ЛңГ«ВҸвҖһ??ГӘВіВөГ¬Е“В )\r\n    // prompt/workflow/comfyuiJobId(Г«ВҜВјГӘВ°Вҗ)ГӮВ·metadataГӮВ·user??select?ЛңГ¬? ?Е ГӘВіВ ,\r\n    // toPublicAssetListItemГ«ВЎ??вҖҳГ«вҖ№Вө ??Г¬В§вҖҳГӯвҖўВ©??ГӘВіВ Г¬В вҖў?Е“Г«вҖ№ВӨ(?В¬Г¬ВёВө Г«В°В©Г¬вҖ“Вҙ).\r\n    const [assets, total] = await Promise.all([\r\n      prisma.generatedAsset.findMany({\r\n        where,\r\n        orderBy: { createdAt: \"desc\" },\r\n        skip: (page - 1) * limit,\r\n        take: limit,\r\n        select: {\r\n          id: true,\r\n          type: true,\r\n          name: true,\r\n          status: true,\r\n          filePath: true,\r\n          thumbnailPath: true,\r\n          createdAt: true,\r\n          updatedAt: true,\r\n        },\r\n      }),\r\n      prisma.generatedAsset.count({ where }),\r\n    ]);\r\n\r\n    return NextResponse.json({\r\n      assets: assets.map(toPublicAssetListItem),\r\n      pagination: {\r\n        page,\r\n        limit,\r\n        total,\r\n        totalPages: Math.ceil(total / limit),\r\n      },\r\n    });\r\n  } catch (error) {\r\n    return NextResponse.json(\r\n      {\r\n        error: \"Failed to fetch assets\",\r\n        details: error instanceof Error ? error.message : undefined,\r\n      },\r\n      { status: 500 }\r\n    );\r\n  }\r\n}\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"Get-Content -Path src\\\\app\\\\api\\\\assets\\\\route.test.ts -TotalCount 260\"","aggregated_output":"import { describe, it, expect, vi, beforeEach } from \"vitest\";\r\nimport { buildGetRequest, makeSession, readJson } from \"@/__tests__/helpers/api-route\";\r\n\r\n// ============================================\r\n// auth()/prisma mock ??vi.hoisted + vi.mock?вӮ¬ ?Е’Г¬ВқВј Г«ВЎЕ“Г¬В»В¬ ?ВёГ¬ВқВҙ?ВӨГӯЕ’вҖҰ?ВҙГ«ВқВј\r\n// ?ВјГ¬ЕЎВ°??import ?вҖһГ¬вҖ”Вҗ ???Е’Г¬ВқВј?ВҗГ¬вҖһЕ“ Г¬В§ВҒГ¬В вҖҳ ?В Г¬вҖ“Вё?ВҙГ¬вҖўВј ?Е“Г«вҖ№ВӨ (?ЛңГ«вҖ№ЛҶ?ВӨГ«ВЎЕ“ Г¬ВӨвҖҳГ¬вҖўв„ў??Г«В¶ЛҶГӘ?).\r\n// ============================================\r\nconst { mockAuth, mockPrisma } = vi.hoisted(() => ({\r\n  mockAuth: vi.fn(),\r\n  mockPrisma: {\r\n    generatedAsset: { findMany: vi.fn(), count: vi.fn() },\r\n  },\r\n}));\r\n\r\nvi.mock(\"@/lib/auth\", () => ({ auth: mockAuth }));\r\nvi.mock(\"@/lib/prisma\", () => ({ prisma: mockPrisma }));\r\n\r\nimport { GET } from \"./route\";\r\n\r\n/** WI-021 Г«ВӘВ©Г«ВЎВқ ?вҖҳГ«вҖ№Вө ГӘВіВөГӘВ°Е“ ??Г¬В§вҖҳГӯвҖўВ© (lean DTO). */\r\nconst LIST_ITEM_KEYS = [\r\n  \"id\",\r\n  \"type\",\r\n  \"name\",\r\n  \"status\",\r\n  \"filePath\",\r\n  \"thumbnailPath\",\r\n  \"createdAt\",\r\n  \"updatedAt\",\r\n] as const;\r\n\r\n/**\r\n * prisma.generatedAsset.findManyГӘВ°вӮ¬ Г«В°ЛңГӯв„ўЛң?ЛңГ«Е вҖқ ??fixture.\r\n * ?вҖҳГ«вҖ№Вө/ select allowlist ?Е’ГӘ?Г«ВҘ??вҖһГӯвҖўВҙ, ?ВёГ¬В¶Е“?ЛңГ«В©Вҙ ???ЛңГ«Е вҖқ Г«ВҜВјГӘВ°Вҗ/?ВҙГ«? ?вҖһГ«вҖңЕ“\r\n * (prompt/workflow/comfyuiJobId/userId/metadata/user/fileSize/isShared)Г«ВҘ? * ?ЛңГ«ВҸвҖһ?ВҒГ¬Е“ВјГ«ВЎ??В¬ГӯвҖўВЁ?Е“Г«вҖ№ВӨ ??findMany??mock?ВҙГ«ВқВј select?вӮ¬ Г«В¬ВҙГӘ??ЛңГӘВІЕ’ ???вҖ°Г¬ВқвҖһ ГӘВ·ВёГ«?Г«ВЎ? * ?Е’Г«В ВӨГ¬ВЈВјГ«?Г«ВЎ? ?вҖҳГ«вҖ№Вө?ВҗГ¬вҖһЕ“ Г«В№В Г¬?Г«В©?transform(toPublicAssetListItem)???В¬Г¬ВёВө Г«В°В©Г¬вҖ“ВҙГӘВ°вӮ¬ ?ВӨГ¬ВҰВқ?Е“Г«вҖ№ВӨ.\r\n */\r\nfunction makeAssetListRow(overrides: Record<string, unknown> = {}) {\r\n  return {\r\n    id: \"asset-1\",\r\n    userId: \"owner-1\",\r\n    type: \"CHARACTER\",\r\n    name: \"?вҖһГ¬вҖҡВ¬\",\r\n    status: \"COMPLETED\",\r\n    filePath: \"/assets/generated/characters/x.png\",\r\n    thumbnailPath: \"/assets/generated/thumbnails/x.png\",\r\n    createdAt: new Date(\"2026-06-22T00:00:00.000Z\"),\r\n    updatedAt: new Date(\"2026-06-22T00:01:00.000Z\"),\r\n    // ???вҖҳГ«вҖ№Вө/select?ВҗГ¬вҖһЕ“ ?Е“Г¬в„ўВё?ВјГ¬вҖўВј ?ЛңГ«Е вҖқ Г«ВҜВјГӘВ°Вҗ/?ВҙГ«? ?вҖһГ«вҖңЕ“ (?Е’ГӘ? ГӘВ°вӮ¬??\r\n    prompt: \"secret prompt\",\r\n    workflow: \"character-default\",\r\n    comfyuiJobId: \"comfy-job-xyz\",\r\n    fileSize: 9999,\r\n    isShared: false,\r\n    metadata: {\r\n      width: 1024,\r\n      frameWidth: 128,\r\n      prompt: \"secret prompt in metadata\",\r\n      accessSecret: \"should-never-leak\",\r\n    },\r\n    user: { id: \"owner-1\", name: \"?ВҚГӘВёВё?? },\r\n    ...overrides,\r\n  };\r\n}\r\n\r\nbeforeEach(() => {\r\n  mockAuth.mockReset();\r\n  mockPrisma.generatedAsset.findMany.mockReset();\r\n  mockPrisma.generatedAsset.count.mockReset();\r\n});\r\n\r\ndescribe(\"GET /api/assets ???ВёГ¬ВҰВқ ГӘВ°вӮ¬??, () => {\r\n  it(\"Г«ВҜВёГ¬ВқВёГ¬ВҰВқГ¬ВқВҙГ«В©?401?ВҙГӘВіВ  prismaГ«ВҘ?ГӘВұВҙГ«вҖңЕ“Г«ВҰВ¬Г¬? ?Е Г«Е вҖқ??, async () => {\r\n    mockAuth.mockResolvedValue(makeSession(null));\r\n\r\n    const res = await GET(buildGetRequest(\"/api/assets\"));\r\n\r\n    expect(res.status).toBe(401);\r\n    expect(mockPrisma.generatedAsset.findMany).not.toHaveBeenCalled();\r\n    expect(mockPrisma.generatedAsset.count).not.toHaveBeenCalled();\r\n  });\r\n});\r\n\r\ndescribe(\"GET /api/assets ??owner Г«В¶вҖһГӘВёВ° (shared Г«ВҜВёГ¬???\", () => {\r\n  beforeEach(() => {\r\n    mockAuth.mockResolvedValue(makeSession({ id: \"owner-1\" }));\r\n    mockPrisma.generatedAsset.findMany.mockResolvedValue([makeAssetListRow()]);\r\n    mockPrisma.generatedAsset.count.mockResolvedValue(1);\r\n  });\r\n\r\n  it(\"Г«ВіВёГ¬ВқВё ?ВҗГ¬вҖҡВ°Г«В§?Г¬ВЎВ°ГӯЕЎЕ’?Е“Г«вҖ№ВӨ (where.userId = session.id, isShared Г«ВҜВёГӯВҸВ¬??\", async () => {\r\n    await GET(buildGetRequest(\"/api/assets\"));\r\n\r\n    const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\r\n      where: Record<string, unknown>;\r\n    };\r\n    expect(arg.where.userId).toBe(\"owner-1\");\r\n    expect(arg.where.isShared).toBeUndefined();\r\n  });\r\n\r\n  it(\"ГӘВ°???ВӘВ©?вӮ¬ ?вҖўГӯв„ўвҖў??lean ГӘВіВөГӘВ°Е“ ??Г¬В§вҖҳГӯвҖўВ©Г«В§?Г«В°ЛңГӯв„ўЛң?Е“Г«вҖ№ВӨ\", async () => {\r\n    const res = await GET(buildGetRequest(\"/api/assets\"));\r\n    const body = await readJson<{ assets: Record<string, unknown>[] }>(res);\r\n\r\n    expect(res.status).toBe(200);\r\n    expect(body.assets).toHaveLength(1);\r\n    expect(Object.keys(body.assets[0]).sort()).toEqual(\r\n      [...LIST_ITEM_KEYS].sort()\r\n    );\r\n  });\r\n\r\n  it(\"Г«ВҜВјГӘВ°Вҗ/?ВҙГ«? ?вҖһГ«вҖңЕ“Г«ВҘ??ВёГ¬В¶Е“?ЛңГ¬? ?Е Г«Е вҖқ??(transform ?В¬Г¬ВёВө Г«В°В©Г¬вҖ“Вҙ)\", async () => {\r\n    const res = await GET(buildGetRequest(\"/api/assets\"));\r\n    const body = await readJson<{ assets: Record<string, unknown>[] }>(res);\r\n    const item = body.assets[0];\r\n\r\n    expect(item.prompt).toBeUndefined();\r\n    expect(item.workflow).toBeUndefined();\r\n    expect(item.comfyuiJobId).toBeUndefined();\r\n    expect(item.userId).toBeUndefined();\r\n    expect(item.metadata).toBeUndefined();\r\n    expect(item.user).toBeUndefined();\r\n    expect(item.fileSize).toBeUndefined();\r\n    expect(item.isShared).toBeUndefined();\r\n  });\r\n\r\n  it(\"findMany??Г«ВҜВјГӘВ°Вҗ/?ВҙГ«? ?вҖһГ«вҖңЕ“Г«ВҘ??В Г¬ВҙЛҶ??select?ЛңГ¬? ?Е Г«Е вҖқ??(Г¬ВҝВјГ«ВҰВ¬ ??Г«В°В©Г¬вҖ“Вҙ)\", async () => {\r\n    await GET(buildGetRequest(\"/api/assets\"));\r\n\r\n    const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\r\n      select?: Record<string, unknown>;\r\n    };\r\n    expect(arg.select).toBeDefined();\r\n    expect(Object.keys(arg.select!).sort()).toEqual([...LIST_ITEM_KEYS].sort());\r\n    expect(arg.select?.prompt).toBeUndefined();\r\n    expect(arg.select?.workflow).toBeUndefined();\r\n    expect(arg.select?.comfyuiJobId).toBeUndefined();\r\n    expect(arg.select?.metadata).toBeUndefined();\r\n    expect(arg.select?.user).toBeUndefined();\r\n    expect(arg.select?.userId).toBeUndefined();\r\n  });\r\n});\r\n\r\ndescribe(\"GET /api/assets ??shared=true Г«В¶вҖһГӘВёВ° (?вӮ¬??ГӘВіВөГ¬Е“В  ?ВҗГ¬вҖҡВ°)\", () => {\r\n  beforeEach(() => {\r\n    mockAuth.mockResolvedValue(makeSession({ id: \"viewer-1\" }));\r\n    // ?вӮ¬??other-user) ?Е’Г¬Е“В  + isShared:true ?ВҗГ¬вҖҡВ°??Г«В°ЛңГӯв„ўЛң?ЛңГ«Е вҖқ ?ВҒГӯв„ўВ©\r\n    mockPrisma.generatedAsset.findMany.mockResolvedValue([\r\n      makeAssetListRow({\r\n        userId: \"other-user\",\r\n        isShared: true,\r\n        user: { id: \"other-user\", name: \"?вӮ¬?ВёГ¬Ж’Вқ?ВұГ¬ЕҫВҗ\" },\r\n      }),\r\n    ]);\r\n    mockPrisma.generatedAsset.count.mockResolvedValue(1);\r\n  });\r\n\r\n  it(\"isShared=trueГ«ВЎ?Г¬ВЎВ°ГӯЕЎЕ’?ЛңГӘВіВ  where.userIdГ«ВЎ?Г«ВіВёГ¬ВқВё ?Е“ГӯвҖўЕ“??ГӘВұВёГ¬? ?Е Г«Е вҖқ??, async () => {\r\n    await GET(buildGetRequest(\"/api/assets\", { shared: \"true\" }));\r\n\r\n    const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\r\n      where: Record<string, unknown>;\r\n    };\r\n    expect(arg.where.isShared).toBe(true);\r\n    expect(arg.where.userId).toBeUndefined();\r\n  });\r\n\r\n  it(\"?вӮ¬??ГӘВіВөГ¬Е“В  ?ВҗГ¬вҖҡВ°??lean ?ВӨГ«В§Е’ Г«В°ЛңГӯв„ўЛң?ЛңГӘВіВ  ?Е’Г¬Е“В ??Г«ВҜВјГӘВ°Вҗ ?вҖўГ«ВіВҙГ«ВҘ??ВёГ¬В¶Е“?ЛңГ¬? ?Е Г«Е вҖқ??, async () => {\r\n    const res = await GET(buildGetRequest(\"/api/assets\", { shared: \"true\" }));\r\n    const body = await readJson<{ assets: Record<string, unknown>[] }>(res);\r\n    const item = body.assets[0];\r\n\r\n    expect(Object.keys(item).sort()).toEqual([...LIST_ITEM_KEYS].sort());\r\n    // ?вӮ¬???ВқГ¬вҖһВұ???вҖўГ«ВіВҙ Г«ВҜВёГ«вҖҰВёГ¬В¶?(codex consult: shared Г«В¶вҖһГӘВёВ° user/metadata Г«В№вҖһГ«вҖҰВё