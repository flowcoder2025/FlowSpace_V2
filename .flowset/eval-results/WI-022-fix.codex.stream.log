);\r\n  31:   if (!Number.isFinite(n) || n <= 0) return defaultLimit;\r\n  32:   return Math.min(n, MAX_PAGE_LIMIT);\r\n  33: }\r\n  34: \r\n  35: /**\r\n  36:  * мҝјлҰ¬мҠӨнҠёл§Ғ `page`(1-base offset нҺҳмқҙм§Җ лІҲнҳё)лҘј м•Ҳм „н•ң м–‘мқҳ м •мҲҳлЎң м •к·ңнҷ”н•ңлӢӨ.\r\n  37:  * - null/л№Ҳк°’/л№„м •мҲҳ/1 лҜёл§Ң вҶ’ 1\r\n  38:  * - мғҒн•ң м—ҶмқҢ (offset нҺҳмқҙм§Җ лІ”мң„лҠ” лҚ°мқҙн„° нҒ¬кё°м—җ мқҳмЎҙ)\r\n  39:  *\r\n  40:  * offset лқјмҡ°нҠём—җм„ң `skip: (page - 1) * limit` кі„мӮ° мӢң pageк°Җ NaN/0/мқҢмҲҳл©ҙ\r\n  41:  * мқҢмҲҳ skipмқҙ лҗҳм–ҙ Prismaк°Җ throw(вҶ’500)н•ҳлҚҳ кІғмқ„ л°©м§Җн•ңлӢӨ.\r\n  42:  */\r\n  43: export function parsePageNumber(raw: string | null): number {\r\n  44:   const n = parseInt(raw ?? \"\", 10);\r\n  45:   if (!Number.isFinite(n) || n < 1) return 1;\r\n  46:   return n;\r\n  47: }\r\n  48: \r\n  49: export interface CursorPage<T> {\r\n  50:   items: T[];\r\n  51:   nextCursor: string | null;\r\n  52:   hasMore: boolean;\r\n  53: }\r\n  54: \r\n  55: /**\r\n  56:  * `take: limit + 1`лЎң мЎ°нҡҢн•ң н–ү л°°м—ҙмқ„ нҺҳмқҙм§ҖлЎң ліҖнҷҳн•ңлӢӨ.\r\n  57:  * н–үмқҙ limitліҙлӢӨ л§Һмңјл©ҙ л§Ҳм§Җл§ү(м—¬л¶„) 1кұҙмқ„ мһҳлқјлӮҙкі  к·ё м§Ғм „ н–үмқҳ idлҘј\r\n  58:  * лӢӨмқҢ cursorлЎң мӮ¬мҡ©н•ңлӢӨ.\r\n  59:  *\r\n  60:  * @param rows  limit + 1 л§ҢнҒј мЎ°нҡҢн•ң н–ү(м •л ¬ мҷ„лЈҢ мғҒнғң, к°Ғ н–үмқҖ кі мң  `id` ліҙмң )\r\n  61:  * @param limit нҺҳмқҙм§Җ нҒ¬кё°\r\n  62:  */\r\n  63: export function buildCursorPage<T extends { id: string }>(\r\n  64:   rows: T[],\r\n  65:   limit: number\r\n  66: ): CursorPage<T> {\r\n  67:   const hasMore = rows.length > limit;\r\n  68:   const items = hasMore ? rows.slice(0, limit) : rows;\r\n  69:   const nextCursor = hasMore ? items[items.length - 1]?.id ?? null : null;\r\n  70:   return { items, nextCursor, hasMore };\r\n  71: }\r\n","exit_code":0,"status":"completed"}}
