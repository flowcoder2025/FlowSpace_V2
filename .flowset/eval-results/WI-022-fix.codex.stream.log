\r\n  34:   try {\r\n  35:     const session = await auth();\r\n  36:     if (!session?.user?.id) {\r\n  37:       return NextResponse.json({ error: \"Unauthorized\" }, { status: 401 });\r\n  38:     }\r\n  39: \r\n  40:     const searchParams = request.nextUrl.searchParams;\r\n  41:     const shared = searchParams.get(\"shared\");\r\n  42: \r\n  43:     // мһ…л Ҙ кІҖмҰқ(WI-022): type/statusлҘј AssetType/AssetStatus allowlistлЎң кІҖмҰқ.\r\n  44:     // мһҳлӘ»лҗң enumмқҖ мЎ°мҡ©нһҲ л¬ҙмӢң(м „мІҙ лӘ©лЎқ мқ‘лӢө)н•ҳм§Җ м•Ҡкі  400мңјлЎң кұ°м Ҳ(WI-009 м •н•©).\r\n  45:     const type = normalizeEnumFilter(searchParams.get(\"type\"), ASSET_TYPE_VALUES);\r\n  46:     const status = normalizeEnumFilter(\r\n  47:       searchParams.get(\"status\"),\r\n  48:       ASSET_STATUS_VALUES\r\n  49:     );\r\n  50:     if (type === null || status === null) {\r\n  51:       return NextResponse.json(\r\n  52:         { error: \"Invalid asset filter\", code: \"INVALID_FILTER\" },\r\n  53:         { status: 400 }\r\n  54:       );\r\n  55:     }\r\n  56: \r\n  57:     // page/limit м •к·ңнҷ”(WI-022): NaN/0/мқҢмҲҳ вҶ’ мқҢмҲҳ skip(500) л°©м§Җ, limit мғҒн•ң 100.\r\n  58:     const page = parsePageNumber(searchParams.get(\"page\"));\r\n  59:     const limit = parsePageLimit(searchParams.get(\"limit\"), ASSETS_DEFAULT_LIMIT);\r\n  60: \r\n  61:     const where: Record<string, unknown> = {};\r\n  62: \r\n  63:     if (shared === \"true\") {\r\n  64:       // кіөмҡ© м—җм…Ӣ мЎ°нҡҢ (м•„л°”нғҖ м„ нғқ л“ұ)\r\n  65:       where.isShared = true;\r\n  66:     } else {\r\n  67:       // ліёмқё м—җм…Ӣл§Ң мЎ°нҡҢ (IDOR л°©м§Җ)\r\n  68:       where.userId = session.user.id;\r\n  69:     }\r\n  70: \r\n  71:     if (type) {\r\n  72:       where.type = type;\r\n  73:     }\r\n  74:     if (status) {\r\n  75:       where.status = status;\r\n  76:     }\r\n  77: \r\n  78:     // мқ‘лӢө allowlist (WI-021): лӘ©лЎқмқҖ lean DTOл§Ң л°ҳнҷҳн•ңлӢӨ.\r\n  79:     // shared=true л¶„кё°лҠ” owner кІҢмқҙнҠё м—Ҷмқҙ нғҖмқё кіөмң  мһҗмӮ°мқ„ л°ҳнҷҳн•ҳлҜҖлЎң(мқҳлҸ„лҗң кіөмң )\r\n  80:     // prompt/workflow/comfyuiJobId(лҜјк°җ)В·metadataВ·userлҠ” selectн•ҳм§Җ м•Ҡкі ,\r\n  81:     // toPublicAssetListItemлЎң мқ‘лӢө нӮӨ м§‘н•©мқ„ кі м •н•ңлӢӨ(мӢ¬мёө л°©м–ҙ).\r\n  82:     const [assets, total] = await Promise.all([\r\n  83:       prisma.generatedAsset.findMany({\r\n  84:         where,\r\n  85:         orderBy: { createdAt: \"desc\" },\r\n  86:         skip: (page - 1) * limit,\r\n  87:         take: limit,\r\n  88:         select: {\r\n  89:           id: true,\r\n  90:           type: true,\r\n  91:           name: true,\r\n  92:           status: true,\r\n  93:           filePath: true,\r\n  94:           thumbnailPath: true,\r\n  95:           createdAt: true,\r\n  96:           updatedAt: true,\r\n  97:         },\r\n  98:       }),\r\n  99:       prisma.generatedAsset.count({ where }),\r\n 100:     ]);\r\n 101: \r\n 102:     return NextResponse.json({\r\n 103:       assets: assets.map(toPublicAssetListItem),\r\n 104:       pagination: {\r\n 105:         page,\r\n 106:         limit,\r\n 107:         total,\r\n 108:         totalPages: Math.ceil(total / limit),\r\n 109:       },\r\n 110:     });\r\n 111:   } catch (error) {\r\n 112:     return NextResponse.json(\r\n 113:       {\r\n 114:         error: \"Failed to fetch assets\",\r\n 115:         details: error instanceof Error ? error.message : undefined,\r\n 116:       },\r\n 117:       { status: 500 }\r\n 118:     );\r\n 119:   }\r\n 120: }\r\n","exit_code":0,"status":"completed"}}
