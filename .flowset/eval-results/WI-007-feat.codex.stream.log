7:     return;\r\n  48:   }\r\n  49: \r\n  50:   if (before.isSuperAdmin === next) {\r\n  51:     console.log(`[변경없음] ${email} 은 이미 isSuperAdmin=${next} 입니다.`);\r\n  52:   } else {\r\n  53:     await prisma.user.update({\r\n  54:       where: { email },\r\n  55:       data: { isSuperAdmin: next },\r\n  56:     });\r\n  57:     console.log(`[완료] ${email} : isSuperAdmin ${before.isSuperAdmin} → ${next}`);\r\n  58:   }\r\n  59: \r\n  60:   console.log(\"\");\r\n  61:   await list();\r\n  62: }\r\n  63: \r\n  64: main()\r\n  65:   .catch((e) => {\r\n  66:     console.error(\"ERROR:\", e.message);\r\n  67:     process.exitCode = 1;\r\n  68:   })\r\n  69:   .finally(() => prisma.$disconnect());\r\n","exit_code":0,"status":"completed"}}
