\n  43:       const res = await fetch(`/api/spaces/${spaceId}/admin/members`, {\r\n  44:         method: \"PATCH\",\r\n  45:         headers: { \"Content-Type\": \"application/json\" },\r\n  46:         body: JSON.stringify({ memberId, action, role }),\r\n  47:       });\r\n  48:       if (!res.ok) {\r\n  49:         const data = await res.json();\r\n  50:         alert(data.error || DASHBOARD_COPY.MEMBERS.actionFailed);\r\n  51:       }\r\n  52:       onRefresh();\r\n  53:     } catch {\r\n  54:       alert(DASHBOARD_COPY.COMMON.networkError);\r\n  55:     } finally {\r\n  56:       setActionLoading(null);\r\n  57:     }\r\n  58:   }\r\n  59: \r\n  60:   return (\r\n  61:     <div className=\"overflow-x-auto\">\r\n  62:       <table className=\"w-full text-sm\">\r\n  63:         <thead>\r\n  64:           <tr className=\"border-b border-line text-left text-ink-muted\">\r\n  65:             <th className=\"pb-3 font-medium\">{DASHBOARD_COPY.MEMBERS.table.name}</th>\r\n  66:             <th className=\"pb-3 font-medium\">{DASHBOARD_COPY.MEMBERS.table.role}</th>\r\n  67:             <th className=\"pb-3 font-medium\">{DASHBOARD_COPY.MEMBERS.table.status}</th>\r\n  68:             <th className=\"pb-3 font-medium\">{DASHBOARD_COPY.MEMBERS.table.joined}</th>\r\n  69:             <th className=\"pb-3 font-medium text-right\">{DASHBOARD_COPY.MEMBERS.table.actions}</th>\r\n  70:           </tr>\r\n  71:         </thead>\r\n  72:         <tbody>\r\n  73:           {members.map((m) => {\r\n  74:             const name = m.user?.name || m.guestSession?.nickname || m.displayName || DASHBOARD_COPY.COMMON.unknown;\r\n  75:             const isOwner = m.role === \"OWNER\";\r\n  76:             const isLoading = actionLoading === m.id;\r\n  77: \r\n  78:             return (\r\n  79:               <tr key={m.id} className=\"border-b border-line\">\r\n  80:                 <td className=\"py-3\">\r\n  81:                   <div className=\"font-medium text-ink\">{name}</div>\r\n  8