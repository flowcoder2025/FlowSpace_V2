src/features/space/livekit-moderation/internal/eviction.ts\n@@ -0,0 +1,76 @@\n+// LiveKit м„ңлІ„ мёЎ к°•м ң м ңкұ°(eviction) вҖ” kick/ban мӢң нҷ”мғҒ нғҖмқј мһ”мЎҙ м ңкұ°(WI-045).\n+//\n+// м„ңлІ„ мһҗкІ© resolve + RoomServiceClient.removeParticipant orchestration(best-effort).\n+// kick/ban мқҳ н•өмӢ¬ м„ұкіө мЎ°кұҙмқҖ DB мғҒнғң ліҖкІҪ + socket enforce мқҙл©°, LiveKit м ңкұ°лҠ”\n+// \"нҷ”мғҒ нғҖмқј мһ”мЎҙ м •лҰ¬\"лҘј мң„н•ң ліҙк°• лҸҷмһ‘мқҙлӢӨ вҖ” мӢӨнҢЁн•ҙлҸ„ admin м•Ўм…ҳ м „мІҙлҘј мӢӨнҢЁмӢңнӮӨм§Җ\n+// м•Ҡкі  лЎңк№…л§Ң н•ңлӢӨ(лҜём ‘мҶҚВ·нҷ”мғҒ лҜёмӮ¬мҡ©В·мқҙлҜё нҮҙмһҘВ·лҜём„Өм • лӘЁл‘җ л¬ҙн•ҙ).\n+import { RoomServiceClient } from \"livekit-server-sdk\";\n+\n+const DEV_API_KEY = \"devkey\";\n+const DEV_API_SECRET = \"devsecret\";\n+\n+export interface LiveKitServerConfig {\n+  apiKey: string;\n+  apiSecret: string;\n+  url: string;\n+}\n+\n+/**\n+ * LiveKit м„ңлІ„ мһҗкІ©мқ„ нҳём¶ң мӢңм җм—җ мқҪлҠ”лӢӨ(лӘЁл“Ҳ лЎңл“ң мӢңм җ мәЎмІҳ нҡҢн”ј вҖ” н…ҢмҠӨнҠём„ұ).\n+ * нҶ нҒ°/moderate лқјмҡ°нҠёмҷҖ лҸҷмқј м •мұ…: prod лҜём„Өм •вҶ’null, devвҶ’devkey нҸҙл°ұ.\n+ */\n+export function resolveLiveKitConfig(): LiveKitServerConfig | null {\n+  const url = process.env.LIVEKIT_URL || \"http://localhost:7880\";\n+  let apiKey = process.env.LIVEKIT_API_KEY;\n+  let apiSecret = process.env.LIVEKIT_API_SECRET;\n+  if (!apiKey || !apiSecret) {\n+    if (process.env.NODE_ENV === \"development\") {\n+      apiKey = DEV_API_KEY;\n+      apiSecret = DEV_API_SECRET;\n+    } else {\n+      return null;\n+    }\n+  }\n+  return { apiKey, apiSecret, url };\n+}\n+\n+export type EvictionReason = \"removed\" | \"not_configured\" | \"remove_failed\";\n+\n+export interface EvictionResult {\n+  removed: boolean;\n+  reason: EvictionReason;\n+}\n+\n+/**\n+ * л“ұлЎқ мӮ¬мҡ©мһҗ(userId)лҘј мҠӨнҺҳмқҙмҠӨ LiveKit room м—җм„ң к°•м ң м ңкұ°н•ңлӢӨ(best-effort).\n+ * - лҜём„Өм •(prod no key) вҶ’ мҠӨнӮө(not_configured, warn).\n+ * - лҜём ‘мҶҚ/нҷ”мғҒ лҜёмӮ¬мҡ©/мқҙлҜё нҮҙмһҘ л“ұ throw вҶ’ л¬ҙмӢң(remove_failed, warn вҖ” мӣҗмқёмқҖ л©”мӢңм§ҖлЎң м¶”м Ғ).\n+ * - м„ұкіө вҶ’ removed.\n+ * нҷ”мғҒ нғҖмқј мһ”мЎҙ м •лҰ¬мҡ© ліҙк°•мқҙлқј м–ҙл–Ө кІҪмҡ°м—җлҸ„ throw н•ҳм§Җ м•ҠлҠ”лӢӨ(нҳём¶ңмёЎ м•Ўм…ҳ ліҙмЎҙ).\n+ */\n+export async function removeSpaceParticipant(\n+  spaceId: string,\n+  userId: string\n+): Promise<EvictionResult> {\n+  const config = resolveLiveKitConfig();\n+  if (!config) {\n+    console.warn(\"[LiveKit Evict] LIVEKIT лҜём„Өм • вҖ” нҷ”мғҒ нғҖмқј м ңкұ° мҠӨнӮө\", { spaceId });\n+    return { removed: false, reason: \"not_configured\" };\n+  }\n+\n+  const roomName = `space-${spaceId}`;\n+  const identity = `user-${userId}`;\n+  const svc = new RoomServiceClient(config.url, config.apiKey, config.apiSecret);\n+\n+  try {\n+    await svc.removeParticipant(roomName, identity);\n+    return { removed: true, reason: \"removed\" };\n+  } catch (err) {\n+    console.warn(\"[LiveKit Evict] removeParticipant мӢӨнҢЁ(л¬ҙмӢң)\", {\n+      roomName,\n+      identity,\n+      message: err instanceof Error ? err.message : String(err),\n+    });\n+    return { removed: false, reason: \"remove_failed\" };\n+  }\n+}\n","exit_code":0,"status":"completed"}}
