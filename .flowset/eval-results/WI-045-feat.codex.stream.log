{"type":"item.completed","item":{"id":"item_13","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"Get-Content -Raw src\\\\features\\\\space\\\\enforce\\\\internal\\\\contract.ts\"","aggregated_output":"// Enforcement Contract ??Next HTTP(API) ??socket.io ?Е“Г«ВІвҖһ ?В¬Г«ВЎЕ“?ВӨГӯвҖқвҖһГ«ВЎЕ“Г¬вҖһВё???Е“Г¬ЕҫВ¬ Г¬ВұвҖһГ«вҖһВҗ (WI-005)\n//\n// dashboard ГӘВҙвӮ¬Г«ВҰ??ВЎГ¬вҖҰЛң(ban/kick/mute/unmute/changeRole)???ВҙГ¬вҖўвҖһ?ЛҶГ«Е вҖқ ?Е’Г¬ВјвҖң ?В°ГӘВІВ°??Г¬ВҰвҖ°Г¬вҖ№Е“\n// Г«В°ЛңГ¬ЛңВҒ?ЛңГӘВёВ° ?вҖһГӯвҖўЕ“ ?Е“Г¬ЛҶЛң ГӘВівҖһГ¬вҖўВҪ. Next API route(?Е“Г«ВӘвҖҰ ?ВқГ¬вҖһВұ)?вӮ¬ socket ?Е“Г«ВІвҖһ(?Е“Г«ВӘвҖҰ ГӘВІвӮ¬Г¬ВҰ? ?вҖҳГ¬ВӘВҪ??// ГӘВіВөГ¬Е“В ?ЛңГ«В©В°, React/Node-fs ?ЛңГ¬ВЎВҙ???вҖ Г«Е вҖқ ?Е“Г¬ЛҶЛң Г«ВӘВЁГ«вҖңЛҶ?ВҙГ«ВқВј server Г«ВІЛҶГ«вҖңВӨ???ВЁГ«ВҸвҖҰ COPY?????ЛҶГ«вҖ№ВӨ.\n//\n// ?ВёГ¬ВҰВқ: ?вҖўГ¬В ВҒ ?ВӨГ«ВҚвҖқ ?Е“ГӯВҒВ¬Г«ВҰВҝГ¬ВқВҙ ?вҖһГ«вҖ№Е’ HMAC-SHA256(`{timestamp}.{rawBody}`) ?Е“Г«ВӘвҖҰ + replay\n// window. ?вҖқГ«вҖңЕ“?В¬Г¬ВқВё?ВёГӘ? socket ?Е“Г«ВІвҖһ?вӮ¬ ГӘВ°в„ўГ¬? public ?В¬ГӯЕ Вё???ВёГ¬В¶Е“?ЛңГӘВіВ  \"ГӘВ°вҖўГ¬В Е“ Г¬В¶вҖқГ«В°В© ГӘВ¶Е’ГӯвҖўЕ“\"??// ГӘВ°вҖ“ГӘВёВ° ?Е’Г«В¬Вё?ВҙГ«вҖ№ВӨ(?ВӨГӘВівҖһ codex consult).\n\nimport { createHmac, timingSafeEqual } from \"crypto\";\n\n/** ?ВЁГ¬ВқВј ?В¬Г¬ЕЎВ©???вӮ¬???Е“Г¬ЕҫВ¬(?В№Г¬В вҖў Г«В©ВӨГ«ВІвҖһ ban/kick/mute/unmute/role). userId ?вҖһГ¬ЛҶЛң. */\nexport const ENFORCE_USER_ACTIONS = [\"ban\", \"kick\", \"mute\", \"unmute\", \"role\"] as const;\nexport type EnforceUserAction = (typeof ENFORCE_USER_ACTIONS)[number];\n\n/** ?вҖһГ¬ВІВҙ enforce action ???В¬Г¬ЕЎВ©???вӮ¬??+ ГӘВіВөГӘВ°вҖһ ?вҖһГ¬ВІВҙ(archive). */\nexport const ENFORCE_ACTIONS = [...ENFORCE_USER_ACTIONS, \"archive\"] as const;\nexport type EnforceAction = (typeof ENFORCE_ACTIONS)[number];\n\nexport const ENFORCE_ROLES = [\"OWNER\", \"STAFF\", \"PARTICIPANT\"] as const;\nexport type EnforceRole = (typeof ENFORCE_ROLES)[number];\n\ninterface EnforceRequestBase {\n  spaceId: string;\n  /** ?Е“Г¬вҖ№Е“??actor ?ВҙГ«ВҰвҖһ(kickedBy/mutedBy ??. ГӘВ¶Е’ГӯвҖўЕ“ ?ВҗГ¬В вҖў???В¬Г¬ЕЎВ©?ЛңГ¬? ?Е Г¬ВқЕ’ */\n  actorName?: string;\n}\n\n/** ?В№Г¬В вҖў Г«В©ВӨГ«ВІвҖһ ?вӮ¬???Е“Г¬ЕҫВ¬ ??userId ?вҖһГ¬ЛҶЛң. */\nexport interface UserEnforceRequest extends EnforceRequestBase {\n  action: EnforceUserAction;\n  userId: string;\n  /** action === \"role\" ?????вҖһГ¬ЛҶЛң ??ГӘВ°вҖўГ«вҖңВұ/?В№ГӘВІВ© ??ГӘВ°ВұГ¬вҖ№В ????вҖўВ  */\n  role?: EnforceRole;\n}\n\n/**\n * ГӘВіВөГӘВ°вҖһ ?вҖһГ¬ВІВҙ archive ??ГӘВ·?ГӘВіВөГӘВ°вҖһ??Г«ВӘВЁГ«вҖңВ  ?вҖҳГ¬вҖ ВҚ?ВҗГ«? Г¬В¶вҖқГ«В°В©?Е“Г«вҖ№ВӨ(WI-036).\n * ?ВЁГ¬ВқВј user ?вӮ¬?ВҒГ¬ВқВҙ ?вҖһГ«вҖ№ЛҶГ«ВҜвӮ¬Г«ВЎ?userId ГӘВ°вӮ¬ ?вҖ Г«вҖ№ВӨ(discriminated union ???вӮ¬?вҖҰГ¬ВқВҙ userId ?вҖһГ«ВқВҪ??ГӘВ°вҖўГ¬В Е“).\n */\nexport interface ArchiveEnforceRequest extends EnforceRequestBase {\n  action: \"archive\";\n}\n\n/**\n * ?В¬Г«ВЎЕ“?ВӨГӯвҖқвҖһГ«ВЎЕ“Г¬вҖһВё???Е“Г¬ЕҫВ¬ ?вҖқГ¬ВІВӯ. action ?ВјГ«ВЎЕ“ Г«В¶вҖһГӘВёВ°?ЛңГ«Е вҖқ discriminated union?ВҙГ«ВқВј\n * archive ??userId Г«ВҘ??ВЈГӘВұВ°??Г«В©ВӨГ«ВІвҖһ ?Е“Г¬ЕҫВ¬?ВҗГ¬вҖһЕ“ userId Г«ВҘ?Г«В№В Г«Е“ВЁГ«ВҰВ¬Г«В©Вҙ Г¬В»ВҙГӯЕ’Е’???вӮ¬?вҖһГ¬вҖ”Вҗ ?ВЎГӯЕҫЕ’??\n */\nexport type EnforceRequest = UserEnforceRequest | ArchiveEnforceRequest;\n\n/** socket ?Е“Г«ВІвҖһ ?ВҙГ«? ?вҖқГ«вҖңЕ“?В¬Г¬ВқВё??ГӘВІВҪГ«ВЎЕ“ */\nexport const ENFORCE_PATH = \"/internal/enforce\";\nexport const ENFORCE_SIGNATURE_HEADER = \"x-flowspace-signature\";\nexport const ENFORCE_TIMESTAMP_HEADER = \"x-flowspace-timestamp\";\n/** replay ?ЛҶГ¬ЕЎВ© ?Е“ГӘВ°вҖһГ¬В°?ГӮВұ) ??Г«В°Е“Г¬вҖ№В /?ЛңГ¬вҖ№В  ?Е“ГӘВівҖһ ?ВӨГ¬В°ВЁ + ?вҖһГ¬вҖ ВЎ Г¬В§вӮ¬???ВЎГ¬ЛҶЛң */\nexport const ENFORCE_REPLAY_WINDOW_MS = 30_000;\n/** ?ВҙГ«? ?вҖқГ¬ВІВӯ body ?ВҒГӯвҖўЕ“ (?вҖҳГ¬? ГӘВіВ Г¬В вҖў ?ЛңГ¬ВқВҙГ«ВЎЕ“Г«вҖңЕ“) */\nexport const ENFORCE_MAX_BODY_BYTES = 4096;\n\nconst HEX_RE = /^[0-9a-f]+$/i;\n\nfunction signaturePayload(timestamp: string, rawBody: string): string {\n  return `${timestamp}.${rawBody}`;\n}\n\n/** HMAC-SHA256 ?Е“Г«ВӘвҖҰ(hex) ?ВқГ¬вҖһВұ */\nexport function computeEnforceSignature(secret: string, timestamp: string, rawBody: string): string {\n  return createHmac(\"sha256\", secret).update(signaturePayload(timestamp, rawBody)).digest(\"hex\");\n}\n\n/**\n * ?Е“Г«ВӘвҖҰ ГӘВІвӮ¬Г¬ВҰ?(timing-safe). Г«В№?hex/?вӮ¬?ЛңГӘВёВё??ГӘВёВёГ¬ВқВҙГ«В¶ЛҶГ¬ВқВјГ¬В№ЛңГ«Е вҖқ timingSafeEqual ?ЛҶГ¬в„ўВё ?вҖ Г¬ВқВҙ false.\n */\nexport function verifyEnforceSignature(\n  secret: string,\n  timestamp: string,\n  rawBody: string,\n  signature: string\n): boolean {\n  if (!signature || signature.length % 2 !== 0 || !HEX_RE.test(signature)) return false;\n  const expected = computeEnforceSignature(secret, timestamp, rawBody);\n  const expectedBuf = Buffer.from(expected, \"hex\");\n  const actualBuf = Buffer.from(signature, \"hex\");\n  // ГӘВёВёГ¬ВқВҙ Г«В¶ЛҶГ¬ВқВјГ¬В№???timingSafeEqual?вӮ¬ throw ???В Г¬В Е“ Г¬В°ВЁГ«вҖ№ВЁ\n  if (expectedBuf.length !== actualBuf.length) return false;\n  return timingSafeEqual(expectedBuf, actualBuf);\n}\n\n/** timestampГӘВ°вӮ¬ replay window ???В Г¬вҖһВ ??ГӘВ°вҖҷГ¬ВқВёГ¬В§вӮ¬ */\nexport function isFreshTimestamp(timestamp: string, nowMs: number): boolean {\n  const ts = Number(timestamp);\n  if (!Number.isFinite(ts)) return false;\n  return Math.abs(nowMs - ts) <= ENFORCE_REPLAY_WINDOW_MS;\n}\n\n/**\n * ?В Г«ВўВ°?????вҖ Г«Е вҖқ ?Е’Г¬вҖ№Вұ ГӘВ°ВқГ¬ВІВҙГ«ВҘ?EnforceRequestГ«ВЎ?ГӘВІвӮ¬Г¬ВҰ? ?ВӨГӯЕ’ВЁ ??null.\n * action Г«ВівҖһГ«ВЎЕ“ Г«В¶вҖһГӘВёВ° ГӘВІвӮ¬Г¬ВҰВқГӯвҖўЕ“??ГӘВёВ°Г¬ВЎВҙ Г«В©ВӨГ«ВІвҖһ ?Е“Г¬ЕҫВ¬ ?Е’ГӘ? Г«В°В©Г¬?):\n *  - \"archive\": userId Г«В¶ЛҶГӯвҖўвҖһ??ГӘВіВөГӘВ°вҖһ ?вҖһГ¬ВІВҙ ?вӮ¬??. ?вҖҰГ«В ВҘ??userIdГӘВ°вӮ¬ ?ЛҶГ¬вҖ“Вҙ??Г«В¬ВҙГ¬вҖ№Е“(?вӮ¬?вҖҰГ¬вҖ”вҖқ Г«ВҜВёГӯВҸВ¬??.\n *  - ГӘВ·???ban/kick/mute/unmute/role): userId ?вҖһГ¬ЛҶЛң. \"role\"?вӮ¬ role ?вҖқГ¬ВқВҙ?ВёГ«ВҰВ¬?ВӨГӯЕ Вё ?вҖһГ¬ЛҶЛң.\n * actorName?вӮ¬ 100?ВҗГ«ВЎЕ“ ?ЛҶГ«вҖ№ВЁ.\n */\nexport function parseEnforceRequest(raw: unknown): EnforceRequest | null {\n  if (typeof raw !== \"object\" || raw === null) return null;\n  const r = raw as Record<string, unknown>;\n\n  if (typeof r.spaceId !== \"string\" || r.spaceId.length === 0) return null;\n  if (typeof r.action !== \"string\" || !ENFORCE_ACTIONS.includes(r.action as EnforceAction)) return null;\n  const action = r.action as EnforceAction;\n\n  const actorName = typeof r.actorName === \"string\" ? r.actorName.slice(0, 100) : undefined;\n\n  if (action === \"archive\") {\n    // ГӘВіВөГӘВ°вҖһ ?вҖһГ¬ВІВҙ archive ??userId/role Г«В¬ВҙГ¬вҖ№Е“(?ВӨГ«ВҘВё ?вҖ°Г¬Е“вҖһ???ВқГ«ВівҖһ?ВҗГӘ? ?ЕҫГ¬вҖ”В¬??Г¬ВұвҖһГӯЖ’Вқ?ЛңГ¬? ?Е Г¬ВқЕ’).\n    return { spaceId: r.spaceId, action: \"archive\", actorName };\n  }\n\n  // Г«В©ВӨГ«ВІвҖһ ?вӮ¬???Е“Г¬ЕҫВ¬ ??userId ?вҖһГ¬ЛҶЛң.\n  if (typeof r.userId !== \"string\" || r.userId.length === 0) return null;\n\n  let role: EnforceRole | undefined;\n  if (action === \"role\") {\n    if (typeof r.role !== \"string\" || !ENFORCE_ROLES.includes(r.role as EnforceRole)) return null;\n    role = r.role as EnforceRole;\n  }\n\n  return { spaceId: r.spaceId, userId: r.userId, action, role, actorName };\n}\n\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_14","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"Get-Content -Raw server\\\\handlers\\\\room.ts\"","aggregated_output":"import type { Server, Socket } from \"socket.io\";\nimport type {\n  ClientToServerEvents,\n  ServerToClientEvents,\n  PlayerData,\n} from \"../../src/features/space/protocol/internal/socket-events\";\nimport { getPrisma } from \"../lib/prisma\";\nimport { recordingStates, spotlightStates, proximityStates } from \"../state\";\n\ntype IO = Server<ClientToServerEvents, ServerToClientEvents>;\ntype TypedSocket = Socket<ClientToServerEvents, ServerToClientEvents>;\n\n// spaceId ??Map<userId, PlayerData>\nexport const spacePlayersMap = new Map<string, Map<string, PlayerData>>();\n\n/**\n * archive ??ГӘВіВөГӘВ°вҖһ deny cache(WI-036, TOCTOU Г«ВіВҙГӘВ°вҖў).\n * archive enforce ?ВҒГ¬ЕЎВ© ??Г¬В¶вҖқГӘ??ЛңГ«В©В°, join:space ГӘВ°вӮ¬ DB Г¬ВЎВ°ГӯЕЎЕ’?вӮ¬ Г«ВівҖһГӘВ°Е“Г«ВЎ?Г¬ВҰвҖ°Г¬вҖ№Е“ ?вҖҰГ¬ЕҫВҘ??ГӘВұВ°Г«??Е“Г«вҖ№ВӨ.\n * archive Г¬В§ВҒГ¬В вҖһ status=ACTIVE Г«ВҘ??ВҪГӘВіВ  Г¬В§вҖһГӯвҖ“вҖ° Г¬ВӨвҖҳГ¬ВқВҙ??in-flight join ??archive ?ВӨГ«Ж’вҖҰ???ВҙГӯвҖәвҖһ room ?? * ?В©Г«ВҘЛң??Г¬В¶вҖқГ«В°В©???вҖңГ¬В№Лң??Г¬ВўВҒГ¬? Г¬В°ВҪГ¬ВқвҖһ ?В«Г«Е вҖқ?? **ГӘВ·ВјГ«ВіВё Г«В°В©Г¬вҖ“Вҙ??join:space ??DB status ГӘВІЕ’Г¬ВқВҙ??*?ВҙГ«В©В°\n * ?ВҙГӘВұВҙ best-effort Г«ВіВҙГӘВ°вҖў ???Е“Г«ВІвҖһ ?В¬Г¬вҖ№Е“????Г«В№вҖһГ¬вҖәЕ’Г¬В§вӮ¬ГӘВі?DB ГӘВІЕ’Г¬ВқВҙ?ВёГӘ? Г¬ВөЕ“Г¬ВўвҖҰ Г«В°В©Г¬вҖ“Вҙ??\n * ГӘВіВөГӘВ°вҖһ?вӮ¬ ARCHIVED ?ВЁГ«В°В©???ЛңГ«ВҸЕ’Г«ВҰВ¬Г«Е вҖқ API ?вҖ Г¬ВқЕ’)?ВҙГ«ВқВј ??ВӘВ©?вӮ¬ ?Е“ГӘВұВ°?ЛңГ¬? ?Е Г¬Е“ВјГ«В©? ?вҖһГ¬В ВҒ ?В¬ГӘВёВ°?? * ?Е“Г«ВІвҖһ ГӘВ°вӮ¬??Г¬ВӨ?archive ??ГӘВіВөГӘВ°вҖһ ?ЛңГ«ВЎЕ“ ?Е“ГӯвҖўЕ“?Е“Г«вҖ№ВӨ.\n */\nconst archivedSpaces = new Set<string>();\n\n/** ГӘВіВөГӘВ°вҖһ??archived deny cache ??Г¬В¶вҖқГӘ??Е“Г«вҖ№ВӨ(archive enforce ?ВҒГ¬ЕЎВ© ??. */\nexport function markSpaceArchived(spaceId: string): void {\n  archivedSpaces.add(spaceId);\n}\n\n/** ГӘВіВөГӘВ°вҖһ??archived deny cache ???ЛҶГ«Е вҖқГ¬В§вӮ¬(?вҖҰГ¬ЕҫВҘ Г¬ВҰвҖ°Г¬вҖ№Е“ ГӘВұВ°Г«? ?ВҗГ¬В вҖў). */\nexport function isSpaceArchived(spaceId: string): boolean {\n  return archivedSpaces.has(spaceId);\n}\n\n/**\n * ГӘВіВөГӘВ°вҖһ??Г«ВӘВЁГ«вҖңВ  ?ВёГ«В©вҖқГ«ВӘВЁГ«ВҰВ¬ ?ВёГ«ВҚВұ?ВӨГ«? ?ВјГӘВҙвҖһ ?Е“ГӘВұВ°(WI-036 archive). spaceId Г«ВЎ??ВӨГ«ВҗЕ“ ?ВҒГӯЖ’Е“?? * presence(spacePlayersMap) + media(recording/spotlight/proximity) ГӘВ°вӮ¬ ?вҖһГ«??? * (chat ??rate-limit/reaction Г«В§ВөГ¬? userId/messageId ?ВӨГ«ВқВј ГӘВіВөГӘВ°вҖһ Г«ВІвҖқГ¬Е“вҖһ ?вҖһГ«вҖ№Лң).\n * archive ??ГӘВіВөГӘВ°вҖһ???ВҒГӘВөВ¬ Г¬ВўвҖҰГ«ВЈЕ’?Е“ГӯвҖҡВӨГ«ВҜвӮ¬Г«ВЎ??вҖқГ¬ВЎВҙ ?ВҒГӯЖ’Е“ГӘВ°вӮ¬ ?ЛҶГ¬? ?Е Г«ВҸвҖһГ«ВЎ?Г¬В§ВҒГ¬В вҖҳ ?вҖўГ«ВҰВ¬?Е“Г«вҖ№ВӨ.\n */\nexport function purgeSpaceState(spaceId: string): void {\n  spacePlayersMap.delete(spaceId);\n  recordingStates.delete(spaceId);\n  spotlightStates.delete(spaceId);\n  proximityStates.delete(spaceId);\n}\n\nfunction getSpacePlayers(spaceId: string): Map<string, PlayerData> {\n  if (!spacePlayersMap.has(spaceId)) {\n    spacePlayersMap.set(spaceId, new Map());\n  }\n  return spacePlayersMap.get(spaceId)!;\n}\n\nexport function handleRoom(io: IO, socket: TypedSocket) {\n  socket.on(\"join:space\", async ({ spaceId, nickname, avatar }) => {\n    // ?ВёГ¬ВҰВқ??userId ?В¬Г¬ЕЎВ© (?ВҙГ«ВқВј?ВҙГ¬вҖ“Вё??ГӘВ°?Г«В¬ВҙГ¬вҖ№Е“)\n    const userId = socket.data.userId;\n    if (!userId) return;\n\n    // join ???в„ўГӘВёВ° ?ВёГӘ? ГӘВІвӮ¬Г¬ВҰ? ГӘВіВөГӘВ°вҖһ Г¬ВЎВҙГ¬ЕҫВ¬/?Е“Г¬вҖһВұ + Г«В©ВӨГ«ВІвҖһ??+ BANNED Г¬В°ВЁГ«вҖ№ВЁ.\n    // ?ВөГӘВіВј?ЛңГӘВёВ° ?вҖһГ¬вҖ”Вҗ??socket.join / role / presence ?ВұГ«ВЎВқ???ЛңГ¬? ?Е Г«Е вҖқ??\n    let role: \"OWNER\" | \"STAFF\" | \"PARTICIPANT\";\n    let restriction: \"NONE\" | \"MUTED\" | \"BANNED\";\n    let memberId: string;\n    try {\n      const prisma = await getPrisma();\n\n      const space = await prisma.space.findUnique({\n        where: { id: spaceId },\n        select: { id: true, status: true },\n      });\n      if (!space || space.status !== \"ACTIVE\") {\n        socket.emit(\"space:error\", {\n          code: \"SPACE_NOT_FOUND\",\n          message: \"ГӘВіВөГӘВ°вҖһ??Г¬В°ВҫГ¬ВқвҖһ ???вҖ ГӘВұВ°??Г«В№вҖһГӯв„ўЕ“???ВҒГӯЖ’Е“?вҖҰГ«вҖ№ЛҶ??\",\n        });\n        return;\n      }\n\n      const member = await prisma.spaceMember.findUnique({\n        where: { spaceId_userId: { spaceId, userId } },\n        select: { id: true, role: true, restriction: true },\n      });\n      if (!member) {\n        socket.emit(\"space:error\", {\n          code: \"NOT_A_MEMBER\",\n          message: \"??ГӘВіВөГӘВ°вҖһ??Г«В©ВӨГ«ВІвҖһГӘВ°вӮ¬ ?вҖһГ«вҖ№в„ў?ЛҶГ«вҖ№ВӨ.\",\n        });\n        return;\n      }\n      if (member.restriction === \"BANNED\") {\n        socket.emit(\"space:error\", {\n          code: \"BANNED\",\n          message: \"??ГӘВіВөГӘВ°вҖһ?ВҗГ¬вҖһЕ“ Г¬В°ВЁГ«вҖ№ВЁ?ЛңГ¬вҖ”ЛҶ?ВөГ«вҖ№ЛҶ??\",\n        });\n        return;\n      }\n\n      memberId = member.id;\n      role = member.role as \"OWNER\" | \"STAFF\" | \"PARTICIPANT\";\n      restriction = member.restriction as \"NONE\" | \"MUTED\" | \"BANNED\";\n    } catch (err) {\n      console.error(\"[Room] join authorization failed:\", err);\n      socket.emit(\"space:error\", {\n        code: \"JOIN_FAILED\",\n        message: \"?вҖҰГ¬ЕҫВҘ Г¬ВІЛңГ«ВҰВ¬ Г¬ВӨ??ВӨГ«ВҘЛңГӘВ°вӮ¬ Г«В°Е“Г¬Ж’Вқ?ЛҶГ¬Е Вө?ЛҶГ«вҖ№ВӨ.\",\n      });\n      return;\n    }\n\n    // TOCTOU Г«ВіВҙГӘВ°вҖў(WI-036): DB status Г«ВҘ??ВҪГ¬? ??archive ГӘВ°вӮ¬ ?ВјГ¬вҖ“Вҙ?В¬Г¬ВқвҖһ ???ЛҶГ«вҖ№ВӨ.\n    // Г«ВӘВЁГ«вҖңВ  await ?ВҙГӯвҖәвҖһГӮВ·room ?В©Г«ВҘЛң Г¬В§ВҒГ¬В вҖһ??deny cache Г«ВҘ??В¬Гӯв„ўвҖў?ВёГӯвҖўВҙ, in-flight join ??    // archive Г¬В¶вҖқГ«В°В© ?ВӨГ«Ж’вҖҰ???ВҙГӯвҖәвҖһ ?В©Г«ВҘЛң???ВҙГ¬вҖўвҖһ?ВЁГ«Е вҖқ Г¬ВўВҒГ¬? Г¬В°ВҪГ¬ВқвҖһ ?В«Г«Е вҖқ??\n    if (isSpaceArchived(spaceId)) {\n      socket.emit(\"space:error\", {\n        code: \"SPACE_NOT_FOUND\",\n        message: \"ГӘВіВөГӘВ°вҖһ??Г¬В°ВҫГ¬ВқвҖһ ???вҖ ГӘВұВ°??Г«В№вҖһГӯв„ўЕ“???ВҒГӯЖ’Е“?вҖҰГ«вҖ№ЛҶ??\",\n      });\n      return;\n    }\n\n    // ?ВёГӘ? ?ВөГӘВіВј ?вҖһГ¬вҖ”ВҗГ«В§?room Г¬В°ВёГӘ? + ГӘВІвӮ¬Г¬ВҰВқГ«ВҗЕ“ ГӘВ¶Е’ГӯвҖўЕ“ ?вҖўГ«ВіВҙ ?ВӨГ¬В вҖў\n    socket.join(spaceId);\n    socket.data.spaceId = spaceId;\n    socket.data.memberId = memberId;\n    socket.data.role = role;\n    socket.data.restriction = restriction;\n\n    const player: PlayerData = {\n      userId,\n      nickname,\n      avatar,\n      position: { x: 400, y: 300 }, // ГӘВёВ°Г«ВіВё ?ВӨГӯВҸВ° ?вҖһГ¬В№Лң\n    };\n\n    const players = getSpacePlayers(spaceId);\n    players.set(userId, player);\n\n    // ГӘВёВ°Г¬ВЎВҙ ?Е’Г«В ЛҶ?ВҙГ¬вҖ“Вҙ Г«ВӘВ©Г«ВЎВқ ?вҖһГ¬вҖ ВЎ\n    socket.emit(\"players:list\", {\n      players: Array.from(players.values()),\n    });\n\n    // ?ВӨГ«ВҘВё ?Е’Г«В ЛҶ?ВҙГ¬вҖ“Вҙ?ВҗГӘВІЕ’ ?вҖҰГ¬ЕҫВҘ ?Е’Г«ВҰВј\n    socket.to(spaceId).emit(\"player:joined\", player);\n\n    console.log(\n      `[Room] ${nickname} joined ${spaceId} (${players.size} players)`\n    );\n  });\n\n  socket.on(\"leave:space\", () => {\n    // ?ВҙГ«ВқВј?ВҙГ¬вҖ“Вё?ВёГӘ? Г«ВіВҙГ«вҖҡВё spaceId ???В Г«ВўВ°?ЛңГ¬? ?Е Г«Е вҖқ??communication invariant #3) ??    // ?Е“Г«ВІвҖһГӘВ°вӮ¬ ?ВёГӘ???socket.data.spaceId Г«В§??В¬Г¬ЕЎВ©.\n    const spaceId = socket.data.spaceId;\n    if (spaceId) leaveSpace(io, socket, spaceId);\n  });\n\n  // ?В°ГӘВІВ° ?ВҙГ¬В Е“ ???ВҗГ«ВҸв„ў ?ВҙГ¬ЕҫВҘ\n  socket.on(\"disconnect\", () => {\n    const spaceId = socket.data.spaceId;\n    if (spaceId) {\n      leaveSpace(io, socket, spaceId);\n    }\n  });\n}\n\n/**\n * ?Е’Г¬ВјвҖң??ГӘВіВөГӘВ°вҖһ?ВҗГ¬вҖһЕ“ Г«В¬ВјГ«ВҰВ¬?ВҒГ¬Е“ВјГ«ВЎ?Г«В¶вҖһГ«ВҰВ¬: ?ВҗГӘВёВ° id Г«ВҘ??Е“Г¬в„ўВё??Г«ВӘВЁГ«вҖңВ  room(ГӘВіВөГӘВ°вҖһ + ?Е’ГӯвҖ№В°) ?ВҙГӯЖ’ЛҶ +\n * ГӘВіВөГӘВ°вҖһ Г«ВІвҖқГ¬Е“вҖһ socket.data Г«В¬ВҙГӯЕЎВЁ?? ?ВҙГӯвҖәвҖһ Г«ВӘВЁГ«вҖңВ  ?ВҙГ«ВІВӨ???ВёГ«вҖңВӨ?В¬ГӘ? socket.data.spaceId ГӘВ°вӮ¬?Е“Г«ВЎЕ“\n * early-return ?ЛңГ«?Г«ВЎ?stale ?ВёГӘ?(?ВҙГ¬ЕҫВҘ/Г¬В¶вҖқГ«В°В© ???вҖқГ¬ВЎВҙ chat/admin/editor/media)ГӘВ°вӮ¬ Г¬В°ВЁГ«вҖ№ВЁ?Е“Г«вҖ№ВӨ.\n * presence/broadcast ???ВёГ¬В¶Е“Г¬Вё?Г¬ВұвҖҰГ¬ЕҫвҖһ(?ВЁГ¬ВқВј ?Е’Г¬ВјвҖң Г«В¶вҖһГ«ВҰВ¬???В¬Г¬ЕЎВ©???ВЁГ¬Е“вҖһ ?Е’Г«ВҰВјГӘВі?Г«В¶вҖһГ«ВҰВ¬).\n */\nexport function detachSocketFromSpace(socket: TypedSocket): void {\n  for (const room of [...socket.rooms]) {\n    if (room !== socket.id) socket.leave(room);\n  }\n  socket.data.spaceId = undefined;\n  socket.data.partyId = undefined;\n  socket.data.partyName = undefined;\n  socket.data.role = undefined;\n  socket.data.restriction = undefined;\n  socket.data.memberId = undefined;\n}\n\n/** presence ?ВҗГ¬вҖһЕ“ ?В¬Г¬ЕЎВ©???Е“ГӘВұВ° + Г¬ВЈВјГ«???player:left 1???В¬Г¬ЕЎВ©???ВЁГ¬Е“вҖһ, ?ВӨГ¬ВӨвҖҳ ??Г¬ВӨвҖҳГ«ВіВө Г«В°В©Г¬?). */\nexport function removeUserPresence(io: IO, spaceId: string, userId: string): void {\n  const players = spacePlayersMap.get(spaceId);\n  if (players) {\n    players.delete(userId);\n    if (players.size === 0) spacePlayersMap.delete(spaceId);\n  }\n  io.to(spaceId).emit(\"player:left\", { userId });\n}\n\n/** ?ВЁГ¬ВқВј ?Е’Г¬ВјвҖң ?ВҙГ¬ЕҫВҘ(leave:space/disconnect): presence ?вҖўГ«ВҰВ¬ 1??+ ?ВҗГӘВёВ° ?Е’Г¬ВјвҖң Г«В¶вҖһГ«ВҰВ¬. */\nexport function leaveSpace(io: IO, socket: TypedSocket, spaceId: string) {\n  const userId = socket.data.userId;\n  removeUserPresence(io, spaceId, userId);\n  detachSocketFromSpace(socket);\n  console.log(`[Room] ${userId} left ${spaceId}`);\n}\n\r\n","exit_code":0,"status":"completed"}}
