{"type":"item.completed","item":{"id":"item_5","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"Get-Content -Raw server\\\\handlers\\\\enforce.ts\"","aggregated_output":"// Enforcement Handler ??socket ?Е“Г«ВІвҖһ Г¬Вё?(WI-005)\n//\n// Next API route(dashboard ?Е“Г¬ЕҫВ¬)ГӘВ°вӮ¬ Г«ВіВҙГ«вҖҡВё HMAC ?Е“Г«ВӘвҖҰ ?вҖқГ¬ВІВӯ??Г«В°вҖәГ¬вҖўвҖһ, ?ВҙГ¬вҖўвҖһ?ЛҶГ«Е вҖқ ?Е’Г¬ВјвҖң ?В°ГӘВІВ°??// ban/kick/mute/unmute/role ??Г¬ВҰвҖ°Г¬вҖ№Е“ Г«В°ЛңГ¬ЛңВҒ?Е“Г«вҖ№ВӨ. socket.io ?вӮ¬ ?в„ўГ¬ВқВј??httpServer ??// non-socket.io ?вҖқГ¬ВІВӯ ГӘВІВҪГ«ВЎЕ“(POST /internal/enforce)Г«ВЎ??ВӨГ¬вҖ“Вҙ?ВЁГ«вҖ№ВӨ.\n//\n// Г«ВіВҙГ¬вҖўЛҶ ?ВӨГ¬ВёВө Г«В°В©Г¬вҖ“Вҙ(?ВӨГӘВівҖһ codex consult):\n//  1) SOCKET_INTERNAL_SECRET HMAC ?Е“Г«ВӘвҖҰ ГӘВІвӮ¬Г¬ВҰ?+ replay window\n//  2) body size limit + ?ВӨГӯвҖҡВӨГ«В§?ГӘВІвӮ¬Г¬ВҰ?//  3) DB postcondition ?В¬Гӯв„ўвҖў?????Е“ГӯВҒВ¬Г«ВҰ??В Г¬В¶Е“/Next ?ВёГ«вҖңВӨ??Г«ВІвҖһГӘВ·ВёГӘВ°вӮ¬ ГӘВіВ§Г«В°вҖқГ«ВЎ??вҖһГ¬ВқЛң Г¬В¶вҖқГ«В°В©?ВјГ«ВЎЕ“\n//     ?вҖўГ«??ЛңГ«Е вҖқ ГӘВІЖ’Г¬ВқвҖһ Г¬В°ВЁГ«вҖ№ВЁ(?? ban?ВҙГ«В©Вҙ ?ВҙГ«вҖ№В№ Г«В©ВӨГ«ВІвҖһГӘВ°вӮ¬ ?ВӨГ¬В Е“ BANNED?ВёГ¬? ?вҖўГ¬ВқВё ???Е ГӘВёВ°)\n\nimport type { IncomingMessage, ServerResponse } from \"http\";\nimport type { Server, Socket } from \"socket.io\";\nimport type {\n  ClientToServerEvents,\n  ServerToClientEvents,\n} from \"../../src/features/space/protocol/internal/socket-events\";\nimport {\n  ENFORCE_PATH,\n  ENFORCE_SIGNATURE_HEADER,\n  ENFORCE_TIMESTAMP_HEADER,\n  ENFORCE_MAX_BODY_BYTES,\n  verifyEnforceSignature,\n  isFreshTimestamp,\n  parseEnforceRequest,\n  type EnforceRequest,\n} from \"../../src/features/space/enforce/internal/contract\";\nimport {\n  spacePlayersMap,\n  detachSocketFromSpace,\n  removeUserPresence,\n  purgeSpaceState,\n  markSpaceArchived,\n} from \"./room\";\nimport { getPrisma } from \"../lib/prisma\";\n\ntype IO = Server<ClientToServerEvents, ServerToClientEvents>;\ntype TypedSocket = Socket<ClientToServerEvents, ServerToClientEvents>;\n\n// space:error emit ???ВҙГ«ВқВј?ВҙГ¬вҖ“Вё?ВёГ¬вҖ”Вҗ ?вҖһГ«вҖ№В¬?????Е ГӘВёВ° ?вҖһГӯвҖўЕ“ Г¬В§В§Г¬? grace.\n// Г¬ВҰвҖ°Г¬вҖ№Е“ disconnect(true) ?ЛңГ«В©Вҙ Г¬В§ВҒГ¬В вҖһ emit ??flush ?ЛңГ¬? ?Е Г¬ВқвҖһ ???ЛҶГ«вҖ№ВӨ(codex).\nconst DISCONNECT_GRACE_MS = 250;\n\n/** spaceId room ?ВҗГ¬вҖһЕ“ ?ВҙГ«вҖ№В№ userId ??Г«ВӘВЁГ«вҖңВ  ?Е’Г¬ВјвҖң(?ВӨГ¬ВӨвҖҳ ?? */\nfunction socketsForUser(io: IO, spaceId: string, userId: string): TypedSocket[] {\n  const ids = io.sockets.adapter.rooms.get(spaceId);\n  if (!ids) return [];\n  const out: TypedSocket[] = [];\n  for (const id of ids) {\n    const s = io.sockets.sockets.get(id) as TypedSocket | undefined;\n    if (s && s.data.userId === userId) out.push(s);\n  }\n  return out;\n}\n\n/**\n * spaceId room ??Г«ВӘВЁГ«вҖңВ  ?Е’Г¬ВјвҖң ?ВӨГ«Ж’вҖҰ??WI-036 archive). detachSocketFromSpace ГӘВ°вӮ¬ room ?? * Г«ВівӮ¬ГӘВІВҪГӯвҖўЛңГ«ВҜвӮ¬Г«ВЎ? ?Е“ГӯЕЎЕ’ Г¬ВӨ?mutation ???ВјГӯвҖўЛң?ВӨГ«В©Вҙ Г¬ВІЛңГ«ВҰВ¬ ?вҖһГ¬вҖ”Вҗ Г«В°В°Г¬вҖ”ВҙГ«ВЎ?ГӘВіВ Г¬В вҖў?ВҙГ¬вҖўВј ?Е“Г«вҖ№ВӨ(codex).\n * socket.data.spaceId ?ВјГ¬В№ЛңГӘВ№Е’Г¬? ?вҖўГ¬ВқВё??join ?ВёГӘ?ГӘВ°вӮ¬ ?ВқГ«вҖҡЕ“ ?Е’Г¬ВјвҖңГ«В§??В¬ГӯвҖўВЁ?Е“Г«вҖ№ВӨ.\n */\nfunction socketsInSpace(io: IO, spaceId: string): TypedSocket[] {\n  const ids = io.sockets.adapter.rooms.get(spaceId);\n  if (!ids) return [];\n  const out: TypedSocket[] = [];\n  for (const id of ids) {\n    const s = io.sockets.sockets.get(id) as TypedSocket | undefined;\n    if (s && s.data.spaceId === spaceId) out.push(s);\n  }\n  return out;\n}\n\n/**\n * DB postcondition ?В¬Гӯв„ўвҖў?? Next ?ВёГ«вҖңВӨ?В¬ГӘ? ?ВӨГ¬В Е“Г«ВЎ?ГӘВ·??ВҒГӯЖ’Е“Г«ВҘ?Г«В§Е’Г«вҖңВӨ?ЛҶГ«Е вҖқГ¬В§вӮ¬ ?вҖўГ¬ВқВё???ВӨГ¬вҖ”ВҗГ«В§? * ?Е’Г¬ВјвҖң??Г¬ВЎВ°Г¬ЕҫвҖҳ?Е“Г«вҖ№ВӨ. Г«В¶ЛҶГ¬ВқВјГ¬В№??ВҗГ«Е вҖқ ГӘВІвӮ¬Г¬ВҰ??ВӨГ«ВҘЛң)Г«В©?false ???ВёГ¬В¶Е“Г¬ВёВЎГ¬ВқВҙ 409 Г«ВЎ?ГӘВұВ°Г«?.\n */\nasync function verifyPostcondition(req: EnforceRequest): Promise<boolean> {\n  const prisma = await getPrisma();\n\n  // ГӘВіВөГӘВ°вҖһ ?вҖһГ¬ВІВҙ archive ??Г«В©ВӨГ«ВІвҖһГӘВ°вӮ¬ ?вҖһГ«вҖ№ЛҶ??Space.status Г«ВҘ??В¬Гӯв„ўвҖў?ВёГӯвҖўЕ“??\n  // ?Е“ГӯВҒВ¬Г«ВҰ??В Г¬В¶Е“/?ВёГ«вҖңВӨ??Г«ВІвҖһГӘВ·ВёГӘВ°вӮ¬ ?ВҙГ¬вҖўвҖһ?ЛҶГ«Е вҖқ ГӘВіВөГӘВ°вҖһ???вҖһГ¬ВқЛңГ«ВЎ?archive-Г¬В¶вҖқГ«В°В©?ЛңГ«Е вҖқ ГӘВІЖ’Г¬ВқвҖһ Г¬В°ВЁГ«вҖ№ВЁ(409).\n  if (req.action === \"archive\") {\n    const space = await prisma.space.findUnique({\n      where: { id: req.spaceId },\n      select: { status: true },\n    });\n    return space?.status === \"ARCHIVED\";\n  }\n\n  // Г«В©ВӨГ«ВІвҖһ ?вӮ¬???Е“Г¬ЕҫВ¬ ??discriminated union ???В¬ГӘВёВ°??req.userId Г¬ВЎВҙГ¬ЕҫВ¬Г«ВҘ?Г«ВіВҙГ¬ЕҫВҘ?Е“Г«вҖ№ВӨ.\n  const member = await prisma.spaceMember.findUnique({\n    where: { spaceId_userId: { spaceId: req.spaceId, userId: req.userId } },\n    select: { restriction: true, role: true },\n  });\n  switch (req.action) {\n    case \"ban\":\n      return member?.restriction === \"BANNED\";\n    case \"kick\":\n      // WI-045: kick ?вӮ¬ Г«В©ВӨГ«ВІвҖһГ«ВҘ???В Е“?ЛңГ¬? ?Е Г«Е вҖқ???В¬Г¬ЕҫвҖҰ???ЛҶГ¬ЕЎВ©) ???В ГӯЕЎВЁ Г«В©ВӨГ«ВІвҖһ(Г«ВҜВёГ¬В°ВЁ??Г«В§?disconnect.\n      // HMAC Г¬В¶Е“Г¬ВІЛң ГӘВІвӮ¬Г¬ВҰ???Г¬ВөЕ“Г¬вҖ Е’ Г«В¶ЛҶГ«????вҖһГ¬ЕҫВ¬ ГӘВ·?Г«В°В©Г¬ВқЛң ?В ГӯЕЎВЁ Г«В©ВӨГ«ВІвҖһГ«В§?kick ГӘВ°вӮ¬??. ГӘВ¶Е’ГӯвҖўЕ“ ГӘВІвӮ¬Г¬ВҰВқГ¬? ?ВјГ¬ЕЎВ°?ВёГӘ? ??\n      return member !== null && member.restriction !== \"BANNED\";\n    case \"mute\":\n      return member?.restriction === \"MUTED\";\n    case \"unmute\":\n      return member?.restriction === \"NONE\";\n    case \"role\":\n      return member?.role === req.role;\n    default:\n      return false;\n  }\n}\n\n/**\n * ГӘВІвӮ¬Г¬ВҰВқГ«ВҗЕ“ enforce ?вҖқГ¬ВІВӯ???Е’Г¬ВјвҖң???ВҒГ¬ЕЎВ©. ?ВҒГӯвҖ“ВҘГ«В°вҖәГ¬? ?Е’Г¬ВјвҖң ??Г«В°ЛңГӯв„ўЛң(?ВӨГӯвҖқвҖһ?ВјГ¬ВқВё?ВҙГ«В©Вҙ 0=no-op).\n */\nexport function applyEnforcement(io: IO, req: EnforceRequest): number {\n  // ГӘВіВөГӘВ°вҖһ ?вҖһГ¬ВІВҙ archive ??ГӘВ·?ГӘВіВөГӘВ°вҖһ??Г«ВӘВЁГ«вҖңВ  ?вҖҳГ¬вҖ ВҚ?ВҗГ«? Г¬В¶вҖқГ«В°В©?Е“Г«вҖ№ВӨ(WI-036).\n  if (req.action === \"archive\") {\n    // 1) deny cache ???ВұГ«ВЎВқ ???ВҙГӯвҖәвҖһ in-flight join ??Г¬ВҰвҖ°Г¬вҖ№Е“ Г¬В°ВЁГ«вҖ№ВЁ(TOCTOU Г«ВіВҙГӘВ°вҖў).\n    markSpaceArchived(req.spaceId);\n    // 2) ?вӮ¬???Е’Г¬ВјвҖң ?ВӨГ«Ж’вҖҰ????Г¬ВІЛңГ«ВҰВ¬(detach ГӘВ°вӮ¬ room ??mutate ?ЛңГ«?Г«ВЎ??Е“ГӯЕЎЕ’ ??ГӘВіВ Г¬В вҖў).\n    const targets = socketsInSpace(io, req.spaceId);\n    const message = \"??ГӘВіВөГӘВ°вҖһ????В Е“?ЛңГ¬вҖ“Вҙ ?В°ГӘВІВ°??Г¬ВўвҖҰГ«ВЈЕ’?ЛңГ¬вҖ”ЛҶ?ВөГ«вҖ№ЛҶ??\";\n    for (const s of targets) {\n      // ?В¬Г¬Е“В  ?ВөГ¬? ???в„ўГӘВёВ° ГӘВ¶Е’ГӯвҖўЕ“ ?Е’Г¬ЛҶЛң(grace ?в„ўГ¬вҖўЛҶ stale ?ВёГӘ? Г¬В°ВЁГ«вҖ№ВЁ) ??kick/ban ГӘВі??в„ўГ¬ВқВј ?ВЁГӯвҖһВҙ.\n      s.emit(\"space:error\", { code: \"SPACE_ARCHIVED\", message });\n      detachSocketFromSpace(s);\n      setTimeout(() => s.disconnect(true), DISCONNECT_GRACE_MS);\n    }\n    // 3) ГӘВіВөГӘВ°вҖһ??Г«ВӘВЁГ«вҖңВ  ?ВёГ«В©вҖқГ«ВӘВЁГ«ВҰВ¬ ?ВёГ«ВҚВұ???ВјГӘВҙвҖһ ?вҖўГ«ВҰВ¬(presence + media). detach ГӘВ°вӮ¬ socket.data Г«ВҘ?    //    Г«В№вҖһГ¬вҖәВ ?ВјГ«?Г«ВЎ?Г¬В§вӮ¬??disconnect ??leaveSpace ???В¬Г¬вҖ№ВӨ?вҖ°Г«ВҗЛңГ¬В§вӮ¬ ?Е Г«Е вҖқ??\n    purgeSpaceState(req.spaceId);\n    return targets.length;\n  }\n\n  const targets = socketsForUser(io, req.spaceId, req.userId);\n  if (targets.length === 0) return 0;\n\n  const players = spacePlayersMap.get(req.spaceId);\n  const nickname = players?.get(req.userId)?.nickname ?? \"Unknown\";\n  const actor = req.actorName ?? \"ГӘВҙвӮ¬Г«ВҰВ¬Г¬ЕҫВҗ\";\n\n  if (req.action === \"ban\" || req.action === \"kick\") {\n    const code = req.action === \"ban\" ? \"BANNED\" : \"KICKED\";\n    const message =\n      req.action === \"ban\"\n        ? \"ГӘВҙвӮ¬Г«ВҰВ¬Г¬ЕҫВҗ???ЛңГӯвҖўВҙ ??ГӘВіВөГӘВ°вҖһ?ВҗГ¬вҖһЕ“ Г¬В°ВЁГ«вҖ№ВЁ?ЛңГ¬вҖ”ЛҶ?ВөГ«вҖ№ЛҶ??\"\n        : \"ГӘВҙвӮ¬Г«ВҰВ¬Г¬ЕҫВҗ???ЛңГӯвҖўВҙ ??ГӘВіВөГӘВ°вҖһ?ВҗГ¬вҖһЕ“ Г¬В¶вҖқГ«В°В©?ЛңГ¬вҖ”ЛҶ?ВөГ«вҖ№ЛҶ??\";\n\n    // 1) ГӘВ°??вӮ¬ГӘВІ??Е’Г¬ВјвҖң: ?В¬Г¬Е“В  ?ВөГ¬? ??**?в„ўГӘВёВ° ГӘВ¶Е’ГӯвҖўЕ“ ?Е’Г¬ЛҶЛң**(detachSocketFromSpace).\n    //    Г«ВӘВЁГ«вҖңВ  ?ВҙГ«ВІВӨ???ВёГ«вҖңВӨ?В¬Г«Е вҖқ socket.data.spaceId Г«ВЎ??ВёГӘ??ЛңГ«?Г«ВЎ? Г«ВӘВЁГ«вҖңВ  room(ГӘВіВөГӘВ°вҖһ + ?Е’ГӯвҖ№В°)\n    //    ?ВҙГӯЖ’ЛҶ + socket.data Г«В¬ВҙГӯЕЎВЁ?вҖқГ«ВЎЕ“ grace ?в„ўГ¬вҖўЛҶ??ГӘВ¶Е’ГӯвҖўЕ“ ?вҖқГ¬ВЎВҙ(?вҖҰГ¬ВқЛң??chat/admin/editor/media\n    //    ?вҖһГ¬вҖ ВЎ, ?Е’ГӯвҖ№В° Г«В©вҖқГ¬вҖ№Е“Г¬В§вӮ¬ ?ЛңГ¬вҖ№В )??Г¬ВҰвҖ°Г¬вҖ№Е“ ?В«ГӯЕҫЕ’?? ??join ?вӮ¬ WI-001 join ГӘВІЕ’Г¬ВқВҙ?ВёГӘ? Г¬В°ВЁГ«вҖ№ВЁ.\n    //    Г«В¬ВјГ«ВҰВ¬ disconnect Г«В§?grace ?вҖһГ«ВЎЕ“ Г«ВҜВёГ«ВӨвҖһ space:error ?ВЁГӯвҖҡВ· flush Г«ВҘ?Г«ВіВҙГ¬ЕҫВҘ.\n    for (const s of targets) {\n      s.emit(\"space:error\", { code, message });\n      detachSocketFromSpace(s);\n      setTimeout(() => s.disconnect(true), DISCONNECT_GRACE_MS);\n    }\n\n    // 2) presence ?вҖўГ«ВҰВ¬ + Г¬ВЈВјГ«? ?Е’Г«ВҰВј?вӮ¬ **?В¬Г¬ЕЎВ©???ВЁГ¬Е“вҖһ 1??*(?ВӨГ¬ВӨвҖҳ ??Г¬ВӨвҖҳГ«ВіВө player:left Г«В°В©Г¬?).\n    //    ?вӮ¬ГӘВІЕёГ¬? ?ВҙГ«? Г«В¶вҖһГ«ВҰВ¬?ВҗГ¬Е“ВјГ«ВҜвӮ¬Г«ВЎ??ВҗГӘВёВ° ?ВҗГ¬вҖ№В ??member:kicked/player:left Г«ВҘ?Г«В°вҖәГ¬? ?Е ГӘВіВ ,\n    //    spaceId Г«ВҘ?Г«В№вҖһГ¬вҖәВ ?ВјГ«?Г«ВЎ?Г¬В§вӮ¬?В°Г«ВҗЕ“ disconnect ?ВёГ«вҖңВӨ?В¬Г¬ВқЛң leaveSpace ???В¬Г¬вҖ№ВӨ?вҖ°Г«ВҗЛңГ¬В§вӮ¬ ?Е Г«Е вҖқ??\n    io.to(req.spaceId).emit(\"member:kicked\", { memberId: req.userId, nickname, kickedBy: actor });\n    removeUserPresence(io, req.spaceId, req.userId);\n  } else if (req.action === \"mute\" || req.action === \"unmute\") {\n    const restriction = req.action === \"mute\" ? \"MUTED\" : \"NONE\";\n    for (const s of targets) s.data.restriction = restriction;\n    if (req.action === \"mute\") {\n      io.to(req.spaceId).emit(\"member:muted\", { memberId: req.userId, nickname, mutedBy: actor });\n    } else {\n      io.to(req.spaceId).emit(\"member:unmuted\", { memberId: req.userId, nickname, unmutedBy: actor });\n    }\n  } else if (req.action === \"role\" && req.role) {\n    // ГӘВ¶Е’ГӯвҖўЕ“ ?Е’Г¬ЛҶЛң/Г«ВівӮ¬ГӘВІ????ВёГ«В©вҖқГ«ВӘВЁГ«ВҰВ¬ role Г¬ВәВҗГ¬вҖ№Е“ ГӘВ°ВұГ¬вҖ№В (ГӘВ°вҖўГ«вҖңВұ ??admin ?ВҙГ«ВІВӨ??Г¬В°ВЁГ«вҖ№ВЁ)\n    for (const s of targets) s.data.role = req.role;\n  }\n\n  return targets.length;\n}\n\nfunction headerStr(req: IncomingMessage, name: string): string | null {\n  const v = req.headers[name];\n  if (Array.isArray(v)) return v[0] ?? null;\n  return v ?? null;\n}\n\nfunction sendJson(res: ServerResponse, status: number, body: unknown): void {\n  res.writeHead(status, { \"content-type\": \"application/json\" });\n  res.end(JSON.stringify(body));\n}\n\n/**\n * /internal/enforce ?вҖқГ¬ВІВӯ Г¬ВІЛңГ«ВҰВ¬. ??ГӘВІВҪГ«ВЎЕ“ГӘВ°вӮ¬ ?вҖһГ«вҖ№ЛҶГ«В©?false(?ВёГ¬В¶Е“Г¬ВёВЎГ¬ВқВҙ 404 Г¬ВІЛңГ«ВҰВ¬).\n * Г¬ВІЛңГ«ВҰВ¬?ЛҶГ¬Е“ВјГ«В©?true.\n */\nexport async function handleInternalHttp(\n  io: IO,\n  req: IncomingMessage,\n  res: ServerResponse\n): Promise<boolean> {\n  const pathname = (req.url ?? \"\").split(\"?\")[0];\n  if (pathname !== ENFORCE_PATH) return false;\n\n  if (req.method !== \"POST\") {\n    sendJson(res, 405, { error: \"Method not allowed\" });\n    return true;\n  }\n\n  const secret = process.env.SOCKET_INTERNAL_SECRET;\n  if (!secret) {\n    console.error(\"[enforce] SOCKET_INTERNAL_SECRET Г«ВҜВёГ¬вҖһВӨ????enforce Г«В№вҖһГӯв„ўЕ“???вҖқГ¬ВІВӯ ГӘВұВ°Г«?)\");\n    sendJson(res, 503, { error: \"Enforcement not configured\" });\n    return true;\n  }\n\n  // body ?ЛңГ¬В§вҖҳ (byte ?ВЁГ¬Е“вҖһ size limit Г¬ВҙЛҶГӘВіВј ??Г¬ВҰвҖ°Г¬вҖ№Е“ Г¬ВӨвҖҳГ«вҖ№ВЁ ??Г«В©вӮ¬?В°Г«В°вҖқ?ВҙГӯЕ Вё UTF-8 ?вҖўГӯв„ўвҖў Г¬ВёВЎГ¬В вҖў)\n  let raw = \"\";\n  let receivedBytes = 0;\n  let tooLarge = false;\n  for await (const chunk of req) {\n    receivedBytes += (chunk as Buffer).length; // chunk ?вӮ¬ Buffer ??.length ГӘВ°вӮ¬ byte ??    if (receivedBytes > ENFORCE_MAX_BODY_BYTES) {\n      tooLarge = true;\n      break;\n    }\n    raw += chunk;\n  }\n  if (tooLarge) {\n    sendJson(res, 413, { error: \"Body too large\" });\n    return true;\n  }\n\n  const signature = headerStr(req, ENFORCE_SIGNATURE_HEADER);\n  const timestamp = headerStr(req, ENFORCE_TIMESTAMP_HEADER);\n  if (!signature || !timestamp) {\n    sendJson(res, 401, { error: \"Missing signature\" });\n    return true;\n  }\n  if (!isFreshTimestamp(timestamp, Date.now())) {\n    s