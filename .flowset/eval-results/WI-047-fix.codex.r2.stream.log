ocket.on(\"leave:space\", () => {\r\n 197:     // ?´ë¼?´ì–¸?¸ê? ë³´ë‚¸ spaceId ??? ë¢°?˜ì? ?ŠëŠ”??communication invariant #3) ??    // ?œë²„ê°€ ?¸ê???socket.data.spaceId ë§??¬ìš©.\r\n 198:     const spaceId = socket.data.spaceId;\r\n 199:     if (spaceId) leaveSpace(io, socket, spaceId);\r\n 200:   });\r\n 201: \r\n 202:   // ?°ê²° ?´ì œ ???ë™ ?´ìž¥\r\n 203:   socket.on(\"disconnect\", () => {\r\n 204:     const spaceId = socket.data.spaceId;\r\n 205:     if (spaceId) {\r\n 206:       leaveSpace(io, socket, spaceId);\r\n 207:     }\r\n 208:   });\r\n 209: }\r\n 210: \r\n 211: /**\r\n 212:  * ?Œì¼“??ê³µê°„?ì„œ ë¬¼ë¦¬?ìœ¼ë¡?ë¶„ë¦¬: ?ê¸° id ë¥??œì™¸??ëª¨ë“  room(ê³µê°„ + ?Œí‹°) ?´íƒˆ +\r\n 213:  * ê³µê°„ ë²”ìœ„ socket.data ë¬´íš¨?? ?´í›„ ëª¨ë“  ?´ë²¤???¸ë“¤?¬ê? socket.data.spaceId ê°€?œë¡œ\r\n 214:  * early-return ?˜ë?ë¡?stale ?¸ê?(?´ìž¥/ì¶”ë°© ???”ì¡´ chat/admin/editor/media)ê°€ ì°¨ë‹¨?œë‹¤.\r\n 215:  * presence/broadcast ???¸ì¶œì¸?ì±…ìž„(?¨ì¼ ?Œì¼“ ë¶„ë¦¬???¬ìš©???¨ìœ„ ?Œë¦¼ê³?ë¶„ë¦¬).\r\n 216:  */\r\n 217: export function detachSocketFromSpace(socket: TypedSocket): void {\r\n 218:   for (const room of [...socket.rooms]) {\r\n 219:     if (room !== socket.id) socket.leave(room);\r\n 220:   }\r\n 221:   socket.data.spaceId = undefined;\r\n 222:   socket.data.partyId = undefined;\r\n 223:   socket.data.partyName = undefined;\r\n 224:   socket.data.role = undefined;\r\n 225:   socket.data.restriction = undefined;\r\n 226:   socket.data.memberId = undefined;\r\n 227: }\r\n 228: \r\n 229: /** presence ?ì„œ ?¬ìš©???œê±° + ì£¼ë???player:left 1???¬ìš©???¨ìœ„, ?¤ì¤‘ ??ì¤‘ë³µ ë°©ì?). */\r\n 230: export function removeUserPresence(io: IO, spaceId: string, userId: string): void {\r\n 231:   const players = spacePlayersMap.get(spaceId);\r\n 232:   if (players) {\r\n 233:     players.delete(userId);\r\n 234:     if (players.size === 0) spacePlayersMap.delete(spaceId);\r\n 235:   }\r\n 236:   io.to(spaceId).emit(\"player:left\", { userId });\r\n 237: }\r\n 238: \r\n 239: /** ?¨ì¼ ?Œì¼“ ?´ìž¥(leave:space/disconnect): presence ?•ë¦¬ 1??+ ?ê¸° ?Œì¼“ ë¶„ë¦¬. */\r\n 240: export function leaveSpace(io: IO, socket: TypedSocket, spaceId: string) {\r\n 241:   const userId = socket.data.userId;\r\n 242:   removeUserPresence(io, spaceId, userId);\r\n 243:   detachSocketFromSpace(socket);\r\n 244:   console.log(`[Room] ${userId} left ${spaceId}`);\r\n 245: }\r\n","exit_code":0,"status":"completed"}}
