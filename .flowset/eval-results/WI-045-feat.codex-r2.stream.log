on === \"MUTED\") {\nserver\\handlers\\enforce.ts:11://     эЩХыМАыРШыКФ ъ▓ГьЭД ь░иыЛи(ьШИ: banьЭ┤ый┤ эХ┤ыЛ╣ ыйды▓Дъ░А ьЛдьаЬ BANNEDьЭ╕ьзА эЩХьЭ╕ эЫД ыБКъ╕░)\nserver\\handlers\\enforce.ts:93:    select: { restriction: true, role: true },\nserver\\handlers\\enforce.ts:97:      return member?.restriction === \"BANNED\";\nserver\\handlers\\enforce.ts:101:      return member !== null && member.restriction !== \"BANNED\";\nserver\\handlers\\enforce.ts:103:      return member?.restriction === \"MUTED\";\nserver\\handlers\\enforce.ts:105:      return member?.restriction === \"NONE\";\nserver\\handlers\\enforce.ts:144:    const code = req.action === \"ban\" ? \"BANNED\" : \"KICKED\";\nserver\\handlers\\enforce.ts:167:    const restriction = req.action === \"mute\" ? \"MUTED\" : \"NONE\";\nserver\\handlers\\enforce.ts:168:    for (const s of targets) s.data.restriction = restriction;\nsrc/features/space\\chat\\internal\\chat-types.ts:56:export type ChatRestriction = \"NONE\" | \"MUTED\" | \"BANNED\";\nserver\\handlers\\chat.ts:42:  return socket.data.restriction === \"MUTED\";\nserver\\handlers\\chat.ts:228:      ts.data.restriction = \"MUTED\";\nserver\\handlers\\chat.ts:253:      ts.data.restriction = \"NONE\";\n","exit_code":0,"status":"completed"}}
