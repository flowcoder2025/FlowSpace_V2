ATCH ?┬╕├м┬╢┼У ???┬╕├м┬╢┼У??OWNER) + ?тВм??PARTICIPANT) findUnique ?┼У├нтВмтВм???тА╣├мтАФтАж. */\r\nfunction setupActorAndTarget(targetOverrides: Record<string, unknown> = {}) {\r\n  mockAuth.mockResolvedValue(makeSession({ id: \"owner-1\", isSuperAdmin: false, name: \"├к┬┤тВм├л┬ж┬м├м┼╛┬Р\" }));\r\n  mockPrisma.spaceMember.findUnique\r\n    .mockResolvedValueOnce({ role: \"OWNER\" })\r\n    .mockResolvedValueOnce({\r\n      id: \"m-target\",\r\n      spaceId: SPACE_ID,\r\n      role: \"PARTICIPANT\",\r\n      userId: \"u-target\",\r\n      displayName: \"?тВм├к┬▓?,\r\n      user: { name: \"?тВм├к┬▓? },\r\n      ...targetOverrides,\r\n    });\r\n}\r\n\r\ndescribe(\"GET /api/spaces/[id]/admin/members ???тАШ├лтА╣┬╡ allowlist (WI-014, onRefresh ├к┬▓┬╜├л┬б┼У ├к┬░тВм??\", () => {\r\n  it(\"findMany├к┬░тВм restricted*/guestSessionId/spaceId ?┼У├мтДв┬╕ select├л┬б??┬╕├м┬╢┼У?┼У├лтА╣┬д\", async () => {\r\n    mockAuth.mockResolvedValue(makeSession({ id: \"owner-1\", isSuperAdmin: false }));\r\n    mockPrisma.spaceMember.findUnique.mockResolvedValue({ role: \"OWNER\" });\r\n    mockPrisma.spaceMember.findMany.mockResolvedValue([]);\r\n\r\n    const res = await GET(\r\n      buildGetRequest(`/api/spaces/${SPACE_ID}/admin/members`),\r\n      ctx\r\n    );\r\n    expect(res.status).toBe(200);\r\n\r\n    // ├к┬▓┬░├м┬атАв??├л┬│тВм?┬┤├к?├м┬ж? include ├л┬│┬╡├к? ?┬Р├л┼атАЭ ├л┬п┬╝├к┬░┬Р?тАЮ├лтАЬ┼У ?┬м├м┬╢тАЭ├к┬░тВм ??FAIL\r\n    const arg = mockPrisma.spaceMember.findMany.mock.calls[0][0] as {\r\n      select: Record<string, unknown>;\r\n    };\r\n    expect(Object.keys(arg.select).sort()).toEqual(\r\n      [\"createdAt\", \"displayName\", \"guestSession\", \"id\", \"restriction\", \"role\", \"user\", \"userId\"].sort()\r\n    );\r\n    for (const leaked of [\r\n      \"restrictedBy\",\r\n      \"restrictedReason\",\r\n      \"restrictedUntil\",\r\n      \"guestSessionId\",\r\n      \"spaceId\",\r\n      \"updatedAt\",\r\n    ]) {\r\n      expect(arg.select).not.toHaveProperty(leaked);\r\n    }\r\n    // ?┼Т├л┬╣тАЮ├м┬▓??тАЮ├м╦Ж╦Ь ?тАЮ├лтАЬ┼У??├л┬│┬┤├м┬б┬┤ (member-table: user{...}/guestSession{...}, media-management: userId)\r\n    expect(arg.select.user).toEqual({ select: { id: true, name: true, email: true, image: true } });\r\n    expect(arg.select.userId).toBe(true);\r\n  });\r\n\r\n  it(\"├л┬й┬д├л┬▓тАЮ???╦Ж├н┬Н┬╝?┬┤├лтАЬ┼У├л┬п┬╝├л┬ПтАЮ ?тАЮ├лтА╣╦Ж├л┬й?403?┬┤├к┬│┬а findMany ├л┬п┬╕├м┬зтАЮ??, async () => {\r\n    mockAuth.mockResolvedValue(makeSession({ id: \"intruder\", isSuperAdmin: false }));\r\n    mockPrisma.spaceMember.findUnique.mockResolvedValue(null);\r\n\r\n    const res = await GET(\r\n      buildGetRequest(`/api/spaces/${SPACE_ID}/admin/members`),\r\n      ctx\r\n    );\r\n\r\n    expect(res.status).toBe(403);\r\n    expect(mockPrisma.spaceMember.findMany).not.toHaveBeenCalled();\r\n  });\r\n});\r\n\r\ndescribe(\"PATCH /api/spaces/[id]/admin/members ???тАШ├лтА╣┬╡ allowlist (WI-014)\", () => {\r\n  it(\"mute: update├к┬░тВм {id,role,restriction} select├л┬б??┬╕├м┬╢┼У?╦Ь├к┬│┬а ?тАШ├лтА╣┬╡ member??restrictedBy ├л┬п┬╕├лтАж┬╕├м┬╢?, async () => {\r\n    mockAuth.mockResolvedValue(makeSession({ id: \"owner-1\", isSuperAdmin: false, name: \"├к┬┤тВм├л┬ж┬м├м┼╛┬Р\" }));\r\n    // 1) ?┬╕├м┬╢┼У??self, OWNER) 2) ?тВм??target, PARTICIPANT, userId ?╦Ж├м┬Э┼Т)\r\n    mockPrisma.spaceMember.findUnique\r\n      .mockResolvedValueOnce({ role: \"OWNER\" })\r\n      .mockResolvedValueOnce({\r\n        id: \"m-target\",\r\n        spaceId: SPACE_ID,\r\n        role: \"PARTICIPANT\",\r\n        userId: \"u-target\",\r\n        displayName: \"?тВм├к┬▓?,\r\n        user: { name: \"?тВм├к┬▓? },\r\n      });\r\n    mockPrisma.spaceMember.update.mockResolvedValue({\r\n      id: \"m-target\",\r\n      role: \"PARTICIPANT\",\r\n      restriction: \"MUTED\",\r\n    });\r\n\r\n    const res = await PATCH(\r\n      buildJsonRequest(`/api/spaces/${SPACE_ID}/admin/members`, \"PATCH\", {\r\n        memberId: \"m-target\",\r\n        action: \"mute\",\r\n      }),\r\n      ctx\r\n    );\r\n\r\n    expect(res.status).toBe(200);\r\n\r\n    // (1) ├к┬▓┬░├м┬атАв??├л┬│тВм?┬┤├к?├м┬ж? update select ??├м┬зтАШ├нтАв┬й\r\n    const updateArg = mockPrisma.spaceMember.update.mock.calls[0][0] as {\r\n      data: Record<string, unknown>;\r\n      select: Record<string, boolean>;\r\n    };\r\n    expect(Object.keys(updateArg.select).sort()).toEqual([\"id\", \"restriction\", \"role\"]);\r\n    expect(updateArg.select).not.toHaveProperty(\"restrictedBy\");\r\n    // ?┬░├к┬╕┬░(data)?┬Р├л┼атАЭ restrictedBy ├л┬░╦Ь├м╦Ь┬Б\r\n    expect(updateArg.data.restrictedBy).toBe(\"owner-1\");\r\n\r\n    // (2) ?тАШ├лтА╣┬╡ ├к┬│тАЮ├мтАв┬╜ ├л┬│┬┤├м┬б┬┤ + member ?┬┤├л? ├л┬п┬╝├к┬░┬Р?тАЮ├лтАЬ┼У ├л┬╢тВм??    const body = await readJson<{ member: Record<string, unknown>; realtimeEnforced: boolean }>(res);\r\n    expect(Object.keys(body).sort()).toEqual([\"member\", \"realtimeEnforced\"]);\r\n    expect(Object.keys(body.member).sort()).toEqual([\"id\", \"restriction\", \"role\"]);\r\n    expect(body.member).not.toHaveProperty(\"restrictedBy\");\r\n  });\r\n\r\n  it(\"├л┬п┬╕├м┬Э┬╕├м┬ж┬Э├м┬Э┬┤├л┬й?401?┬┤├к┬│┬а update ├л┬п┬╕├м┬зтАЮ??, async () => {\r\n    mockAuth.mockResolvedValue(makeSession(null));\r\n\r\n    const res = await PATCH(\r\n      buildJsonRequest(`/api/spaces/${SPACE_ID}/admin/members`, \"PATCH\", {\r\n        memberId: \"m\",\r\n        action: \"mute\",\r\n      }),\r\n      ctx\r\n    );\r\n\r\n    expect(res.status).toBe(401);\r\n    expect(mockPrisma.spaceMember.update).not.toHaveBeenCalled();\r\n  });\r\n});\r\n\r\n// WI-045: ├к┬░тАв├нтАб┬┤/├м┬░┬и├лтА╣┬и/?┬┤├м┬а┼У ├л┬к┬и├л┬Н┬╕ ??kick ├л┬й┬д├л┬▓тАЮ ├л┬п┬╕├мтАЪ┬н???┬м├м┼╛тАж???╦Ж├м┼б┬й) + LiveKit ?┼У├к┬▒┬░, ban LiveKit ?┼У├к┬▒┬░,\r\n// unban DB-only(enforce ├л┬п┬╕├л┬░┼У??.\r\ndescribe(\"PATCH ??WI-045 ├к┬░тАв├нтАб┬┤/├м┬░┬и├лтА╣┬и/?┬┤├м┬а┼У (kick├В┬╖ban├В┬╖unban)\", () => {\r\n  it(\"kick: ├л┬й┬д├л┬▓тАЮ├л┬е???┬а┼У?╦Ь├м? ?┼а├к┬│┬а enforce kick + LiveKit removeSpaceParticipant ?┬╕├м┬╢┼У\", async () => {\r\n    setupActorAndTarget();\r\n\r\n    const res = await PATCH(\r\n      buildJsonRequest(`/api/spaces/${SPACE_ID}/admin/members`, \"PATCH\", {\r\n        memberId: \"m-target\",\r\n        action: \"kick\",\r\n","exit_code":0,"status":"completed"}}
