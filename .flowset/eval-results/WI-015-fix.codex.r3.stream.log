   const { userId } = payload as { userId: string };\r\n  48:     this.handleLeft(userId);\r\n  49:   };\r\n  50: \r\n  51:   private onRemoteAvatarUpdated = (payload: unknown) => {\r\n  52:     if (!this.ready) {\r\n  53:       this.pendingEvents.push({ type: \"avatarUpdated\", data: payload });\r\n  54:       return;\r\n  55:     }\r\n  56:     this.handleAvatarUpdated(payload as AvatarUpdateData);\r\n  57:   };\r\n  58: \r\n  59:   constructor(private scene: Phaser.Scene) {\r\n  60:     eventBridge.on(GameEvents.REMOTE_PLAYER_JOINED, this.onRemoteJoined);\r\n  61:     eventBridge.on(GameEvents.REMOTE_PLAYER_MOVED, this.onRemoteMoved);\r\n  62:     eventBridge.on(GameEvents.REMOTE_PLAYER_LEFT, this.onRemoteLeft);\r\n  63:     eventBridge.on(GameEvents.REMOTE_PLAYER_AVATAR_UPDATED, this.onRemoteAvatarUpdated);\r\n  64: \r\n  65:     // 씬 준비 후 pending 이벤트 처리\r\n  66:     this.setReady();\r\n  67:   }\r\n  68: \r\n  69:   /** 준비 완료 → pending 이벤트 처리 */\r\n  70:   setReady(): void {\r\n  71:     this.ready = true;\r\n  72:     for (const event of this.pendingEvents) {\r\n  73:       switch (event.type) {\r\n  74:         case \"joined\":\r\n  75:           this.handleJoined(event.data as RemotePlayerData);\r\n  76:           break;\r\n  77:         case \"moved\":\r\n  78:           this.handleMoved(event.data as RemotePlayerData);\r\n  79:           break;\r\n  80:         case \"left\":\r\n  81:           this.handleLeft((event.data as { userId: string }).userId);\r\n  82:           break;\r\n  83:         case \"avatarUpdated\":\r\n  84:           this.handleAvatarUpdated(event.data as AvatarUpdateData);\r\n  85:           break;\r\n  86:       }\r\n  87:     }\r\n  88:     this.pendingEvents = [];\r\n  89:   }\r\n  90: \r\n  91:   /** 매 프레임 보간 업데이트 */\r\n  92:   update(): void {\r\n  93:     for (const player of this.players.values()) {\r\n  94:       player.update();\r\n  95:     }\r\n  96:   }\r\n  97: \r\n  98:   private handleAvatarUpdated(data: AvatarUpdateData): void {\r\n  99:     const player = this.players.get(data.userId);\r\n 100:     if (player) {\r\n 101:       player.updateAvatar(data.avatar);\r\n 102:     }\r\n 103:   }\r\n 104: \r\n 105:   /** 리소스 정리 */\r\n 106:   destroy(): void {\r\n 107:     eventBridge.off(GameEvents.REMOTE_PLAYER_JOINED, this.onRemoteJoined);\r\n 108:     eventBridge.off(GameEvents.REMOTE_PLAYER_MOVED, this.onRemoteMoved);\r\n 109:     eventBridge.off(GameEvents.REMOTE_PLAYER_LEFT, this.onRemoteLeft);\r\n 110:     eventBridge.off(GameEvents.REMOTE_PLAYER_AVATAR_UPDATED, this.onRemoteAvatarUpdated);\r\n 111: \r\n 112:     for (const player of this.players.values()) {\r\n 113:       player.destroy();\r\n 114:     }\r\n 115:     this.players.clear();\r\n 116:   }\r\n 117: \r\n 118:   private handleJoined(data: RemotePlayerData): void {\r\n 119:     // 이미 존재하면 스킵\r\n 120:     if (this.players.has(data.userId)) return;\r\n 121: \r\n 122:     const info: RemotePlayerInfo = {\r\n 123:       userId: data.userId,\r\n 124:       nickname: data.nickname ?? \"Unknown\",\r\n 125:       avatar: data.avatar ?? \"default\",\r\n 126:       x: data.x,\r\n 127:       y: data.y,\r\n 128:       direction: data.direction,\r\n 129:     };\r\n 130: \r\n 131:     const sprite = new RemotePlayerSprite(this.scene, info);\r\n 132:     this.players.set(data.userId, sprite);\r\n 133:   }\r\n 134: \r\n 135:   private handleMoved(data: RemotePlayerData): void {\r\n 136:     const player = this.players.get(data.userId);\r\n 137:     if (player) {\r\n 138:       player.moveTo(data.x, data.y, data.direction);\r\n 139:     } else {\r\n 140:       // 아직 joined 안 됐으면 자동 추가\r\n 141:       this.handleJoined(data);\r\n 142:     }\r\n 143:   }\r\n 144: \r\n 145:   private handleLeft(userId: string): void {\r\n 146:     const player = this.players.get(userId);\r\n 147:     if (player) {\r\n 148:       player.destroy();\r\n 149:       this.players.delete(userId);\r\n 150:     }\r\n 151:   }\r\n 152: }\r\n","exit_code":0,"status":"c