SpriteFromConfig(scene, avatarConfig);\r\n  44: \r\n  45:     // ?ろ攧?检澊???濎劚 (氍茧Μ ?嗢潓 - 氤搓皠 ?措彊)\r\n  46:     this.sprite = scene.add.sprite(info.x, info.y, textureKey, 0);\r\n  47:     this.sprite.setDepth(DEPTH.PLAYER);\r\n  48:     this.sprite.setScale(PLAYER_SCALE);\r\n  49: \r\n  50:     // ?夒劋??    this.nameText = scene.add.text(info.x, info.y + NAME_OFFSET_Y, info.nickname, {\r\n  51:       fontSize: \"12px\",\r\n  52:       fontStyle: \"bold\",\r\n  53:       color: \"#ffffff\",\r\n  54:       fontFamily: \"Arial, 'Malgun Gothic', sans-serif\",\r\n  55:       backgroundColor: \"#00000088\",\r\n  56:       padding: { x: 4, y: 2 },\r\n  57:     });\r\n  58:     this.nameText.setOrigin(0.5);\r\n  59:     this.nameText.setDepth(DEPTH.PLAYER_NAME);\r\n  60: \r\n  61:     // ?犽媹氅旍澊???濎劚\r\n  62:     this.createAnimations(textureKey);\r\n  63: \r\n  64:     if (info.direction) {\r\n  65:       this.currentDirection = info.direction as Direction;\r\n  66:     }\r\n  67:   }\r\n  68: \r\n  69:   /** Tween 氤搓皠 ?措彊 */\r\n  70:   moveTo(x: number, y: number, direction: string): void {\r\n  71:     this.targetX = x;\r\n  72:     this.targetY = y;\r\n  73:     this.isMoving = true;\r\n  74: \r\n  75:     if (direction) {\r\n  76:       this.currentDirection = direction as Direction;\r\n  77:     }\r\n  78: \r\n  79:     // 瓯逢赴 ?犽媹氅旍澊??    const animKey = `remote-walk-${this.userId}-${this.currentDirection}`;\r\n  80:     if (this.scene.anims.exists(animKey) || this.tryCreateAnim(animKey)) {\r\n  81:       this.sprite.anims.play(animKey, true);\r\n  82:     }\r\n  83: \r\n  84:     // Tween?茧 攵€?滊煬???措彊\r\n  85:     this.scene.tweens.add({\r\n  86:       targets: [this.sprite, this.nameText],\r\n  87:       x: x,\r\n  88:       duration: LERP_DURATION,\r\n  89:       ease: \"Linear\",\r\n  90:     });\r\n  91: \r\n  92:     this.scene.tweens.add({\r\n  93:       targets: this.sprite,\r\n  94:       y: y,\r\n  95:       duration: LERP_DURATION,\r\n  96:       ease: \"Linear\",\r\n  97:     });\r\n  98: \r\n  99:     this.scene.tweens.add({\r\n 100:       targets: this.nameText,\r\n 101:       y: y + NAME_OFFSET_Y,\r\n 102:       duration: LERP_DURATION,\r\n 103:       ease: \"Linear\",\r\n 104:       onComplete: () => {\r\n 105:         this.isMoving = false;\r\n 106:         this.sprite.anims.stop();\r\n 107:         this.sprite.setFrame(IDLE_FRAMES[this.currentDirection]);\r\n 108:       },\r\n 109:     });\r\n 110:   }\r\n 111: \r\n 112:   /** ?愴攧 ?滉皝 ?臣 (?措菠??氚滍枆 ?嗢潓) */\r\n 113:   jump(): void {\r\n 114:     if (this.isJumping) return;\r\n 115:     this.isJumping = true;\r\n 116: \r\n 117:     this.scene.tweens.add({\r\n 118:       targets: this,\r\n 119:       jumpOffsetY: -JUMP_HEIGHT,\r\n 120:       duration: JUMP_DURATION / 2,\r\n 121:       ease: \"Sine.Out\",\r\n 122:       yoyo: true,\r\n 123:       onComplete: () => {\r\n 124:         this.jumpOffsetY = 0;\r\n 125:         this.isJumping = false;\r\n 126:       },\r\n 127:     });\r\n 128:   }\r\n 129: \r\n 130:   /** ?呺嵃?错姼 (毵??勲爤?? */\r\n 131:   update(): void {\r\n 132:     // ?挫爠 ?勲爤???滉皝 ?ろ攧??氤奠洂\r\n 133:     if (this.appliedVisualOffsetY !== 0) {\r\n 134:       this.sprite.y -= this.appliedVisualOffsetY;\r\n 135:       this.nameText.y -= this.appliedVisualOffsetY;\r\n 136:       this.appliedVisualOffsetY = 0;\r\n 137:     }\r\n 138: \r\n 139:     // ?夒劋???勳箻 ?欔赴??(tween???勲嫄 ??\r\n 140:     if (!this.isMoving) {\r\n 141:       this.nameText.setPosition(this.sprite.x, this.sprite.y + NAME_OFFSET_Y);\r\n 142:     }\r\n 143: \r\n 144:     // ?愴攧 ?滉皝 ?ろ攧??(?岆崝 歆侅爠, ?れ潓 update?愳劀 氤奠洂)\r\n 145:     if (this.jumpOffsetY !== 0) {\r\n 146:       this.sprite.y += this.jumpOffsetY;\r\n 147:       this.nameText.y += this.jumpOffsetY;\r\n 148:       this.appliedVisualOffsetY = this.jumpOffsetY;\r\n 149:     }\r\n 150:   }\r\n 151: \r\n 152:   /** ?绊????勲皵?€ 氤€瓴?*/\r\n 153:   updateAvatar(avatarString: string): void {\r\n 154:     const config = parseAvatarString(avatarString);\r\n 155:     const newKey = generateAvatarSpriteFromConfig(this.scene, config);\r\n 156: \r\n 157:     // 旮办〈 ?犽媹氅旍澊???滉卑\r\n 158:     const directions: Direction[] = [\"down\", \"left\", \"right\", \"up\"];\r\n 159:     for (const dir of directions) {\r\n 160:       const key = `remote-walk-${this.userId}-${dir}`;\r\n 161:       if (this.scene.anims.exists(key)) {\r\n 162:         this.scene.anims.remove(key);\r\n 163:       }\r\n 164:     }\r\n 165: \r\n 166:     // ?嶌姢觳?甑愳泊\r\n 167:     this.sprite.setTexture(newKey);\r\n 168: \r\n 169:     // ???犽媹氅旍澊???濎劚\r\n 170:     this.createAnimations(newKey);\r\n 171:     this.sprite.setFrame(IDLE_FRAMES[this.currentDirection]);\r\n 172:   }\r\n 173: \r\n 174:   /** 毽唽???曤Μ */\r\n 175:   destroy(): void {\r\n 176:     // Phaser??GameObject destroy ??攴??€?侅潉 臧€毽偆??tween???愲彊 ?滉卑?橃? ?婋姅??\r\n 177:     // jump tween?€ this(?茧皹 臧濎泊)毳? moveTo tween?€ sprite/nameText毳?target?茧 ?橂?搿?    // 氇憪 氇呾嫓?侅溂搿??滉卑?滊嫟 ???岅创 ??stale tween??onComplete?愳劀 ?岅创??sprite.anims毳?    // 毵岇?瓯半倶(crash) jumpOffsetY毳?臧膘嫚?橂┌ ?胳姢?挫姢毳??§晞?愲姅(leak) 瓴冹潉 彀嫧.\r\n 178:     this.scene.tweens.killTweensOf(this);\r\n 179:     this.scene.tweens.killTweensOf(this.sprite);\r\n 180:     this.scene.tweens.killTweensOf(this.nameText);\r\n 181:     this.sprite.destroy();\r\n 182:     this.nameText.destroy();\r\n 183:   }\r\n 184: \r\n 185:   private createAnimations(textureKey: string): void {\r\n 186:     const directions: Direction[] = [\"down\", \"left\", \"right\", \"up\"];\r\n 187:     for (const dir of directions) {\r\n 188:       const key = `remote-walk-${this.userId}-${dir}`;\r\n 189:       if (!this.scene.anims.exists(key)) {\r\n 190:         this.scene.anims.create({\r\n 191:           key,\r\n 192:           frames: this.scene.anims.generateFrameNumbers(textureKey, {\r\n 193:             start: DIRECTION_FRAMES[dir].start,\r\n 194:             end: DIRECTION_FRAMES[dir].end,\r\n 195:           }),\r\n 196:           frameRate: 8,\r\n 197:           repeat: -1,\r\n 198:         });\r\n 199:       }\r\n 200:     }\r\n 201:   }\r\n 202: \r\n 203:   private tryCreateAnim(key: string): boolean {\r\n 204:     return this.scene.anims.exists(key);\r\n 205:   }\r\n 206: }\r\n","exit_code":0,"status":"completed"}}
