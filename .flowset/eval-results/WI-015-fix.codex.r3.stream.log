{"type":"item.completed","item":{"id":"item_32","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -Encoding UTF8 -Path '\"'src/features/space/game/internal/objects/object-manager.ts' | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: /**\r\n   2:  * Object Manager - 인터랙티브 오브젝트 레지스트리 + 근접 체크\r\n   3:  *\r\n   4:  * OBJECT_INTERACT 이벤트를 EventBridge로 발행\r\n   5:  * EDITOR_MAP_LOADED 이벤트로 동적 오브젝트 로딩 지원\r\n   6:  */\r\n   7: \r\n   8: import { TILE_SIZE, INTERACT_DISTANCE } from \"@/constants/game-constants\";\r\n   9: import { eventBridge, GameEvents } from \"../../events\";\r\n  10: import type { EditorMapLoadedPayload, EditorObjectPlacedPayload, EditorObjectMovedPayload, EditorObjectDeletedPayload } from \"../../events\";\r\n  11: import { InteractiveObject, type InteractiveObjectConfig } from \"./interactive-object\";\r\n  12: \r\n  13: export class ObjectManager {\r\n  14:   private objects = new Map<string, InteractiveObject>();\r\n  15:   private nearestObject: InteractiveObject | null = null;\r\n  16:   private interactKey: Phaser.Input.Keyboard.Key;\r\n  17: \r\n  18:   constructor(private scene: Phaser.Scene) {\r\n  19:     this.interactKey = scene.input.keyboard!.addKey(\r\n  20:       Phaser.Input.Keyboard.KeyCodes.E\r\n  21:     );\r\n  22:     this.interactKey.on(\"down\", this.onInteract);\r\n  23: \r\n  24:     // EventBridge 리스너: 동적 오브젝트 로딩\r\n  25:     eventBridge.on(GameEvents.EDITOR_MAP_LOADED, this.onMapLoaded);\r\n  26:     eventBridge.on(GameEvents.EDITOR_OBJECT_PLACED, this.onObjectPlaced);\r\n  27:     eventBridge.on(GameEvents.EDITOR_OBJECT_MOVED, this.onObjectMoved);\r\n  28:     eventBridge.on(GameEvents.EDITOR_OBJECT_DELETED, this.onObjectDeleted);\r\n  29: \r\n  30:     this.registerMapObjects();\r\n  31:   }\r\n  32: \r\n  33:   /** 근접 체크 (매 프레임) */\r\n  34:   checkProximity(playerX: number, playerY: number): void {\r\n  35:     let nearest: InteractiveObject | null = null;\r\n  36:     let nearestDist = Infinity;\r\n  37: \r\n  38:     for (const obj of this.objects.values()) {\r\n  39:       const dx = playerX - obj.worldX;\r\n  40:       const dy = playerY - obj.worldY;\r\n  41:       const dist = Math.sqrt(dx * dx + dy * dy);\r\n  42: \r\n  43:       if (dist < INTERACT_DISTANCE && dist < nearestDist) {\r\n  44:         nearest = obj;\r\n  45:         nearestDist = dist;\r\n  46:       }\r\n  47: \r\n  48:       obj.setNearby(false);\r\n  49:     }\r\n  50: \r\n  51:     if (nearest) {\r\n  52:       nearest.setNearby(true);\r\n  53:     }\r\n  54:     this.nearestObject = nearest;\r\n  55:   }\r\n  56: \r\n  57:   /** 리소스 정리 */\r\n  58:   destroy(): void {\r\n  59:     this.interactKey.off(\"down\", this.onInteract);\r\n  60:     eventBridge.off(GameEvents.EDITOR_MAP_LOADED, this.onMapLoaded);\r\n  61:     eventBridge.off(GameEvents.EDITOR_OBJECT_PLACED, this.onObjectPlaced);\r\n  62:     eventBridge.off(GameEvents.EDITOR_OBJECT_MOVED, this.onObjectMoved);\r\n  63:     eventBridge.off(GameEvents.EDITOR_OBJECT_DELETED, this.onObjectDeleted);\r\n  64:     for (const obj of this.objects.values()) {\r\n  65:       obj.destroy();\r\n  66:     }\r\n  67:     this.objects.clear();\r\n  68:   }\r\n  69: \r\n  70:   /** [E] 키 입력 시 가장 가까운 오브젝트와 상호작용 */\r\n  71:   private onInteract = (): void => {\r\n  72:     if (!this.nearestObject) return;\r\n  73: \r\n  74:     eventBridge.emit(GameEvents.OBJECT_INTERACT, {\r\n  75:       objectId: this.nearestObject.id,\r\n  76:       type: this.nearestObject.type,\r\n  77:     });\r\n  78:   };\r\n  79: \r\n  80:   /** 맵 데이터에서 인터랙티브 오브젝트 자동 등록 */\r\n  81:   private registerMapObjects(): void {\r\n  82:     // 포털 (고정 위치 - map-data.ts 참조)\r\n  83:     this.addObject({\r\n  84:       id: \"portal-1\",\r\n  85:       type: \"portal\",\r\n  86:       x: 3 * TILE_SIZE + TILE_SIZE / 2,\r\n  87:       y: 14 * TILE_SIZE + TILE_SIZE / 2,\r\n  88:       label: \"[E] Portal\",\r\n  89:     });\r\n  90: \r\n  91:     // 스폰 포인트\r\n  92:     this.addObject({\r\n  93:       id: \"spawn-1\",\r\n  94:       type: \"spawn\",\r\n  95:       x: 20 * TILE_SIZE + TILE_SIZE / 2,\r\n  96:       y: 28 * TILE_SIZE + TILE_SIZE / 2,\r\n  97:     });\r\n  98: \r\n  99:     // 표지판\r\n 100:     this.addObject({\r\n 101:       id: \"sign-1\",\r\n 102:       type: \"npc\",\r\n 103:       x: 16 * TILE_SIZE + TILE_SIZE / 2,\r\n 104:       y: 26 * TILE_SIZE + TILE_SIZE / 2,\r\n 105:       label: \"[E] Read\",\r\n 106:     });\r\n 107:   }\r\n 108: \r\n 109:   /** DB에서 로드된 오브젝트들로 재등록 */\r\n 110:   private onMapLoaded = (payload: unknown): void => {\r\n 111:     const data = payload as EditorMapLoadedPayload;\r\n 112:     if (!data.objects || data.objects.length === 0) return;\r\n 113: \r\n 114:     // 기존 하드코딩 오브젝트 제거\r\n 115:     for (const obj of this.objects.values()) {\r\n 116:       obj.destroy();\r\n 117:     }\r\n 118:     this.objects.clear();\r\n 119: \r\n 120:     // DB 오브젝트 등록\r\n 121:     for (const obj of data.objects) {\r\n 122:       this.addObject({\r\n 123:         id: obj.id,\r\n 124:         type: obj.objectType,\r\n 125:         x: obj.positionX * TILE_SIZE + TILE_SIZE / 2,\r\n 126:         y: obj.positionY * TILE_SIZE + TILE_SIZE / 2,\r\n 127:         label: obj.label ?? undefined,\r\n 128:       });\r\n 129:     }\r\n 130:   };\r\n 131: \r\n 132:   /** 에디터에서 오브젝트 배치 */\r\n 133:   private onObjectPlaced = (payload: unknown): void => {\r\n 134:     const data = payload as EditorObjectPlacedPayload;\r\n 135:     const id = data.id || data.tempId || `temp-${Date.now()}`;\r\n 136:     this.addObject({\r\n 137:       id,\r\n 138:       type: data.objectType,\r\n 139:       x: data.positionX * TILE_SIZE + TILE_SIZE / 2,\r\n 140:       y: data.positionY * TILE_SIZE + TILE_SIZE / 2,\r\n 141:       label: data.label,\r\n 142:     });\r\n 143:   };\r\n 144: \r\n 145:   /** 에디터에서 오브젝트 이동 */\r\n 146:   private onObjectMoved = (payload: unknown): void => {\r\n 147:     const data = payload as EditorObjectMovedPayload;\r\n 148:     const existing = this.objects.get(data.id);\r\n 149:     if (existing) {\r\n 150:       existing.destroy();\r\n 151:       this.objects.delete(data.id);\r\n 152:     }\r\n 153:     this.addObject({\r\n 154:       id: data.id,\r\n 155:       type: existing?.type ?? \"default\",\r\n 156:       x: data.positionX * TILE_SIZE + TILE_SIZE / 2,\r\n 157:       y: data.positionY * TILE_SIZE + TILE_SIZE / 2,\r\n 158:     });\r\n 159:   };\r\n 160: \r\n 161:   /** 에디터에서 오브젝트 삭제 */\r\n 162:   private onObjectDeleted = (payload: unknown): void => {\r\n 163:     const data = payload as EditorObjectDeletedPayload;\r\n 164:     const existing = this.objects.get(data.id);\r\n 165:     if (existing) {\r\n 166:       existing.destroy();\r\n 167:       this.objects.delete(data.id);\r\n 168:     }\r\n 169:   };\r\n 170: \r\n 171:   private addObject(config: InteractiveObjectConfig): void {\r\n 172:     const obj = new InteractiveObject(this.scene, config);\r\n 173:     this.objects.set(config.id, obj);\r\n 174:   }\r\n 175: }\r\n","exit_code":0,"status":"completed"}}
