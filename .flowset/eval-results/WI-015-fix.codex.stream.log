atar);\r\n  44:     const textureKey = generateAvatarSpriteFromConfig(scene, avatarConfig);\r\n  45: \r\n  46:     // ?ろ攧?检澊???濎劚 (氍茧Μ ?嗢潓 - 氤搓皠 ?措彊)\r\n  47:     this.sprite = scene.add.sprite(info.x, info.y, textureKey, 0);\r\n  48:     this.sprite.setDepth(DEPTH.PLAYER);\r\n  49:     this.sprite.setScale(PLAYER_SCALE);\r\n  50: \r\n  51:     // ?夒劋??    this.nameText = scene.add.text(info.x, info.y + NAME_OFFSET_Y, info.nickname, {\r\n  52:       fontSize: \"12px\",\r\n  53:       fontStyle: \"bold\",\r\n  54:       color: \"#ffffff\",\r\n  55:       fontFamily: \"Arial, 'Malgun Gothic', sans-serif\",\r\n  56:       backgroundColor: \"#00000088\",\r\n  57:       padding: { x: 4, y: 2 },\r\n  58:     });\r\n  59:     this.nameText.setOrigin(0.5);\r\n  60:     this.nameText.setDepth(DEPTH.PLAYER_NAME);\r\n  61: \r\n  62:     // ?犽媹氅旍澊???濎劚\r\n  63:     this.createAnimations(textureKey);\r\n  64: \r\n  65:     if (info.direction) {\r\n  66:       this.currentDirection = info.direction as Direction;\r\n  67:     }\r\n  68:   }\r\n  69: \r\n  70:   /** Tween 氤搓皠 ?措彊 */\r\n  71:   moveTo(x: number, y: number, direction: string): void {\r\n  72:     this.targetX = x;\r\n  73:     this.targetY = y;\r\n  74:     this.isMoving = true;\r\n  75: \r\n  76:     if (direction) {\r\n  77:       this.currentDirection = direction as Direction;\r\n  78:     }\r\n  79: \r\n  80:     // 瓯逢赴 ?犽媹氅旍澊??    const animKey = `remote-walk-${this.userId}-${this.currentDirection}`;\r\n  81:     if (this.scene.anims.exists(animKey) || this.tryCreateAnim(animKey)) {\r\n  82:       this.sprite.anims.play(animKey, true);\r\n  83:     }\r\n  84: \r\n  85:     // Tween?茧 攵€?滊煬???措彊\r\n  86:     this.scene.tweens.add({\r\n  87:       targets: [this.sprite, this.nameText],\r\n  88:       x: x,\r\n  89:       duration: LERP_DURATION,\r\n  90:       ease: \"Linear\",\r\n  91:     });\r\n  92: \r\n  93:     this.scene.tweens.add({\r\n  94:       targets: this.sprite,\r\n  95:       y: y,\r\n  96:       duration: LERP_DURATION,\r\n  97:       ease: \"Linear\",\r\n  98:     });\r\n  99: \r\n 100:     this.scene.tweens.add({\r\n 101:       targets: this.nameText,\r\n 102:       y: y + NAME_OFFSET_Y,\r\n 103:       duration: LERP_DURATION,\r\n 104:       ease: \"Linear\",\r\n 105:       onComplete: () => {\r\n 106:         this.isMoving = false;\r\n 107:         this.sprite.anims.stop();\r\n 108:         this.sprite.setFrame(IDLE_FRAMES[this.currentDirection]);\r\n 109:       },\r\n 110:     });\r\n 111:   }\r\n 112: \r\n 113:   /** ?愴攧 ?滉皝 ?臣 (?措菠??氚滍枆 ?嗢潓) */\r\n 114:   jump(): void {\r\n 115:     if (this.isJumping) return;\r\n 116:     this.isJumping = true;\r\n 117: \r\n 118:     this.jumpTween = this.scene.tweens.add({\r\n 119:       targets: this,\r\n 120:       jumpOffsetY: -JUMP_HEIGHT,\r\n 121:       duration: JUMP_DURATION / 2,\r\n 122:       ease: \"Sine.Out\",\r\n 123:       yoyo: true,\r\n 124:       onComplete: () => {\r\n 125:         this.jumpOffsetY = 0;\r\n 126:         this.isJumping = false;\r\n 127:         this.jumpTween = undefined;\r\n 128:       },\r\n 129:     });\r\n 130:   }\r\n 131: \r\n 132:   /** ?呺嵃?错姼 (毵??勲爤?? */\r\n 133:   update(): void {\r\n 134:     // ?挫爠 ?勲爤???滉皝 ?ろ攧??氤奠洂\r\n 135:     if (this.appliedVisualOffsetY !== 0) {\r\n 136:       this.sprite.y -= this.appliedVisualOffsetY;\r\n 137:       this.nameText.y -= this.appliedVisualOffsetY;\r\n 138:       this.appliedVisualOffsetY = 0;\r\n 139:     }\r\n 140: \r\n 141:     // ?夒劋???勳箻 ?欔赴??(tween???勲嫄 ??\r\n 142:     if (!this.isMoving) {\r\n 143:       this.nameText.setPosition(this.sprite.x, this.sprite.y + NAME_OFFSET_Y);\r\n 144:     }\r\n 145: \r\n 146:     // ?愴攧 ?滉皝 ?ろ攧??(?岆崝 歆侅爠, ?れ潓 update?愳劀 氤奠洂)\r\n 147:     if (this.jumpOffsetY !== 0) {\r\n 148:       this.sprite.y += this.jumpOffsetY;\r\n 149:       this.nameText.y += this.jumpOffsetY;\r\n 150:       this.appliedVisualOffsetY = this.jumpOffsetY;\r\n 151:     }\r\n 152:   }\r\n 153: \r\n 154:   /** ?绊????勲皵?€ 氤€瓴?*/\r\n 155:   updateAvatar(avatarString: string): void {\r\n 156:     const config = parseAvatarString(avatarString);\r\n 157:     const newKey = generateAvatarSpriteFromConfig(this.scene, config);\r\n 158: \r\n 159:     // 旮办〈 ?犽媹氅旍澊???滉卑\r\n 160:     const directions: Direction[] = [\"down\", \"left\", \"right\", \"up\"];\r\n 161:     for (const dir of directions) {\r\n 162:       const key = `remote-walk-${this.userId}-${dir}`;\r\n 163:       if (this.scene.anims.exists(key)) {\r\n 164:         this.scene.anims.remove(key);\r\n 165:       }\r\n 166:     }\r\n 167: \r\n 168:     // ?嶌姢觳?甑愳泊\r\n 169:     this.sprite.setTexture(newKey);\r\n 170: \r\n 171:     // ???犽媹氅旍澊???濎劚\r\n 172:     this.createAnimations(newKey);\r\n 173:     this.sprite.setFrame(IDLE_FRAMES[this.currentDirection]);\r\n 174:   }\r\n 175: \r\n 176:   /** 毽唽???曤Μ */\r\n 177:   destroy(): void {\r\n 178:     // jump tween??targets??this(GameObject ?勲嫎)??sprite/nameText destroy搿?    // Phaser臧€ ?愲彊 ?曤Μ?橃? ?婌潓 ??氇呾嫓?侅溂搿??滉卑(?岅创 ??stale tween??jumpOffsetY毳?    // 瓿勳啀 臧膘嫚?橂┌ ?胳姢?挫姢毳??§晞?愲姅 ?勳垬 彀嫧). moveTo??tween?€ sprite/nameText毳?    // targets搿??橂?搿?GameObject destroy ???愲彊 ?曤Μ?滊嫟.\r\n 179:     if (this.jumpTween) {\r\n 180:       this.jumpTween.remove();\r\n 181:       this.jumpTween = undefined;\r\n 182:     }\r\n 183:     this.scene.tweens.killTweensOf(this);\r\n 184:     this.sprite.destroy();\r\n 185:     this.nameText.destroy();\r\n 186:   }\r\n 187: \r\n 188:   private createAnimations(textureKey: string): void {\r\n 189:     const directions: Direction[] = [\"down\", \"left\", \"right\", \"up\"];\r\n 190:     for (const dir of directions) {\r\n 191:       const key = `remote-walk-${this.userId}-${dir}`;\r\n 192:       if (!this.scene.anims.exists(key)) {\r\n 193:         this.scene.anims.create({\r\n 194:           key,\r\n 195:           frames: this.scene.anims.generateFrameNumbers(textureKey, {\r\n 196:             start: DIRECTION_FRAMES[dir].start,\r\n 197:             end: DIRECTION_FRAMES[dir].end,\r\n 198:           }),\r\n 199:           frameRate: 8,\r\n 200:           repeat: -1,\r\n 201:         });\r\n 202:       }\r\n 203:     }\r\n 204:   }\r\n 205: \r\n 206:   private tryCreateAnim(key: string): boolean {\r\n 207:     return this.scene.anims.exists(key);\r\n 208:   }\r\n 209: }\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_4","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=1; Get-Content -LiteralPath '\"'src/features/space/game/internal/scenes/main-scene.ts' | ForEach-Object { '{0,4}: {1}' -f \"'$i, $_; $i++ }'","aggregated_output":"   1: /**\r\n   2:  * Main Scene - ???¤ì??¤íŠ¸?ˆì´?? *\r\n   3:  * ?œë¸Œ?œìŠ¤??ì¡°í•©: Tilemap + LocalPlayer + RemotePlayerManager + Camera + Objects\r\n   4:  * EventBridgeë¡?React??SCENE_READY ?Œë¦¼\r\n   5:  */\r\n   6: \r\n   7: import { SCENE_KEYS, MAP_WIDTH, MAP_HEIGHT, TILE_SIZE, DEPTH, MAP_COLS, MAP_ROWS, PLAYER_WIDTH, PLAYER_HEIGHT } from \"@/constants/game-constants\";\r\n   8: import { eventBridge, GameEvents } from \"../../events\";\r\n   9: import { createTilemapSystem, type TilemapResult } from \"../tilemap/tilemap-system\";\r\n  10: import { LocalPlayer } from \"../player/local-player\";\r\n  11: import { InputController } from \"../player/input-controller\";\r\n  12: import { TileCollisionChecker } from \"../player/tile-collision-checker\";\r\n  13: import { RemotePlayerManager } from \"../remote/remote-player-manager\";\r\n  14: import { CameraController } from \"../camera/camera-controller\";\r\n  15: import { ObjectManager } from \"../objects/object-manager\";\r\n  16: import { EditorSystem } from \"@/features/space/editor\";\r\n  17: import { createLoadableAssets, loadAssetsInScene } from \"../asset-loader\";\r\n  18: import { COLLISION_LAYER_NAMES } from \"../tilemap/map-data\";\r\n  19: import type { AssetGeneratedPayload } from \"../../events\";\r\n  20: import { CHIBI_CHARACTERS, getChibiTextureKey } from \"@/features/space/avatar\";\r\n  21: \r\n  22: export class MainScene extends Phaser.Scene {\r\n  23:   tilemapResult!: TilemapResult;\r\n  24:   private localPlayer!: LocalPlayer;\r\n  25:   private inputController!: InputController;\r\n  26:   private tileCollisionChecker!: TileCollisionChecker;\r\n  27:   private remotePlayerManager!: RemotePlayerManager;\r\n  28:   private cameraController!: CameraController;\r\n  29:   private objectManager!: ObjectManager;\r\n  30:   private editorSystem!: EditorSystem;\r\n  31:   /** cleanup ë©±ë“± ê°€????SHUTDOWN/DESTROY ì¤‘ë³µ ë°œìƒ ???´ì¤‘ ?•ë¦¬ ë°©ì? */\r\n  32:   private cleanedUp = false;\r\n  33: \r\n  34:   constructor() {\r\n  35:     super({ key: SCENE_KEYS.MAIN });\r\n  36:   }\r\n  37: \r\n  38:   preload(): void {\r\n  39:     // AI ?€???´ë?ì§€\r\n  40:     this.load.image(\"tile-wood-floor\", \"/assets/tiles/wood-floor.png\");\r\n  41:     this.load.image(\"tile-carpet-floor\", \"/assets/tiles/carpet-floor.png\");\r\n  42:     this.load.image(\"tile-wall\", \"/assets/tiles/wall.png\");\r\n  43:     // AI ê°€êµ??¤ë¸Œ?íŠ¸ (ë°°ê²½ ?œê±°??\r\n  44:     this.load.image(\"obj-desk\", \"/assets/objects/desk.png\");\r\n  45:     this.load.image(\"obj-chair\", \"/assets/objects/chair.png\");\r\n  46:     this.load.image(\"obj-bookshelf\", \"/assets/objects/bookshelf.png\");\r\n  47:     this.load.image(\"obj-sofa\", \"/assets/objects/sofa.png\");\r\n  48:     this.load.image(\"obj-plant\", \"/assets/objects/plant.png\");\r\n  49:     this.load.image(\"obj-watercooler\", \"/assets/objects/watercooler.png\");\r\n  50:     this.load.image(\"obj-whiteboard\", \"/assets/objects/whiteboard.png\");\r\n  51:     this.load.image(\"obj-table\", \"/assets/objects/table.png\");\r\n  52:     this.load.image(\"obj-chair-back\", \"/assets/objects/chair_back.png\");\r\n  53:     // ì¹˜ë¹„ AI ìºë¦­???¤í”„?¼ì´?¸ì‹œ??    for (const ch of CHIBI_CHARACTERS) {\r\n  54:       this.load.spritesheet(getChibiTextureKey(ch.id), ch.spritePath, {\r\n  55:         frameWidth: PLAYER_WIDTH,\r\n  56:         frameHeight: PLAYER_HEIGHT,\r\n  57:       });\r\n  58:     }\r\n  59:   }\r\n  60: \r\n  61:   create(): void {\r\n  62:     // Phaser SceneManager??init/preload/create/updateë§??ë™ ?°ê²°?œë‹¤.\r\n  63:     // scene.shutdown()?€ ?ë™ ?¸ì¶œ?˜ì?