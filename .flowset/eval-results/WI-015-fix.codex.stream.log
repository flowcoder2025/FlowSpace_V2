ber;\r\n  48:   private logicalY: number;\r\n  49: \r\n  50:   // ?愴攧 (?滉皝 ?勳毄, logicalY?€ ?呺 ??氤勲弰 臧濎泊搿??措彊 Tween瓿??€瓴?攵勲Μ)\r\n  51:   private jumpState = { offsetY: 0 };\r\n  52:   private isJumping = false;\r\n  53: \r\n  54:   // Grid state\r\n  55:   private tileCol: number;\r\n  56:   private tileRow: number;\r\n  57:   private isStepping = false;\r\n  58:   private isIdle = true;\r\n  59:   private lastStepEndTime = 0;\r\n  60:   private collisionChecker: TileCollisionChecker | null = null;\r\n  61: \r\n  62:   constructor(private scene: Phaser.Scene, options: LocalPlayerOptions) {\r\n  63:     this.userId = options.userId;\r\n  64:     this.tileCol = options.col;\r\n  65:     this.tileRow = options.row;\r\n  66: \r\n  67:     this.logicalX = options.col * TILE_SIZE + TILE_HALF;\r\n  68:     this.logicalY = options.row * TILE_SIZE + TILE_HALF;\r\n  69: \r\n  70:     // ?勲皵?€ ?嶌姢觳??濎劚\r\n  71:     const avatarConfig = parseAvatarString(options.avatar);\r\n  72:     const textureKey = generateAvatarSpriteFromConfig(scene, avatarConfig);\r\n  73: \r\n  74:     // ?ろ攧?检澊???濎劚 (氍茧Μ ?嗢潓 ??Tween ?措彊)\r\n  75:     this.sprite = scene.add.sprite(this.logicalX, this.logicalY, textureKey, 0);\r\n  76:     this.sprite.setDepth(DEPTH.PLAYER);\r\n  77:     this.sprite.setScale(PLAYER_SCALE);\r\n  78: \r\n  79:     // 氚旊嫢 攴鸽??    this.shadow = scene.add.ellipse(this.logicalX, this.logicalY + 28, 30, 10, 0x000000, 0.25);\r\n  80:     this.shadow.setDepth(DEPTH.PLAYER - 1);\r\n  81: \r\n  82:     // ?夒劋???嶌姢??    this.nameText = scene.add.text(this.logicalX, this.logicalY + NAME_OFFSET_Y, options.nickname, {\r\n  83:       fontSize: \"12px\",\r\n  84:       fontStyle: \"bold\",\r\n  85:       color: \"#ffffff\",\r\n  86:       fontFamily: \"Arial, 'Malgun Gothic', sans-serif\",\r\n  87:       backgroundColor: \"#00000088\",\r\n  88:       padding: { x: 4, y: 2 },\r\n  89:     });\r\n  90:     this.nameText.setOrigin(0.5);\r\n  91:     this.nameText.setDepth(DEPTH.PLAYER_NAME);\r\n  92: \r\n  93:     // ?犽媹氅旍澊???濎劚\r\n  94:     this.createAnimations(textureKey);\r\n  95: \r\n  96:     // 齑堦赴 ?勳箻 敫岆?滌簮?ろ姼\r\n  97:     this.emitMovement(false);\r\n  98:   }\r\n  99: \r\n 100:   /** 於╇弻 觳挫护 欤检瀰 */\r\n 101:   setCollisionChecker(checker: TileCollisionChecker): void {\r\n 102:     this.collisionChecker = checker;\r\n 103:   }\r\n 104: \r\n 105:   /** ?勲爤???呺嵃?错姼 ??idle???岆 ?呺牓 觳橂Μ */\r\n 106:   update(input: MovementInput): void {\r\n 107:     const { dx, dy, direction, isMoving } = input;\r\n 108: \r\n 109:     if (!this.isStepping && isMoving) {\r\n 110:       const targetCol = this.tileCol + dx;\r\n 111:       const targetRow = this.tileRow + dy;\r\n 112: \r\n 113:       if (dx !== 0 && dy !== 0) {\r\n 114:         if (this.canMoveTo(targetCol, targetRow)) {\r\n 115:           this.startStep(targetCol, targetRow, direction);\r\n 116:         } else if (this.canMoveTo(this.tileCol + dx, this.tileRow)) {\r\n 117:           const hDir: Direction = dx < 0 ? \"left\" : \"right\";\r\n 118:           this.startStep(this.tileCol + dx, this.tileRow, hDir);\r\n 119:         } else if (this.canMoveTo(this.tileCol, this.tileRow + dy)) {\r\n 120:           const vDir: Direction = dy < 0 ? \"up\" : \"down\";\r\n 121:           this.startStep(this.tileCol, this.tileRow + dy, vDir);\r\n 122:         } else {\r\n 123:           this.setIdle(direction);\r\n 124:         }\r\n 125:       } else {\r\n 126:         if (this.canMoveTo(targetCol, targetRow)) {\r\n 127:           this.startStep(targetCol, targetRow, direction);\r\n 128:         } else {\r\n 129:           this.setIdle(direction);\r\n 130:         }\r\n 131:       }\r\n 132:     } else if (!this.isStepping && !isMoving) {\r\n 133:       // Shift+氚╉枼: direction??氤€瓴诫悩?堨溂氅?歃夓嫓 氚橃榿\r\n 134:       if (direction !== this.currentDirection) {\r\n 135:         this.setIdle(direction);\r\n 136:         this.emitMovement(false);\r\n 137:       } else {\r\n 138:         const elapsed = this.scene.time.now - this.lastStepEndTime;\r\n 139:         if (!this.isIdle && elapsed > 80) {\r\n 140:           this.setIdle(this.currentDirection);\r\n 141:         }\r\n 142:       }\r\n 143:     }\r\n 144: \r\n 145:     // ?岆崝 ?欔赴?? logicalX/Y + jumpState.offsetY ??sprite/nameText/shadow ?勳箻\r\n 146:     this.syncVisuals();\r\n 147:   }\r\n 148: \r\n 149:   /** ?愴攧 ?滉皝 ?臣 */\r\n 150:   jump(): void {\r\n 151:     if (this.isJumping) return;\r\n 152:     this.isJumping = true;\r\n 153: \r\n 154:     const baseScale = PLAYER_SCALE;\r\n 155: \r\n 156:     // 1) ?勳暯 ?ろ姼?堨箻\r\n 157:     this.scene.tweens.add({\r\n 158:       targets: this.sprite,\r\n 159:       scaleY: baseScale * 1.15,\r\n 160:       scaleX: baseScale * 0.9,\r\n 161:       duration: 60,\r\n 162:       ease: \"Sine.Out\",\r\n 163:       onComplete: () => {\r\n 164:         this.sprite.setScale(baseScale);\r\n 165: \r\n 166:         // 2) ?愴攧 甓れ爜 (jumpState 氤勲弰 臧濎泊 ???措彊 Tween瓿??€瓴?攵勲Μ)\r\n 167:         this.scene.tweens.add({\r\n 168:           targets: this.jumpState,\r\n 169:           offsetY: -JUMP_HEIGHT,\r\n 170:           duration: JUMP_DURATION / 2,\r\n 171:           ease: \"Sine.Out\",\r\n 172:           yoyo: true,\r\n 173:           onComplete: () => {\r\n 174:             this.jumpState.offsetY = 0;\r\n 175: \r\n 176:             // 3) 彀╈? ?れ考??            this.scene.tweens.add({\r\n 177:               targets: this.sprite,\r\n 178:               scaleY: baseScale * 0.85,\r\n 179:               scaleX: baseScale * 1.12,\r\n 180:               duration: 80,\r\n 181:               ease: \"Sine.Out\",\r\n 182:               yoyo: true,\r\n 183:               onComplete: () => {\r\n 184:                 this.sprite.setScale(baseScale);\r\n 185:                 this.isJumping = false;\r\n 186:               },\r\n 187:             });\r\n 188:           },\r\n 189:         });\r\n 190:       },\r\n 191:     });\r\n 192: \r\n 193:     eventBridge.emit(GameEvents.PLAYER_JUMPED, { id: this.userId });\r\n 194:   }\r\n 195: \r\n 196:   /** ?勳灛 ?茧Μ ?勳箻 氚橅櫂 (?ろ姼?岉伂/攴检爲 觳错伂?? ?愴攧 ?ろ攧??氙疙彫?? */\r\n 197:   getPosition(): { x: number; y: number } {\r\n 198:     return { x: this.logicalX, y: this.logicalY };\r\n 199:   }\r\n 200: \r\n 201:   /** ?ろ攧?检澊??氚橅櫂 (旃措⿺??於旍爜?? */\r\n 202:   getSprite(): Phaser.GameObjects.Sprite {\r\n 203:     return this.sprite;\r\n 204:   }\r\n 205: \r\n 206:   /** ?绊????勲皵?€ 氤€瓴?*/\r\n 207:   updateAvatar(avatarString: string): void {\r\n 208:     const config = parseAvatarString(avatarString);\r\n 209:     const newKey = generateAvatarSpriteFromConfig(this.scene, config);\r\n 210: \r\n 211:     const directions: Direction[] = [\"down\", \"left\", \"right\", \"up\"];\r\n 212:     for (const dir of directions) {\r\n 213:       const key = `player-walk-${dir}`;\r\n 214:       if (this.scene.anims.exists(key)) {\r\n 215:         this.scene.anims.remove(key);\r\n 216:       }\r\n 217:     }\r\n 218: \r\n 219:     this.sprite.setTexture(newKey);\r\n 220:     this.createAnimations(newKey);\r\n 221:     this.sprite.setFrame(IDLE_FRAMES[this.currentDirection]);\r\n 222:   }\r\n 223: \r\n 224:   /** 毽唽???曤Μ */\r\n 225:   destroy(): void {\r\n 226:     this.sprite.destroy();\r\n 227:     this.nameText.destroy();\r\n 228:     this.shadow.destroy();\r\n 229:   }\r\n 230: \r\n 231:   // === Private ===\r\n 232: \r\n 233:   /** 於╇弻 觳错伂 */\r\n 234:   private canMoveTo(col: number, row: number): boolean {\r\n 235:     if (!this.collisionChecker) return true;\r\n 236:     return this.collisionChecker.isWalkable(col, row);\r\n 237:   }\r\n 238: \r\n 239:   /** ?€????旃??措彊 ?滌瀾 */\r\n 240:   private startStep(col: number, row: number, dir: Direction): void {\r\n 241:     this.isStepping = true;\r\n 242:     this.isIdle = false;\r\n 243:     this.currentDirection = dir;\r\n 244: \r\n 245:     const targetX = col * TILE_SIZE + TILE_HALF;\r\n 246:     const targetY = row * TILE_SIZE + TILE_HALF;\r\n 247: \r\n 248:     // ?€臧侅劆?€ ??氚?瓯半Μ ??duration 氤挫爼?茧 ?措彊 ?嶋弰 ?检爼\r\n 249:     const isDiagonal = col !== this.tileCol && row !== this.tileRow;\r\n 250:     const duration = isDiagonal\r\n 251:       ? Math.round(TILE_STEP_DURATION * Math.SQRT2)\r\n 252:       : TILE_STEP_DURATION;\r\n 253: \r\n 254:     // 瓯逢赴 ?犽媹氅旍澊???儩\r\n 255:     this.sprite.anims.play(`player-walk-${dir}`, true);\r\n 256: \r\n 257:     // Tween?茧 ?茧Μ 膦岉憸 ?措彊 (sprite.y 歆侅爲 氤€瓴????????愴攧?€ 臧勳劖 ?嗢潓)\r\n 258:     this.scene.tweens.add({\r\n 259:       targets: this,\r\n 260:       logicalX: targetX,\r\n 261:       logicalY: targetY,\r\n 262:       duration,\r\n 263:       ease: \"Linear\",\r\n 264:       onComplete: () => {\r\n 265:         this.tileCol = col;\r\n 266:         this.tileRow = row;\r\n 267:         this.isStepping = false;\r\n 268:         this.lastStepEndTime = this.scene.time.now;\r\n 269:         this.emitMovement(true);\r\n 270:       },\r\n 271:     });\r\n 272:   }\r\n 273: \r\n 274:   /** idle ?來儨 ?れ爼 */\r\n 275:   private setIdle(dir: Direction): void {\r\n 276:     this.currentDirection = dir;\r\n 277:     if (!this.isIdle) {\r\n 278:       this.isIdle = true;\r\n 279:       this.sprite.anims.stop();\r\n 280:     }\r\n 281:     this.sprite.setFrame(IDLE_FRAMES[this.currentDirection]);\r\n 282:   }\r\n 283: \r\n 284:   /** ?茧Μ 膦岉憸 + ?愴攧 ?ろ攧?????滉皝 ?勳箻 ?欔赴??(毵??勲爤?? */\r\n 285:   private syncVisuals(): void {\r\n 286:     // ?愴攧 欷??橃 ?措彊 ???ろ攧??氤挫爼 (?橅枼=?侅噭 氚╈?, ?來枼=瓿检灔 ?奠牅)\r\n 287:     let jy = this.jumpState.offsetY;\r\n 288:     if (jy !== 0 && this.isStepping && this.currentDirection === \"down\") {\r\n 289:       jy *= 1.5; // ?橅枼 ?措彊 ???愴攧 ?侅噭 氤挫儊\r\n 290:     }\r\n 291:     const visualY = this.logicalY + jy;\r\n 292: \r\n 293:     this.sprite.setPosition(this.logicalX, visualY);\r\n 294:     this.nameText.setPosition(this.logicalX, visualY + NAME_OFFSET_Y);\r\n 295:     // 攴鸽?愲姅 ??儊 歆€氅?(?愴攧 ?ろ攧??氙胳爜??\r\n 296:     this.shadow.setPosition(this.logicalX, this.logicalY + 28);\r\n 297: \r\n 298:     // ?愴攧 ?掛澊??牍勲???攴鸽??於曥唽\r\n 299:     if (jy !== 0) {\r\n 300:       const jumpRatio = Math.abs(jy) / JUMP_HEIGHT;\r\n 301:       this.shadow.setScale(1 - jumpRatio * 0.5, 1 - jumpRatio * 0.5);\r\n 302:       this.shadow.setAlpha(0.25 * (1 - jumpRatio * 0.6));\r\n 303:     } else {\r\n 304:       this.shadow.setScale(1, 1);\r\n 305:       this.shadow.setAlpha(0.25);\r\n 306:     }\r\n 307:   }\r\n 308: \r\n 309:   /** 瓯逢赴 ?犽媹氅旍澊???濎劚 */\r\n 310:   private createAnimations(textureKey: string): void {\r\n 311:     const directions: Direction[] = [\"down\", \"left\", \"right\", \"up\"];\r\n 312:     for (const dir of directions) {\r\n 313:       const frames = DIRECTION_FRAMES[dir];\r\n 314:       const key = `player-walk-${dir}`;\r\n 315:       if (!this.scene.anims.exists(key)) {\r\n 316:         this.scene.anims.create({\r\n 317:           key,\r\n 318:           frames: this.scene.anims.generateFrameNumbers(textureKey, {\r\n 319:             start: frames.start,\r\n 320:             end: frames.end,\r\n 321:           }),\r\n 322:           frameRate: 12,\r\n 323:           repeat: -1,\r\n 324:         });\r\n 325:       }\r\n 326:     }\r\n 327:   }\r\n 328: \r\n 329:   /** ?措彊 ?措菠??氚滍枆 */\r\n 330:   private emitMovement(isMoving: boolean): void {\r\n 331:     eventBridge.emit(GameEvents.PLAYER_MOVED, {\r\n 332:       id: this.userId,\r\n 333:       x: Math.round(this.logicalX),\r\n 334:       y: Math.round(this.logicalY),\r\n 335:       direction: this.currentDirection,\r\n 336:       isMoving,\r\n 337:     });\r\n 338:   }\r\n 339: }\r\n","exit_code":0,"status":"completed"}}
