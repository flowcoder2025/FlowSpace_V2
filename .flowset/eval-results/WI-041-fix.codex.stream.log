 17: export const CHAT_RESTRICTIONS = [\\\"NONE\\\", \\\"MUTED\\\", \\\"BANNED\\\"] as const;\\r\\n  18: export type ChatRestrictionValue = (typeof CHAT_RESTRICTIONS)[number];\\r\\n  19: \\r\\n  20: /**\\r\\n  21:  * 행위자가 대상에게 관리 액션을 수행할 수 있는지 판정한다.\\r\\n  22:  *\\r\\n  23:  * 원칙: 호출자 역할이 대상 역할보다 **엄격히 상위**일 때만 허용한다.\\r\\n  24:  * 즉 동급(STAFF→STAFF)이나 상위(STAFF→OWNER) 제재는 불가.\\r\\n  25:  * superAdmin은 계층과 무관하게 항상 허용.\\r\\n  26:  */\\r\\n  27: export function canActOn(\\r\\n  28:   actorRole: SpaceRole,\\r\\n  29:   targetRole: SpaceRole,\\r\\n  30:   isSuperAdmin = false\\r\\n  31: ): boolean {\\r\\n  32:   if (isSuperAdmin) return true;\\r\\n  33:   return ROLE_RANK[actorRole] > ROLE_RANK[targetRole];\\r\\n  34: }\\r\\n  35: \\r\\n  36: /** 값이 유효한 SpaceRole enum 인지 런타임 검증. */\\r\\n  37: export function isSpaceRole(value: unknown): value is SpaceRole {\\r\\n  38:   return typeof value === \\\"string\\\" && (SPACE_ROLES as readonly string[]).includes(value);\\r\\n  39: }\\r\\n  40: \\r\\n  41: /** 값이 유효한 ChatRestriction enum 인지 런타임 검증. */\\r\\n  42: export function isChatRestriction(value: unknown): value is ChatRestrictionValue {\\r\\n  43:   return (\\r\\n  44:     typeof value === \\\"string\\\" && (CHAT_RESTRICTIONS as readonly string[]).includes(value)\\r\\n  45:   );\\r\\n  46: }\\r\\n  47: \\r\\n  48: /** 인-스페이스 진입 시 멤버십/role 처리 결정. */\\r\\n  49: export type SpaceRoleDecision =\\r\\n  50:   | { action: \\\"use\\\"; role: SpaceRole } // 기존 멤버 행 role 사용\\r\\n  51:   | { action: \\\"create\\\"; role: SpaceRole } // 멤버 행 생성 후 그 role 사용\\r\\n  52:   | { action: \\\"redirect\\\" }; // 가입 불가 → 접근 거부\\r\\n  53: \\r\\n  54: /**\\r\\n  55:  * 인-스페이스 페이지 진입 시 사용자의 공간 role 결정을 한 곳에서 산정한다.\\r\\n  56:  *\\r\\n  57:  * 인-스페이스 권한 SoT는 `SpaceMember.role`이다 ? 소켓 `join:space`\\r\\n  58:  * (server/handlers/room.ts)와 `requireSpaceAdmin`이 같은 값을 권위로 쓴다.\\r\\n  59:  * 클라이언트가 소켓과 다른 근거로 role을 추정하면 권한 UI/명령 파서는 열리나\\r\\n  60:  * 소켓 서버가 거부하는 발산이 생기므로, 항상 멤버 행 role을 따른다.\\r\\n  61:  *\\r\\n  62:  * 결정:\\r\\n  63:  * - 멤버 행 있음 + BANNED → `redirect` (소켓 join:space와 동일하게 입장 거부, role 무관)\\r\\n  64:  * - 멤버 행 있음 + 비BANNED → `use`(그 role)\\r\\n  65:  * - 멤버 행 없음 + 오너 → `create` OWNER (합성 OWNER 대신 행을 self-heal 해 소켓과 정합)\\r\\n  66:  * - 멤버 행 없음 + PUBLIC 비멤버 → `create` PARTICIPANT (자동 가입)\\r\\n  67:  * - 멤버 행 없음 + PRIVATE/PASSWORD 비멤버 → `redirect` (초대 코드로만 가입)\\r\\n  68:  *\\r\\n  69:  * BANNED는 role보다 먼저 차단한다 ? 소켓이 BANNED 멤버를 입장 거부하므로\\r\\n  70:  * (room.ts: `restriction === \\\"BANNED\\\"` → `space:error`) 클라가 그들에게 role을 주면\\r\\n  71:  * 에디터/관리 UI가 열리는 발산이 생긴다(맵 편집 HTTP 라우트는 BANNED 미검사).\\r\\n  72:  *\\r\\n  73:  * superAdmin은 입력이 아니다 ? `join:space`에 superAdmin 특례가 없어\\r\\n  74:  * (비멤버 superAdmin은 `NOT_A_MEMBER`로 거부됨) 인-스페이스 클라 role에 반영하면\\r\\n  75:  * 동일한 발산을 만든다. superAdmin이 실제 멤버이면 자기 멤버 role을 그대로 따른다.\\r\\n  76:  */\\r\\n  77: export function resolveSpaceRoleDecision(input: {\\r\\n  78:   memberRole: SpaceRole | null;\\r\\n  79:   restriction: ChatRestrictionValue | null;\\r\\n  80:   isOwner: boolean;\\r\\n  81:   accessType: SpaceAccessType;\\r\\n  82: }): SpaceRoleDecision {\\r\\n  83:   const { memberRole, restriction, isOwner, accessType } = input;\\r\\n  84:   if (memberRole) {\\r\\n  85:     if (restriction === \\\"BANNED\\\") return { action: \\\"redirect\\\" };\\r\\n  86:     return { action: \\\"use\\\", role: memberRole };\\r\\n  87:   }\\r\\n  88:   if (isOwner) return { action: \\\"create\\\", role: \\\"OWNER\\\" };\\r\\n  89:   if (accessType === \\\"PUBLIC\\\") return { action: \\\"create\\\", role: \\\"PARTICIPANT\\\" };\\r\\n  90:   return { action: \\\"redirect\\\" };\\r\\n  91: }\\r\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n.\\scratchpad\\verify-wi039-codex.out.txt:32:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_13\",\"type\":\"command_execution\",\"command\":\"\\\"C:\\\\\\\\Windows\\\\\\\\System32\\\\\\\\WindowsPowerShell\\\\\\\\v1.0\\\\\\\\powershell.exe\\\" -Command '$i=0; Get-Content -Encoding UTF8 src/constants/s