t type { ManagedMember } from \\\"./use-space-members\\\";\\r\\n  18: \\r\\n  19: type RestrictAction = \\\"mute\\\" | \\\"unmute\\\" | \\\"kick\\\" | \\\"ban\\\";\\r\\n  20: \\r\\n  21: interface MemberActionsMenuProps {\\r\\n  22:   spaceId: string;\\r\\n  23:   target: { userId: string; nickname: string };\\r\\n  24:   /** 해당 참가자의 SpaceMember 매핑(없으면 = 게스트/미매칭 → 관리 불가). */\\r\\n  25:   member: ManagedMember | null;\\r\\n  26:   /** 호출자 본인의 권위 role(스냅샷 기준). */\\r\\n  27:   actorRole: SpaceRole | null;\\r\\n  28:   currentUserId: string;\\r\\n  29:   /** 액션 성공 시 호출(멤버 스냅샷 재조회). */\\r\\n  30:   onActionDone: () => void;\\r\\n  31:   /** 드롭다운 전개 방향(버튼 위치에 맞춰). 기본 우측 정렬. */\\r\\n  32:   align?: \\\"left\\\" | \\\"right\\\";\\r\\n  33:   /**\\r\\n  34:    * 음성 강제 음소거(WI-038/039)용 **LiveKit identity**(`user-{userId}`/`guest-{...}`).\\r\\n  35:    * LiveKit room에 연결된 참가자에게만 주어진다(비-미디어 소켓 전용 플레이어는 undefined →\\r\\n  36:    * 음성 액션 미노출). userId에서 재구성하지 않는다 ? 라우트 계약(LiveKit identity)을\\r\\n  37:    * UI에서 복제하지 않기 위함이고, guest-* 확장을 막지 않기 위함이다.\\r\\n  38:    *\\r\\n  39:    * ?? 메뉴 가시성 게이트(member/actorRole/canActOn)와 **분리된** 액션별 게이트다 ?\\r\\n  40:    * 음성 액션 추가가 기존 채팅/킥/밴 권한 모델을 흐리지 않는다.\\r\\n  41:    */\\r\\n  42:   participantIdentity?: string | null;\\r\\n  43: }\\r\\n  44: \\r\\n  45: const COPY = SPACE_COPY.PARTICIPANT_PANEL;\\r\\n  46: \\r\\n  47: export function MemberActionsMenu({\\r\\n  48:   spaceId,\\r\\n  49:   target,\\r\\n  50:   member,\\r\\n  51:   actorRole,\\r\\n  52:   currentUserId,\\r\\n  53:   onActionDone,\\r\\n  54:   align = \\\"right\\\",\\r\\n  55:   participantIdentity,\\r\\n  56: }: MemberActionsMenuProps) {\\r\\n  57:   const [open, setOpen] = useState(false);\\r\\n  58:   const [loading, setLoading] = useState(false);\\r\\n  59:   const [error, setError] = useState<string | null>(null);\\r\\n  60:   const [pendingConfirm, setPendingConfirm] = useState<\\\"kick\\\" | \\\"ban\\\" | null>(null);\\r\\n  61:   const containerRef = useRef<HTMLDivElement>(null);\\r\\n  62: \\r\\n  63:   const closeMenu = useCallback(() => {\\r\\n  64:     setOpen(false);\\r\\n  65:     setPendingConfirm(null);\\r\\n  66:     setError(null);\\r\\n  67:   }, []);\\r\\n  68: \\r\\n  69:   // 메뉴 밖 클릭 시 닫기\\r\\n  70:   useEffect(() => {\\r\\n  71:     if (!open) return;\\r\\n  72:     const handler = (e: MouseEvent) => {\\r\\n  73:       if (containerRef.current && !containerRef.current.contains(e.target as Node)) {\\r\\n  74:         closeMenu();\\r\\n  75:       }\\r\\n  76:     };\\r\\n  77:     document.addEventListener(\\\"mousedown\\\", handler);\\r\\n  78:     return () => document.removeEventListener(\\\"mousedown\\\", handler);\\r\\n  79:   }, [open, closeMenu]);\\r\\n  80: \\r\\n  81:   const runAction = useCallback(\\r\\n  82:     async (action: RestrictAction) => {\\r\\n  83:       if (!member || loading) return;\\r\\n  84:       setLoading(true);\\r\\n  85:       setError(null);\\r\\n  86:       try {\\r\\n  87:         const res = await fetch(`/api/spaces/${spaceId}/admin/members`, {\\r\\n  88:           method: \\\"PATCH\\\",\\r\\n  89:           headers: { \\\"Content-Type\\\": \\\"application/json\\\" },\\r\\n  90:           // 식별자 혼동 방지: SpaceMember.id만 사용(userId·identity 금지).\\r\\n  91:           body: JSON.stringify({ memberId: member.memberId, action }),\\r\\n  92:         });\\r\\n  93:         if (!res.ok) {\\r\\n  94:           const data = (await res.json().catch(() => ({}))) as { error?: string };\\r\\n  95:           setError(data.error || COPY.actionFailed);\\r\\n  96:           setPendingConfirm(null);\\r\\n  97:           return;\\r\\n  98:         }\\r\\n  99:         closeMenu();\\r\\n 100:         onActionDone();\\r\\n 101:       } catch {\\r\\n 102:         setError(COPY.networkError);\\r\\n 103:         setPendingConfirm(null);\\r\\n 104:       } finally {\\r\\n 105:         setLoading(false);\\r\\n 106:       }\\r\\n 107:     },\\r\\n 108:     [member, loading, spaceId, onActionDone, closeMenu]\\r\\n 109:   );\\r\\n 110: \\r\\n 111:   // 음성 강제 음소거(WI-038/039) ? LiveKit identity로 moderate 라우트 호출.\\r\\n 112:   // 멤버 상태(restriction)를 바꾸지 않으므로 onActionDone(refetch) 호출하지 않는다.\\r\\n 113:   // 실제 오디오 상태는 LiveKit 이벤트로 자연 갱신된다.\\r\\n 114:   const runVoiceAction = useCallback(\\r\\n 115:     async (muted: boolean) => {\\r\\n 116:       if (!participantIdentity || loading) return;\\r\\n 117:       setLoading(true);\\r\\n 118:       setError(null);\\r\\n 119:       try {\\r\\n 120:         const res = await fetch(`/api/spaces/${spaceId}/livekit/moderate`, {\\r\\n 121:           method: \\\"POST\\\",\\r\\n 122:           headers: { \\\"Content-Type\\\": \\\"application/json\\\" },\\r\\n 123:           body: JSON.stringify({ identity: participantIdentity, muted }),\\r\\n 124:         });\\r\\n 125:         if (!res.ok) {\\r\\n 126:           const data = (await res.json().catch(() => ({}))) as { code?: string };\\r\\n 127:           // 서버 영문 error 미노출 ? code별 한글 매핑, 미지의 code는 폴백.\\r\\n 128:           setError((data.code && COPY.voiceError[data.code]) || COPY.actionFailed);\\r\\n 129:           return;\\r\\n 130:         }\\r\\n 131:         closeMenu();\\r\\n 132:       } catch {\\r\\n 133:         setError(COPY.networkError);\\r\\n 134:       } finally {\\r\\n 135:         setLoading(false);\\r\\n 136:       }\\r\\n 137:     },\\r\\n 138:     [participantIdentity, loading, spaceId, closeMenu]\\r\\n 139:   );\\r\\n 140: \\r\\n 141:   // 게이팅: 멤버 매핑/권위 role 없으면, 본인이면, 계층상 불가하면 표시 안 함.\\r\\n 142:   if (!member || !actorRole) return null;\\r\\n 143:   if (member.userId === currentUserId) return null;\\r\\n 144:   if (!canActOn(actorRole, member.role)) return null;\\r\\n 145: \\r\\n 146:   const isMuted = member.restriction === \\\"MUTED\\\";\\r\\n 147:   // 음성 액션은 LiveKit identity가 있을 때만(LiveKit room 참가자). 메뉴 가시성과 분리된 게이트.\\r\\n 148:   const showVoiceActions = !!participantIdentity;\\r\\n 149: \\r\\n 150:   return (\\r\\n 151:     <div ref={containerRef} className=\\\"relative\\\">\\r\\n 152:       <button\\r\\n 153:         type=\\\"button\\\"\\r\\n 154:         aria-label={COPY.manageAriaLabel(target.nickname)}\\r\\n 155:         onClick={(e) => {\\r\\n 156:           e.stopPropagation();\\r\\n 157:           setOpen((v) => !v);\\r\\n 158:           setPendingConfirm(null);\\r\\n 159:           setError(null);\\r\\n 160:         }}\\r\\n 161:         className=\\\"rounded bg-black/60 p-1 text-white/90 transition-colors hover:bg-black/80\\\"\\r\\n 162:       >\\r\\n 163:         <svg className=\\\"size-4\\\" fill=\\\"currentColor\\\" viewBox=\\\"0 0 20 20\\\">\\r\\n 164:           <path d=\\\"M10 6a2 2 0 110-4 2 2 0 010 4zm0 6a2 2 0 110-4 2 2 0 010 4zm0 6a2 2 0 110-4 2 2 0 010 4z\\\" />\\r\\n 165:         </svg>\\r\\n 166:       </button>\\r\\n 167: \\r\\n 168:       {open && (\\r\\n 169:         <div\\r\\n 170:           className={`absolute ${align === \\\"left\\\" ? \\\"left-0\\\" : \\\"right-0\\\"} z-50 mt-1 w-44 overflow-hidden rounded-md border border-cream/15 bg-ink/95 text-sm text-cream shadow-lg backdrop-blur-md`}\\r\\n 171:           onClick={(e) => e.stopPropagation()}\\r\\n 172:         >\\r\\n 173:           {pendingConfirm ? (\\r\\n 174:             <div className=\\\"p-2\\\">\\r\\n 175:               <p className=\\\"mb-2 text-xs leading-snug text-ink-light\\\">\\r\\n 176:                 {pendingConfirm === \\\"kick\\\"\\r\\n 177:                   ? COPY.confirm.kick(target.nickname)\\r\\n 178:                   : COPY.confirm.ban(target.nickname)}\\r\\n 179:               </p>\\r\\n 180:               <div className=\\\"flex gap-1\\\">\\r\\n 181:                 <button\\r\\n 182:                   type=\\\"button\\\"\\r\\n 183:                   disabled={loading}\\r\\n 184:                   onClick={() => runAction(pendingConfirm)}\\r\\n 185:                   className=\\\"flex-1 rounded bg-red-600 px-2 py-1 text-xs font-medium text-white transition-colors hover:bg-red-500 disabled:opacity-50\\\"\\r\\n 186:                 >\\r\\n 187:                   {COPY.confirm.confirmLabel}\\r\\n 188:                 </button>\\r\\n 189:                 <button\\r\\n 190:                   type=\\\"button\\\"\\r\\n 191:                   disabled={loading}\\r\\n 192:                   onClick={() => setPendingConfirm(null)}\\r\\n 193:                   className=\\\"flex-1 rounded bg-cream/10 px-2 py-1 text-xs text-cream transition-colors hover:bg-cream/20 disabled:opacity-50\\\"\\r\\n 194:                 >\\r\\n 195:                   {COPY.confirm.cancelLabel}\\r\\n 196:                 </button>\\r\\n 197:               </div>\\r\\n 198:             </div>\\r\\n 199:           ) : (\\r\\n 200:             <ul className=\\\"py-1\\\">\\r\\n 201:               <li>\\r\\n 202:                 <button\\r\\n 203:                   type=\\\"button\\\"\\r\\n 204:                   disabled={loading}\\r\\n 205:                   onClick={() => runAction(isMuted ? \\\"unmute\\\" : \\\"mute\\\")}\\r\\n 206:                   className=\\\"block w-full px-3 py-1.5 text-left transition-colors hover:bg-cream/10 disabled:opacity-50\\\"\\r\\n 207:                 >\\r\\n 208:                   {isMuted ? COPY.actions.unmute : COPY.actions.mute}\\r\\n 209:                 </button>\\r\\n 210:               </li>\\r\\n 211:               {/* 음성 제어 ? LiveKit 강제 음소거(채팅 음소거와 별개 레이어). identity 있을 때만. */}\\r\\n 212:               {showVoiceActions && (\\r\\n 213:                 <>\\r\\n 214:                   <li\\r\\n 215:                     aria-hidden=\\\"true\\\"\\r\\n 216:                     className=\\\"mt-1 border-t border-cream/10 px-3 pb-0.5 pt-1.5 text-[10px] font-medium uppercase tracking-wide text-ink-muted\\\"\\r\\n 217:                   >\\r\\n 218:                     {COPY.voiceSectionLabel}\\r\\n 219:                   </li>\\r\\n 220:                   <li>\\r\\n 221:                     <button\\r\\n 222:                       type=\\\"button\\\"\\r\\n 223:                       disabled={loading}\\r\\n 224:                       onClick={() => runVoiceAction(true)}\\r\\n 225:                       className=\\\"block w-full px-3 py-1.5 text-left transition-colors hover:bg-cream/10 disabled:opacity-50\\\"\\r\\n 226:                     >\\r\\n 227:                       {COPY.voiceActions.mute}\\r\\n 228:                     </button>\\r\\n 229:                   </li>\\r\\n 230:                   <li className=\\\"border-b border-cream/10 pb-1\\\">\\r\\n 231:                     <button\\r\\n 232:                       type=\\\"button\\\"\\r\\n 233:                       disabled={loading}\\r\\n 234:                       onClick={() => runVoiceAction(false)}\\r\\n 235:                       className=\\\"block w-full px-3 py-1.5 text-left transition-colors hover:bg-cream/10 disabled:opacity-50\\\"\\r\\n 236:                     >\\r\\n 237:                       {COPY.voiceActions.allow}\\r\\n 238:                     </button>\\r\\n 239:                   </li>\\r\\n 240:                 </>\\r\\n 241:               )}\\r\\n 242:               <li>\\r\\n 243:                 <button\\r\\n 244:                   type=\\\"button\\\"\\r\\n 245:                   disabled={loading}\\r\\n 246:                   onClick={() => setPendingConfirm(\\\"kick\\\")}\\r\\n 247:                   className=\\\"block w-full px-3 py-1.5 text-left transition-colors hover:bg-cream/10 disabled:opacity-50\\\"\\r\\n 248:                 >\\r\\n 249:                   {COPY.actions.kick}\\r\\n 250:                 </button>\\r\\n 251:               </li>\\r\\n 252:               <li>\\r\\n 253:                 <button\\r\\n 254:                   type=\\\"button\\\"\\r\\n 255:                   disabled={loading}\\r\\n 256:                   onClick={() => setPendingConfirm(\\\"ban\\\")}\\r\\n 257:                   className=\\\"block w-full px-3 py-1.5 text-left text-red-400 transition-colors hover:bg-cream/10 disabled:opacity-50\\\"\\r\\n 258:                 >