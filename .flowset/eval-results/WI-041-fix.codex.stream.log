<string, ManagedMember>;\\r\\n  34:   /** 호출자 본인의 권위 role(스냅샷 기준) ? stale prop 대신 사용. 미인가/미발견 시 null. */\\r\\n  35:   actorRole: SpaceRole | null;\\r\\n  36:   /** GET 200(OWNER/STAFF/superAdmin) 여부. false면 관리 UI 숨김. */\\r\\n  37:   isAuthorized: boolean;\\r\\n  38:   isLoading: boolean;\\r\\n  39:   /** 액션 후 스냅샷 재조회. */\\r\\n  40:   refetch: () => void;\\r\\n  41: }\\r\\n  42: \\r\\n  43: interface AdminMemberRow {\\r\\n  44:   id: string;\\r\\n  45:   role: SpaceRole;\\r\\n  46:   restriction: ChatRestrictionValue;\\r\\n  47:   userId: string | null;\\r\\n  48: }\\r\\n  49: \\r\\n  50: /**\\r\\n  51:  * LiveKit identity에서 관리 대상 userId를 해석한다.\\r\\n  52:  * `user-{userId}`만 userId로 본다. `guest-*`/`dev-anon-*`/기타는 관리 대상 아님(null).\\r\\n  53:  */\\r\\n  54: export function managedUserIdFromIdentity(identity: string): string | null {\\r\\n  55:   const PREFIX = \\\"user-\\\";\\r\\n  56:   if (!identity.startsWith(PREFIX)) return null;\\r\\n  57:   const userId = identity.slice(PREFIX.length);\\r\\n  58:   return userId.length > 0 ? userId : null;\\r\\n  59: }\\r\\n  60: \\r\\n  61: export function useSpaceMembers(\\r\\n  62:   spaceId: string,\\r\\n  63:   currentUserId: string,\\r\\n  64:   enabled: boolean\\r\\n  65: ): UseSpaceMembersResult {\\r\\n  66:   const [membersByUserId, setMembersByUserId] = useState<Map<string, ManagedMember>>(\\r\\n  67:     () => new Map()\\r\\n  68:   );\\r\\n  69:   const [actorRole, setActorRole] = useState<SpaceRole | null>(null);\\r\\n  70:   const [isAuthorized, setIsAuthorized] = useState(false);\\r\\n  71:   const [isLoading, setIsLoading] = useState(false);\\r\\n  72:   const [reqTick, setReqTick] = useState(0);\\r\\n  73: \\r\\n  74:   const refetch = useCallback(() => setReqTick((n) => n + 1), []);\\r\\n  75: \\r\\n  76:   useEffect(() => {\\r\\n  77:     // 비활성/식별자 없음 → 이전 스냅샷을 폐기(닫힌 패널이 stale 관리 상태를 보유하지 않게).\\r\\n  78:     if (!enabled || !spaceId || !currentUserId) {\\r\\n  79:       setMembersByUserId(new Map());\\r\\n  80:       setActorRole(null);\\r\\n  81:       setIsAuthorized(false);\\r\\n  82:       setIsLoading(false);\\r\\n  83:       return;\\r\\n  84:     }\\r\\n  85: \\r\\n  86:     let cancelled = false;\\r\\n  87:     setIsLoading(true);\\r\\n  88: \\r\\n  89:     (async () => {\\r\\n  90:       try {\\r\\n  91:         const res = await fetch(`/api/spaces/${spaceId}/admin/members`);\\r\\n  92:         if (cancelled) return;\\r\\n  93: \\r\\n  94:         if (!res.ok) {\\r\\n  95:           // 403(비인가)·기타 → 관리 UI 숨김.\\r\\n  96:           setIsAuthorized(false);\\r\\n  97:           setActorRole(null);\\r\\n  98:           setMembersByUserId(new Map());\\r\\n  99:           return;\\r\\n 100:         }\\r\\n 101: \\r\\n 102:         const data = (await res.json().catch(() => null)) as\\r\\n 103:           | { members?: AdminMemberRow[] }\\r\\n 104:           | null;\\r\\n 105:         if (cancelled) return;\\r\\n 106: \\r\\n 107:         const rows = data?.members ?? [];\\r\\n 108:         const map = new Map<string, ManagedMember>();\\r\\n 109:         let selfRole: SpaceRole | null = null;\\r\\n 110:         for (const m of rows) {\\r\\n 111:           if (!m.userId) continue; // 게스트 제외(1차 범위)\\r\\n 112:           map.set(m.userId, {\\r\\n 113:             memberId: m.id,\\r\\n 114:             userId: m.userId,\\r\\n 115:             role: m.role,\\r\\n 116:             restriction: m.restriction,\\r\\n 117:           });\\r\\n 118:           if (m.userId === currentUserId) selfRole = m.role;\\r\\n 119:         }\\r\\n 120: \\r\\n 121:         setMembersByUserId(map);\\r\\n 122:         setActorRole(selfRole);\\r\\n 123:         setIsAuthorized(true);\\r\\n 124:       } catch {\\r\\n 125:         if (cancelled) return;\\r\\n 126:         // 네트워크 오류 → 권한 확인 불가 → 관리 UI 숨김(보수적).\\r\\n 127:         setIsAuthorized(false);\\r\\n 128:         setActorRole(null);\\r\\n 129:         setMembersByUserId(new Map());\\r\\n 130:       } finally {\\r\\n 131:         if (!cancelled) 