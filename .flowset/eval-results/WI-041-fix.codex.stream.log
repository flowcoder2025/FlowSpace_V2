\\n  27:   localParticipantId: string | null;\\r\\n  28:   spaceId: string;\\r\\n  29:   spaceName?: string;\\r\\n  30:   viewMode?: ViewMode;\\r\\n  31:   onViewModeChange?: (mode: ViewMode) => void;\\r\\n  32:   spotlightUsers?: Set<string>;\\r\\n  33:   globalOutputVolume?: number;\\r\\n  34:   mirrorLocalVideo?: boolean;\\r\\n  35:   players?: PlayerInfo[];\\r\\n  36:   currentUserId?: string;\\r\\n  37:   currentNickname?: string;\\r\\n  38: }\\r\\n  39: \\r\\n  40: export function ParticipantPanel({\\r\\n  41:   participantTracks,\\r\\n  42:   localParticipantId,\\r\\n  43:   spaceId,\\r\\n  44:   spaceName = \\\"Space\\\",\\r\\n  45:   viewMode: externalViewMode,\\r\\n  46:   onViewModeChange,\\r\\n  47:   spotlightUsers = new Set(),\\r\\n  48:   globalOutputVolume = 100,\\r\\n  49:   mirrorLocalVideo = true,\\r\\n  50:   players = [],\\r\\n  51:   currentUserId,\\r\\n  52:   currentNickname,\\r\\n  53: }: ParticipantPanelProps) {\\r\\n  54:   const [internalViewMode, setInternalViewMode] =\\r\\n  55:     useState<ViewMode>(\\\"sidebar\\\");\\r\\n  56: \\r\\n  57:   const viewMode = externalViewMode ?? internalViewMode;\\r\\n  58:   const setViewMode = onViewModeChange ?? setInternalViewMode;\\r\\n  59: \\r\\n  60:   // 멤버 관리 스냅샷 ? 패널이 보일 때만 조회(GET 403이면 관리 UI 자연 숨김).\\r\\n  61:   const { membersByUserId, actorRole, refetch } = useSpaceMembers(\\r\\n  62:     spaceId,\\r\\n  63:     currentUserId ?? \\\"\\\",\\r\\n  64:     viewMode !== \\\"hidden\\\" && !!currentUserId\\r\\n  65:   );\\r\\n  66: \\r\\n  67:   // 미디어 참가자 ID set\\r\\n  68:   const mediaParticipantIds = useMemo(\\r\\n  69:     () => new Set(participantTracks.keys()),\\r\\n  70:     [participantTracks]\\r\\n  71:   );\\r\\n  72: \\r\\n  73:   // 미디어 없는 플레이어 (소켓만 연결)\\r\\n  74:   const nonMediaPlayers = useMemo(() => {\\r\\n  75:     // localParticipantId 형식: \\\"user-{userId}\\\" or just \\\"{userId}\\\"\\r\\n  76:     const normalizeId = (id: string) => id.replace(/^(user-|guest-)/, \\\"\\\");\\r\\n  77:     const mediaUserIds = new Set(\\r\\n  78:       Array.from(mediaParticipantIds).map(normalizeId)\\r\\n  79:     );\\r\\n  80: \\r\\n  81:     const result: Array<{ id: string; nickname: string; isSelf: boolean }> = [];\\r\\n  82: \\r\\n  83:     // 자기 자신 (미디어에 없을 때만)\\r\\n  84:     if (currentUserId && !mediaUserIds.has(currentUserId)) {\\r\\n  85:       result.push({ id: currentUserId, nickname: currentNickname || \\\"나\\\", isSelf: true });\\r\\n  86:     }\\r\\n  87: \\r\\n  88:     // 다른 플레이어 (미디어에 없는 사람만)\\r\\n  89:     for (const p of players) {\\r\\n  90:       if (!mediaUserIds.has(p.userId) && p.userId !== currentUserId) {\\r\\n  91:         result.push({ id: p.userId, nickname: p.nickname, isSelf: false });\\r\\n  92:       }\\r\\n  93:     }\\r\\n  94: \\r\\n  95:     return result;\\r\\n  96:   }, [players, mediaParticipantIds, currentUserId, currentNickname]);\\r\\n  97: \\r\\n  98:   // 미디어 참가자 정렬\\r\\n  99:   const sortedTracks = useMemo(() => {\\r\\n 100:     const all = Array.from(participantTracks.values());\\r\\n 101:     return all.sort((a, b) => {\\r\\n 102:       const aHasScreen = !!a.screenTrack;\\r\\n 103:       const bHasScreen = !!b.screenTrack;\\r\\n 104:       if (aHasScreen && !bHasScreen) return -1;\\r\\n 105:       if (!aHasScreen && bHasScreen) return 1;\\r\\n 106: \\r\\n 107:       const aIsLocal = a.participantId === localParticipantId;\\r\\n 108:       const bIsLocal = b.participantId === localParticipantId;\\r\\n 109:       if (aIsLocal && !bIsLocal) return -1;\\r\\n 110:       if (!aIsLocal && bIsLocal) return 1;\\r\\n 111: \\r\\n 112:       return a.participantName.localeCompare(b.participantName, \\\"ko\\\");\\r\\n 113:     });\\r\\n 114:   }, [participantTracks, localParticipantId]);\\r\\n 115: \\r\\n 116:   const allAudioTracks = useMemo(() => {\\r\\n 117:     const tracks: MediaStreamTrack[] = [];\\r\\n 118:     participantTracks.forEach((track) => {\\r\\n 119:       if (track.audioTrack) tracks.push(track.aud