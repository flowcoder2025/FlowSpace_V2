{"type":"item.completed","item":{"id":"item_37","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -LiteralPath '\"'server\\\\handlers\\\\room.ts' -Encoding UTF8 | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: import type { Server, Socket } from \"socket.io\";\r\n   2: import type {\r\n   3:   ClientToServerEvents,\r\n   4:   ServerToClientEvents,\r\n   5:   PlayerData,\r\n   6: } from \"../../src/features/space/protocol/internal/socket-events\";\r\n   7: import { getPrisma } from \"../lib/prisma\";\r\n   8: \r\n   9: type IO = Server<ClientToServerEvents, ServerToClientEvents>;\r\n  10: type TypedSocket = Socket<ClientToServerEvents, ServerToClientEvents>;\r\n  11: \r\n  12: // spaceId → Map<userId, PlayerData>\r\n  13: export const spacePlayersMap = new Map<string, Map<string, PlayerData>>();\r\n  14: \r\n  15: function getSpacePlayers(spaceId: string): Map<string, PlayerData> {\r\n  16:   if (!spacePlayersMap.has(spaceId)) {\r\n  17:     spacePlayersMap.set(spaceId, new Map());\r\n  18:   }\r\n  19:   return spacePlayersMap.get(spaceId)!;\r\n  20: }\r\n  21: \r\n  22: export function handleRoom(io: IO, socket: TypedSocket) {\r\n  23:   socket.on(\"join:space\", async ({ spaceId, nickname, avatar }) => {\r\n  24:     // 인증된 userId 사용 (클라이언트 값 무시)\r\n  25:     const userId = socket.data.userId;\r\n  26:     if (!userId) return;\r\n  27: \r\n  28:     // join 전 동기 인가 검증: 공간 존재/활성 + 멤버십 + BANNED 차단.\r\n  29:     // 통과하기 전에는 socket.join / role / presence 등록을 하지 않는다.\r\n  30:     let role: \"OWNER\" | \"STAFF\" | \"PARTICIPANT\";\r\n  31:     let restriction: \"NONE\" | \"MUTED\" | \"BANNED\";\r\n  32:     let memberId: string;\r\n  33:     try {\r\n  34:       const prisma = await getPrisma();\r\n  35: \r\n  36:       const space = await prisma.space.findUnique({\r\n  37:         where: { id: spaceId },\r\n  38:         select: { id: true, status: true },\r\n  39:       });\r\n  40:       if (!space || space.status !== \"ACTIVE\") {\r\n  41:         socket.emit(\"space:error\", {\r\n  42:           code: \"SPACE_NOT_FOUND\",\r\n  43:           message: \"공간을 찾을 수 없거나 비활성 상태입니다.\",\r\n  44:         });\r\n  45:         return;\r\n  46:       }\r\n  47: \r\n  48:       const member = await prisma.spaceMember.findUnique({\r\n  49:         where: { spaceId_userId: { spaceId, userId } },\r\n  50:         select: { id: true, role: true, restriction: true },\r\n  51:       });\r\n  52:       if (!member) {\r\n  53:         socket.emit(\"space:error\", {\r\n  54:           code: \"NOT_A_MEMBER\",\r\n  55:           message: \"이 공간의 멤버가 아닙니다.\",\r\n  56:         });\r\n  57:         return;\r\n  58:       }\r\n  59:       if (member.restriction === \"BANNED\") {\r\n  60:         socket.emit(\"space:error\", {\r\n  61:           code: \"BANNED\",\r\n  62:           message: \"이 공간에서 차단되었습니다.\",\r\n  63:         });\r\n  64:         return;\r\n  65:       }\r\n  66: \r\n  67:       memberId = member.id;\r\n  68:       role = member.role as \"OWNER\" | \"STAFF\" | \"PARTICIPANT\";\r\n  69:       restriction = member.restriction as \"NONE\" | \"MUTED\" | \"BANNED\";\r\n  70:     } catch (err) {\r\n  71:       console.error(\"[Room] join authorization failed:\", err);\r\n  72:       socket.emit(\"space:error\", {\r\n  73:         code: \"JOIN_FAILED\",\r\n  74:         message: \"입장 처리 중 오류가 발생했습니다.\",\r\n  75:       });\r\n  76:       return;\r\n  77:     }\r\n  78: \r\n  79:     // 인가 통과 후에만 room 참가 + 검증된 권한 정보 설정\r\n  80:     socket.join(spaceId);\r\n  81:     socket.data.spaceId = spaceId;\r\n  82:     socket.data.memberId = memberId;\r\n  83:     socket.data.role = role;\r\n  84:     socket.data.restriction = restriction;\r\n  85: \r\n  86:     const player: PlayerData = {\r\n  87:       userId,\r\n  88:       nickname,\r\n  89:       avatar,\r\n  90:       position: { x: 400, y: 300 }, // 기본 스폰 위치\r\n  91:     };\r\n  92: \r\n  93:     const players = getSpacePlayers(spaceId);\r\n  94:     players.set(userId, player);\r\n  95: \r\n  96:     // 기존 플레이어 목록 전송\r\n  97:     socket.emit(\"players:list\", {\r\n  98:       players: Array.from(players.values()),\r\n  99:     });\r\n 100: \r\n 101:     // 다른 플레이어에게 입장 알림\r\n 102:     socket.to(spaceId).emit(\"player:joined\", player);\r\n 103: \r\n 104:     console.log(\r\n 105:       `[Room] ${nickname} joined ${spaceId} (${players.size} players)`\r\n 106:     );\r\n 107:   });\r\n 108: \r\n 109:   socket.on(\"leave:space\", () => {\r\n 110:     // 클라이언트가 보낸 spaceId 는 신뢰하지 않는다(communication invariant #3) ?\r\n 111:     // 서버가 인가한 socket.data.spaceId 만 사용.\r\n 112:     const spaceId = socket.data.spaceId;\r\n 113:     if (spaceId) leaveSpace(io, socket, spaceId);\r\n 114:   });\r\n 115: \r\n 116:   // 연결 해제 시 자동 퇴장\r\n 117:   socket.on(\"disconnect\", () => {\r\n 118:     const spaceId = socket.data.spaceId;\r\n 119:     if (spaceId) {\r\n 120:       leaveSpace(io, socket, spaceId);\r\n 121:     }\r\n 122:   });\r\n 123: }\r\n 124: \r\n 125: /**\r\n 126:  * 소켓을 공간에서 물리적으로 분리: 자기 id 를 제외한 모든 room(공간 + 파티) 이탈 +\r\n 127:  * 공간 범위 socket.data 무효화. 이후 모든 이벤트 핸들러가 socket.data.spaceId 가드로\r\n 128:  * early-return 하므로 stale 인가(퇴장/추방 후 잔존 chat/admin/editor/media)가 차단된다.\r\n 129:  * presence/broadcast 는 호출측 책임(단일 소켓 분리라 사용자 단위 알림과 분리).\r\n 130:  */\r\n 131: export function detachSocketFromSpace(socket: TypedSocket): void {\r\n 132:   for (const room of [...socket.rooms]) {\r\n 133:     if (room !== socket.id) socket.leave(room);\r\n 134:   }\r\n 135:   socket.data.spaceId = undefined;\r\n 136:   socket.data.partyId = undefined;\r\n 137:   socket.data.partyName = undefined;\r\n 138:   socket.data.role = undefined;\r\n 139:   socket.data.restriction = undefined;\r\n 140:   socket.data.memberId = undefined;\r\n 141: }\r\n 142: \r\n 143: /** presence 에서 사용자 제거 + 주변에 player:left 1회(사용자 단위, 다중 탭 중복 방지). */\r\n 144: export function removeUserPresence(io: IO, spaceId: string, userId: string): void {\r\n 145:   const players = spacePlayersMap.get(spaceId);\r\n 146:   if (players) {\r\n 147:     players.delete(userId);\r\n 148:     if (players.size === 0) spacePlayersMap.delete(spaceId);\r\n 149:   }\r\n 150:   io.to(spaceId).emit(\"player:left\", { userId });\r\n 151: }\r\n 152: \r\n 153: /** 단일 소켓 퇴장(leave:space/disconnect): presence 정리 1회 + 자기 소켓 분리. */\r\n 154: export function leaveSpace(io: IO, socket: TypedSocket, spaceId: string) {\r\n 155:   const userId = socket.data.userId;\r\n 156:   removeUserPresence(io, spaceId, userId);\r\n 157:   detachSocketFromSpace(socket);\r\n 158:   console.log(`[Room] ${userId} left ${spaceId}`);\r\n 159: }\r\n","exit_code":0,"status":"completed"}}
