", restriction: \"MUTED\", userId: \"u-part\" },\r\n  33:   // 게스트 ? userId null → 매핑 제외\r\n  34:   { id: \"m-guest\", role: \"PARTICIPANT\", restriction: \"NONE\", userId: null },\r\n  35: ];\r\n  36: \r\n  37: beforeEach(() => {\r\n  38:   global.fetch = vi.fn() as unknown as typeof fetch;\r\n  39: });\r\n  40: afterEach(() => {\r\n  41:   vi.restoreAllMocks();\r\n  42: });\r\n  43: \r\n  44: describe(\"useSpaceMembers\", () => {\r\n  45:   it(\"enabled=false → fetch 미호출·미인가·빈 맵\", async () => {\r\n  46:     const { result } = renderHook(() =>\r\n  47:       useSpaceMembers(\"space-1\", \"u-owner\", false)\r\n  48:     );\r\n  49:     expect(global.fetch).not.toHaveBeenCalled();\r\n  50:     expect(result.current.isAuthorized).toBe(false);\r\n  51:     expect(result.current.membersByUserId.size).toBe(0);\r\n  52:     expect(result.current.actorRole).toBeNull();\r\n  53:   });\r\n  54: \r\n  55:   it(\"GET 200 → userId 맵 구성(게스트 제외) + self role 도출\", async () => {\r\n  56:     (global.fetch as ReturnType<typeof vi.fn>).mockResolvedValue(\r\n  57:       jsonOk({ members: MEMBERS })\r\n  58:     );\r\n  59:     const { result } = renderHook(() =>\r\n  60:       useSpaceMembers(\"space-1\", \"u-owner\", true)\r\n  61:     );\r\n  62: \r\n  63:     await waitFor(() => expect(result.current.isAuthorized).toBe(true));\r\n  64: \r\n  65:     expect(global.fetch).toHaveBeenCalledWith(\"/api/spaces/space-1/admin/members\");\r\n  66:     // 게스트(userId null) 제외 → 3건\r\n  67:     expect(result.current.membersByUserId.size).toBe(3);\r\n  68:     // 호출자(self=OWNER) 권위 role\r\n  69:     expect(result.current.actorRole).toBe(\"OWNER\");\r\n  70:     // 매핑 값: memberId = SpaceMember.id (userId와 구별)\r\n  71:     const staff = result.current.membersByUserId.get(\"u-staff\");\r\n  72:     expect(staff?.memberId).toBe(\"m-staff\");\r\n  73:     expect(staff?.userId).toBe(\"u-staff\");\r\n  74:     expect(staff?.role).toBe(\"STAFF\");\r\n  75:     expect(result.current.membersByUserId.get(\"u-part\")?.restriction).toBe(\"MUTED\");\r\n  76:   });\r\n  77: \r\n  78:   it(\"GET 403 → 미인가·빈 맵·actorRole null\", async () => {\r\n  79:     (global.fetch as ReturnType<typeof vi.fn>).mockResolvedValue({\r\n  80:       ok: false,\r\n  81:       json: async () => ({ error: \"Forbidden\" }),\r\n  82:     });\r\n  83:     const { result } = renderHook(() =>\r\n  84:       useSpaceMembers(\"space-1\", \"u-part\", true)\r\n  85:     );\r\n  86: \r\n  87:     await waitFor(() => expect(global.fetch).toHaveBeenCalled());\r\n  88:     await waitFor(() => expect(result.current.isLoading).toBe(false));\r\n  89: \r\n  90:     expect(result.current.isAuthorized).toBe(false);\r\n  91:     expect(result.current.membersByUserId.size).toBe(0);\r\n  92:     expect(result.current.actorRole).toBeNull();\r\n  93:   });\r\n  94: \r\n  95:   it(\"refetch() → 재조회 트리거\", async () => {\r\n  96:     (global.fetch as ReturnType<typeof vi.fn>).mockResolvedValue(\r\n  97:       jsonOk({ members: MEMBERS })\r\n  98:     );\r\n  99:     const { result } = renderHook(() =>\r\n 100:       useSpaceMembers(\"space-1\", \"u-owner\", true)\r\n 101:     );\r\n 102:     await waitFor(() => expect(result.current.isAuthorized).toBe(true));\r\n 103:     expect(global.fetch).toHaveBeenCalledTimes(1);\r\n 104: \r\n 105:     act(() => result.current.refetch());\r\n 106:     await waitFor(() => expect(global.fetch).toHaveBeenCalledTimes(2));\r\n 107:   });\r\n 108: \r\n 109:   it(\"네트워크 오류 → 미인가(보수적)\", async () => {\r\n 110:     (global.fetch as ReturnType<typeof vi.fn>).mockRejectedValue(new Error(\"net\"));\r\n 111:     const { result } = renderHook(() =>\r\n 112:       useSpaceMembers(\"space-1\", \"u-owner\", true)\r\n 113:     );\r\n 114:     await waitFor(() => expect(result.current.isLoading).toBe(false));\r\n 115:     expect(result.current.isAuthorized).toBe(false);\r\n 116:     expect(result.current.membersByUserId.size).toBe(0);\r\n 117:   });\r\n 118: });\r\n","exit_code":0,"status":"completed"}}
