{"type":"item.completed","item":{"id":"item_38","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -LiteralPath '\"'src\\\\features\\\\space\\\\bridge\\\\internal\\\\use-socket-bridge.ts' -Encoding UTF8 | Select-Object -First 260 | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: /**\r\n   2:  * Socket <-> EventBridge 양방향 브릿지\r\n   3:  *\r\n   4:  * Socket 이벤트 -> EventBridge (REMOTE_*)\r\n   5:  * EventBridge (PLAYER_MOVED) -> Socket emit\r\n   6:  */\r\n   7: \r\n   8: \"use client\";\r\n   9: \r\n  10: import { useEffect, useRef, useCallback } from \"react\";\r\n  11: import { eventBridge, GameEvents, type PlayerPosition } from \"@/features/space/game\";\r\n  12: import { useSocket, type PlayerData, type RecordingStatusData, type SpotlightData, type ProximityChangedData } from \"@/features/space/socket\";\r\n  13: \r\n  14: interface ChatMessageData {\r\n  15:   id?: string;\r\n  16:   tempId?: string;\r\n  17:   userId: string;\r\n  18:   nickname: string;\r\n  19:   content: string;\r\n  20:   type: string;\r\n  21:   timestamp: string;\r\n  22:   replyTo?: { id: string; senderNickname: string; content: string };\r\n  23:   partyId?: string;\r\n  24:   partyName?: string;\r\n  25: }\r\n  26: \r\n  27: interface UseSocketBridgeOptions {\r\n  28:   spaceId: string;\r\n  29:   userId: string;\r\n  30:   nickname: string;\r\n  31:   avatar: string;\r\n  32:   onChatMessage?: (data: ChatMessageData) => void;\r\n  33:   onWhisperReceive?: (data: { senderId: string; senderNickname: string; content: string; timestamp: string }) => void;\r\n  34:   onWhisperSent?: (data: { targetNickname: string; content: string; timestamp: string }) => void;\r\n  35:   onMessageIdUpdate?: (data: { tempId: string; realId: string }) => void;\r\n  36:   onMessageFailed?: (data: { tempId: string; error: string }) => void;\r\n  37:   onMessageDeleted?: (data: { messageId: string; deletedBy: string }) => void;\r\n  38:   onReactionUpdated?: (data: { messageId: string; reactions: Array<{ type: \"thumbsup\" | \"heart\" | \"check\"; userId: string; userNickname: string }> }) => void;\r\n  39:   onPartyMessage?: (data: ChatMessageData) => void;\r\n  40:   onMemberMuted?: (data: { memberId: string; nickname: string; mutedBy: string }) => void;\r\n  41:   onMemberUnmuted?: (data: { memberId: string; nickname: string; unmutedBy: string }) => void;\r\n  42:   onMemberKicked?: (data: { memberId: string; nickname: string; kickedBy: string }) => void;\r\n  43:   onAnnouncement?: (data: { content: string; announcer: string; timestamp: string }) => void;\r\n  44:   onEditorTileUpdated?: (data: { userId: string; layer: string; col: number; row: number; tileIndex: number }) => void;\r\n  45:   onEditorObjectPlaced?: (data: { userId: string; id: string; objectType: string; positionX: number; positionY: number; label?: string }) => void;\r\n  46:   onEditorObjectMoved?: (data: { userId: string; id: string; positionX: number; positionY: number }) => void;\r\n  47:   onEditorObjectDeleted?: (data: { userId: string; id: string }) => void;\r\n  48:   // Media events\r\n  49:   onRecordingStarted?: (data: RecordingStatusData) => void;\r\n  50:   onRecordingStopped?: (data: RecordingStatusData) => void;\r\n  51:   onSpotlightActivated?: (data: SpotlightData) => void;\r\n  52:   onSpotlightDeactivated?: (data: SpotlightData) => void;\r\n  53:   onProximityChanged?: (data: ProximityChangedData) => void;\r\n  54:   onSocketError?: (data: { code: string; message: string }) => void;\r\n  55: }\r\n  56: \r\n  57: interface UseSocketBridgeReturn {\r\n  58:   isConnected: boolean;\r\n  59:   socketError: string | null;\r\n  60:   players: PlayerData[];\r\n  61:   sendAvatarUpdate: (avatar: string) => void;\r\n  62:   sendChat: (content: string, type: \"group\" | \"whisper\" | \"party\", targetId?: string) => void;\r\n  63:   sendWhisper: (targetNickname: string, content: string) => void;\r\n  64:   sendReactionToggle: (messageId: string, reactionType: \"thumbsup\" | \"heart\" | \"check\") => void;\r\n  65:   sendAdminCommand: (command: string, data: Record<string, unknown>) => void;\r\n  66:   joinParty: (zoneId: string) => void;\r\n  67:   leaveParty: (zoneId: string) => void;\r\n  68:   sendPartyMessage: (content: string) => void;\r\n  69:   sendEditorTileUpdate: (data: { layer: string; col: number; row: number; tileIndex: number }) => void;\r\n  70:   sendEditorObjectPlace: (data: { id: string; objectType: string; positionX: number; positionY: number; label?: string }) => void;\r\n  71:   sendEditorObjectMove: (data: { id: string; positionX: number; positionY: number }) => void;\r\n  72:   sendEditorObjectDelete: (data: { id: string }) => void;\r\n  73:   // Media emitters\r\n  74:   sendRecordingStart: () => void;\r\n  75:   sendRecordingStop: () => void;\r\n  76:   sendSpotlightActivate: () => void;\r\n  77:   sendSpotlightDeactivate: () => void;\r\n  78:   sendProximitySet: (enabled: boolean) => void;\r\n  79: }\r\n  80: \r\n  81: export function useSocketBridge(options: UseSocketBridgeOptions): UseSocketBridgeReturn {\r\n  82:   const {\r\n  83:     spaceId, userId, nickname, avatar,\r\n  84:     onChatMessage, onWhisperReceive, onWhisperSent,\r\n  85:     onMessageIdUpdate, onMessageFailed, onMessageDeleted,\r\n  86:     onReactionUpdated, onPartyMessage,\r\n  87:     onMemberMuted, onMemberUnmuted, onMemberKicked, onAnnouncement,\r\n  88:     onEditorTileUpdated, onEditorObjectPlaced, onEditorObjectMoved, onEditorObjectDeleted,\r\n  89:     onRecordingStarted, onRecordingStopped,\r\n  90:     onSpotlightActivated, onSpotlightDeactivated, onProximityChanged,\r\n  91:     onSocketError,\r\n  92:   } = options;\r\n  93: \r\n  94:   const {\r\n  95:     isConnected, socketError, players, sendMovement, sendChat,\r\n  96:     sendWhisper, sendReactionToggle, sendAdminCommand, sendAvatarUpdate,\r\n  97:     joinParty, leaveParty, sendPartyMessage,\r\n  98:     sendEditorTileUpdate, sendEditorObjectPlace,\r\n  99:     sendEditorObjectMove, sendEditorObjectDelete,\r\n 100:     sendRecordingStart, sendRecordingStop,\r\n 101:     sendSpotlightActivate, sendSpotlightDeactivate, sendProximitySet,\r\n 102:   } = useSocket({\r\n 103:     spaceId, userId, nickname, avatar,\r\n 104:     onChatMessage, onWhisperReceive, onWhisperSent,\r\n 105:     onMessageIdUpdate, onMessageFailed, onMessageDeleted,\r\n 106:     onReactionUpdated, onPartyMessage,\r\n 107:     onMemberMuted, onMemberUnmuted, onMemberKicked, onAnnouncement,\r\n 108:     onEditorTileUpdated, onEditorObjectPlaced, onEditorObjectMoved, onEditorObjectDeleted,\r\n 109:     onRecordingStarted, onRecordingStopped,\r\n 110:     onSpotlightActivated, onSpotlightDeactivated, onProximityChanged,\r\n 111:     onSocketError,\r\n 112:   });\r\n 113: \r\n 114:   const prevPlayersRef = useRef<Map<string, PlayerData>>(new Map());\r\n 115: \r\n 116:   // EventBridge -> Socket: PLAYER_MOVED -> sock.emit(\"move\")\r\n 117:   const onPlayerMoved = useCallback(\r\n 118:     (payload: unknown) => {\r\n 119:       const data = payload as PlayerPosition;\r\n 120:       sendMovement({\r\n 121:         x: data.x,\r\n 122:         y: data.y,\r\n 123:         direction: data.direction,\r\n 124:       });\r\n 125:     },\r\n 126:     [sendMovement]\r\n 127:   );\r\n 128: \r\n 129:   useEffect(() => {\r\n 130:     eventBridge.on(GameEvents.PLAYER_MOVED, onPlayerMoved);\r\n 131:     return () => {\r\n 132:       eventBridge.off(GameEvents.PLAYER_MOVED, onPlayerMoved);\r\n 133:     };\r\n 134:   }, [onPlayerMoved]);\r\n 135: \r\n 136:   // Socket -> EventBridge: players 변경 감지 -> REMOTE_* 이벤트 발행\r\n 137:   useEffect(() => {\r\n 138:     const prevMap = prevPlayersRef.current;\r\n 139:     const currentMap = new Map(players.map((p) => [p.userId, p]));\r\n 140: \r\n 141:     // 새 플레이어 (joined)\r\n 142:     for (const [id, player] of currentMap) {\r\n 143:       if (!prevMap.has(id)) {\r\n 144:         eventBridge.emit(GameEvents.REMOTE_PLAYER_JOINED, {\r\n 145:           userId: player.userId,\r\n 146:           x: player.position.x,\r\n 147:           y: player.position.y,\r\n 148:           direction: player.direction ?? \"down\",\r\n 149:           nickname: player.nickname,\r\n 150:           avatar: player.avatar,\r\n 151:         });\r\n 152:       } else {\r\n 153:         const prev = prevMap.get(id)!;\r\n 154:         // 아바타 변경\r\n 155:         if (prev.avatar !== player.avatar) {\r\n 156:           eventBridge.emit(GameEvents.REMOTE_PLAYER_AVATAR_UPDATED, {\r\n 157:             userId: player.userId,\r\n 158:             avatar: player.avatar,\r\n 159:           });\r\n 160:         }\r\n 161:         // 위치/방향 변경 (moved)\r\n 162:         if (prev !== player) {\r\n 163:           eventBridge.emit(GameEvents.REMOTE_PLAYER_MOVED, {\r\n 164:             userId: player.userId,\r\n 165:             x: player.position.x,\r\n 166:             y: player.position.y,\r\n 167:             direction: player.direction ?? \"down\",\r\n 168:             nickname: player.nickname,\r\n 169:             avatar: player.avatar,\r\n 170:           });\r\n 171:         }\r\n 172:       }\r\n 173:     }\r\n 174: \r\n 175:     // 떠난 플레이어 (left)\r\n 176:     for (const [id] of prevMap) {\r\n 177:       if (!currentMap.has(id)) {\r\n 178:         eventBridge.emit(GameEvents.REMOTE_PLAYER_LEFT, { userId: id });\r\n 179:       }\r\n 180:     }\r\n 181: \r\n 182:     prevPlayersRef.current = currentMap;\r\n 183:   }, [players]);\r\n 184: \r\n 185:   return {\r\n 186:     isConnected, socketError, players, sendAvatarUpdate, sendChat,\r\n 187:     sendWhisper, sendReactionToggle, sendAdminCommand,\r\n 188:     joinParty, leaveParty, sendPartyMessage,\r\n 189:     sendEditorTileUpdate, sendEditorObjectPlace,\r\n 190:     sendEditorObjectMove, sendEditorObjectDelete,\r\n 191:     sendRecordingStart, sendRecordingStop,\r\n 192:     sendSpotlightActivate, sendSpotlightDeactivate, sendProximitySet,\r\n 193:   };\r\n 194: }\r\n","exit_code":0,"status":"completed"}}
