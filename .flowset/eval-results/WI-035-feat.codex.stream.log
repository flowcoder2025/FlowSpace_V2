amp: string;\r\n  44:   replyTo?: { id: string; senderNickname: string; content: string };\r\n  45:   partyId?: string;\r\n  46:   partyName?: string;\r\n  47: }\r\n  48: \r\n  49: interface WhisperReceiveData {\r\n  50:   id?: string;\r\n  51:   senderId: string;\r\n  52:   senderNickname: string;\r\n  53:   content: string;\r\n  54:   timestamp: string;\r\n  55: }\r\n  56: \r\n  57: interface WhisperSentData {\r\n  58:   id?: string;\r\n  59:   targetNickname: string;\r\n  60:   content: string;\r\n  61:   timestamp: string;\r\n  62: }\r\n  63: \r\n  64: interface ReactionUpdatedData {\r\n  65:   messageId: string;\r\n  66:   reactions: Array<{ type: \"thumbsup\" | \"heart\" | \"check\"; userId: string; userNickname: string }>;\r\n  67: }\r\n  68: \r\n  69: interface EditorTileUpdatedData {\r\n  70:   userId: string;\r\n  71:   layer: string;\r\n  72:   col: number;\r\n  73:   row: number;\r\n  74:   tileIndex: number;\r\n  75: }\r\n  76: \r\n  77: interface EditorObjectPlacedData {\r\n  78:   userId: string;\r\n  79:   id: string;\r\n  80:   objectType: string;\r\n  81:   positionX: number;\r\n  82:   positionY: number;\r\n  83:   label?: string;\r\n  84: }\r\n  85: \r\n  86: interface EditorObjectMovedData {\r\n  87:   userId: string;\r\n  88:   id: string;\r\n  89:   positionX: number;\r\n  90:   positionY: number;\r\n  91: }\r\n  92: \r\n  93: interface EditorObjectDeletedData {\r\n  94:   userId: string;\r\n  95:   id: string;\r\n  96: }\r\n  97: \r\n  98: interface SocketErrorData {\r\n  99:   code: string;\r\n 100:   message: string;\r\n 101: }\r\n 102: \r\n 103: // Media event data types\r\n 104: export interface RecordingStatusData {\r\n 105:   isRecording: boolean;\r\n 106:   recorderId: string;\r\n 107:   recorderNickname: string;\r\n 108:   startedAt: number;\r\n 109: }\r\n 110: \r\n 111: export interface SpotlightData {\r\n 112:   participantId: string;\r\n 113:   nickname: string;\r\n 114:   isActive: boolean;\r\n 115: }\r\n 116: \r\n 117: export interface ProximityChangedData {\r\n 118:   enabled: boolean;\r\n 119:   changedBy: string;\r\n 120: }\r\n 121: \r\n 122: interface UseSocketOptions {\r\n 123:   spaceId: string;\r\n 124:   userId: string;\r\n 125:   nickname: string;\r\n 126:   avatar: string;\r\n 127:   onChatMessage?: (data: ChatMessageData) => void;\r\n 128:   onWhisperReceive?: (data: WhisperReceiveData) => void;\r\n 129:   onWhisperSent?: (data: WhisperSentData) => void;\r\n 130:   onMessageIdUpdate?: (data: { tempId: string; realId: string }) => void;\r\n 131:   onMessageFailed?: (data: { tempId: string; error: string }) => void;\r\n 132:   onMessageDeleted?: (data: { messageId: string; deletedBy: string }) => void;\r\n 133:   onReactionUpdated?: (data: ReactionUpdatedData) => void;\r\n 134:   onPartyMessage?: (data: ChatMessageData) => void;\r\n 135:   onMemberMuted?: (data: { memberId: string; nickname: string; mutedBy: string }) => void;\r\n 136:   onMemberUnmuted?: (data: { memberId: string; nickname: string; unmutedBy: string }) => void;\r\n 137:   onMemberKicked?: (data: { memberId: string; nickname: string; kickedBy: string }) => void;\r\n 138:   onAnnouncement?: (data: { content: string; announcer: string; timestamp: string }) => void;\r\n 139:   onEditorTileUpdated?: (data: EditorTileUpdatedData) => void;\r\n 140:   onEditorObjectPlaced?: (data: EditorObjectPlacedData) => void;\r\n 141:   onEditorObjectMoved?: (data: EditorObjectMovedData) => void;\r\n 142:   onEditorObjectDeleted?: (data: EditorObjectDeletedData) => void;\r\n 143:   onSocketError?: (data: SocketErrorData) => void;\r\n 144:   // Media events\r\n 145:   onRecordingStarted?: (data: RecordingStatusData) => void;\r\n 146:   onRecordingStopped?: (data: RecordingStatusData) => void;\r\n 147:   onSpotlightActivated?: (data: SpotlightData) => void;\r\n 148:   onSpotlightDeactivated?: (data: SpotlightData) => void;\r\n 149:   onProximityChanged?: (data: ProximityChangedData) => void;\r\n 150: }\r\n 151: \r\n 152: interface UseSocketReturn {\r\n 153:   isConnected: boolean;\r\n 154:   socketError: string | null;\r\n 155:   players: PlayerData[];\r\n 156:   sendMovement: (data: MovementData) => void;\r\n 157:   sendChat: (content: string, type: \"group\" | \"whisper\" | \"party\", targetId?: string, replyTo?: { id: string; senderNickname: string; content: string }) => void;\r\n 158:   sendWhisper: (targetNickname: string, content: string) => void;\r\n 159:   sendReactionToggle: (messageId: string, reactionType: \"thumbsup\" | \"heart\" | \"check\") => void;\r\n 160:   sendAdminCommand: (command: string, data: Record<string, unknown>) => void;\r\n 161:   joinParty: (zoneId: string) => void;\r\n 162:   leaveParty: (zoneId: string) => void;\r\n 163:   sendPartyMessage: (content: string) => void;\r\n 164:   sendEditorTileUpdate: (data: { layer: string; col: number; row: number; tileIndex: number }) => void;\r\n 165:   sendEditorObjectPlace: (data: { id: string; objectType: string; positionX: number; positionY: number; label?: string }) => void;\r\n 166:   sendEditorObjectMove: (data: { id: string; positionX: number; positionY: number }) => void;\r\n 167:   sendEditorObjectDelete: (data: { id: string }) => void;\r\n 168:   // Avatar\r\n 169:   sendAvatarUpdate: (avatar: string) => void;\r\n 170:   // Media emitters\r\n 171:   sendRecordingStart: () => void;\r\n 172:   sendRecordingStop: () => void;\r\n 173:   sendSpotlightActivate: () => void;\r\n 174:   sendSpotlightDeactivate: () => void;\r\n 175:   sendProximitySet: (enabled: boolean) => void;\r\n 176: }\r\n 177: \r\n 178: export function useSocket({\r\n 179:   spaceId,\r\n 180:   userId,\r\n 181:   nickname,\r\n 182:   avatar,\r\n 183:   onChatMessage,\r\n 184:   onWhisperReceive,\r\n 185:   onWhisperSent,\r\n 186:   onMessageIdUpdate,\r\n 187:   onMessageFailed,\r\n 188:   onMessageDeleted,\r\n 189:   onReactionUpdated,\r\n 190:   onPartyMessage,\r\n 191:   onMemberMuted,\r\n 192:   onMemberUnmuted,\r\n 193:   onMemberKicked,\r\n 194:   onAnnouncement,\r\n 195:   onEditorTileUpdated,\r\n 196:   onEditorObjectPlaced,\r\n 197:   onEditorObjectMoved,\r\n 198:   onEditorObjectDeleted,\r\n 199:   onSocketError,\r\n 200:   onRecordingStarted,\r\n 201:   onRecordingStopped,\r\n 202:   onSpotlightActivated,\r\n 203:   onSpotlightDeactivated,\r\n 204:   onProximityChanged,\r\n 205: }: UseSocketOptions): UseSocketReturn {\r\n 206:   const [isConnected, setIsConnected] = useState(false);\r\n 207:   const [socketError, setSocketError] = useState<string | null>(null);\r\n 208:   const [players, setPlayers] = useState<PlayerData[]>([]);\r\n 209:   const socketRef = useRef<TypedSocket | null>(null);\r\n 210:   // connect effect 세대(generation) 카운터 ? 비동기 토큰 발급 중 effect가\r\n 211:   // 교체/언마운트됐는지 식별해 stale effect가 후속 effect의 소켓을 끊지 않게 한다.\r\n 212:   const connectAttemptRef = useRef(0);\r\n 213:   const lastMoveRef = useRef(0);\r\n 214:   const playersMapRef = useRef(new Map<string, PlayerData>());\r\n 215: \r\n 216:   // Refs for callbacks to avoid stale closures\r\n 217:   const onChatMessageRef = useRef(onChatMessage);\r\n 218:   const onWhisperReceiveRef = useRef(onWhisperReceive);\r\n 219:   const onWhisperSentRef = useRef(onWhisperSent);\r\n 220:   const onMessageIdUpdateRef = useRef(onMessageIdUpdate);\r\n 221:   const onMessageFailedRef = useRef(onMessageFailed);\r\n 222:   const onMessageDeletedRef = useRef(onMessageDeleted);\r\n 223:   const onReactionUpdatedRef = useRef(onReactionUpdated);\r\n 224:   const onPartyMessageRef = useRef(onPartyMessage);\r\n 225:   const onMemberMutedRef = useRef(onMemberMuted);\r\n 226:   const onMemberUnmutedRef = useRef(onMemberUnmuted);\r\n 227:   const onMemberKickedRef = useRef(onMemberKicked);\r\n 228:   const onAnnouncementRef = useRef(onAnnouncement);\r\n 229:   const onEditorTileUpdatedRef = useRef(onEditorTileUpdated);\r\n 230:   const onEditorObjectPlacedRef = useRef(onEditorObjectPlaced);\r\n 231:   const onEditorObjectMovedRef = useRef(onEditorObjectMoved);\r\n 232:   const onEditorObjectDeletedRef = useRef(onEditorObjectDeleted);\r\n 233:   const onSocketErrorRef = useRef(onSocketError);\r\n 234:   const onRecordingStartedRef = useRef(onRecordingStarted);\r\n 235:   const onRecordingStoppedRef = useRef(onRecordingStopped);\r\n 236:   const onSpotlightActivatedRef = useRef(onSpotlightActivated);\r\n 237:   const onSpotlightDeactivatedRef = useRef(onSpotlightDeactivated);\r\n 238:   const onProximityChangedRef = useRef(onProximityChanged);\r\n 239: \r\n 240:   useEffect(() => {\r\n 241:     onChatMessageRef.current = onChatMessage;\r\n 242:     onWhisperReceiveRef.current = onWhisperReceive;\r\n 243:     onWhisperSentRef.current = onWhisperSent;\r\n 244:     onMessageIdUpdateRef.current = onMessageIdUpdate;\r\n 245:     onMessageFailedRef.current = onMessageFailed;\r\n 246:     onMessageDeletedRef.current = onMessageDeleted;\r\n 247:     onReactionUpdatedRef.current = onReactionUpdated;\r\n 248:     onPartyMessageRef.current = onPartyMessage;\r\n 249:     onMemberMutedRef.current = onMemberMuted;\r\n 250:     onMemberUnmutedRef.current = onMemberUnmuted;\r\n 251:     onMemberKickedRef.current = onMemberKicked;\r\n 252:     onAnnouncementRef.current = onAnnouncement;\r\n 253:     onEditorTileUpdatedRef.current = onEditorTileUpdated;\r\n 254:     onEditorObjectPlacedRef.current = onEditorObjectPlaced;\r\n 255:     onEditorObjectMovedRef.current = onEditorObjectMoved;\r\n 256:     onEditorObjectDeletedRef.current = onEditorObjectDeleted;\r\n 257:     onSocketErrorRef.current = onSocketError;\r\n 258:     onRecordingStartedRef.current = onRecordingStarted;\r\n 259:     onRecordingStoppedRef.current = onRecordingStopped;\r\n 260:     onSpotlightActivatedRef.current = onSpotlightActivated;\r\n 261:     onSpotlightDeactivatedRef.current = onSpotlightDeactivated;\r\n 262:     onProximityChangedRef.current = onProximityChanged;\r\n 263:   }, [\r\n 264:     onChatMessage, onWhisperReceive, onWhisperSent, onMessageIdUpdate,\r\n 265:     onMessageFailed, onMessageDeleted, onReactionUpdated, onPartyMessage,\r\n 266:     onMemberMuted, onMemberUnmuted, onMemberKicked, onAnnouncement,\r\n 267:     onEditorTileUpdated, onEditorObjectPlaced, onEditorObjectMoved, onEditorObjectDeleted,\r\n 268:     onSocketError,\r\n 269:     onRecordingStarted, onRecordingStopped,\r\n 270:     onSpotlightActivated, onSpotlightDeactivated, onProximityChanged,\r\n 271:   ]);\r\n 272: \r\n 273:   useEffect(() => {\r\n 274:     let mounted = true;\r\n 275:     const attemptId = ++connectAttemptRef.current;\r\n 276: \r\n 277:     function syncPlayers() {\r\n 278:       setPlayers(Array.from(playersMapRef.current.values()));\r\n 279:     }\r\n 280: \r\n 281:     async function connect() {\r\n 282:       try {\r\n 283:         const sock = await getSocketClient();\r\n 284: \r\n 285:         // 토큰 발급(재시도 포함) 중 언마운트/effect 교체가 일어났을 수 있다.\r\n 286:         if (!mounted) {\r\n 287:           // 후속 effect가 시작되지 않았을 때만(=내가 마지막 시도) orphan 소켓 정리.\r\n 288:           // deps 변경으로 새 effect가 시작됐다면 그 effect가 동일 소켓을 이어 쓰므로 끊지 않는다.\r\n 289:           if (connectAttemptRef.current === attemptId) {\r\n 290:             disconnectSocket();\r\n 291:           }\r\n 292:           return;\r\n 293:         }\r\n 294:         if (connectAttemptRef.current !== attemptId) return;\r\n 295: \r\n 296:         socketRef.current = sock;\r\n 297: \r\n 298:         sock.on(\"connect\", () => {\r\n 299:           setIsConnected(true);\r\n 300:           setSocketError(null);\r\n 301:           sock.emit(\"join:space\", { spaceId, userId, nickname, avatar });\r\n 302:         });\r\n 303: \r\n 304:         sock.on(\"disconnect\", () => {\r\n 305:           setIsConnected(false);\r\n 306:         });\r\n 307: \r\n 308:         sock.on(\"connect_error\", (err) => {\r\n 309:           console.error(\"[Socket] Connect error:\", err.message);\r\n 310:           setSocketError(`소켓 연결 실패: ${err.message}`);\r\n 311:           setIsConnected(false);\r\n 312:         });\r\n 313: \r\n 314:         // ── 재연결 모니터링 ──\r\n 315:         sock.io.on(\"reconnect_attempt\", (attempt) => {\r\n 316:           console.log(`[Socket] Reconnect attempt #${attempt}`);\r\n 317:           setSocketError(`재연결 시도 중... (#${attempt})`);\r\n 318:         });\r\n 319: \r\n 320:         sock.io.on(\"reconnect\", () => {\r\n 321:           console.log(\"[Socket] Reconnected successfully\");\r\n 322:           setSocketError(null);\r\n 323:           setIsConnected(true);\r\n 324:           // 재연결 시 자동 join:space 재발송\r\n 325:           sock.emit(\"join:space\", { spaceId, userId, nickname, avatar });\r\n 326:         });\r\n 327: \r\n 328:         sock.io.on(\"reconnect_error\", (err) => {\r\n 329:           console.error(\"[Socket] Reconnect error:\", err.message);\r\n 330:         });\r\n 331: \r\n 332:         sock.io.on(\"reconnect_failed\", () => {\r\n 333:           console.error(\"[Socket] Reconnect failed after all attempts\");\r\n 334:           setSocketError(\"서버 연결에 실패했습니다. 페이지를 새로고침해주세요.\");\r\n 335:         });\r\n 336: \r\n 337:         // 입장 인가 거부 (비멤버/차단/비활성 공간)\r\n 338:         sock.on(\"space:error\", (data) => {\r\n 339:           console.error(\"[Socket] space:error:\", data.code, data.message);\r\n 340:           setSocketError(data.message);\r\n 341:         });\r\n 342: \r\n 343:         // ── 플레이어 이벤트 ──\r\n 344:         sock.on(\"players:list\", ({ players: list }) => {\r\n 345:           playersMapRef.current.clear();\r\n 346:           for (const p of list) {\r\n 347:             if (p.userId !== userId) {\r\n 348:               playersMapRef.current.set(p.userId, p);\r\n 349:             }\r\n 350:           }\r\n 351:           syncPlayers();\r\n 352:         });\r\n 353: \r\n 354:         sock.on(\"player:joined\", (data) => {\r\n 355:           if (data.userId !== userId) {\r\n 356:             playersMapRef.current.set(data.userId, data);\r\n 357:             syncPlayers();\r\n 358:           }\r\n 359:         });\r\n 360: \r\n","exit_code":0,"status":"completed"}}
