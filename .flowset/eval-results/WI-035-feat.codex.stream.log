{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -LiteralPath '\"'src\\\\app\\\\space\\\\[id]\\\\space-client.tsx' -Encoding UTF8 | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: \"use client\";\r\n   2: \r\n   3: import { useEffect, useCallback, useRef, useState } from \"react\";\r\n   4: import { useGameStore } from \"@/stores/game-store\";\r\n   5: import { eventBridge, GameEvents } from \"@/features/space/game\";\r\n   6: import { useSocketBridge } from \"@/features/space/bridge\";\r\n   7: import { useChat, type ChatMessage } from \"@/features/space/chat\";\r\n   8: import { useEditor, type StoredMapData, type EditorMapObject } from \"@/features/space/editor\";\r\n   9: import { LiveKitRoomProvider } from \"@/features/space/livekit\";\r\n  10: import type { RecordingStatusData, SpotlightData, ProximityChangedData } from \"@/features/space/socket\";\r\n  11: import GameCanvas from \"@/components/space/game-canvas\";\r\n  12: import LoadingScreen from \"@/components/space/loading-screen\";\r\n  13: import SpaceHud from \"@/components/space/space-hud\";\r\n  14: import ChatPanel from \"@/components/space/chat-panel\";\r\n  15: import { EditorToggleButton, EditorSidebar } from \"@/components/space/editor\";\r\n  16: import { SpaceMediaLayer } from \"@/components/space/video/SpaceMediaLayer\";\r\n  17: import { AvatarEditorModal } from \"@/components/space/avatar-editor-modal\";\r\n  18: \r\n  19: interface SpaceClientProps {\r\n  20:   space: {\r\n  21:     id: string;\r\n  22:     name: string;\r\n  23:     description: string | null;\r\n  24:     maxUsers: number;\r\n  25:     memberCount: number;\r\n  26:   };\r\n  27:   user: {\r\n  28:     id: string;\r\n  29:     nickname: string;\r\n  30:     avatar: string;\r\n  31:     role?: \"OWNER\" | \"STAFF\" | \"PARTICIPANT\";\r\n  32:   };\r\n  33: }\r\n  34: \r\n  35: let chatMsgId = Date.now();\r\n  36: \r\n  37: export default function SpaceClient({ space, user }: SpaceClientProps) {\r\n  38:   const { isLoading, isSceneReady, error, setSceneReady, setError, reset } = useGameStore();\r\n  39:   const [mapData, setMapData] = useState<StoredMapData | null>(null);\r\n  40:   const [mapObjects, setMapObjects] = useState<EditorMapObject[]>([]);\r\n  41: \r\n  42:   // Avatar editor modal\r\n  43:   const [showAvatarEditor, setShowAvatarEditor] = useState(false);\r\n  44:   const [currentAvatar, setCurrentAvatar] = useState(user.avatar);\r\n  45: \r\n  46:   // Media state (from socket events)\r\n  47:   const [isRecording, setIsRecording] = useState(false);\r\n  48:   const [recorderNickname, setRecorderNickname] = useState<string>();\r\n  49:   const [spotlightUsers, setSpotlightUsers] = useState<Set<string>>(new Set());\r\n  50: \r\n  51:   // 맵 데이터 로드\r\n  52:   useEffect(() => {\r\n  53:     let cancelled = false;\r\n  54:     async function loadMap() {\r\n  55:       try {\r\n  56:         const res = await fetch(`/api/spaces/${space.id}/map`);\r\n  57:         if (!res.ok) return;\r\n  58:         const data = await res.json();\r\n  59:         if (cancelled) return;\r\n  60:         if (data.mapData) setMapData(data.mapData as StoredMapData);\r\n  61:         if (data.objects) setMapObjects(data.objects as EditorMapObject[]);\r\n  62:       } catch {\r\n  63:         // 맵 데이터 로드 실패 시 기본 맵 사용\r\n  64:       }\r\n  65:     }\r\n  66:     loadMap();\r\n  67:     return () => { cancelled = true; };\r\n  68:   }, [space.id]);\r\n  69: \r\n  70:   // SCENE_READY 후 맵 오브젝트를 EventBridge로 전달\r\n  71:   useEffect(() => {\r\n  72:     if (!isSceneReady || mapObjects.length === 0) return;\r\n  73:     eventBridge.emit(GameEvents.EDITOR_MAP_LOADED, {\r\n  74:       layers: mapData?.layers ?? null,\r\n  75:       objects: mapObjects,\r\n  76:     });\r\n  77:   }, [isSceneReady, mapData, mapObjects]);\r\n  78: \r\n  79:   // 에디터 훅\r\n  80:   const canEdit = user.role === \"OWNER\" || user.role === \"STAFF\";\r\n  81:   const editor = useEditor({ spaceId: space.id, canEdit });\r\n  82: \r\n  83:   // 맵 오브젝트를 에디터 스토어에도 동기화\r\n  84:   useEffect(() => {\r\n  85:     if (mapObjects.length > 0) {\r\n  86:       editor.setMapObjects(mapObjects);\r\n  87:     }\r\n  88:   }, [mapObjects]); // eslint-disable-line react-hooks/exhaustive-deps\r\n  89: \r\n  90:   // 맵 타일 데이터를 에디터 스토어에 동기화\r\n  91:   useEffect(() => {\r\n  92:     if (mapData?.layers) {\r\n  93:       editor.setTileData(mapData.layers);\r\n  94:     }\r\n  95:   }, [mapData]); // eslint-disable-line react-hooks/exhaustive-deps\r\n  96: \r\n  97:   // Refs for circular dependency resolution (useChat <-> useSocketBridge)\r\n  98:   const sendChatRef = useRef<(content: string, type: \"group\" | \"whisper\" | \"party\", targetId?: string) => void>(\r\n  99:     () => {}\r\n 100:   );\r\n 101:   const sendWhisperRef = useRef<(targetNickname: string, content: string) => void>(() => {});\r\n 102:   const sendReactionToggleRef = useRef<(messageId: string, reactionType: \"thumbsup\" | \"heart\" | \"check\") => void>(\r\n 103:     () => {}\r\n 104:   );\r\n 105:   const sendAdminCommandRef = useRef<(command: string, data: Record<string, unknown>) => void>(() => {});\r\n 106: \r\n 107:   const sendChatStable = useCallback(\r\n 108:     (content: string, type: \"group\" | \"whisper\" | \"party\", targetId?: string) => {\r\n 109:       sendChatRef.current(content, type, targetId);\r\n 110:     },\r\n 111:     []\r\n 112:   );\r\n 113:   const sendWhisperStable = useCallback(\r\n 114:     (targetNickname: string, content: string) => sendWhisperRef.current(targetNickname, content),\r\n 115:     []\r\n 116:   );\r\n 117:   const sendReactionStable = useCallback(\r\n 118:     (messageId: string, reactionType: \"thumbsup\" | \"heart\" | \"check\") =>\r\n 119:       sendReactionToggleRef.current(messageId, reactionType),\r\n 120:     []\r\n 121:   );\r\n 122:   const sendAdminStable = useCallback(\r\n 123:     (command: string, data: Record<string, unknown>) => sendAdminCommandRef.current(command, data),\r\n 124:     []\r\n 125:   );\r\n 126: \r\n 127:   const chatReturn = useChat({\r\n 128:     sendChat: sendChatStable,\r\n 129:     sendWhisper: sendWhisperStable,\r\n 130:     sendReactionToggle: sendReactionStable,\r\n 131:     sendAdminCommand: sendAdminStable,\r\n 132:     spaceId: space.id,\r\n 133:     userId: user.id,\r\n 134:     nickname: user.nickname,\r\n 135:     role: user.role,\r\n 136:   });\r\n 137: \r\n 138:   const {\r\n 139:     messages, activeTab, setActiveTab, sendMessage, setChatFocused, addMessage,\r\n 140:     replyTo, setReplyTo, toggleReaction, deleteMessage,\r\n 141:   } = chatReturn;\r\n 142: \r\n 143:   // 내부 핸들러 (타입 캐스트로 접근)\r\n 144:   const chatInternal = chatReturn as unknown as {\r\n 145:     _handleMessageIdUpdate: (tempId: string, realId: string) => void;\r\n 146:     _handleMessageFailed: (tempId: string) => void;\r\n 147:     _handleMessageDeleted: (messageId: string) => void;\r\n 148:     _handleReactionUpdated: (\r\n 149:       messageId: string,\r\n 150:       reactions: Array<{ type: \"thumbsup\" | \"heart\" | \"check\"; userId: string; userNickname: string }>\r\n 151:     ) => void;\r\n 152:   };\r\n 153: \r\n 154:   // Socket callbacks ? Chat\r\n 155:   const onChatMessage = useCallback(\r\n 156:     (data: {\r\n 157:       id?: string;\r\n 158:       tempId?: string;\r\n 159:       userId: string;\r\n 160:       nickname: string;\r\n 161:       content: string;\r\n 162:       type: string;\r\n 163:       timestamp: string;\r\n 164:       replyTo?: { id: string; senderNickname: string; content: string };\r\n 165:       partyId?: string;\r\n 166:       partyName?: string;\r\n 167:     }) => {\r\n 168:       const msg: ChatMessage = {\r\n 169:         id: data.id || `chat-${++chatMsgId}`,\r\n 170:         tempId: data.tempId,\r\n 171:         userId: data.userId,\r\n 172:         nickname: data.nickname,\r\n 173:         content: data.content,\r\n 174:         type: data.type as ChatMessage[\"type\"],\r\n 175:         timestamp: data.timestamp,\r\n 176:         replyTo: data.replyTo,\r\n 177:         partyId: data.partyId,\r\n 178:         partyName: data.partyName,\r\n 179:       };\r\n 180:       addMessage(msg);\r\n 181:     },\r\n 182:     [addMessage]\r\n 183:   );\r\n 184: \r\n 185:   const onWhisperReceive = useCallback(\r\n 186:     (data: { senderId: string; senderNickname: string; content: string; timestamp: string }) => {\r\n 187:       const msg: ChatMessage = {\r\n 188:         id: `whisper-in-${++chatMsgId}`,\r\n 189:         userId: data.senderId,\r\n 190:         nickname: data.senderNickname,\r\n 191:         content: data.content,\r\n 192:         type: \"whisper\",\r\n 193:         timestamp: data.timestamp,\r\n 194:       };\r\n 195:       addMessage(msg);\r\n 196:     },\r\n 197:     [addMessage]\r\n 198:   );\r\n 199: \r\n 200:   const onWhisperSent = useCallback(\r\n 201:     (data: { targetNickname: string; content: string; timestamp: string }) => {\r\n 202:       // 이미 낙관적으로 추가됨 (useChat에서)\r\n 203:       void data;\r\n 204:     },\r\n 205:     []\r\n 206:   );\r\n 207: \r\n 208:   const onMessageIdUpdate = useCallback(\r\n 209:     (data: { tempId: string; realId: string }) => {\r\n 210:       chatInternal._handleMessageIdUpdate?.(data.tempId, data.realId);\r\n 211:     },\r\n 212:     [chatInternal]\r\n 213:   );\r\n 214: \r\n 215:   const onMessageFailed = useCallback(\r\n 216:     (data: { tempId: string; error: string }) => {\r\n 217:       chatInternal._handleMessageFailed?.(data.tempId);\r\n 218:     },\r\n 219:     [chatInternal]\r\n 220:   );\r\n 221: \r\n 222:   const onMessageDeleted = useCallback(\r\n 223:     (data: { messageId: string; deletedBy: string }) => {\r\n 224:       chatInternal._handleMessageDeleted?.(data.messageId);\r\n 225:     },\r\n 226:     [chatInternal]\r\n 227:   );\r\n 228: \r\n 229:   const onReactionUpdated = useCallback(\r\n 230:     (data: {\r\n 231:       messageId: string;\r\n 232:       reactions: Array<{ type: \"thumbsup\" | \"heart\" | \"check\"; userId: string; userNickname: string }>;\r\n 233:     }) => {\r\n 234:       chatInternal._handleReactionUpdated?.(data.messageId, data.reactions);\r\n 235:     },\r\n 236:     [chatInternal]\r\n 237:   );\r\n 238: \r\n 239:   const onMemberMuted = useCallback(\r\n 240:     (data: { nickname: string; mutedBy: string }) => {\r\n 241:       addMessage({\r\n 242:         id: `sys-${++chatMsgId}`,\r\n 243:         userId: \"system\",\r\n 244:         nickname: \"System\",\r\n 245:         content: `${data.nickname}님이 ${data.mutedBy}에 의해 뮤트되었습니다.`,\r\n 246:         type: \"system\",\r\n 247:         timestamp: new Date().toISOString(),\r\n 248:       });\r\n 249:     },\r\n 250:     [addMessage]\r\n 251:   );\r\n 252: \r\n 253:   const onMemberUnmuted = useCallback(\r\n 254:     (data: { nickname: string; unmutedBy: string }) => {\r\n 255:       addMessage({\r\n 256:         id: `sys-${++chatMsgId}`,\r\n 257:         userId: \"system\",\r\n 258:         nickname: \"System\",\r\n 259:         content: `${data.nickname}님의 뮤트가 ${data.unmutedBy}에 의해 해제되었습니다.`,\r\n 260:         type: \"system\",\r\n 261:         timestamp: new Date().toISOString(),\r\n 262:       });\r\n 263:     },\r\n 264:     [addMessage]\r\n 265:   );\r\n 266: \r\n 267:   const onMemberKicked = useCallback(\r\n 268:     (data: { nickname: string; kickedBy: string }) => {\r\n 269:       addMessage({\r\n 270:         id: `sys-${++chatMsgId}`,\r\n 271:         userId: \"system\",\r\n 272:         nickname: \"System\",\r\n 273:         content: `${data.nickname}님이 ${data.kickedBy}에 의해 추방되었습니다.`,\r\n 274:         type: \"system\",\r\n 275:         timestamp: new Date().toISOString(),\r\n 276:       });\r\n 277:     },\r\n 278:     [addMessage]\r\n 279:   );\r\n 280: \r\n 281:   const onAnnouncement = useCallback(\r\n 282:     (data: { content: string; announcer: string; timestamp: string }) => {\r\n 283:       addMessage({\r\n 284:         id: `announce-${++chatMsgId}`,\r\n 285:         userId: \"system\",\r\n 286:         nickname: data.announcer,\r\n 287:         content: data.content,\r\n 288:         type: \"announcement\",\r\n 289:         timestamp: data.timestamp,\r\n 290:       });\r\n 291:     },\r\n 292:     [addMessage]\r\n 293:   );\r\n 294: \r\n 295:   // Socket callbacks ? Media\r\n 296:   const onRecordingStarted = useCallback((data: RecordingStatusData) => {\r\n 297:     setIsRecording(data.isRecording);\r\n 298:     setRecorderNickname(data.recorderNickname);\r\n 299:   }, []);\r\n 300: \r\n 301:   const onRecordingStopped = useCallback((_: RecordingStatusData) => {\r\n 302:     void _;\r\n 303:     setIsRecording(false);\r\n 304:     setRecorderNickname(undefined);\r\n 305:   }, []);\r\n 306: \r\n 307:   const onSpotlightActivated = useCallback((data: SpotlightData) => {\r\n 308:     setSpotlightUsers((prev) => new Set(prev).add(data.participantId));\r\n 309:   }, []);\r\n 310: \r\n 311:   const onSpotlightDeactivated = useCallback((data: SpotlightData) => {\r\n 312:     setSpotlightUsers((prev) => {\r\n 313:       const next = new Set(prev);\r\n 314:       next.delete(data.participantId);\r\n 315:       return next;\r\n 316:     });\r\n 317:   }, []);\r\n 318: \r\n 319:   const onProximityChanged = useCallback((_: ProximityChangedData) => {\r\n 320:     void _;\r\n 321:     // Proximity 상태는 LiveKit useProximitySubscription에서 직접 관리\r\n 322:   }, []);\r\n 323: \r\n 324:   const onSocketError = useCallback(\r\n 325:     (data: { code: string; message: string }) => {\r\n 326:       console.warn(`[Socket] Error (${data.code}): ${data.message}`);\r\n 327:       addMessage({\r\n 328:         id: `sys-${++chatMsgId}`,\r\n 329:         userId: \"system\",\r\n 330:         nickname: \"System\",\r\n 331:         content: data.message,\r\n 332:         type: \"system\",\r\n 333:         timestamp: new Date().toISOString(),\r\n 334:       });\r\n 335:     },\r\n 336:     [addMessage]\r\n 337:   );\r\n 338: \r\n 339:   const {\r\n 340:     isConnected, socketError, players, sendChat, sendWhisper,\r\n 341:     sendReactionToggle, sendAdminCommand, sendAvatarUpdate,\r\n 342:   } = useSocketBridge({\r\n 343:     spaceId: space.id,\r\n 344:     userId: user.id,\r\n 345:     nickname: user.nickname,\r\n 346:     avatar: user.avatar,\r\n 347:     onChatMessage,\r\n 348:     onWhisperReceive,\r\n 349:     onWhisperSent,\r\n 350:     onMessageIdUpdate,\r\n 351:     onMessageFailed,\r\n 352:     onMessageDeleted,\r\n 353:     onReactionUpdated,\r\n 354:     onMemberMuted,\r\n 355:     onMemberUnmuted,\r\n 356:     onMemberKicked,\r\n 357:     onAnnouncement,\r\n 358:     onRecordingStarted,\r\n 359:     onRecordingStopped,\r\n 360:     onSpotlightActivated,\r\n 361:     onSpotlightDeactivated,\r\n 362:     onProximityChanged,\r\n 363:     onSocketError,\r\n 364:   });\r\n 365: \r\n 366:   // Ref 업데이트\r\n 367:   sendChatRef.current = sendChat;\r\n 368:   sendWhisperRef.current = sendWhisper;\r\n 369:   sendReactionToggleRef.current = sendReactionToggle;\r\n 370:   sendAdminCommandRef.current = sendAdminCommand;\r\n 371: \r\n 372:   // SCENE_READY / SCENE_ERROR 이벤트 리스닝\r\n 373:   useEffect(() => {\r\n 374:     const onSceneReady = () => {\r\n 375:       setSceneReady(true);\r\n 376:     };\r\n 377: \r\n 378:     const onSceneError = (payload: unknown) => {\r\n 379:       const { error: errMsg } = payload as { error: string };\r\n 380:       setError(errMsg);\r\n 381:     };\r\n 382: \r\n 383:     eventBridge.on(GameEvents.SCENE_READY, onSceneReady);\r\n 384:     eventBridge.on(GameEvents.SCENE_ERROR, onSceneError);\r\n 385: \r\n 386:     return () => {\r\n 387:       eventBridge.off(GameEvents.SCENE_READY, onSceneReady);\r\n 388:       eventBridge.off(GameEvents.SCENE_ERROR, onSceneError);\r\n 389:       reset();\r\n 390:     };\r\n 391:   }, [setSceneReady, setError, reset]);\r\n 392: \r\n 393:   if (error) {\r\n 394:     return (\r\n 395:       <div className=\"flex h-screen items-center justify-center bg-ink text-cream\">\r\n 396:         <div className=\"text-center\">\r\n 397:           <h2 className=\"font-serif text-2xl font-medium mb-2\">오류가 발생했습니다</h2>\r\n 398:           <p className=\"text-ink-light\">{error}</p>\r\n 399:           <a href=\"/my-spaces\" className=\"mt-4 inline-block text-cream underline-offset-4 hover:underline\">\r\n 400:             스페이스 목록으로 돌아가기\r\n 401:           </a>\r\n 402:         </div>\r\n 403:       </div>\r\n 404:     );\r\n 405:   }\r\n 406: \r\n 407:   return (\r\n 408:     <LiveKitRoomProvider\r\n 409:       spaceId={space.id}\r\n 410:       participantId={user.id}\r\n 411:       participantName={user.nickname}\r\n 412:     >\r\n 413:       <div className=\"relative h-screen w-screen overflow-hidden bg-ink\">\r\n 414:         {/* Phaser Canvas */}\r\n 415:         <GameCanvas\r\n 416:           spaceId={space.id}\r\n 417:           userId={user.id}\r\n 418:           nickname={user.nickname}\r\n 419:           avatar={user.avatar}\r\n 420:           mapData={mapData}\r\n 421:         />\r\n 422: \r\n 423:         {/* Loading Overlay */}\r\n 424:         {isLoading && <LoadingScreen spaceName={space.name} />}\r\n 425: \r\n 426:         {/* HUD (씬 준비 후 표시) */}\r\n 427:         {isSceneReady && (\r\n 428:           <>\r\n 429:             <SpaceHud\r\n 430:               spaceName={space.name}\r\n 431:               isConnected={isConnected}\r\n 432:               playerCount={players.length + 1}\r\n 433:               editorSlot={\r\n 434:                 <EditorToggleButton\r\n 435:                   isEditorMode={editor.isEditorMode}\r\n 436:                   canEdit={editor.canEdit}\r\n 437:                   onToggle={() =>\r\n 438:                     editor.isEditorMode\r\n 439:                       ? editor.exitEditor()\r\n 440:                       : editor.enterEditor()\r\n 441:                   }\r\n 442:                 />\r\n 443:               }\r\n 444:             />\r\n 445:             <ChatPanel\r\n 446:               messages={messages}\r\n 447:               activeTab={activeTab}\r\n 448:               onTabChange={setActiveTab}\r\n 449:               onSend={sendMessage}\r\n 450:               onFocusChange={setChatFocused}\r\n 451:               onReply={setReplyTo}\r\n 452:               onReactionToggle={toggleReaction}\r\n 453:               onDeleteMessage={deleteMessage}\r\n 454:               replyTo={replyTo}\r\n 455:               currentUserId={user.id}\r\n 456:               role={user.role}\r\n 457:               players={players}\r\n 458:               socketError={socketError}\r\n 459:             />\r\n 460: \r\n 461:             {/* Avatar Edit Button */}\r\n 462:             <button\r\n 463:               type=\"button\"\r\n 464:               onClick={() => setShowAvatarEditor(true)}\r\n 465:               className=\"absolute left-4 top-14 z-50 rounded-lg bg-ink/80 px-3 py-1.5 text-xs font-medium text-cream backdrop-blur-sm transition-colors hover:bg-ink/90\"\r\n 466:             >\r\n 467:               Edit Avatar\r\n 468:             </button>\r\n 469: \r\n 470:             {/* LiveKit Media Layer */}\r\n 471:             <SpaceMediaLayer\r\n 472:               spaceId={space.id}\r\n 473:               spaceName={space.name}\r\n 474:               spotlightUsers={spotlightUsers}\r\n 475:               isRecording={isRecording}\r\n 476:               recorderNickname={recorderNickname}\r\n 477:               players={players}\r\n 478:               currentUserId={user.id}\r\n 479:               currentNickname={user.nickname}\r\n 480:             />\r\n 481: \r\n 482:             {/* Editor Sidebar */}\r\n 483:             {editor.isEditorMode && (\r\n 484:               <EditorSidebar\r\n 485:                 activeTool={editor.activeTool}\r\n 486:                 activeLayer={editor.activeLayer}\r\n 487:                 selectedTileIndex={editor.selectedTileIndex}\r\n 488:                 selectedObjectType={editor.selectedObjectType}\r\n 489:                 selectedAssetId={editor.selectedAssetId}\r\n 490:                 selectedObject={\r\n 491:                   editor.selectedObjectId\r\n 492:                     ? editor.mapObjects.find(\r\n 493:                         (o) => o.id === editor.selectedObjectId\r\n 494:                       ) ?? null\r\n 495:                     : null\r\n 496:                 }\r\n 497:                 paletteTab={editor.paletteTab}\r\n 498:                 layerVisibility={editor.layerVisibility}\r\n 499:                 isDirty={editor.isDirty}\r\n 500:                 isSaving={editor.isSaving}\r\n 501:                 onToolChange={editor.setTool}\r\n 502:                 onLayerChange={editor.setLayer}\r\n 503:                 onTileSelect={editor.setTile}\r\n 504:                 onObjectTypeSelect={editor.setObjectType}\r\n 505:                 onAssetSelect={editor.setAssetSelection}\r\n 506:                 onToggleLayerVisibility={editor.toggleLayerVisibility}\r\n 507:                 onPaletteTabChange={editor.setPaletteTab}\r\n 508:                 onSave={editor.saveTiles}\r\n 509:                 onDeleteObject={editor.deleteObject}\r\n 510:                 onLinkPortal={(sourceId) => {\r\n 511:                   // 간단한 포탈 링킹: 다음 포탈 선택 대기 모드\r\n 512:                   const portals = editor.mapObjects.filter(\r\n 513:                     (o) =>\r\n 514:                       o.objectType === \"portal\" && o.id !== sourceId\r\n 515:                   );\r\n 516:                   if (portals.length > 0) {\r\n 517:                     editor.linkPortal(sourceId, portals[0].id);\r\n 518:                   }\r\n 519:                 }}\r\n 520:               />\r\n 521:             )}\r\n 522:           </>\r\n 523:         )}\r\n 524:         {/* Avatar Editor Modal */}\r\n 525:         {showAvatarEditor && (\r\n 526:           <AvatarEditorModal\r\n 527:             currentAvatar={currentAvatar}\r\n 528:             onSave={(avatarString) => {\r\n 529:               setCurrentAvatar(avatarString);\r\n 530:               // 소켓으로 다른 유저에게 브로드캐스트\r\n 531:               sendAvatarUpdate(avatarString);\r\n 532:               // 로컬 플레이어 스프라이트 업데이트\r\n 533:               eventBridge.emit(GameEvents.PLAYER_AVATAR_UPDATED, { avatar: avatarString });\r\n 534:             }}\r\n 535:             onClose={() => setShowAvatarEditor(false)}\r\n 536:           />\r\n 537:         )}\r\n 538:       </div>\r\n 539:     </LiveKitRoomProvider>\r\n 540:   );\r\n 541: }\r\n","exit_code":0,"status":"completed"}}
