n/members ? 응답 allowlist (WI-014, onRefresh 경로 가드)\", () => {\r\n  40:   it(\"findMany가 restricted*/guestSessionId/spaceId 제외 select로 호출된다\", async () => {\r\n  41:     mockAuth.mockResolvedValue(makeSession({ id: \"owner-1\", isSuperAdmin: false }));\r\n  42:     mockPrisma.spaceMember.findUnique.mockResolvedValue({ role: \"OWNER\" });\r\n  43:     mockPrisma.spaceMember.findMany.mockResolvedValue([]);\r\n  44: \r\n  45:     const res = await GET(\r\n  46:       buildGetRequest(`/api/spaces/${SPACE_ID}/admin/members`),\r\n  47:       ctx\r\n  48:     );\r\n  49:     expect(res.status).toBe(200);\r\n  50: \r\n  51:     // 결정적 변이검증: include 복귀 또는 민감필드 재추가 시 FAIL\r\n  52:     const arg = mockPrisma.spaceMember.findMany.mock.calls[0][0] as {\r\n  53:       select: Record<string, unknown>;\r\n  54:     };\r\n  55:     expect(Object.keys(arg.select).sort()).toEqual(\r\n  56:       [\"createdAt\", \"displayName\", \"guestSession\", \"id\", \"restriction\", \"role\", \"user\", \"userId\"].sort()\r\n  57:     );\r\n  58:     for (const leaked of [\r\n  59:       \"restrictedBy\",\r\n  60:       \"restrictedReason\",\r\n  61:       \"restrictedUntil\",\r\n  62:       \"guestSessionId\",\r\n  63:       \"spaceId\",\r\n  64:       \"updatedAt\",\r\n  65:     ]) {\r\n  66:       expect(arg.select).not.toHaveProperty(leaked);\r\n  67:     }\r\n  68:     // 소비처 필수 필드는 보존 (member-table: user{...}/guestSession{...}, media-management: userId)\r\n  69:     expect(arg.select.user).toEqual({ select: { id: true, name: true, email: true, image: true } });\r\n  70:     expect(arg.select.userId).toBe(true);\r\n  71:   });\r\n  72: \r\n  73:   it(\"멤버도 슈퍼어드민도 아니면 403이고 findMany 미진입\", async () => {\r\n  74:     mockAuth.mockResolvedValue(makeSession({ id: \"intruder\", isSuperAdmin: false }));\r\n  75:     mockPrisma.spaceMember.findUnique.mockResolvedValue(null);\r\n  76: \r\n  77:     const res = await GET(\r\n  78:       buildGetRequest(`/api/spaces/${SPACE_ID}/admin/members`),\r\n  79:       ctx\r\n  80:     );\r\n  81: \r\n  82:     expect(res.status).toBe(403);\r\n  83:     expect(mockPrisma.spaceMember.findMany).not.toHaveBeenCalled();\r\n  84:   });\r\n  85: });\r\n  86: \r\n  87: describe(\"PATCH /api/spaces/[id]/admin/members ? 응답 allowlist (WI-014)\", () => {\r\n  88:   it(\"mute: update가 {id,role,restriction} select로 호출되고 응답 member에 restrictedBy 미노출\", async () => {\r\n  89:     mockAuth.mockResolvedValue(makeSession({ id: \"owner-1\", isSuperAdmin: false, name: \"관리자\" }));\r\n  90:     // 1) 호출자(self, OWNER) 2) 대상(target, PARTICIPANT, userId 있음)\r\n  91:     mockPrisma.spaceMember.findUnique\r\n  92:       .mockResolvedValueOnce({ role: \"OWNER\" })\r\n  93:       .mockResolvedValueOnce({\r\n  94:         id: \"m-target\",\r\n  95:         spaceId: SPACE_ID,\r\n  96:         role: \"PARTICIPANT\",\r\n  97:         userId: \"u-target\",\r\n  98:         displayName: \"타겟\",\r\n  99:         user: { name: \"타겟\" },\r\n 100:       });\r\n 101:     mockPrisma.spaceMember.update.mockResolvedValue({\r\n 102:       id: \"m-target\",\r\n 103:       role: \"PARTICIPANT\",\r\n 104:       restriction: \"MUTED\",\r\n 105:     });\r\n 106: \r\n 107:     const res = await PATCH(\r\n 108:       buildJsonRequest(`/api/spaces/${SPACE_ID}/admin/members`, \"PATCH\", {\r\n 109:         memberId: \"m-target\",\r\n 110:         action: \"mute\",\r\n 111:       }),\r\n 112:       ctx\r\n 113:     );\r\n 114: \r\n 115:     expect(res.status).toBe(200);\r\n 116: \r\n 117:     // (1) 결정적 변이검증: update select 키 집합\r\n 118:     const updateArg = mockPrisma.spaceMember.update.mock.calls[0][0] as {\r\n 119:       data: Record<string, unknown>;\r\n 120:       select: Record<string, boolean>;\r\n 121:     };\r\n 122:     expect(Object.keys(updateArg.select).sort()).toEqual([\"id\", \"restriction\", \"role\"]);\r\n 123:     expect(updateArg.select).not.toHaveProperty(\"restrictedBy\");\r\n 124:     // 쓰기(data)에는 restrictedBy 반영\r\n 125:     expect(updateArg.data.restrictedBy).toBe(\"owner-1\");\r\n 126: \r\n 127:     // (2) 응답 계약 보존 + member 내부 민감필드 부재\r\n 128:     const body = await readJson<{ member: Record<string, unknown>; realtimeEnforced: boolean }>(res);\r\n 129:     expect(Object.keys(body).sort()).toEqual([\"member\", \"realtimeEnforced\"]);\r\n 130:     expect(Object.keys(body.member).sort()).toEqual([\"id\", \"restriction\", \"role\"]);\r\n 131:     expect(body.member).not.toHaveProperty(\"restrictedBy\");\r\n 132:   });\r\n 133: \r\n 134:   it(\"미인증이면 401이고 update 미진입\", async () => {\r\n 135:     mockAuth.mockResolvedValue(makeSession(null));\r\n 136: \r\n 137:     const res = await PATCH(\r\n 138:       buildJsonRequest(`/api/spaces/${SPACE_ID}/admin/members`, \"PATCH\", {\r\n 139:         memberId: \"m\",\r\n 140:         action: \"mute\",\r\n 141:       }),\r\n 142:       ctx\r\n 143:     );\r\n 144: \r\n 145:     expect(res.status).toBe(401);\r\n 146:     expect(mockPrisma.spaceMember.update).not.toHaveBeenCalled();\r\n 147:   });\r\n 148: });\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content -LiteralPath '\"'src\\\\components\\\\space\\\\member-actions-menu.test.tsx' -Encoding UTF8 | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: import { describe, it, expect, vi, beforeEach, afterEach } from \"vitest\";\r\n   2: import { render, screen, fireEvent, cleanup, waitFor } from \"@testing-library/react\";\r\n   3: import { MemberActionsMenu } from \"./member-actions-menu\";\r\n   4: import type { ManagedMember } from \"./use-space-members\";\r\n   5: \r\n   6: // ============================================================\r\n   7: // WI-035: 인-스페이스 멤버 관리 메뉴 ? 게이팅·PATCH 식별자·확인 플로우\r\n   8: // ============================================================\r\n   9: \r\n  10: const STAFF_MEMBER: ManagedMember = {\r\n  11:   memberId: \"m-staff\",\r\n  12:   userId: \"u-staff\",\r\n  13:   role: \"STAFF\",\r\n  14:   restriction: \"NONE\",\r\n  15: };\r\n  16: \r\n  17: const MUTED_PART: ManagedMember = {\r\n  18:   memberId: \"m-part\",\r\n  19:   userId: \"u-part\",\r\n  20:   role: \"PARTICIPANT\",\r\n  21:   restriction: \"MUTED\",\r\n  22: };\r\n  23: \r\n  24: function renderMenu(overrides: Partial<React.ComponentProps<typeof MemberActionsMenu>> = {}) {\r\n  25:   const onActionDone = vi.fn();\r\n  26:   const props: React.ComponentProps<typeof MemberActionsMenu> = {\r\n  27:     spaceId: \"space-1\",\r\n  28:     target: { userId: \"u-staff\", nickname: \"Staff Kim\" },\r\n  29:     member: STAFF_MEMBER,\r\n  30:     actorRole: \"OWNER\",\r\n  31:     currentUserId: \"u-owner\",\r\n  32:     onActionDone,\r\n  33:     ...overrides,\r\n  34:   };\r\n  35:   render(<MemberActionsMenu {...props} />);\r\n  36:   return { onActionDone };\r\n  37: }\r\n  38: \r\n  39: beforeEach(() => {\r\n  40:   global.fetch = vi.fn() as unknown as typeof fetch;\r\n  41: });\r\n  42: afterEach(() => {\r\n  43:   cleanup();\r\n  44:   vi.restoreAllMocks();\r\n  45: });\r\n  46: \r\n  47: describe(\"MemberActionsMenu ? 게이팅\", () => {\r\n  48:   it(\"member 없음(게스트/미매칭) → 렌더 안 함\", () => {\r\n  49:     renderMenu({ member: null });\r\n  50:     expect(screen.queryByRole(\"button\")).toBeNull();\r\n  51:   });\r\n  52: \r\n  53:   it(\"actorRole null(미인가) → 렌더 안 함\", () => {\r\n  54:     renderMenu({ actorRole: null });\r\n  55:     expect(screen.queryByRole(\"button\")).toBeNull();\r\n  56:   });\r\n  57: \r\n  58:   it(\"본인 → 렌더 안 함\", () => {\r\n  59:     renderMenu({\r\n  60:       member: { ...STAFF_MEMBER, userId: \"u-owner\" },\r\n  61:       currentUserId: \"u-owner\",\r\n  62:     });\r\n  63:     expect(screen.queryByRole(\"button\")).toBeNull();\r\n  64:   });\r\n  65: \r\n  66:   it(\"canActOn 불가(STAFF가 STAFF 대상) → 렌더 안 함\", () => {\r\n  67:     renderMenu({ actorRole: \"STAFF\", member: STAFF_MEMBER });\r\n  68:     expect(screen.queryByRole(\"button\")).toBeNull();\r\n  69:   });\r\n  70: \r\n  71:   it(\"OWNER 대상(동급/상위) → 렌더 안 함\", () => {\r\n  72:     renderMenu({\r\n  73:       actorRole: \"OWNER\",\r\n  74:       member: { memberId: \"m-o2\", userId: \"u-o2\", role: \"OWNER\", restriction: \"NONE\" },\r\n  75:       target: { userId: \"u-o2\", nickname: \"Other Owner\" },\r\n  76:     });\r\n  77:     expect(screen.queryByRole(\"button\")).toBeNull();\r\n  78:   });\r\n  79: });\r\n  80: \r\n  81: describe(\"MemberActionsMenu ? 액션\", () => {\r\n  82:   it(\"OWNER→STAFF(NONE): 음소거·내보내기·차단 노출(해제 미노출)\", () => {\r\n  83:     renderMenu();\r\n  84:     fireEvent.click(screen.getByLabelText(\"Staff Kim 관리\"));\r\n  85:     expect(screen.getByText(\"채팅 음소거\")).toBeTruthy();\r\n  86:     expect(screen.queryByText(\"채팅 음소거 해제\")).toBeNull();\r\n  87:     expect(screen.getByText(\"내보내기\")).toBeTruthy();\r\n  88:     expect(screen.getByText(\"차단\")).toBeTruthy();\r\n  89:   });\r\n  90: \r\n  91:   it(\"MUTED 대상 → '채팅 음소거 해제' 노출\", () => {\r\n  92:     renderMenu({ member: MUTED_PART, target: { userId: \"u-part\", nickname: \"Part\" } });\r\n  93:     fireEvent.click(screen.getByLabelText(\"Part 관리\"));\r\n  94:     expect(screen.getByText(\"채팅 음소거 해제\")).toBeTruthy();\r\n  95:     expect(screen.queryByText(\"채팅 음소거\")).toBeNull();\r\n  96:   });\r\n  97: \r\n  98:   it(\"음소거 → PATCH는 memberId만 사용(userId 금지) + onActionDone 호출\", async () => {\r\n  99:     (global.fetch as ReturnType<typeof vi.fn>).mockResolvedValue({\r\n 100:       ok: true,\r\n 101:       json: async () => ({ member: {} }),\r\n 102:     });\r\n 103:     const { onActionDone } = renderMenu();\r\n 104:     fireEvent.click(screen.getByLabelText(\"Staff Kim 관리\"));\r\n 105:     fireEvent.click(screen.getByText(\"채팅 음소거\"));\r\n 106: \r\n 107:     await waitFor(() => expect(global.fetch).toHaveBeenCalled());\r\n 108:     const [url, init] = (global.fetch as ReturnType<typeof vi.fn>).mock.calls[0];\r\n 109:     expect(url).toBe(\"/api/spaces/space-1/admin/members\");\r\n 110:     const body = JSON.parse((init as RequestInit).body as string);\r\n 111:     expect(body).toEqual({ memberId: \"m-staff\", action: \"mute\" });\r\n 112:     // 식별자 혼동 방지: userId가 PATCH 본문에 절대 없어야 함\r\n 113:     expect(JSON.stringify(body)).not.toContain(\"u-staff\");\r\n 114: \r\n 115:     await waitFor(() => expect(onActionDone).toHaveBeenCalledTimes(1));\r\n 116:   });\r\n 117: \r\n 118:   it(\"내보내기 → 인라인 확인 후 PATCH(kick)\", async () => {\r\n 119:     (global.fetch as ReturnType<typeof vi.fn>).mockResolvedValue({\r\n 120:       ok: true,\r\n 121:       json: async () => ({ message: \"Member kicked\" }),\r\n 122:     });\r\n 123:     const { onActionDone } = renderMenu();\r\n 124:     fireEvent.click(screen.getByLabelText(\"Staff Kim 관리\"));\r\n 125:     fireEvent.click(screen.getByText(\"내보내기\"));\r\n 126: \r\n 127:     // 확인 단계 ? 바로 PATCH 안 됨\r\n 128:     expect(global.fetch).not.toHaveBeenCalled();\r\n 129:     expect(screen.getByText(/내보낼까요/)).toBeTruthy();\r\n 130: \r\n 131:     fireEvent.click(screen.getByText(\"확인\"));\r\n 132:     await waitFor(() => expect(global.fetch).toHaveBeenCalled());\r\n 133:     const body = JSON.parse(\r\n 134:       ((global.fetch as ReturnType<typeof vi.fn>).mock.calls[0][1] as RequestInit).body as string\r\n 135:     );\r\n 136:     expect(body).toEqual({ memberId: \"m-staff\", action: \"kick\" });\r\n 137:     await waitFor(() => expect(onActionDone).toHaveBeenCalled());\r\n 138:   });\r\n 139: \r\n 140:   it(\"차단 확인 취소 → PATCH 미호출\", () => {\r\n 141:     renderMenu();\r\n 142:     fireEvent.click(screen.getByLabelText(\"Staff Kim 관리\"));\r\n 143:     fireEvent.click(screen.getByText(\"차단\"));\r\n 144:     expect(screen.getByText(/차단할까요/)).toBeTruthy();\r\n 145:     fireEvent.click(screen.getByText(\"취소\"));\r\n 146:     expect(global.fetch).not.toHaveBeenCalled();\r\n 147:     // 액션 목록 복귀\r\n 148:     expect(screen.getByText(\"내보내기\")).toBeTruthy();\r\n 149:   });\r\n 150: \r\n 151:   it(\"PATCH 실패 → 인라인 에러 + onActionDone 미호출\", async () => {\r\n 152:     (global.fetch as ReturnType<typeof vi.fn>).mockResolvedValue({\r\n 153:       ok: false,\r\n 154:       json: async () => ({ error: \"Cannot modify a member of equal or higher role\" }),\r\n 155:     });\r\n 156:     const { onActionDone } = renderMenu();\r\n 157:     fireEvent.click(screen.getByLabelText(\"Staff Kim 관리\"));\r\n 158:     fireEvent.click(screen.getByText(\"채팅 음소거\"));\r\n 159: \r\n 160:     await screen.findByText(\"Cannot modify a member of equal or higher role\");\r\n 161:     expect(onActionDone).not.toHaveBeenCalled();\r\n 162:   });\r\n 163: });\r\n","exit_code":0,"status":"completed"}}
