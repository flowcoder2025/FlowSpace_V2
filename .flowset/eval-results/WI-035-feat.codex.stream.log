PATCH 정형화가 onRefresh GET로\r\n  35:     // 무력화되지 않도록 동일 리소스의 GET도 정형화한다 (소비처: member-table·media-management).\r\n  36:     // userId는 media-management가 스포트라이트 대상 선택에 사용(이미 user.id로 노출됨).\r\n  37:     const members = await prisma.spaceMember.findMany({\r\n  38:       where: { spaceId },\r\n  39:       select: {\r\n  40:         id: true,\r\n  41:         role: true,\r\n  42:         restriction: true,\r\n  43:         displayName: true,\r\n  44:         userId: true,\r\n  45:         createdAt: true,\r\n  46:         user: { select: { id: true, name: true, email: true, image: true } },\r\n  47:         guestSession: { select: { id: true, nickname: true } },\r\n  48:       },\r\n  49:       orderBy: { createdAt: \"asc\" },\r\n  50:     });\r\n  51: \r\n  52:     return NextResponse.json({ members });\r\n  53:   } catch (error) {\r\n  54:     return internalErrorResponse(\"GET /api/spaces/[id]/admin/members\", error, \"Failed to fetch members\");\r\n  55:   }\r\n  56: }\r\n  57: \r\n  58: export async function PATCH(request: Request, { params }: RouteParams) {\r\n  59:   try {\r\n  60:     const session = await auth();\r\n  61:     if (!session?.user?.id) {\r\n  62:       return NextResponse.json({ error: \"Unauthorized\" }, { status: 401 });\r\n  63:     }\r\n  64: \r\n  65:     const { id: spaceId } = await params;\r\n  66:     const isSuperAdmin = session.user.isSuperAdmin === true;\r\n  67: \r\n  68:     const self = await prisma.spaceMember.findUnique({\r\n  69:       where: { spaceId_userId: { spaceId, userId: session.user.id } },\r\n  70:       select: { role: true },\r\n  71:     });\r\n  72:     if (!self && !isSuperAdmin) {\r\n  73:       return NextResponse.json({ error: \"Forbidden\" }, { status: 403 });\r\n  74:     }\r\n  75:     if (self && self.role !== \"OWNER\" && self.role !== \"STAFF\" && !isSuperAdmin) {\r\n  76:       return NextResponse.json({ error: \"Forbidden\" }, { status: 403 });\r\n  77:     }\r\n  78:     const actorRole = (self?.role ?? \"