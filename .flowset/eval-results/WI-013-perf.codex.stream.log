rverParticipantId) {\r\n      if (IS_DEV) {\r\n        serverParticipantId = `dev-anon-${Date.now()}`;\r\n      } else {\r\n        return NextResponse.json(\r\n          { error: \"Authentication required\" },\r\n          { status: 401 }\r\n        );\r\n","exit_code":0,"status":"completed"}}
