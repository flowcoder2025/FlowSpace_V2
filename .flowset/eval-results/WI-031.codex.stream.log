 <span\r\n  43:                   className={`inline-block px-2 py-0.5 rounded text-xs font-medium ${\r\n  44:                     EVENT_COLORS[log.eventType] || \"bg-cream-deep text-ink-muted\"\r\n  45:                   }`}\r\n  46:                 >\r\n  47:                   {log.eventType}\r\n  48:                 </span>\r\n  49:               </td>\r\n  50:               <td className=\"py-2 text-ink-soft\">\r\n  51:                 {log.user?.name || log.user?.email || \"-\"}\r\n  52:               </td>\r\n  53:               <td className=\"py-2 text-ink-muted text-xs max-w-xs truncate\">\r\n  54:                 {log.payload ? JSON.stringify(log.payload) : \"-\"}\r\n  55:               </td>\r\n  56:               <td className=\"py-2 text-ink-light text-xs text-right whitespace-nowrap\">\r\n  57:                 {new Date(log.createdAt).toLocaleString(\"ko-KR\")}\r\n  58:               </td>\r\n  59:             </tr>\r\n  60:           ))}\r\n  61:         </tbody>\r\n  62:       </table>\r\n  63: \r\n  64:       {hasMore && (\r\n  65:         <div className=\"mt-4 text-center\">\r\n  66:           <button\r\n  67:             onClick={onLoadMore}\r\n  68:             disabled={isLoading}\r\n  69:             className=\"px-4 py-2 text-sm text-ink hover:text-brand-deep disabled:opacity-50\"\r\n  70:           >\r\n  71:             {isLoading ? \"Loading...\" : \"Load more\"}\r\n  72:           </button>\r\n  73:         </div>\r\n  74:       )}\r\n  75:     </div>\r\n  76:   );\r\n  77: }\r\n","exit_code":0,"status":"completed"}}
