;\r\n  79: \r\n  80:     const body = await request.json();\r\n  81:     const { memberId, action, role } = body as {\r\n  82:       memberId: string;\r\n  83:       action: \"changeRole\" | \"mute\" | \"unmute\" | \"kick\" | \"ban\";\r\n  84:       role?: SpaceRole;\r\n  85:     };\r\n  86: \r\n  87:     if (!memberId || !action) {\r\n  88:       return NextResponse.json({ error: \"memberId and action are required\" }, { status: 400 });\r\n  89:     }\r\n  90: \r\n  91:     const target = await prisma.spaceMember.findUnique({\r\n  92:       where: { id: memberId },\r\n  93:       include: { user: { select: { name: true } } },\r\n  94:     });\r\n  95:     if (!target || target.spaceId !== spaceId) {\r\n  96:       return NextResponse.json({ error: \"Member not found\" }, { status: 404 });\r\n  97:     }\r\n  98: \r\n  99:     // OWNER는 변경 불가\r\n 100:     if (target.role === \"OWNER\" && !isSuperAdmin) {\r\n 101:       return NextResponse.json({ error: \"Cannot modify the space owner\" }, { status: 403 });\r\n 102:     }\r\n 103: \r\n 104:     // 역할 계층: 호출자 역할이 대상보다 상위일 때만 제재/변경 가능\r\n 105:     // (STAFF가 동급 STAFF를 ban/kick/mute 하는 것을 차단)\r\n 106:     if (!canActOn(actorRole, target.role, isSuperAdmin)) {\r\n 107:       return NextResponse.json(\r\n 108:         { error: \"Cannot modify a member of equal or higher role\" },\r\n 109:         { status: 403 }\r\n 110:       );\r\n 111:     }\r\n 112: \r\n 113:     let updatedRestriction: ChatRestriction | undefined;\r\n 114:     let updatedRole: SpaceRole | undefined;\r\n 115:     const actionLabel = action;\r\n 116:     const actorName = session.user.name ?? undefined;\r\n 117: \r\n 118:     switch (action) {\r\n 119:       case \"changeRole\": {\r\n 120:         if (!role) {\r\n 121:           return NextResponse.json({ error: \"role is required for changeRole\" }, { status: 400 });\r\n 122:         }\r\n 123:         // enum allowlist (임의 값 주입 차단)\r\n 124:         if (!isSpaceRole(role)) {\r\n 125:           return NextResponse.json({ error: \"Invalid role\" }, { status: 400 });\r\n 126:         }\r\n 127:         // OWNER 역할은 superAdmin만 부여 가능\r\n 128:         if (role === \"OWNER\" && !isSuperAdmin) {\r\n 129:           return NextResponse.json({ error: \"Only superAdmin can assign OWNER role\" }, { status: 403 });\r\n 130:         }\r\n 131:         // 부여하려는 역할도 호출자보다 하위여야 함 (STAFF→STAFF/OWNER 차단)\r\n 132:         if (!canActOn(actorRole, role, isSuperAdmin)) {\r\n 133:           return NextResponse.json(\r\n 134:             { error: \"Cannot assign a role equal to or higher than your own\" },\r\n 135:             { status: 403 }\r\n 136:           );\r\n 137:         }\r\n 138:         updatedRole = role;\r\n 139:         break;\r\n 140:       }\r\n 141:       case \"mute\":\r\n 142:         updatedRestriction = \"MUTED\";\r\n 143:         break;\r\n 144:       case \"unmute\":\r\n 145:         updatedRestriction = \"NONE\";\r\n 146:         break;\r\n 147:       case \"ban\":\r\n 148:         updatedRestriction = \"BANNED\";\r\n 149:         break;\r\n 150:       case \"kick\": {\r\n 151:         // kick은 멤버 삭제\r\n 152:         await prisma.spaceMember.delete({ where: { id: memberId } });\r\n 153:         await prisma.spaceEventLog.create({\r\n 154:           data: {\r\n 155:             spaceId,\r\n 156:             userId: session.user.id,\r\n 157:             eventType: \"ADMIN_ACTION\",\r\n 158:             payload: { action: \"kick\", targetName: target.user?.name || target.displayName },\r\n 159:           },\r\n 160:         });\r\n 161:         // 살아있는 소켓 실시간 추방 (DB 삭제 후 best-effort)\r\n 162:         let realtimeEnforced = false;\r\n 163:         if (target.userId) {\r\n 164:           const r = await dispatchEnforcement({\r\n 165:             spaceId,\r\n 166:             userId: target.userId,\r\n 167:             action: \"kick\",\r\n 168:             actorName,\r\n 169:           });\r\n 170:           realtimeEnforced = r.enforced;\r\n 171:         }\r\n 172:         return NextResponse.json({ message: \"Member kicked\", realtimeEnforced });\r\n 173:       }\r\n 174:       default:\r\n 175:         return NextResponse.json({ error: \"Invalid action\" }, { status: 400 });\r\n 176:     }\r\n 177: \r\n 178:     const updateData: Record<string, unknown> = {};\r\n 179:     if (updatedRole) updateData.role = updatedRole;\r\n 180:     if (updatedRestriction !== undefined) {\r\n 181:       updateData.restriction = updatedRestriction;\r\n 182:       updateData.restrictedBy = session.user.id;\r\n 183:     }\r\n 184: \r\n 185:     // 응답 allowlist ? restrictedBy 등 관리 메타·식별자 미반환(member-table는 본문 미사용).\r\n 186:     const updated = await prisma.spaceMember.update({\r\n 187:       where: { id: memberId },\r\n 188:       data: updateData,\r\n 189:       select: { id: true, role: true, restriction: true },\r\n 190:     });\r\n 191: \r\n 192:     // 이벤트 로그 기록\r\n 193:     await prisma.spaceEventLog.create({\r\n 194:       data: {\r\n 195:         spaceId,\r\n 196:         userId: session.user.id,\r\n 197:         eventType: \"ADMIN_ACTION\",\r\n 198:         payload: {\r\n 199:           action: actionLabel,\r\n 200:           targetMemberId: memberId,\r\n 201:           targetName: target.user?.name || target.displayName,\r\n 202:         },\r\n 203:       },\r\n 204:     });\r\n 205: \r\n 206:     // 살아있는 소켓에 실시간 반영 (ban/mute/unmute/changeRole). DB 갱신 후 best-effort.\r\n 207:     // changeRole 강등은 권한 회수이므로(인메모리 role 캐시 갱신) 보안상 실시간 반영 필요.\r\n 208:     let realtimeEnforced = false;\r\n 209:     if (target.userId) {\r\n 210:       const enforceAction: EnforceAction = actionLabel === \"changeRole\" ? \"role\" : actionLabel;\r\n 211:       const r = await dispatchEnforcement({\r\n 212:         spaceId,\r\n 213:         userId: target.userId,\r\n 214:         action: enforceAction,\r\n 215:         role: actionLabel === \"changeRole\" ? updatedRole : undefined,\r\n 216:         actorName,\r\n 217:       });\r\n 218:       realtimeEnforced = r.enforced;\r\n 219:     }\r\n 220: \r\n 221:     return NextResponse.json({ member: updated, realtimeEnforced });\r\n 222:   } catch (error) {\r\n 223:     return internalErrorResponse(\"PATCH /api/spaces/[id]/admin/members\", error, \"Failed to update member\");\r\n 224:   }\r\n 225: }\r\n","exit_code":0,"status":"completed"}}
