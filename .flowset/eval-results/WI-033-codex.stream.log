Š”??\n\n/**\n * ë©¤ë²„ ëª©ë¡??CSVë¡?ì§ë ¬?”í•œ?? ?´ë¦„?€ MemberTable/filterMembers?€ **?™ì¼???œì‹œ\n * ?°ì„ ?œìœ„**(truthy `||` ì²´ì¸)ë¡??´ì„?œë‹¤ ??`??`(nullish)ë¥??°ë©´ ë¹?ë¬¸ìž???´ë¦„?? * ?´ë°±?˜ì? ?Šì•„ ?”ë©´ê³?CSVê°€ ?´ê¸‹?œë‹¤(codex ?ì¶œ). ìµœì¢… ?´ë°±?€ ?”ë©´ ?œê¸°?€ ?™ì¼?˜ê²Œ\n * `DASHBOARD_COPY.CSV.unknown`(\"?????†ìŒ\"). role/restriction?€ ?”ë©´ê³??™ì¼ ?¼ë²¨ë¡??œì‹œ.\n */\nexport function membersToCsv(members: ReadonlyArray<Member>): string {\n  const rows = members.map((m) => [\n    m.user?.name || m.guestSession?.nickname || m.displayName || DASHBOARD_COPY.CSV.unknown,\n    m.user?.email ?? \"\",\n    DASHBOARD_COPY.roleLabel(m.role),\n    DASHBOARD_COPY.restrictionLabel(m.restriction),\n    m.guestSession ? DASHBOARD_COPY.CSV.guestYes : DASHBOARD_COPY.CSV.guestNo,\n    m.createdAt,\n  ]);\n  return toCsv(DASHBOARD_COPY.CSV.memberHeaders, rows);\n}\n\n/** ë¡œë“œ???´ë²¤??ë¡œê·¸ë¥?CSVë¡?ì§ë ¬?”í•œ???”ë©´ ?•ë ¬ ?œì„œ ? ì?). eventType?€ ?”ë©´ê³??™ì¼ ?¼ë²¨. */\nexport function logsToCsv(logs: ReadonlyArray<LogExportEntry>): string {\n  const rows = logs.map((log) => [\n    log.createdAt,\n    DASHBOARD_COPY.eventTypeLabel(log.eventType),\n    log.user?.name || log.user?.email || \"\",\n    stringifyPayload(log.payload),\n  ]);\n  return toCsv(DASHBOARD_COPY.CSV.logHeaders, rows);\n}\n\nfunction stringifyPayload(payload?: PublicSpaceEventPayload): string {\n  if (payload == null) return \"\";\n  try {\n    return JSON.stringify(payload);\n  } catch {\n    return DASHBOARD_COPY.CSV.unserializable;\n  }\n}\n\n/**\n * ?¼ë³„ ë©”ì‹œì§€/ë°©ë¬¸?????œê³„?´ì„ ? ì§œ union?¼ë¡œ ë¨¸ì???CSVë¡?ì§ë ¬?”í•œ??\n * ?œìª½?ë§Œ ?ˆëŠ” ? ì§œ??ê²°ì¸¡ ê°’ì? 0, ? ì§œ???¤ë¦„ì°¨ìˆœ(YYYY-MM-DD ?¬ì „???œê°„??.\n */\nexport function analyticsToCsv(data: AnalyticsExportData): string {\n  const messagesByDate = new Map(\n    data.dailyMessages.map((d) => [d.date, d.count])\n  );\n  const visitorsByDate = new Map(\n    data.dailyVisitors.map((d) => [d.date, d.count])\n  );\n  const dates = [\n    ...new Set([...messagesByDate.keys(), ...visitorsByDate.keys()]),\n  ].sort();\n  const rows = dates.map((date) => [\n    date,\n    String(messagesByDate.get(date) ?? 0),\n    String(visitorsByDate.get(date) ?? 0),\n  ]);\n  return toCsv(DASHBOARD_COPY.CSV.analyticsHeaders, rows);\n}\n\n/** `flowspace-<kind>-<spaceId>-<YYYY-MM-DD>.csv` ?¤ìš´ë¡œë“œ ?Œì¼ëª…ì„ ë§Œë“ ?? */\nexport function csvFilename(kind: string, spaceId: string, date: Date): string {\n  const ymd = date.toISOString().slice(0, 10);\n  return `flowspace-${kind}-${spaceId}-${ymd}.csv`;\n}\n\n/**\n * CSV ë¬¸ìž?´ì„ BOMê³??¨ê»˜ ?¤ìš´ë¡œë“œ?œë‹¤(ë¸Œë¼?°ì? ?„ìš©). useScreenRecorder???µì»¤ ?´ë¦­\n * ?¨í„´ê³??™ì¼ ??createObjectURL ??a[download] ??click ??revoke.\n */\nexport function downloadCsv(filename: string, csv: string): void {\n  const blob = new Blob([CSV_BOM + csv], { type: \"text/csv;charset=utf-8\" });\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement(\"a\");\n  a.href = url;\n  a.download = filename;\n  document.body.appendChild(a);\n  try {\n    a.click();\n  } finally {\n    // click/?œê±°ê°€ ?˜ì ¸???µì»¤ ë¶„ë¦¬ + objectURL ?´ì œë¥?ë³´ìž¥(?„ìˆ˜ ë°©ì?).\n    a.remove();\n    URL.revokeObjectURL(url);\n  }\n}\n\r\n","exit_code":0,"status":"completed"}}
