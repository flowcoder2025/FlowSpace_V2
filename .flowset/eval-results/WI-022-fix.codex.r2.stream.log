p\\api\\assets\\route.ts:43:    // мһ…л Ҙ кІҖмҰқ(WI-022): type/statusлҘј AssetType/AssetStatus allowlistлЎң кІҖмҰқ.\nsrc\\app\\api\\assets\\route.ts:58:    const page = parsePageNumber(searchParams.get(\"page\"));\nsrc\\app\\api\\assets\\route.ts:59:    const limit = parsePageLimit(searchParams.get(\"limit\"), ASSETS_DEFAULT_LIMIT);\nsrc\\app\\api\\assets\\batch\\route.ts:16:/** POST /api/assets/batch - л°°м№ҳ м—җм…Ӣ мғқм„ұ */\nsrc\\app\\api\\assets\\batch\\route.ts:119:/** GET /api/assets/batch?batchId=xxx - л°°м№ҳ мғҒнғң мЎ°нҡҢ */\nsrc\\app\\api\\assets\\generate\\route.ts:14:/** POST /api/assets/generate - м—җм…Ӣ мғқм„ұ мһ‘м—… мӢңмһ‘ */\nsrc\\app\\api\\assets\\[id]\\route.test.ts:65:describe(\"GET /api/assets/[id] вҖ” мқёмҰқ/мқёк°Җ к°Җл“ң\", () => {\nsrc\\app\\api\\assets\\[id]\\route.test.ts:105:describe(\"GET /api/assets/[id] вҖ” мқ‘лӢө allowlist\", () => {\nsrc\\app\\api\\assets\\[id]\\route.test.ts:180:describe(\"GET /api/assets/[id] вҖ” м—җлҹ¬ мІҳлҰ¬\", () => {\nsrc\\app\\api\\assets\\[id]\\route.ts:11:/** GET /api/assets/[id] - м—җм…Ӣ мғҒм„ё + мғҒнғң */\nsrc\\app\\api\\assets\\[id]\\route.ts:66:/** DELETE /api/assets/[id] - м—җм…Ӣ мӮӯм ң */\nsrc\\app\\api\\spaces\\route.ts:5:import { buildCursorPage, parsePageLimit } from \"@/lib/pagination\";\nsrc\\app\\api\\spaces\\route.ts:42:    const limit = parsePageLimit(request.nextUrl.searchParams.get(\"limit\"));\nsrc\\app\\api\\spaces\\[id]\\messages\\route.ts:4:import { buildCursorPage, parsePageLimit } from \"@/lib/pagination\";\nsrc\\app\\api\\spaces\\[id]\\messages\\route.ts:34:    const limit = parsePageLimit(searchParams.get(\"limit\"));\nsrc\\app\\api\\spaces\\[id]\\messages\\route.test.ts:55:    expect(args.take).toBe(51); // parsePageLimit кё°ліё 50 + 1\nsrc\\app\\api\\spaces\\[id]\\admin\\messages\\route.test.ts:55:    expect(args.take).toBe(51); // parsePageLimit кё°ліё 50 + 1\nsrc\\app\\api\\spaces\\[id]\\admin\\messages\\route.ts:4:import { buildCursorPage, parsePageLimit } from \"@/lib/pagination\";