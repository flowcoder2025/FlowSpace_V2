{"type":"item.completed","item":{"id":"item_20","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'Get-Content -Path src/__tests__/helpers/api-route.ts'","aggregated_output":"/**\r\n * API ?жЈҖжҜҺ???еІҮе§ў???ж©ӮеӘ№?????ж»Ңеһ¬ зүҚеІҶеҙқ (WI-011)\r\n *\r\n * Next.js Route Handler(GET/POST ??жҜі?vitest?ж„іеҠҖ жӯҶдҫ…зҲІ ?иғізЁ–?ж©Ғиөҙ ?еӢҙжҡ… з“ҝеҘ жҜ„ ?зҠҝе«ә.\r\n * ???еІҮжҫ•?вӮ¬ mock wiring???ж©ғ? ?е©Ҳзўғ ?ж—Қз®” ?жҝҺеҠҡ и·Ҝ ?иғіеҺҙ/??fixture и·Ҝ ?жҲЁе«· ?еІҮе«іжҜө??ж»үиҪҰ?ж»Ҡе«ҹ.\r\n * (auth()/prisma з”‘ж„іжіҠ??vitest??vi.hoisted + vi.mock ?иғіжҫҠ?гӮҚеҜҳ???еІҮжҫ• жҗҝж»Ңж»‘?жҺӘжҫ•\r\n *  иҮ§??жЈҖжҜҺ???еІҮе§ў???еІҮжҫ• ?дҫӮе«§?ж„іеҠҖ жӯҶдҫ…зҲІ ?зҠҫжҹӣ?жҢ«жҡӯ ?ж»Ҡе«ҹ ??ж¬·жҲ©жҡҖ??ж”өе Ұ?.)\r\n *\r\n * ?еІҮе§ў???еІҮжҫ• ?еӢІОң?еҚҠз¬– ?оҹҗеҠҘ (?жЈҖжҜҺ??import ?еӢіжЈҺ ?зҠҫжҹӣ):\r\n *   const { mockAuth, mockPrisma } = vi.hoisted(() => ({\r\n *     mockAuth: vi.fn(),\r\n *     mockPrisma: { space: { findMany: vi.fn() } },\r\n *   }));\r\n *   vi.mock(\"@/lib/auth\", () => ({ auth: mockAuth }));\r\n *   vi.mock(\"@/lib/prisma\", () => ({ prisma: mockPrisma }));\r\n */\r\nimport { NextRequest } from \"next/server\";\r\n\r\nconst TEST_ORIGIN = \"http://localhost\";\r\n\r\nexport interface MockSessionUser {\r\n  id: string;\r\n  isSuperAdmin?: boolean;\r\n  name?: string | null;\r\n  email?: string | null;\r\n}\r\n\r\nexport type MockSession = { user: MockSessionUser } | null;\r\n\r\n/** auth()иҮ§вӮ¬ ж°ҡж©…ж«Ӯ???иғіеҺҙ иҮ§жҝҺжіҠ(?ж„Іе§… ж°ҷиғіжҫ‘жӯғ?null)жҜі?жҜөеІҶж‘–?? */\r\nexport function makeSession(user: MockSessionUser | null): MockSession {\r\n  return user ? { user } : null;\r\n}\r\n\r\n/** зӮңиҢ§Оң ?еІҶжҫ•ж°ҷз–ҷеҠҷжҜі?ж”өж¬–жҫ‘ GET??NextRequestжҜі?жҜөеІҶж‘–?? */\r\nexport function buildGetRequest(\r\n  path: string,\r\n  params?: Record<string, string>\r\n): NextRequest {\r\n  const url = new URL(path, TEST_ORIGIN);\r\n  if (params) {\r\n    for (const [key, value] of Object.entries(params)) {\r\n      url.searchParams.set(key, value);\r\n    }\r\n  }\r\n  return new NextRequest(url);\r\n}\r\n\r\n/** JSON bodyиҮ§вӮ¬ ?е §е§… ?ж—Қз®”(POST/PATCH ????NextRequestжҜі?жҜөеІҶж‘–?? */\r\nexport function buildJsonRequest(\r\n  path: string,\r\n  method: string,\r\n  body: unknown\r\n): NextRequest {\r\n  return new NextRequest(new URL(path, TEST_ORIGIN), {\r\n    method,\r\n    headers: { \"content-type\": \"application/json\" },\r\n    body: JSON.stringify(body),\r\n  });\r\n}\r\n\r\n/** makeSpaceRow ?гӮӢзҹӮ?жЈҖжҫҠ??(?ж„іпјң ж°ҡж—үйқ–???еӢІж‘җжҜө??иғізЁ–) */\r\nexport interface SpaceRowOverrides {\r\n  id?: string;\r\n  name?: string;\r\n  /** ?иғізЁ–??ж°Өиғіжҫ‘ ж°…гӮӢзҹӮ????жҡҠ. null?жҺӘв”җ зүҚеӢІв”Җж°©?members: []) */\r\n  role?: string | null;\r\n  memberCount?: number;\r\n  status?: string;\r\n}\r\n\r\n/**\r\n * prisma.space.findManyиҮ§вӮ¬ ж°ҡж©…ж«Ӯ?ж©Ӯе§… ???жӣ§е„Ё??fixture.\r\n * route??include({ template, _count, members })жҜі?ж°ҡж©ғжҰҝ?ж©Ӯв”Ң,\r\n * ?жҲЁе«· allowlist ?еІ…?жҜі??еӢҙжҡЈ \"?жҲЁе«·???иғізЁ–?ж©Ӯв”җ ???ж©Ӯе§…\" ж°ҷзј„зҡӯ/?жҺӘ? ?еӢІж‘җ\r\n * (inviteCode/accessSecret/ownerId)???ж©Ӯеј°?дҫ…жәӮжҗҝ??о„Ҳжҡ”?ж»Ҡе«ҹ.\r\n */\r\nexport function makeSpaceRow(overrides: SpaceRowOverrides = {}) {\r\n  const {\r\n    id = \"space-1\",\r\n    name = \"?еІҮе§ў??з“ҝеә—зҡ \",\r\n    role = \"MEMBER\",\r\n    memberCount = 3,\r\n    status = \"ACTIVE\",\r\n  } = overrides;\r\n\r\n  return {\r\n    id,\r\n    name,\r\n    description: \"?гӮӢзҚҸ\",\r\n    accessType: \"PUBLIC\",\r\n    maxUsers: 50,\r\n    logoUrl: null,\r\n    primaryColor: \"#000000\",\r\n    createdAt: \"2026-01-01T00:00:00.000Z\",\r\n    updatedAt: \"2026-01-02T00:00:00.000Z\",\r\n    status,\r\n    templateId: \"tpl-1\",\r\n    // ?жҲЁе«· allowlist?ж„іеҠҖ ?ж»Ңж«ў?ж©ғжҹҺ???ж©Ӯе§… ж°ҷзј„зҡӯ/?жҺӘ? ?еӢІж‘җ (?еІ…? иҮ§вӮ¬??\r\n    ownerId: \"owner-1\",\r\n    inviteCode: \"SECRET-INVITE\",\r\n    accessSecret: \"hashed-secret\",\r\n    template: { key: \"OFFICE\", name: \"?гӮҚж•ҝ?? },\r\n    _count: { members: memberCount },\r\n    members: role === null ? [] : [{ role }],\r\n  };\r\n}\r\n\r\n/** Response??JSON bodyжҜі??вӮ¬?е‘№иҮЈ ?оҹҚзІҜ ?иҜ«е§…?? */\r\nexport async function readJson<T = unknown>(res: Response): Promise<T> {\r\n  return (await res.json()) as T;\r\n}\r\n","exit_code":0,"status":"completed"}}
