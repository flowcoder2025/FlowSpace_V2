ธ?หรฌ?\r\n * ?ล รซล โ??`disabled`/`[hidden]`รซยง??ลรฌโขยธ). ???ลรซยนโ รซยชยจรซโนยฌ??รชยทยธรซลธยฐ ?โรฌโ ลรชยฐโฌ ?โ รซโนยค.\r\n */\r\n\r\nimport { useCallback, useEffect, useRef, type ReactNode } from \"react\";\r\n\r\ninterface DialogProps {\r\n  open: boolean;\r\n  onClose: () => void;\r\n  /** aria-labelledby ?โฌ??id(?ลรซยชยฉ ?โรฌโ ล???โขรฌยยผ id รซยถโฌ??. useIdรซยก??ยรฌโยฑ??รฌยฃยผรฌลพโฆ รชยถลรฌลพยฅ. */\r\n  labelledById?: string;\r\n  /** ESCรซยก?onClose ?ยธรฌยถล(รชยธยฐรซยณยธ true). */\r\n  closeOnEscape?: boolean;\r\n  /** รซยฐยฑรซโลรซยก??ยดรซยฆยญ?ยผรซยกล onClose ?ยธรฌยถล(รชยธยฐรซยณยธ true). */\r\n  closeOnBackdrop?: boolean;\r\n  /** รซยฐยฑรซโลรซยก??ยครซยฒโ?หรฌยยด) className ???โรฌยนห/รซยฐยฐรชยฒยฝ/z-index. */\r\n  backdropClassName?: string;\r\n  /** ?ยครฌยยด?ยผรซยกลรชยท??ยจรซโย className. */\r\n  className?: string;\r\n  children: ReactNode;\r\n}\r\n\r\nconst DEFAULT_BACKDROP =\r\n  \"fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4\";\r\n\r\nconst FOCUSABLE_SELECTOR =\r\n  'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex=\"-1\"])';\r\n\r\n/** ?ยจรซโย ??focusable ?โรฌโ ล(?ลรฌโล?โฌรซยก?. disabled/[hidden]?โฌ ?ลรฌโขยธ. */\r\nfunction getFocusable(panel: HTMLElement): HTMLElement[] {\r\n  return Array.from(\r\n    panel.querySelectorAll<HTMLElement>(FOCUSABLE_SELECTOR)\r\n  ).filter((el) => !el.hasAttribute(\"hidden\") && el.getAttribute(\"aria-hidden\") !== \"true\");\r\n}\r\n\r\nexport function Dialog({\r\n  open,\r\n  onClose,\r\n  labelledById,\r\n  closeOnEscape = true,\r\n  closeOnBackdrop = true,\r\n  backdropClassName = DEFAULT_BACKDROP,\r\n  className,\r\n  children,\r\n}: DialogProps) {\r\n  const panelRef = useRef<HTMLDivElement>(null);\r\n  const openerRef = useRef<HTMLElement | null>(null);\r\n\r\n  // ?ยดรซยฆยด ??opener ?โฌ??+ รฌยดหรชยธยฐ ?ยฌรฌยปยค?? ?ยซรญลพย ??opener รซยณยตรฌโบย.\r\n  useEffect(() => {\r\n    if (!open) return;\r\n    openerRef.current = (document.activeElement as HTMLElement | null) ?? null;\r\n    const panel = panelRef.current;\r\n    if (panel) {\r\n      const focusables = getFocusable(panel);\r\n      (focusables[0] ?? panel).focus();\r\n    }\r\n    return () => {\r\n      openerRef.current?.focus?.();\r\n    };\r\n  }, [open]);\r\n\r\n  // ESC + Tab focus-trap (capture ?ยจรชยณโ ???ยดรซ? ?ยธรซโยค?ยฌรซยณยด??รซยจยผรฌ? รชยฐโฌรซยกลรฌยฑโรชยธ?.\r\n  useEffect(() => {\r\n    if (!open) return;\r\n    const onKeyDown = (e: KeyboardEvent) => {\r\n      if (e.key === \"Escape\") {\r\n        if (closeOnEscape) {\r\n          e.stopPropagation();\r\n          onClose();\r\n        }\r\n        return;\r\n      }\r\n      if (e.key !== \"Tab\") return;\r\n      const panel = panelRef.current;\r\n      if (!panel) return;\r\n      const focusables = getFocusable(panel);\r\n      if (focusables.length === 0) {\r\n        // focusable??0รชยฐ??? ?โรซ? disabled)รซยฉ??ยฌรฌยปยค?ยครซ? ?ยจรซโย??รซยฌยถรฌโยด รซยฐโรฌลยผรซยก?รซยช??หรช?รชยฒ??ลรซโนยค.\r\n        e.preventDefault();\r\n        panel.focus();\r\n        return;\r\n      }\r\n      const first = focusables[0];\r\n      const last = focusables[focusables.length - 1];\r\n      const active = document.activeElement;\r\n      if (e.shiftKey) {\r\n        if (active === first || !panel.contains(active)) {\r\n          e.preventDefault();\r\n          last.focus();\r\n        }\r\n      } else {\r\n        if (active === last || !panel.contains(active)) {\r\n          e.preventDefault();\r\n          first.focus();\r\n        }\r\n      }\r\n    };\r\n    document.addEventListener(\"keydown\", onKeyDown, true);\r\n    return () => document.removeEventListener(\"keydown\", onKeyDown, true);\r\n  }, [open, closeOnEscape, onClose]);\r\n\r\n  const handleBackdropClick = useCallback(() => {\r\n    if (closeOnBackdrop) onClose();\r\n  }, [closeOnBackdrop, onClose]);\r\n\r\n  if (!open) return null;\r\n\r\n  return (\r\n    <div className={backdropClassName} onClick={handleBackdropClick}>\r\n      <div\r\n        ref={panelRef}\r\n        role=\"dialog\"\r\n        aria-modal=\"true\"\r\n        aria-labelledby={labelledById}\r\n        tabIndex={-1}\r\n        className={className}\r\n        onClick={(e) => e.stopPropagation()}\r\n      >\r\n        {children}\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\"use client\";\r\n\r\n/**\r\n * DeleteSpaceSection ???ยครฌย โข ?โรซยฉยด??\"?โรญโห รชยตยฌรฌโยญ\" ?ยครญลฝห?ยดรฌล ยค ??ย ล UI (WI-037).\r\n *\r\n * ?ยดรซยฆโ ?โฌ?ยดรญโขโ ?โขรฌยยธ รซยชยจรซโนยฌ ??`DELETE /api/spaces/[id]`(soft delete=ARCHIVED, WI-036) ?? * ?ยฑรชยณยต ??`/my-spaces`รซยก??ยดรซยโข(รซยชยฉรซยกย?โฌ status=ACTIVEรซยง?รซยฐหรญโขห?หรซ?รซยก?archived???ยรฌโยฐ ?ลรฌโขยธ).\r\n *\r\n * ?ย รฏยธย รชยถลรญโขล: ??รฌยปยดรญยยฌ?ลรญล ยธ??OWNER/superAdmin?ยรชยฒลรซยง??ลรซยโ?ลรซโนยค(?ยครฌย โข ?หรฌยยดรฌยงโฌ?ยรฌโล canDelete รชยฒลรฌยยด??.\r\n * ?ลรซยฒโ DELETE รชยฒลรฌยยด??`space.ownerId === userId || isSuperAdmin`)รชยฐโฌ hard gate?ยดรชยณย ,\r\n * ?ยดรซยยผ รชยฒลรฌยยด???ยดรซยฆโ ?โขรฌยยธ?โฌ best-effort UX??STAFF???ยครฌย โข ?หรฌยยดรฌยงโฌ??รฌยงโรฌลพโฆ?ยดรซยโ รซยฏยธรซย ล??.\r\n */\r\nimport { useCallback, useState } from \"react\";\r\nimport { useRouter } from \"next/navigation\";\r\nimport { DASHBOARD_COPY } from \"@/constants/dashboard-copy\";\r\nimport { Dialog } from \"@/components/common/dialog\";\r\n\r\ninterface DeleteSpaceSectionProps {\r\n  spaceId: string;\r\n  spaceName: string;\r\n}\r\n\r\nconst COPY = DASHBOARD_COPY.SETTINGS.dangerZone;\r\n\r\nexport function DeleteSpaceSection({ spaceId, spaceName }: DeleteSpaceSectionProps) {\r\n  const router = useRouter();\r\n  const [isOpen, setIsOpen] = useState(false);\r\n  const [confirmInput, setConfirmInput] = useState(\"\");\r\n  const [isDeleting, setIsDeleting] = useState(false);\r\n  const [error, setError] = useState<string | null>(null);\r\n\r\n  // ?โฆรซย ยฅรชยฐโรฌยยด ?ยครญลฝห?ยดรฌล ยค ?ยดรซยฆโรชยณ??โขรญโขโข???ยผรฌยนห???ลรซยงล ??ย ล ?ลรฌโยฑ(?หรซยลรซยฆ????โ รซล โ ?ยกรฌโฆห รชยฐโฌ??.\r\n  // spaceName.length > 0 รชยฐโฌ?? รซยน??ยดรซยฆโ ?ยครญลฝห?ยดรฌล ยค(PATCH??รซยน?รซยน??ยดรซยฆโ รซยฏยธรชยฐโข?????ยฐรฌยยด???ลรซยฆยฌ?โรญล ยธรซยก?  // รซยฐลรฌฦย รชยฐโฌ???ยรฌโล รซยน??โฆรซย ยฅ(\"\")??รฌยฆโฐรฌโนล ?ยผรฌยนห????ย ลรชยฐโฌ รซยฌยดรญ??ยดรญโขโ ?ลรฌโยฑ?หรซล โ รชยฒฦรฌยโ รฌยฐยจรซโนยจ?ลรซโนยค.\r\n  const canConfirm = spaceName.length > 0 && confirmInput === spaceName && !isDeleting;\r\n\r\n  const openModal = useCallback(() => {\r\n    setConfirmInput(\"\");\r\n    setError(null);\r\n    setIsOpen(true);\r\n  }, []);\r\n\r\n  const closeModal = useCallback(() => {\r\n    // ??ย ล รฌยงโรญโโฐ รฌยคโรฌโย???ยซรชยธยฐ/รฌยทยจรฌโ ล รฌยฐยจรซโนยจ(รฌยคโรซยโ ?ยดรญฦหรซยก??ยธรญโขล ?ยผรซยโขรยทรฌยคโรซยณยต?โรฌยฒยญ รซยฐยฉรฌ?).\r\n    if (isDeleting) return;\r\n    setIsOpen(false);\r\n    setConfirmInput(\"\");\r\n    setError(null);\r\n  }, [isDeleting]);\r\n\r\n  async function handleDelete() {\r\n    if (!canConfirm) return;\r\n    setIsDeleting(true);\r\n    setError(null);\r\n    try {\r\n      const res = await fetch(`/api/spaces/${spaceId}`, { method: \"DELETE\" });\r\n      if (!res.ok) {\r\n        const data = (await res.json().catch(() => ({}))) as { error?: string };\r\n        setError(data.error || COPY.deleteError);\r\n        setIsDeleting(false);\r\n        return;\r\n      }\r\n      // ?ยฑรชยณยต(?ยดรซ? archived??รซยฉยฑรซโยฑ 200 ?ยฌรญโขยจ) ??รซยชยฉรซยกย?ยผรซยกล ?ยดรซยโข.\r\n      // replaceรซยก???ย ล???ยครญลฝห?ยดรฌล ยค???ยครฌย โข ?หรฌยยดรฌยงโฌรซยฅ??ยครซยกลรชยฐโฌรชยธ??ยดรซย ยฅ?ยรฌโล ?ลรชยฑยฐ?ลรซโนยค.\r\n      // isDeleting??รซยฆยฌรฌโฆโน?หรฌ? ?ล รฌโขโ ?ยครซยนโรชยฒลรฌยยด???โขรฌโขห รซยฒโรญล ยผ???ย รชยธยด ?ยรญฦลรซยฅ??ย รฌ?(รฌยคโรซยณยต ?ลรฌยถล รซยฐยฉรฌ?).\r\n      router.replace(\"/my-spaces\");\r\n    } catch {\r\n      setError(COPY.deleteError);\r\n      setIsDeleting(false);\r\n    }\r\n  }\r\n\r\n  return (\r\n    <div className=\"max-w-2xl rounded-lg border border-red-200 bg-red-50/50 p-6\">\r\n      <h2 className=\"text-base font-semibold text-red-700\">{COPY.title}</h2>\r\n      <p className=\"mt-1 text-sm text-ink-soft\">{COPY.description}</p>\r\n      <button\r\n        type=\"button\"\r\n        onClick={openModal}\r\n        className=\"mt-4 rounded-md border border-red-300 bg-white px-4 py-2 text-sm font-medium text-red-700 transition-colors hover:bg-red-100\"\r\n      >\r\n        {COPY.deleteButton}\r\n      </button>\r\n\r\n      <Dialog\r\n        open={isOpen}\r\n        onClose={closeModal}\r\n        labelledById=\"delete-space-title\"\r\n        backdropClassName=\"fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4\"\r\n        className=\"w-full max-w-md rounded-lg bg-white p-6 shadow-xl\"\r\n      >\r\n        <h3 id=\"delete-space-title\" className=\"text-lg font-bold text-ink\">\r\n          {COPY.modalTitle}\r\n        </h3>\r\n        <p className=\"mt-2 text-sm leading-relaxed text-ink-soft\">{COPY.modalWarning}</p>\r\n        <p className=\"mt-4 text-sm text-ink-soft\">{COPY.confirmPrompt}</p>\r\n        <p className=\"mt-1 select-all break-all rounded bg-cream-deep px-3 py-2 font-mono text-sm text-ink\">\r\n          {spaceName}\r\n        </p>\r\n        <input\r\n          type=\"text\"\r\n          value={confirmInput}\r\n          onChange={(e) => setConfirmInput(e.target.value)}\r\n          placeholder={COPY.confirmPlaceholder}\r\n          autoFocus\r\n          disabled={isDeleting}\r\n          aria-label={COPY.confirmPlaceholder}\r\n          className=\"mt-3 w-full rounded-md border border-line px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-300 disabled:opacity-50\"\r\n        />\r\n        {error && <p className=\"mt-2 text-sm text-red-600\">{error}</p>}\r\n        <div className=\"mt-5 flex justify-end gap-2\">\r\n          <button\r\n            type=\"button\"\r\n            onClick={closeModal}\r\n            disabled={isDeleting}\r\n            className=\"rounded-md border border-line px-4 py-2 text-sm text-ink-soft transition-colors hover:bg-cream-deep disabled:opacity-50\"\r\n          >\r\n            {COPY.cancel}\r\n          </button>\r\n          <button\r\n            type=\"button\"\r\n            onClick={handleDelete}\r\n            disabled={!canConfirm}\r\n            className=\"rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-red-500 disabled:cursor-not-allowed disabled:opacity-50\"\r\n          >\r\n            {isDeleting ? COPY.deleting : COPY.confirm}\r\n          </button>\r\n        </div>\r\n      </Dialog>\r\n    </div>\r\n  );\r\n}\r\n\"use client\";\r\n\r\nimport { useState, useCallback, useRef, useEffect, useId } from \"react\";\r\nimport type { PartsAvatarConfig } from \"@/features/space/avatar\";\r\nimport { DEFAULT_PARTS_AVATAR, buildPartsAvatarString, parseAvatarString, CHIBI_CHARACTERS } from \"@/features/space/avatar\";\r\nimport { PLAYER_WIDTH, PLAYER_HEIGHT } from \"@/constants/game-constants\";\r\nimport { CharacterEditor } from \"@/components/avatar\";\r\nimport { Dialog } from \"@/components/common/dialog\";\r\n\r\ninterface AvatarEditorModalProps {\r\n  currentAvatar: string;\r\n  onSave: (avatarString: string) => void;\r\n  onClose: () => void;\r\n}\r\n\r\ntype AvatarTab = \"parts\" | \"ai\";\r\n\r\nexport function AvatarEditorModal({ currentAvatar, onSave, onClose }: AvatarEditorModalProps) {\r\n  // ?โรฌลพยฌ ?โรซยฐโ?โฌรชยฐโฌ parts ?โฌ?โฆรฌยยดรซยฉ??ลรฌโนยฑ, ?โรซโนหรซยฉ?รชยธยฐรซยณยธรชยฐ?  const parsed = parseAvatarString(currentAvatar);\r\n  const initialConfig: PartsAvatarConfig =\r\n    parsed.type === \"parts\" ? parsed : DEFAULT_PARTS_AVATAR;\r\n\r\n  const [tab, setTab] = useState<AvatarTab>(\r\n    parsed.type === \"chibi\" ? \"ai\" : \"parts\"\r\n  );\r\n  const [config, setConfig] = useState<PartsAvatarConfig>(initialConfig);\r\n  const [selectedChibiId, setSelectedChibiId] = useState<string | null>(\r\n    parsed.type === \"chibi\" ? parsed.characterId : null\r\n  );\r\n  const [saving, setSaving] = useState(false);\r\n  const titleId = useId();\r\n\r\n  const handleSave = useCallback(async () => {\r\n    setSaving(true);\r\n\r\n    let avatarString: string;\r\n    if (tab === \"ai\" && selectedChibiId) {\r\n      avatarString = `chibi:${selectedChibiId}`;\r\n    } else {\r\n      avatarString = buildPartsAvatarString(config);\r\n    }\r\n\r\n    try {\r\n      // DB ?โฌ??      const res = await fetch(\"/api/users/me\", {\r\n        method: \"PATCH\",\r\n        headers: { \"Content-Type\": \"application/json\" },\r\n        body: JSON.stringify({ avatarConfig: { avatarString } }),\r\n      });\r\n\r\n      if (res.ok) {\r\n        onSave(avatarString);\r\n        onClose();\r\n      }\r\n    } finally {\r\n      setSaving(false);\r\n    }\r\n  }, [tab, selectedChibiId, config, onSave, onClose]);\r\n\r\n  return (\r\n    /* WI-043: รชยณยตรฌลกยฉ Dialogรซยก??ยตรญโขยฉ ??focus-trap/focus-restore/aria + ESCรยทรซยฐยฑรซโลรซยก??ยซรชยธยฐ รฌยถโรช?.\r\n       (รชยธยฐรฌยกยด???ยซรชยธยฐ รซยฒโรญล ยผรซยง??หรฌโห?????ลรฌ? dialog ?ยซรชยธยฐ รชยฒยฝรซยกล[ESC/รซยฐยฑรซโลรซยก?รชยฐโฌ รฌยถโรช??หรซล โ ?หรซยโ???โขรฌลพโ รซยณโฌรชยฒ?) */\r\n    <Dialog\r\n      open\r\n      onClose={onClose}\r\n      labelledById={titleId}\r\n      backdropClassName=\"fixed inset-0 z-[100] flex items-center justify-center bg-black/60\"\r\n      className=\"mx-4 max-h-[90vh] w-full max-w-lg overflow-y-auto rounded-xl bg-white p-5 shadow-2xl\"\r\n    >\r\n        <div className=\"mb-4 flex items-center justify-between\">\r\n          <h2 id={titleId} className=\"text-lg font-semibold text-ink\">รฌยบยรซยฆยญ???ยธรฌยงโ</h2>\r\n          <button\r\n            type=\"button\"\r\n            onClick={onClose}\r\n            className=\"rounded-lg p-1.5 text-ink-light hover:bg-cream-deep hover:text-ink-muted\"\r\n          >\r\n            <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"currentColor\">\r\n              <path d=\"M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z\" />\r\n            </svg>\r\n          </button>\r\n        </div>\r\n\r\n        {/* Tab selector */}\r\n        <div className=\"mb-4 flex gap-1 rounded-lg bg-cream-deep p-1\">\r\n          <button\r\n            type=\"button\"\r\n            onClick={() => setTab(\"parts\")}\r\n            className={`flex-1 rounded-md px-3 py-1.5 text-sm font-medium transition-colors ${\r\n              tab === \"parts\"\r\n                ? \"bg-white text-ink shadow-sm\"\r\n                : \"text-ink-muted hover:text-ink-soft\"\r\n            }`}\r\n          >\r\n            ?ลรฌยธย  รฌยกยฐรญโขยฉ\r\n          </button>\r\n          <button\r\n            type=\"button\"\r\n            onClick={() => setTab(\"ai\")}\r\n            className={`flex-1 rounded-md px-3 py-1.5 text-sm font-medium transition-colors ${\r\n              tab === \"ai\"\r\n                ? \"bg-white text-ink shadow-sm\"\r\n                : \"text-ink-muted hover:text-ink-soft\"\r\n            }`}\r\n          >\r\n            AI รฌยบยรซยฆยญ??          </button>\r\n        </div>\r\n\r\n        {/* Tab content */}\r\n        {tab === \"parts\" ? (\r\n          <CharacterEditor initialConfig={initialConfig} onChange={setConfig} />\r\n        ) : (\r\n          <div className=\"min-h-[200px]\">\r\n            <div className=\"grid grid-cols-4 gap-2\">\r\n              {CHIBI_CHARACTERS.map((ch) => (\r\n                <button\r\n                  key={ch.id}\r\n                  type=\"button\"\r\n                  onClick={() =>\r\n                    setSelectedChibiId(selectedChibiId === ch.id ? null : ch.id)\r\n                  }\r\n                  className={`flex flex-col items-center rounded-lg border-2 p-2 transition-colors ${\r\n                    selectedChibiId === ch.id\r\n                      ? \"border-ink bg-cream-deep\"\r\n                      : \"border-line hover:border-line\"\r\n                  }`}\r\n                >\r\n                  <ChibiThumbnail spritePath={ch.spritePath} alt={ch.name} />\r\n                  <span className=\"mt-1 w-full truncate text-center text-[10px] text-ink-muted\">\r\n                    {ch.name}\r\n                  </span>\r\n                </button>\r\n              ))}\r\n            </div>\r\n          </div>\r\n        )}\r\n\r\n        <div className=\"mt-4 flex gap-3\">\r\n          <button\r\n            type=\"button\"\r\n            onClick={onClose}\r\n            className=\"flex-1 rounded-lg border border-line py-2 text-sm font-medium text-ink-soft hover:bg-cream-deep\"\r\n          >\r\n            รฌยทยจรฌโ ล\r\n          </button>\r\n          <button\r\n            type=\"button\"\r\n            onClick={handleSave}\r\n            disabled={saving || (tab === \"ai\" && !selectedChibiId)}\r\n            className=\"flex-1 rounded-lg bg-brand py-2 text-sm font-medium text-white hover:bg-brand-deep disabled:opacity-50\"\r\n          >\r\n            {saving ? \"?โฌ??รฌยค?..\" : \"?ยรฌลกยฉ\"}\r\n          </button>\r\n        </div>\r\n    </Dialog>\r\n  );\r\n}\r\n\r\n/** ?ยครญโโ?ยผรฌยยด?ยธรฌโนล??รฌยฒ??โรซย ห???โขรซยฉยด idle)??canvasรซยก?รฌยถโรฌยถล?หรฌโยฌ ?ยธรซโยค???ลรฌโนล */\r\nfunction ChibiThumbnail({ spritePath, alt }: { spritePath: string; alt: string }) {\r\n  const canvasRef = useRef<HTMLCanvasElement>(null);\r\n\r\n  useEffect(() => {\r\n    const canvas = canvasRef.current;\r\n    if (!canvas) return;\r\n    const ctx = canvas.getContext(\"2d\");\r\n    if (!ctx) return;\r\n\r\n    const img = new Image();\r\n    img.src = spritePath;\r\n    img.onload = () => {\r\n      canvas.width = PLAYER_WIDTH;\r\n      canvas.height = PLAYER_HEIGHT;\r\n      ctx.clearRect(0, 0, PLAYER_WIDTH, PLAYER_HEIGHT);\r\n      ctx.drawImage(img, 0, 0, PLAYER_WIDTH, PLAYER_HEIGHT, 0, 0, PLAYER_WIDTH, PLAYER_HEIGHT);\r\n    };\r\n  }, [spritePath]);\r\n\r\n  return (\r\n    <canvas\r\n      ref={canvasRef}\r\n      width={PLAYER_WIDTH}\r\n      height={PLAYER_HEIGHT}\r\n      className=\"h-16 w-12 object-contain\"\r\n      style={{ imageRendering: \"pixelated\" }}\r\n      aria-label={alt}\r\n    />\r\n  );\r\n}\r\n","exit_code":0,"status":"completed"}}
