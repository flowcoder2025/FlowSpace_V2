",\r\n    \"sharp\": \"^0.34.5\",\r\n    \"socket.io\": \"^4.8.1\",\r\n    \"socket.io-client\": \"^4.8.1\",\r\n    \"tailwind-merge\": \"^2.5.0\",\r\n    \"tsx\": \"^4.0.0\",\r\n    \"zustand\": \"^5.0.9\"\r\n  },\r\n  \"devDependencies\": {\r\n    \"@tailwindcss/postcss\": \"^4.0.15\",\r\n    \"@testing-library/jest-dom\": \"^6.9.1\",\r\n    \"@testing-library/react\": \"^16.3.2\",\r\n    \"@types/dompurify\": \"3.0.5\",\r\n    \"@types/node\": \"^20.0.0\",\r\n    \"@types/react\": \"^19.0.0\",\r\n    \"@types/react-dom\": \"^19.0.0\",\r\n    \"concurrently\": \"^9.2.1\",\r\n    \"cross-env\": \"^10.1.0\",\r\n    \"eslint\": \"^9.39.1\",\r\n    \"eslint-config-next\": \"^16.0.8\",\r\n    \"jsdom\": \"^28.1.0\",\r\n    \"playwright\": \"^1.58.2\",\r\n    \"prisma\": \"^6.0.0\",\r\n    \"tailwindcss\": \"^4.0.15\",\r\n    \"typescript\": \"^5.0.0\",\r\n    \"vitest\": \"^4.0.18\"\r\n  }\r\n}\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_6","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'Get-Content -Path src/components/dashboard/delete-space-section.test.tsx'","aggregated_output":"import { describe, it, expect, vi, beforeEach, afterEach } from \"vitest\";\r\nimport { render, screen, fireEvent, cleanup, waitFor } from \"@testing-library/react\";\r\n\r\nconst mockReplace = vi.fn();\r\nvi.mock(\"next/navigation\", () => ({\r\n  useRouter: () => ({ replace: mockReplace }),\r\n}));\r\n\r\nimport { DeleteSpaceSection } from \"./delete-space-section\";\r\nimport { DASHBOARD_COPY } from \"@/constants/dashboard-copy\";\r\n\r\n// ============================================================\r\n// WI-037: ?ยครฌย โข ?โรซยฉยด ?ยครญลฝห?ยดรฌล ยค ??ย ล UI ???ยดรซยฆโ ?โฌ?ยดรญโขโ ?โขรฌยยธ + DELETE + redirect\r\n// ============================================================\r\n\r\nconst COPY = DASHBOARD_COPY.SETTINGS.dangerZone;\r\nconst SPACE = { id: \"space-1\", name: \"รซยงหรฌ???รซยณยธรซ?\" };\r\n\r\nfunction setup(name = SPACE.name) {\r\n  render(<DeleteSpaceSection spaceId={SPACE.id} spaceName={name} />);\r\n}\r\n\r\n/** รซยชยจรซโนยฌ ?ยดรชยณย  ?ยดรซยฆโ???โฆรซย ยฅ?ลรซโนยค. */\r\nfunction openAndType(text: string) {\r\n  fireEvent.click(screen.getByRole(\"button\", { name: COPY.deleteButton }));\r\n  fireEvent.change(screen.getByLabelText(COPY.confirmPlaceholder), {\r\n    target: { value: text },\r\n  });\r\n}\r\n\r\nfunction confirmButton() {\r\n  return screen.getByRole(\"button\", { name: COPY.confirm });\r\n}\r\n\r\nfunction okResponse() {\r\n  return { ok: true, json: async () => ({ message: \"Space archived\", realtimeEnforced: true }) };\r\n}\r\n\r\nbeforeEach(() => {\r\n  mockReplace.mockReset();\r\n  global.fetch = vi.fn() as unknown as typeof fetch;\r\n});\r\nafterEach(() => {\r\n  cleanup();\r\n  vi.restoreAllMocks();\r\n});\r\n\r\ndescribe(\"DeleteSpaceSection ??