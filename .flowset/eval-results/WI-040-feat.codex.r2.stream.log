{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'Get-Content -Path src/features/space/game/events/event-bridge.ts | Select-Object -First 220'","aggregated_output":"/**\r\n * EventBridge - React ??Phaser ?µì‹  ë¸Œë¦¿ì§€\r\n *\r\n * flow_metaverse??events.tsë¥?ê¸°ë°˜?¼ë¡œ ?€???ˆì „?±ì„ ê°•í™”??ë²„ì „\r\n */\r\n\r\ntype EventCallback = (...args: unknown[]) => void;\r\n\r\nclass EventBridge {\r\n  private events: Map<string, Set<EventCallback>> = new Map();\r\n\r\n  /** ?´ë²¤??êµ¬ë… */\r\n  on(event: string, callback: EventCallback): void {\r\n    if (!this.events.has(event)) {\r\n      this.events.set(event, new Set());\r\n    }\r\n    this.events.get(event)!.add(callback);\r\n  }\r\n\r\n  /** ?´ë²¤??êµ¬ë… ?´ì œ */\r\n  off(event: string, callback: EventCallback): void {\r\n    const callbacks = this.events.get(event);\r\n    if (callbacks) {\r\n      callbacks.delete(callback);\r\n    }\r\n  }\r\n\r\n  /** ?´ë²¤??ë°œí–‰ */\r\n  emit(event: string, ...args: unknown[]): void {\r\n    const callbacks = this.events.get(event);\r\n    if (callbacks) {\r\n      callbacks.forEach((callback) => callback(...args));\r\n    }\r\n  }\r\n\r\n  /** ?¹ì • ?´ë²¤???ëŠ” ?„ì²´ ë¦¬ìŠ¤???œê±° */\r\n  removeAllListeners(event?: string): void {\r\n    if (event) {\r\n      this.events.delete(event);\r\n    } else {\r\n      this.events.clear();\r\n    }\r\n  }\r\n\r\n  /** ?±ë¡??ë¦¬ìŠ¤?????•ì¸ (?”ë²„ê·¸ìš©) */\r\n  listenerCount(event: string): number {\r\n    return this.events.get(event)?.size ?? 0;\r\n  }\r\n}\r\n\r\n/** Singleton EventBridge ?¸ìŠ¤?´ìŠ¤ */\r\nexport const eventBridge = new EventBridge();\r\n","exit_code":0,"status":"completed"}}
