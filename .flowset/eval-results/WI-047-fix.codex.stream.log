{"type":"item.completed","item":{"id":"item_17","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'Get-Content -Encoding UTF8 -Path src/constants/space-copy.ts | ForEach-Object -Begin {$i=1} -Process {\"$i`t$_\"; $i++}'","aggregated_output":"1\t/**\r\n2\t * 인-스페이스(실시간 공간) UI 카피 ? 단일 SoT.\r\n3\t *\r\n4\t * 어드민 대시보드 카피(`dashboard-copy.ts`)와 분리한다. WI-033이 대시보드 카피를\r\n5\t * dashboard scope로 엄격히 고정했고, 인-스페이스는 권한/UX 경계가 달라\r\n6\t * (예: \"채팅 음소거\"는 음성 음소거와 명확히 구분해야 함) 별도 상수로 둔다.\r\n7\t *\r\n8\t * 키는 영문, 값은 한글 (단일 한국어 제품 ? i18n 미도입).\r\n9\t */\r\n10\texport const SPACE_COPY = {\r\n11\t  /** 참가자 패널의 멤버 관리(채팅 음소거/해제·내보내기·차단) UI. */\r\n12\t  PARTICIPANT_PANEL: {\r\n13\t    /** 관리 메뉴 토글 버튼 aria-label. */\r\n14\t    manageAriaLabel: (nickname: string) => `${nickname} 관리`,\r\n15\t    /**\r\n16\t     * 관리 액션 ? value(토큰)는 admin API의 action 값(mute/unmute/kick/ban),\r\n17\t     * 라벨만 한글. \"채팅 음소거\"는 음성 강제 음소거(WI-038/039)와 혼동 방지용 명시.\r\n18\t     */\r\n19\t    actions: {\r\n20\t      mute: \"채팅 음소거\",\r\n21\t      unmute: \"채팅 음소거 해제\",\r\n22\t      kick: \"내보내기\",\r\n23\t      ban: \"차단\",\r\n24\t      // WI-045: 차단된 멤버에게만 노출(restriction=BANNED → NONE 복원, 재입장 허용).\r\n25\t      unban: \"차단 해제\",\r\n26\t    },\r\n27\t    /**\r\n28\t     * 음성 제어(WI-038/039) ? LiveKit 서버 측 강제 음소거. **채팅 음소거와 별개 레이어**라\r\n29\t     * 라벨로 명확히 구분한다(운영자 오제재 방지). LiveKit room 참가자에게만 노출.\r\n30\t     * - mute: 마이크 publish 권한 회수 + 기존 트랙 강제 음소거(muted:true).\r\n31\t     * - allow: publish 권한 복원만(muted:false). **사용자 self-mute는 풀지 않음** →\r\n32\t     *   \"해제\"가 아니라 \"발언 허용\"으로 표기(force-unmute 아님을 드러냄).\r\n33\t     */\r\n34\t    voiceSectionLabel: \"음성 제어\",\r\n35\t    voiceActions: {\r\n36\t      mute: \"음성 강제 음소거\",\r\n37\t      allow: \"음성 발언 허용\",\r\n38\t    },\r\n39\t    /** 음성 제어 실패 ? 라우트 code별 한글 매핑(서버 영문 미노출). 미지의 code는 actionFailed 폴백. */\r\n40\t    voiceError: {\r\n41\t      INVALID_IDENTITY: \"참가자 식별자가 올바르지 않습니다.\",\r\n42\t      SELF_TARGET: \"자기 자신은 음성 제어할 수 없습니다.\",\r\n43\t      TARGET_NOT_MEMBER: \"대상이 이 공간의 멤버가 아닙니다.\",\r\n44\t      PARTICIPANT_NOT_FOUND: \"참가자가 음성 방에 연결되어 있지 않습니다.\",\r\n45\t      LIVEKIT_NOT_CONFIGURED: \"음성 서버 설정을 확인할 수 없습니다.\",\r\n46\t      LIVEKIT_OPERATION_FAILED: \"음성 제한 처리에 실패했습니다.\",\r\n47\t    } as Record<string, string>,\r\n48\t    /** 파괴적 액션(내보내기/차단) 인라인 확인 ? kick=재입장 가능, ban=재입장 차단. */\r\n49\t    confirm: {\r\n50\t      kick: (nickname: string) =>\r\n51\t        `${nickname}님을 내보낼까요? 다시 입장할 수 있습니다.`,\r\n52\t      ban: (nickname: string) =>\r\n53\t        `${nickname}님을 차단할까요? 재입장이 차단됩니다.`,\r\n54\t      confirmLabel: \"확인\",\r\n55\t      cancelLabel: \"취소\",\r\n56\t    },\r\n57\t    /** 액션 실패 메시지(서버가 error 미반환 시 폴백). */\r\n58\t    actionFailed: \"작업에 실패했습니다.\",\r\n59\t    /** 네트워크 오류(fetch 예외). */\r\n60\t    networkError: \"네트워크 오류가 발생했습니다.\",\r\n61\t  },\r\n62\t  /** 실시간 소켓 연결 상태 안내. */\r\n63\t  SOCKET: {\r\n64\t    /** 강퇴(WI-047) 쿨다운 중 재입장 시도 ? 클라 가드/서버 게이트 모두 거부. */\r\n65\t    kickedCooldown: \"강퇴되어 잠시 후 다시 입장할 수 있습니다.\",\r\n66\t  },\r\n67\t} as const;\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'Get-Content -Encoding UTF8 -Path src/features/space/socket/internal/use-socket.test.ts | ForEach-Object -Begin {$i=1} -Process {\"$i`t$_\"; $i++}'","aggregated_output":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from \"vitest\";\r\n2\timport { renderHook, act, cleanup } from \"@testing-library/react\";\r\n3\t\r\n4\t// ============================================================\r\n5\t// WI-017 P2-2: 토큰 발급(재시도 포함) 비동기 윈도우 중 언마운트/effect 교체 시\r\n6\t// stale effect가 후속 effect의 소켓을 끊지 않고(generation 가드), 순수 언마운트\r\n7\t// 시에는 orphan 소켓을 정리하는지 검증한다.\r\n8\t//\r\n9\t// ./socket-client를 모킹해 getSocketClient 해소 타이밍을 수동 제어하고,\r\n10\t// disconnectSocket 호출 횟수로 생명주기 동작을 단언한다.\r\n11\t// ============================================================\r\n12\t\r\n13\tconst { getSocketClientMock, disconnectSocketMock } = vi.hoisted(() => ({\r\n14\t  getSocketClientMock: vi.fn(),\r\n15\t  disconnectSocketMock: vi.fn(),\r\n16\t}));\r\n17\t\r\n18\tvi.mock(\"./socket-client\", async (importActual) => {\r\n19\t  const actual = await importActual<typeof import(\"./socket-client\")>();\r\n20\t  return {\r\n21\t    ...actual, // SocketTokenError / 타입 등 실제 export 유지\r\n22\t    getSocketClient: getSocketClientMock,\r\n23\t    disconnectSocket: disconnectSocketMock,\r\n24\t  };\r\n25\t});\r\n26\t\r\n27\t// WI-047: kick 가드를 모킹해 isSpaceKicked 반환값을 제어하고 markSpaceKicked 호출을 단언한다.\r\n28\tconst { isSpaceKickedMock, markSpaceKickedMock } = vi.hoisted(() => ({\r\n29\t  isSpaceKickedMock: vi.fn(() => false),\r\n30\t  markSpaceKickedMock: vi.fn(),\r\n31\t}));\r\n32\t\r\n33\tvi.mock(\"./kick-guard\", () => ({\r\n34\t  isSpaceKicked: isSpaceKickedMock,\r\n35\t  markSpaceKicked: markSpaceKickedMock,\r\n36\t  clearSpaceKicked: vi.fn(),\r\n37\t}));\r\n38\t\r\n39\timport { useSocket } from \"./use-socket\";\r\n40\t\r\n41\t/** useSocket effect가 반환 소켓에 호출하는 표면을 최소 충족하는 가짜 소켓 */\r\n42\tfunction makeFakeSocket() {\r\n43\t  return {\r\n44\t    on: vi.fn(),\r\n45\t    io: { on: vi.fn() },\r\n46\t    connected: false,\r\n47\t    connect: vi.fn(),\r\n48\t    emit: vi.fn(),\r\n49\t  };\r\n50\t}\r\n51\t\r\n52\t/** 수동 해소 가능한 deferred */\r\n53\tfunction defer<T>() {\r\n54\t  let resolve!: (v: T) => void;\r\n55\t  const promise = new Promise<T>((r) => {\r\n56\t    resolve = r;\r\n57\t  });\r\n58\t  return { promise, resolve };\r\n59\t}\r\n60\t\r\n61\tconst flush = () => new Promise((r) => setTimeout(r, 0));\r\n62\t\r\n63\tconst baseProps = {\r\n64\t  spaceId: \"space-1\",\r\n65\t  userId: \"user-1\",\r\n66\t  nickname: \"tester\",\r\n67\t  avatar: \"avatar-1\",\r\n68\t};\r\n69\t\r\n70\tbeforeEach(() => {\r\n71\t  getSocketClientMock.mockReset();\r\n72\t  disconnectSocketMock.mockReset();\r\n73\t  isSpaceKickedMock.mockReset();\r\n74\t  isSpaceKickedMock.mockReturnValue(false); // 기본: 강퇴 아님\r\n75\t  markSpaceKickedMock.mockReset();\r\n76\t});\r\n77\t\r\n78\tafterEach(() => {\r\n79\t  cleanup();\r\n80\t  vi.restoreAllMocks();\r\n81\t});\r\n82\t\r\n83\tdescribe(\"useSocket ? 토큰 발급 중 생명주기 race (WI-017 P2-2)\", () => {\r\n84\t  it(\"순수 언마운트(토큰 발급 중) → 해소된 orphan 소켓을 정리한다\", async () => {\r\n85\t    const d = defer<ReturnType<typeof makeFakeSocket>>();\r\n86\t    getSocketClientMock.mockReturnValue(d.promise);\r\n87\t\r\n88\t    const { unmount } = renderHook(() => useSocket(baseProps));\r\n89\t\r\n90\t    // 토큰 발급 진행 중 언마운트 → cleanup이 disconnectSocket 1회 호출(이 시점 소켓 미생성)\r\n91\t    act(() => {\r\n92\t      unmount();\r\n93\t    });\r\n94\t    const callsAfterUnmount = disconnectSocketMock.mock.calls.length;\r\n95\t    expect(callsAfterUnmount).toBe(1);\r\n96\t\r\n97\t    // 이후 소켓 생성이 완료되면(orphan) ? 후속 effect가 없으므로 정리되어야 한다\r\n98\t    await act(async () => {\r\n99\t      d.resolve(makeFakeSocket());\r\n100\t      await flush();\r\n101\t    });\r\n102\t\r\n103\t    expect(disconnectSocketMock.mock.calls.length).toBe(callsAfterUnmount + 1);\r\n104\t  });\r\n105\t\r\n106\t  it(\"토큰 발급 중 deps 변경 → stale effect가 공유 소켓을 끊지 않는다\", async () => {\r\n107\t    // 두 effect가 동일 pending(공유 소켓)을 받도록 같은 promise 반환\r\n108\t    const d = defer<ReturnType<typeof makeFakeSocket>>();\r\n109\t    getSocketClientMock.mockReturnValue(d.promise);\r\n110\t\r\n111\t    const { rerender } = renderHook((props) => useSocket(props), {\r\n112\t      initialProps: baseProps,\r\n113\t    });\r\n114\t\r\n115\t    // deps 변경(nickname) → cleanup(disconnectSocket 1회) + 새 effect 시작\r\n116\t    act(() => {\r\n117\t      rerender({ ...baseProps, nickname: \"tester-2\" });\r\n118\t    });\r\n119\t    expect(disconnectSocketMock.mock.calls.length).toBe(1);\r\n120\t\r\n121\t    const fake = makeFakeSocket();\r\n122\t    await act(async () => {\r\n123\t      d.resolve(fake);\r\n124\t      await flush();\r\n125\t    });\r\n126\t\r\n127\t    // stale(이전) effect는 generation 불일치로 disconnect를 호출하지 않아야 한다\r\n128\t    // → 누적 호출은 cleanup 1회 그대로(2회가 되면 stale이 공유 소켓을 끊은 것)\r\n129\t    expect(disconnectSocketMock.mock.calls.length).toBe(1);\r\n130\t    // 후속 effect는 공유 소켓을 정상 사용(핸들러 등록)\r\n131\t    expect(fake.on).toHaveBeenCalled();\r\n132\t  });\r\n133\t});\r\n134\t\r\n135\t/** 등록된 sock.on(event) 핸들러 추출 */\r\n136\tfunction onHandler(fake: ReturnType<typeof makeFakeSocket>, event: string) {\r\n137\t  return fake.on.mock.calls.find((c) => c[0] === event)?.[1] as\r\n138\t    | ((data?: unknown) => void)\r\n139\t    | undefined;\r\n140\t}\r\n141\t/** 등록된 sock.io.on(event) 핸들러 추출 */\r\n142\tfunction ioHandler(fake: ReturnType<typeof makeFakeSocket>, event: string) {\r\n143\t  return fake.io.on.mock.calls.find((c) => c[0] === event)?.[1] as\r\n144\t    | ((data?: unknown) => void)\r\n145\t    | undefined;\r\n146\t}\r\n147\tconst joinEmits = (fake: ReturnType<typeof makeFakeSocket>) =>\r\n148\t  fake.emit.mock.calls.filter((c) => c[0] === \"join:space\");\r\n149\t\r\n150\tdescribe(\"useSocket ? kick 가드(WI-047)\", () => {\r\n151