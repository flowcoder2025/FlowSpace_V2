{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'Get-Content -Encoding UTF8 -Path src/features/space/socket/internal/kick-guard.ts | ForEach-Object -Begin {$i=1} -Process {\"$i`t$_\"; $i++}'","aggregated_output":"1\t/**\r\n2\t * 클라이언트 kick 가드(WI-047) ? space 단위 자동 재입장 차단.\r\n3\t *\r\n4\t * 강퇴(`space:error` code=\"KICKED\") 수신 시 해당 space를 짧게 기록해, effect 리마운트/\r\n5\t * 소켓 재연결로 join:space가 자동 재발송되는 루프를 끊는다. **최종 강제력은 서버 join:space\r\n6\t * 쿨다운**이며 이 가드는 UX 보조다(다중 탭은 모듈 메모리를 공유하지 않으므로 ? codex).\r\n7\t *\r\n8\t * 모듈 레벨 싱글턴이라 use-socket effect가 리마운트돼도 가드 상태가 유지된다.\r\n9\t */\r\n10\timport { createKickCooldown, KICK_COOLDOWN_MS } from \"@/lib/kick-cooldown\";\r\n11\t\r\n12\tconst guard = createKickCooldown(KICK_COOLDOWN_MS);\r\n13\t\r\n14\t/** space를 kick 가드에 등록(KICKED 수신 시). */\r\n15\texport function markSpaceKicked(spaceId: string): void {\r\n16\t  guard.mark(spaceId, Date.now());\r\n17\t}\r\n18\t\r\n19\t/** space가 kick 가드 쿨다운 중인지(join 재발송 차단 판정). */\r\n20\texport function isSpaceKicked(spaceId: string): boolean {\r\n21\t  return guard.isActive(spaceId, Date.now());\r\n22\t}\r\n23\t\r\n24\t/** space의 kick 가드를 즉시 해제(테스트/재입장 허용). */\r\n25\texport function clearSpaceKicked(spaceId: string): void {\r\n26\t  guard.clear(spaceId);\r\n27\t}\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'Get-Content -Encoding UTF8 -Path src/lib/kick-cooldown.test.ts | ForEach-Object -Begin {$i=1} -Process {\"$i`t$_\"; $i++}'","aggregated_output":"1\timport { describe, it, expect } from \"vitest\";\r\n2\timport { createKickCooldown, KICK_COOLDOWN_MS } from \"./kick-cooldown\";\r\n3\t\r\n4\t// ============================================================\r\n5\t// WI-047: kick 쿨다운 순수 스토어. now(ms)를 주입해 결정적으로 검증한다.\r\n6\t// ============================================================\r\n7\t\r\n8\tdescribe(\"createKickCooldown (WI-047)\", () => {\r\n9\t  it(\"mark 직후 ttl 이내는 isActive=true, 미등록 키는 false\", () => {\r\n10\t    const c = createKickCooldown(30_000);\r\n11\t    expect(c.isActive(\"k\", 1000)).toBe(false); // 미등록\r\n12\t    c.mark(\"k\", 1000);\r\n13\t    expect(c.isActive(\"k\", 1000)).toBe(true); // now == mark\r\n14\t    expect(c.isActive(\"k\", 1000 + 29_999)).toBe(true); // 만료 직전\r\n15\t  });\r\n16\t\r\n17\t  it(\"만료 시점(now >= until)은 false ? 경계 포함\", () => {\r\n18\t    const c = createKickCooldown(30_000);\r\n19\t    c.mark(\"k\", 1000);\r\n20\t    // until = 31000. now가 정확히 31000이면 만료로 본다(>=).\r\n21\t    expect(c.isActive(\"k\", 31_000)).toBe(false);\r\n22\t    expect(c.isActive(\"k\", 31_001)).toBe(false);\r\n23\t  });\r\n24\t\r\n25\t  it(\"만료 조회 시 lazy 삭제로 size가 줄어든다(누수 방지)\", () => {\r\n26\t    const c = createKickCooldown(30_000);\r\n27\t    c.mark(\"k\", 1000);\r\n28\t    expect(c.size()).toBe(1);\r\n29\t    // 만료 전 조회는 보관 유지\r\n30\t    expect(c.isActive(\"k\", 1500)).toBe(true);\r\n31\t    expect(c.size()).toBe(1);\r\n32\t    // 만료 후 조회 → 삭제\r\n33\t    expect(c.isActive(\"k\", 40_000)).toBe(false);\r\n34\t    expect(c.size()).toBe(0);\r\n35\t  });\r\n36\t\r\n37\t  it(\"clear는 쿨다운을 즉시 해제한다\", () => {\r\n38\t    const c = createKickCooldown(30_000);\r\n39\t    c.mark(\"k\", 1000);\r\n40\t    expect(c.isActive(\"k\", 1500)).toBe(true);\r\n41\t    c.clear(\"k\");\r\n42\t    expect(c.isActive(\"k\", 1500)).toBe(false);\r\n43\t    expect(c.size()).toBe(0);\r\n44\t  });\r\n45\t\r\n46\t  it(\"키별 독립 ? 한 키의 만료가 다른 키에 영향 없음\", () => {\r\n47\t    const c = createKickCooldown(30_000);\r\n48\t    c.mark(\"a\", 1000);\r\n49\t    c.mark(\"b\", 20_000);\r\n50\t    expect(c.isActive(\"a\", 35_000)).toBe(false); // a 만료\r\n51\t    expect(c.isActive(\"b\", 35_000)).toBe(true); // b 유효(until 50000)\r\n52\t  });\r\n53\t\r\n54\t  it(\"재-mark는 만료를 연장한다(기존 값 덮어씀)\", () => {\r\n55\t    const c = createKickCooldown(30_000);\r\n56\t    c.mark(\"k\", 1000); // until 31000\r\n57\t    c.mark(\"k\", 25_000); // until 55000 으로 갱신\r\n58\t    expect(c.isActive(\"k\", 40_000)).toBe(true); // 원래라면 만료, 재-mark로 유효\r\n59\t    expect(c.isActive(\"k\", 55_000)).toBe(false);\r\n60\t  });\r\n61\t\r\n62\t  it(\"KICK_COOLDOWN_MS는 30초\", () => {\r\n63\t    expect(KICK_COOLDOWN_MS).toBe(30_000);\r\n64\t  });\r\n65\t});\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_13","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'Get-Content -Encoding UTF8 -Path src/features/space/socket/internal/kick-guard.test.ts | ForEach-Object -Begin {$i=1} -Process {\"$i`t$_\"; $i++}'","aggregated_output":"1\timport { describe, it, expect, beforeEach, afterEach, vi } from \"vitest\";\r\n2\timport { markSpaceKicked, isSpaceKicked, clearSpaceKicked } from \"./kick-guard\";\r\n3\timport { KICK_COOLDOWN_MS } from \"@/lib/kick-cooldown\";\r\n4\t\r\n5\t// ============================================================\r\n6\t// WI-047: 클라 kick 가드(모듈 싱글턴). Date.now() 기반이라 fake timer로 검증한다.\r\n7\t// 싱글턴 상태가 테스트 간 누수되지 않도록 afterEach에서 clear한다.\r\n8\t// ============================================================\r\n9\t\r\n10\tconst SPACE = \"space-guard-1\";\r\n11\t\r\n12\tbeforeEach(() => {\r\n13\t  vi.useFakeTimers();\r\n14\t  vi.setSystemTime(0);\r\n15\t  clearSpaceKicked(SPACE);\r\n16\t});\r\n17\t\r\n18\tafterEach(() => {\r\n19\t  clearSpaceKicked(SPACE);\r\n20\t  vi.useRealTimers();\r\n21\t});\r\n22\t\r\n23\tdescribe(\"kick-guard (WI-047)\", () => {\r\n24\t  it(\"markSpaceKicked 후 쿨다운 이내는 isSpaceKicked=true\", () => {\r\n25\t    expect(isSpaceKicked(SPACE)).toBe(false);\r\n26\t    markSpaceKicked(SPACE);\r\n27\t    expect(isSpaceKicked(SPACE)).toBe(true);\r\n28\t    vi.advanceTimersByTime(KICK_COOLDOWN_MS - 1);\r\n29\t    expect(isSpaceKicked(SPACE)).toBe(true);\r\n30\t  });\r\n31\t\r\n32\t  it(\"쿨다운 경과 후 isSpaceKicked=false\", () => {\r\n33\t    markSpaceKicked(SPACE);\r\n34\t    vi.advanceTimersByTime(KICK_COOLDOWN_MS);\r\n35\t    expect(isSpaceKicked(SPACE)).toBe(false);\r\n36\t  });\r\n37\t\r\n38\t  it(\"clearSpaceKicked는 즉시 해제\", () => {\r\n39\t    markSpaceKicked(SPACE);\r\n40\t    expect(isSpaceKicked(SPACE)).toBe(true);\r\n41\t    clearSpaceKicked(SPACE);\r\n42\t    expect(isSpaceKicked(SPACE)).toBe(false);\r\n43\t  });\r\n44\t\r\n45\t  it(\"space별 독립 ? 한 space kick이 다른 space에 영향 없음\", () => {\r\n46\t    markSpaceKicked(SPACE);\r\n47\t    expect(isSpaceKicked(\"other-space\")).toBe(false);\r\n48\t    clearSpaceKicked(\"other-space\");\r\n49\t  });\r\n50\t});\r\n","exit_code":0,"status":"completed"}}
