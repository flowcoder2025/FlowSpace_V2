 onMemberMuted, onMemberUnmuted, onMemberKicked, onAnnouncement,\r\n274\t    onEditorTileUpdated, onEditorObjectPlaced, onEditorObjectMoved, onEditorObjectDeleted,\r\n275\t    onSocketError, onKicked,\r\n276\t    onRecordingStarted, onRecordingStopped,\r\n277\t    onSpotlightActivated, onSpotlightDeactivated, onProximityChanged,\r\n278\t  ]);\r\n279\t\r\n280\t  useEffect(() => {\r\n281\t    let mounted = true;\r\n282\t    const attemptId = ++connectAttemptRef.current;\r\n283\t\r\n284\t    function syncPlayers() {\r\n285\t      setPlayers(Array.from(playersMapRef.current.values()));\r\n286\t    }\r\n287\t\r\n288\t    async function connect() {\r\n289\t      try {\r\n290\t        const sock = await getSocketClient();\r\n291\t\r\n292\t        // 토큰 발급(재시도 포함) 중 언마운트/effect 교체가 일어났을 수 있다.\r\n293\t        if (!mounted) {\r\n294\t          // 후속 effect가 시작되지 않았을 때만(=내가 마지막 시도) orphan 소켓 정리.\r\n295\t          // deps 변경으로 새 effect가 시작됐다면 그 effect가 동일 소켓을 이어 쓰므로 끊지 않는다.\r\n296\t          if (connectAttemptRef.current === attemptId) {\r\n297\t            disconnectSocket();\r\n298\t          }\r\n299\t          return;\r\n300\t        }\r\n301\t        if (connectAttemptRef.current !== attemptId) return;\r\n302\t\r\n303\t        socketRef.current = sock;\r\n304\t\r\n305\t        sock.on(\"connect\", () => {\r\n306\t          setIsConnected(true);\r\n307\t          // WI-047: 강퇴 쿨다운 중이면 자동 재입장 차단(서버 join 게이트도 거부). 안내만 표시.\r\n308\t          if (isSpaceKicked(spaceId)) {\r\n309\t            setSocketError(SPACE_COPY.SOCKET.kickedCooldown);\r\n310\t            return;\r\n311\t          }\r\n312\t          setSocketError(null);\r\n313\t          sock.emit(\"join:space\", { spaceId, userId, nickname, avatar });\r\n314\t        });\r\n315\t\r\n316\t        sock.on(\"disconnect\", () => {\r\n317\t          setIsConnected(false);\r\n318\t        });\r\n319\t\r\n320\t        sock.on(\"connect_error\", (err) => {\r\n321\t          console.error(\"[Socket] Connect error:\", err.message);\r\n322\t          setSocketError(`소켓 연결 실패: ${err.message}`);\r\n323\t          setIsConnected(false);\r\n324\t        });\r\n325\t\r\n326\t        // ── 재연결 모니터링 ──\r\n327\t        sock.io.on(\"reconnect_attempt\", (attempt) => {\r\n328\t          console.log(`[Socket] Reconnect attempt #${attempt}`);\r\n329\t          setSocketError(`재연결 시도 중... (#${attempt})`);\r\n330\t        });\r\n331\t\r\n332\t        sock.io.on(\"reconnect\", () => {\r\n333\t          console.log(\"[Socket] Reconnected successfully\");\r\n334\t          setIsConnected(true);\r\n335\t          // WI-047: 강퇴 쿨다운 중이면 재연결 시 자동 join 재발송을 차단(루프 무력화).\r\n336\t          if (isSpaceKicked(spaceId)) {\r\n337\t            setSocketError(SPACE_COPY.SOCKET.kickedCooldown);\r\n338\t            return;\r\n339\t          }\r\n340\t          setSocketError(null);\r\n341\t          // 재연결 시 자동 join:space 재발송\r\n342\t          sock.emit(\"join:space\", { spaceId, userId, nickname, avatar });\r\n343\t        });\r\n344\t\r\n345\t        sock.io.on(\"reconnect_error\", (err) => {\r\n346\t          console.error(\"[Socket] Reconnect error:\", err.message);\r\n347\t        });\r\n348\t\r\n349\t        sock.io.on(\"reconnect_failed\", () => {\r\n350\t          console.error(\"[Socket] Reconnect failed after all attempts\");\r\n351\t          setSocketError(\"서버 연결에 실패했습니다. 페이지를 새로고침해주세요.\");\r\n352\t        });\r\n353\t\r\n354\t        // 입장 인가 거부 (비멤버/차단/비활성 공간/강퇴)\r\n355\t        sock.on(\"space:error\", (data) => {\r\n356\t          console.error(\"[Socket] space:error:\", data.code, data.message);\r\n357\t          // WI-047: 본인 강퇴 ? 클라 가드 등록(재입장 루프 차단) + 공간 이탈 콜백(/my-spaces).\r\n358\t          if (data.code === \"KICKED\") {\r\n359\t            markSpaceKicked(spaceId);\r\n360\t            onKickedRef.current?.();\r\n361\t          }\r\n362\t          setSocketError(data.message);\r\n363\t        });\r\n364\t\r\n365\t        // ── 플레이어 이벤트 ──\r\n366\t        sock.on(\"players:list\", ({ players: list }) => {\r\n367\t          playersMapRef.current.clear();\r\n368\t          for (const p of list) {\r\n369\t            if (p.userId !== userId) {\r\n370\t              playersMapRef.current.set(p.userId, p);\r\n371\t            }\r\n372\t          }\r\n373\t          syncPlayers();\r\n374\t        });\r\n375\t\r\n376\t        sock.on(\"player:joined\", (data) => {\r\n377\t          if (data.userId !== userId) {\r\n378\t            playersMapRef.current.set(data.userId, data);\r\n379\t            syncPlayers();\r\n380\t          }\r\n381\t        });\r\n382\t\r\n383\t        sock.on(\"player:left\", ({ userId: leftId }) => {\r\n384\t          playersMapRef.current.delete(leftId);\r\n385\t          syncPlayers();\r\n386\t        });\r\n387\t\r\n388\t        sock.on(\"player:moved\", ({ userId: movedId, x, y, direction }) => {\r\n389\t          const player = playersMapRef.current.get(movedId);\r\n390\t          if (player) {\r\n391\t            // 새 객체로 교체 (mutation → 참조 비교 실패 방지)\r\n392\t            playersMapRef.current.set(movedId, {\r\n393\t              ...player,\r\n394\t              position: { x, y },\r\n395\t              direction,\r\n396\t            });\r\n397\t          } else if (movedId !== userId) {\r\n398\t            playersMapRef.current.set(movedId, {\r\n399\t              userId: movedId,\r\n400\t              nickname: DEFAULT_NICKNAME,\r\n401\t              avatar: \"default\",\r\n402\t              position: { x, y },\r\n403\t              direction,\r\n404\t            });\r\n405\t          }\r\n406\t          syncPlayers();\r\n407\t        });\r\n408\t\r\n409\t        sock.on(\"player:avatar-updated\", ({ userId: updatedId, avatar: newAvatar }) => {\r\n410\t          const player = playersMapRef.current.get(updatedId);\r\n411\t          if (player) {\r\n412\t            player.avatar = newAvatar;\r\n413\t            syncPlayers();\r\n414\t          }\r\n415\t        });\r\n416\t\r\n417\t        // ── Chat events ──\r\n418\t        sock.on(\"chat:message\", (data) => {\r\n419\t          onChatMessageRef.current?.(data);\r\n420\t        });\r\n421\t\r\n422\t        sock.on(\"chat:messageIdUpdate\", (data) => {\r\n423\t          onMessageIdUpdateRef.current?.(data);\r\n424\t        });\r\n425\t\r\n426\t        sock.on(\"chat:messageFailed\", (data) => {\r\n427\t          onMessageFailedRef.current?.(data);\r\n428\t        });\r\n429\t\r\n430\t        sock.on(\"chat:messageDeleted\", (data) => {\r\n431\t          onMessageDeletedRef.current?.(data);\r\n432\t        });\r\n433\t\r\n434\t        // ── Whisper events ──\r\n435\t        sock.on(\"whisper:receive\", (data) => {\r\n436\t          onWhisperReceiveRef.current?.(data);\r\n437\t        });\r\n438\t\r\n439\t        sock.on(\"whisper:sent\", (data) => {\r\n440\t          onWhisperSentRef.current?.(data);\r\n441\t        });\r\n442\t\r\n443\t        // ── Party events ──\r\n444\t        sock.on(\"party:message\", (data) => {\r\n445\t          onPartyMessageRef.current?.({ ...data, type: \"party\" });\r\n446\t        });\r\n447\t\r\n448\t        // ── Reaction events ──\r\n449\t        sock.on(\"reaction:updated\", (data) => {\r\n450\t          onReactionUpdatedRef.current?.(data);\r\n451\t        });\r\n452\t\r\n453\t        // ── Admin events ──\r\n454\t        sock.on(\"member:muted\", (data) => {\r\n455\t          onMemberMutedRef.current?.(data);\r\n456\t        });\r\n457\t\r\n458\t        sock.on(\"member:unmuted\", (data) => {\r\n459\t          onMemberUnmutedRef.current?.(data);\r\n460\t        });\r\n461\t\r\n462\t        sock.on(\"member:kicked\", (data) => {\r\n463\t          onMemberKickedRef.current?.(data);\r\n464\t        });\r\n465\t\r\n466\t        sock.on(\"space:announcement\", (data) => {\r\n467\t          onAnnouncementRef.current?.(data);\r\n468\t        });\r\n469\t\r\n470\t        // ── Error events (세분화) ──\r\n471\t        sock.on(\"chat:error\", (data) => {\r\n472\t          onSocketErrorRef.current?.(data);\r\n473\t        });\r\n474\t        sock.on(\"whisper:error\", (data) => {\r\n475\t          onSocketErrorRef.current?.(data);\r\n476\t        });\r\n477\t        sock.on(\"party:error\", (data) => {\r\n478\t          onSocketErrorRef.current?.(data);\r\n479\t        });\r\n480\t        sock.on(\"admin:error\", (data) => {\r\n481\t          onSocketErrorRef.current?.(data);\r\n482\t        });\r\n483\t\r\n484\t        // ── Editor events ──\r\n485\t        sock.on(\"editor:tile-updated\", (data) => {\r\n486\t          onEditorTileUpdatedRef.current?.(data);\r\n487\t        });\r\n488\t        sock.on(\"editor:object-placed\", (data) => {\r\n489\t          onEditorObjectPlacedRef.current?.(data);\r\n490\t        });\r\n491\t        sock.on(\"editor:object-moved\", (data) => {\r\n492\t          onEditorObjectMovedRef.current?.(data);\r\n493\t        });\r\n494\t        sock.on(\"editor:object-deleted\", (data) => {\r\n495\t          onEditorObjectDeletedRef.current?.(data);\r\n496\t        });\r\n497\t\r\n498\t        // ── Media events ──\r\n499\t        sock.on(\"recording:started\", (data) => {\r\n500\t          onRecordingStartedRef.current?.(data);\r\n501\t        });\r\n502\t        sock.on(\"recording:stopped\", (data) => {\r\n503\t          onRecordingStoppedRef.current?.(data);\r\n504\t        });\r\n505\t        sock.on(\"spotlight:activated\", (data) => {\r\n506\t          onSpotlightActivatedRef.current?.(data);\r\n507\t        });\r\n508\t        sock.on(\"spotlight:deactivated\", (data) => {\r\n509\t          onSpotlightDeactivatedRef.current?.(data);\r\n510\t        });\r\n511\t        sock.on(\"proximity:changed\", (data) => {\r\n512\t          onProximityChangedRef.current?.(data);\r\n513\t        });\r\n514\t        sock.on(\"media:error\", (data) => {\r\n515\t          onSocketErrorRef.current?.(data);\r\n516\t        });\r\n517\t\r\n518\t        sock.on(\"error\", ({ message }) => {\r\n519\t          console.error(\"[Socket] Error:\", message);\r\n520\t        });\r\n521\t\r\n522\t        if (!sock.connected) {\r\n523\t          sock.connect();\r\n524\t        }\r\n525\t      } catch (err) {\r\n526\t        console.error(\"[Socket] Connection failed:\", err);\r\n527\t        if (!mounted || connectAttemptRef.current !== attemptId) return;\r\n528\t        setSocketError(\r\n529\t          err instanceof SocketTokenError\r\n530\t            ? socketTokenErrorMessage(err.code)\r\n531\t            : \"소켓 연결에 실패했습니다.\"\r\n532\t        );\r\n533\t      }\r\n534\t    }\r\n535\t\r\n536\t    connect();\r\n537\t\r\n538\t    // ── 브라우저 가시성 처리 ──\r\n539\t    function handleBeforeUnload() {\r\n540\t      socketRef.current?.emit(\"leave:space\", { spaceId });\r\n541\t      disconnectSocket();\r\n542\t    }\r\n543\t\r\n544\t    function handlePageHide() {\r\n545\t      // 모바일 Safari 대응\r\n546\t      socketRef.current?.emit(\"leave:space\", { spaceId });\r\n547\t      disconnectSocket();\r\n548\t    }\r\n549\t\r\n550\t    function handleVisibilityChange() {\r\n551\t      if (document.visibilityState === \"hidden\") {\r\n552\t        console.log(\"[Socket] Page hidden ? relying on server ping timeout\");\r\n553\t      } else {\r\n554\t        console.log(\"[Socket] Page visible\");\r\n555\t      }\r\n556\t    }\r\n557\t\r\n558\t    window.addEventListener(\"beforeunload\", handleBeforeUnload);\r\n559\t    window.addEventListener(\"pagehide\", handlePageHide);\r\n560\t    document.addEventListener(\"visibilitychange\", handleVisibilityChange);\r\n561\t\r\n562\t    return () => {\r\n563\t      mounted = false;\r\n564\t      window.removeEventListener(\"beforeunload\", handleBeforeUnload);\r\n565\t      window.removeEventListener(\"pagehide\", handlePageHide);\r\n566\t      document.removeEventListener(\"visibilitychange\", handleVisibilityChange);\r\n567\t      socketRef.current?.emit(\"leave:space\", { spaceId });\r\n568\t      disconnectSocket();\r\n569\t      setIsConnected(false);\r\n570\t    };\r\n571\t  }, [spaceId, userId, nickname, avatar]);\r\n572\t\r\n573\t  const sendMovement = useCallback((data: MovementData) => {\r\n574\t    const now = Date.now();\r\n575\t    if (now - lastMoveRef.current < MOVE_THROTTLE_MS) return;\r\n576\t    lastMoveRef.current = now;\r\n577\t    socketRef.current?.emit(\"move\", data);\r\n578\t  }, []);\r\n579\t\r\n580\t  const sendChat = useCallback(\r\n581\t    (content: string, type: \"group\" | \"whisper\" | \"party\", targetId?: string, replyTo?: { id: string; senderNickname: string; content: string }) => {\r\n582\t      const sock = socketRef.current;\r\n583\t      if (!sock || !sock.connected) {\r\n584\t        console.error(\"[Socket] sendChat failed: socket not connected\", { hasSocket: !!sock, connected: sock?.connected });\r\n585\t        return;\r\n586\t      }\r\n587\t      sock.emit(\"chat:send\", { content, type, targetId, replyTo });\r\n588\t    },\r\n589\t    []\r\n590\t  );\r\n591\t\r\n592\t  const sendWhisper = useCallback(\r\n593\t    (targetNickname: string, content: string) => {\r\n594\t      socketRef.current?.emit(\"whisper:send\", { targetNickname, content });\r\n595\t    },\r\n596\t    []\r\n597\t  );\r\n598\t\r\n599\t  const sendReactionToggle = useCallback(\r\n600\t    (messageId: string, reactionType: \"thumbsup\" | \"heart\" | \"check\") => {\r\n601\t      socketRef.current?.emit(\"reaction:toggle\", { messageId, reactionType });\r\n602\t    },\r\n603\t    []\r\n604\t  );\r\n605\t\r\n606\t  const sendAdminCommand = useCallback(\r\n607\t    (command: string, data: Record<string, unknown>) => {\r\n608\t      const sock = socketRef.current;\r\n609\t      if (!sock) return;\r\n610\t\r\n611\t      switch (command) {\r\n612\t        case \"admin:mute\":\r\n613\t          sock.emit(\"admin:mute\", data as { targetNickname: string; duration?: number });\r\n614\t          break;\r\n615\t        case \"admin:unmute\":\r\n616\t          sock.emit(\"admin:unmute\", data as { targetNickname: string });\r\n617\t          break;\r\n618\t        case \"admin:kick\":\r\n619\t          sock.emit(\"admin:kick\", data as { targetNickname: string });\r\n620\t          break;\r\n621\t        case \"admin:announce\":\r\n622\t          sock.emit(\"admin:announce\", data as { content: string });\r\n623\t          break;\r\n624\t        case \"chat:delete\":\r\n625\t          sock.emit(\"chat:delete\", data as { messageId: string });\r\n626\t          break;\r\n627\t      }\r\n628\t    },\r\n629\t    []\r\n630\t  );\r\n631\t\r\n632\t  const joinParty = useCallback((zoneId: string) => {\r\n633\t    socketRef.current?.emit(\"party:join\", { zoneId });\r\n634\t  }, []);\r\n635\t\r\n636\t  const leaveParty = useCallback((zoneId: string) => {\r\n637\t    socketRef.current?.emit(\"party:leave\", { zoneId });\r\n638\t  }, []);\r\n639\t\r\n640\t  const sendPartyMessage = useCallback((content: string) => {\r\n641\t    socketRef.current?.emit(\"party:message\", { content });\r\n642\t  }, []);\r\n643\t\r\n644\t  const sendEditorTileUpdate = useCallback(\r\n645\t    (data: { layer: string; col: number; row: number; tileIndex: number }) => {\r\n646\t      socketRef.current?.emit(\"editor:tile-update\", data);\r\n647\t    },\r\n648\t    []\r\n649\t  );\r\n650\t\r\n651\t  const sendEditorObjectPlace = useCallback(\r\n652\t    (data: { id: string; objectType: string; positionX: number; positionY: number; label?: string }) => {\r\n653\t      socketRef.current?.emit(\"editor:object-place\", data);\r\n654\t    },\r\n655\t    []\r\n656\t  );\r\n657\t\r\n658\t  const sendEditorObjectMove = useCallback(\r\n659\t    (data: { id: string; positionX: number; positionY: number }) => {\r\n660\t      socketRef.current?.emit(\"editor:object-move\", data);\r\n661\t    },\r\n662\t    []\r\n663\t  );\r\n664\t\r\n665\t  const sendEditorObjectDelete = useCallback(\r\n666\t    (data: { id: string }) => {\r\n667\t      socketRef.current?.emit(\"editor:object-delete\", data);\r\n668\t    },\r\n669\t    []\r\n670\t  );\r\n671\t\r\n672\t  // Avatar emitter\r\n673\t  const sendAvatarUpdate = useCallback((avatar: string) => {\r\n674\t    socketRef.current?.emit(\"avatar:update\", { avatar });\r\n675\t  }, []);\r\n676\t\r\n677\t  // Media emitters\r\n678\t  const sendRecordingStart = useCallback(() => {\r\n679\t    socketRef.current?.emit(\"recording:start\");\r\n680\t  }, []);\r\n681\t\r\n682\t  const sendRecordingStop = useCallback(() => {\r\n683\t    socketRef.current?.emit(\"recording:stop\");\r\n684\t  }, []);\r\n685\t\r\n686\t  const sendSpotlightActivate = useCallback(() => {\r\n687\t    socketRef.current?.emit(\"spotlight:activate\");\r\n688\t  }, []);\r\n689\t\r\n690\t  const sendSpotlightDeactivate = useCallback(() => {\r\n691\t    socketRef.current?.emit(\"spotlight:deactivate\");\r\n692\t  }, []);\r\n693\t\r\n694\t  const sendProximitySet = useCallback((enabled: boolean) => {\r\n695\t    socketRef.current?.emit(\"proximity:set\", { enabled });\r\n696\t  }, []);\r\n697\t\r\n698\t  return {\r\n699\t    isConnected,\r\n700\t    socketError,\r\n701\t    players,\r\n702\t    sendMovement,\r\n703\t    sendChat,\r\n704\t    sendWhisper,\r\n705\t    sendReactionToggle,\r\n706\t    sendAdminCommand,\r\n707\t    joinParty,\r\n708\t    leaveParty,\r\n709\t    sendPartyMessage,\r\n710\t    sendEditorTileUpdate,\r\n711\t    sendEditorObjectPlace,\r\n712\t    sendEditorObjectMove,\r\n713\t    sendEditorObjectDelete,\r\n714\t    sendAvatarUpdate,\r\n715\t    sendRecordingStart,\r\n716\t    sendRecordingStop,\r\n717\t    sendSpotlightActivate,\r\n718\t    sendSpotlightDeactivate,\r\n719\t    sendProximitySet,\r\n720\t  };\r\n721\t}\r\n","exit_code":0,"status":"completed"}}
