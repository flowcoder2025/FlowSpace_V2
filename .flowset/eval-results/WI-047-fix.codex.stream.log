(409).\r\n78\t  if (req.action === \"archive\") {\r\n79\t    const space = await prisma.space.findUnique({\r\n80\t      where: { id: req.spaceId },\r\n81\t      select: { status: true },\r\n82\t    });\r\n83\t    return space?.status === \"ARCHIVED\";\r\n84\t  }\r\n85\t\r\n86\t  // ë©¤ë²„ ?€???œìž¬ ??discriminated union ???¬ê¸°??req.userId ì¡´ìž¬ë¥?ë³´ìž¥?œë‹¤.\r\n87\t  const member = await prisma.spaceMember.findUnique({\r\n88\t    where: { spaceId_userId: { spaceId: req.spaceId, userId: req.userId } },\r\n89\t    select: { restriction: true, role: true },\r\n90\t  });\r\n91\t  switch (req.action) {\r\n92\t    case \"ban\":\r\n93\t      return member?.restriction === \"BANNED\";\r\n94\t    case \"kick\":\r\n95\t      // WI-045: kick ?€ ë©¤ë²„ë¥??? œ?˜ì? ?ŠëŠ”???¬ìž…???ˆìš©) ??? íš¨ ë©¤ë²„(ë¯¸ì°¨??ë§?disconnect.\r\n96\t      // HMAC ì¶œì²˜ ê²€ì¦???ìµœì†Œ ë¶ˆë????„ìž¬ ê·?ë°©ì˜ ? íš¨ ë©¤ë²„ë§?kick ê°€??. ê¶Œí•œ ê²€ì¦ì? ?¼ìš°?¸ê? ??\r\n97\t      return member !== null && member.restriction !== \"BANNED\";\r\n98\t    case \"mute\":\r\n99\t      return member?.restriction === \"MUTED\";\r\n100\t    case \"unmute\":\r\n101\t      return member?.restriction === \"NONE\";\r\n102\t    case \"role\":\r\n103\t      return member?.role === req.role;\r\n104\t    default:\r\n105\t      return false;\r\n106\t  }\r\n107\t}\r\n108\t\r\n109\t/**\r\n110\t * ê²€ì¦ëœ enforce ?”ì²­???Œì¼“???ìš©. ?í–¥ë°›ì? ?Œì¼“ ??ë°˜í™˜(?¤í”„?¼ì¸?´ë©´ 0=no-op).\r\n111\t */\r\n112\texport function applyEnforcement(io: IO, req: EnforceRequest): number {\r\n113\t  // ê³µê°„ ?„ì²´ archive ??ê·?ê³µê°„??ëª¨ë“  ?‘ì†?ë? ì¶”ë°©?œë‹¤(WI-036).\r\n114\t  if (req.action === \"archive\") {\r\n115\t    // 1) deny cache ???±ë¡ ???´í›„ in-flight join ??ì¦‰ì‹œ ì°¨ë‹¨(TOCTOU ë³´ê°•).\r\n116\t    markSpaceArchived(req.spaceId);\r\n117\t    // 2) ?€???Œì¼“ ?¤ëƒ…????ì²˜ë¦¬(detach ê°€ room ??mutate ?˜ë?ë¡??œíšŒ ??ê³ ì •).\r\n118\t    const targets = socketsInSpace(io, req.spaceId);\r\n119\t    const message = \"??ê³µê°„???? œ?˜ì–´ ?°ê²°??ì¢…ë£Œ?˜ì—ˆ?µë‹ˆ??\";\r\n120\t    for (const s of targets) {\r\n121\t      // ?¬ìœ  ?µì? ???™ê¸° ê¶Œí•œ ?Œìˆ˜(grace ?™ì•ˆ stale ?¸ê? ì°¨ë‹¨) ??kick/ban ê³??™ì¼ ?¨í„´.\r\n122\t      s.emit(\"space:error\", { code: \"SPACE_ARCHIVED\", message });\r\n123\t      detachSocketFromSpace(s);\r\n124\t      setTimeout(() => s.disconnect(true), DISCONNECT_GRACE_MS);\r\n125\t    }\r\n126\t    // 3) ê³µê°„??ëª¨ë“  ?¸ë©”ëª¨ë¦¬ ?¸ë±???¼ê´„ ?•ë¦¬(presence + media). detach ê°€ socket.data ë¥?    //    ë¹„ì› ?¼ë?ë¡?ì§€??disconnect ??leaveSpace ???¬ì‹¤?‰ë˜ì§€ ?ŠëŠ”??\r\n127\t    purgeSpaceState(req.spaceId);\r\n128\t    return targets.length;\r\n129\t  }\r\n130\t\r\n131\t  // WI-047: kick?€ DBë¥?ë°”ê¾¸ì§€ ?Šìœ¼ë¯€ë¡? ê°•í‡´ ì§í›„ ?ë™ ?¬ìž…?¥ì„ ë§‰ëŠ” ì¿¨ë‹¤?´ì„ ?€???Œì¼“\r\n132\t  // ? ë¬´?€ ë¬´ê??˜ê²Œ ë¨¼ì? ?±ë¡?œë‹¤(?¤í”„?¼ì¸/?¤ë¥¸ ??´ ê³§ë°”ë¡??¬ì§„?…í•˜??ê²½ë¡œê¹Œì? ì°¨ë‹¨).\r\n133\t  if (req.action === \"kick\") {\r\n134\t    markUserKicked(req.spaceId, req.userId);\r\n135\t  }\r\n136\t\r\n137\t  const targets = socketsForUser(io, req.spaceId, req.userId);\r\n138\t  if (targets.length === 0) return 0;\r\n139\t\r\n140\t  const players = spacePlayersMap.get(req.spaceId);\r\n141\t  const nickname = players?.get(req.userId)?.nickname ?? \"Unknown\";\r\n142\t  const actor = req.actorName ?? \"ê´€ë¦¬ìž\";\r\n143\t\r\n144\t  if (req.action === \"ban\" || req.action === \"kick\") {\r\n145\t    const code = req.action === \"ban\" ? \"BANNED\" : \"KICKED\";\r\n146\t    const message =\r\n147\t      req.action === \"ban\"\r\n148\t        ? \"ê´€ë¦¬ìž???˜í•´ ??ê³µê°„?ì„œ ì°¨ë‹¨?˜ì—ˆ?µë‹ˆ??\"\r\n149\t        : \"ê´€ë¦¬ìž???˜í•´ ??ê³µê°„?ì„œ ì¶”ë°©?˜ì—ˆ?µë‹ˆ??\";\r\n150\t\r\n151\t    // 1) ê°??€ê²??Œì¼“: ?¬ìœ  ?µì? ??**?™ê¸° ê¶Œí•œ ?Œìˆ˜**(detachSocketFromSpace).\r\n152\t    //    ëª¨ë“  ?´ë²¤???¸ë“¤?¬ëŠ” socket.data.spaceId ë¡??¸ê??˜ë?ë¡? ëª¨ë“  room(ê³µê°„ + ?Œí‹°)\r\n153\t    //    ?´íƒˆ + socket.data ë¬´íš¨?”ë¡œ grace ?™ì•ˆ??ê¶Œí•œ ?”ì¡´(?…ì˜??chat/admin/editor/media\r\n154\t    //    ?„ì†¡, ?Œí‹° ë©”ì‹œì§€ ?˜ì‹ )??ì¦‰ì‹œ ?«ížŒ?? ??join ?€ WI-001 join ê²Œì´?¸ê? ì°¨ë‹¨.\r\n155\t    //    ë¬¼ë¦¬ disconnect ë§?grace ?„ë¡œ ë¯¸ë¤„ space:error ?¨í‚· flush ë¥?ë³´ìž¥.\r\n156\t    for (const s of targets) {\r\n157\t      s.emit(\"space:error\", { code, message });\r\n158\t      detachSocketFromSpace(s);\r\n159\t      setTimeout(() => s.disconnect(true), DISCONNECT_GRACE_MS);\r\n160\t    }\r\n161\t\r\n162\t    // 2) presence ?•ë¦¬ + ì£¼ë? ?Œë¦¼?€ **?¬ìš©???¨ìœ„ 1??*(?¤ì¤‘ ??ì¤‘ë³µ player:left ë°©ì?).\r\n163\t    //    ?€ê²Ÿì? ?´ë? ë¶„ë¦¬?ìœ¼ë¯€ë¡??ê¸° ?ì‹ ??member:kicked/player:left ë¥?ë°›ì? ?Šê³ ,\r\n164\t    //    spaceId ë¥?ë¹„ì› ?¼ë?ë¡?ì§€?°ëœ disconnect ?¸ë“¤?¬ì˜ leaveSpace ???¬ì‹¤?‰ë˜ì§€ ?ŠëŠ”??\r\n165\t    io.to(req.spaceId).emit(\"member:kicked\", { memberId: req.userId, nickname, kickedBy: actor });\r\n166\t    removeUserPresence(io, req.spaceId, req.userId);\r\n167\t  } else if (req.action === \"mute\" || req.action === \"unmute\") {\r\n168\t    const restriction = req.action === \"mute\" ? \"MUTED\" : \"NONE\";\r\n169\t    for (const s of targets) s.data.restriction = restriction;\r\n170\t    if (req.action === \"mute\") {\r\n171\t      io.to(req.spaceId).emit(\"member:muted\", { memberId: req.userId, nickname, mutedBy: actor });\r\n172\t    } else {\r\n173\t      io.to(req.spaceId).emit(\"member:unmuted\", { memberId: req.userId, nickname, unmutedBy: actor });\r\n174\t    }\r\n175\t  } else if (req.action === \"role\" && req.role) {\r\n176\t    // ê¶Œí•œ ?Œìˆ˜/ë³€ê²????¸ë©”ëª¨ë¦¬ role ìºì‹œ ê°±ì‹ (ê°•ë“± ??admin ?´ë²¤??ì°¨ë‹¨)\r\n177\t    for (const s of targets) s.data.role = req.role;\r\n178\t  }\r\n179\t\r\n180\t  return targets.length;\r\n181\t}\r\n182\t\r\n183\tfunction headerStr(req: IncomingMessage, name: string): string | null {\r\n184\t  const v = req.headers[name];\r\n185\t  if (Array.isArray(v)) return v[0] ?? null;\r\n186\t  return v ?? null;\r\n187\t}\r\n188\t\r\n189\tfunction sendJson(res: ServerResponse, status: number, body: unknown): void {\r\n190\t  res.writeHead(status, { \"content-type\": \"application/json\" });\r\n191\t  res.end(JSON.stringify(body));\r\n192\t}\r\n193\t\r\n194\t/**\r\n195\t * /internal/enforce ?”ì²­ ì²˜ë¦¬. ??ê²½ë¡œê°€ ?„ë‹ˆë©?false(?¸ì¶œì¸¡ì´ 404 ì²˜ë¦¬).\r\n196\t * ì²˜ë¦¬?ˆìœ¼ë©?true.\r\n197\t */\r\n198\texport async function handleInternalHttp(\r\n199\t  io: IO,\r\n200\t  req: IncomingMessage,\r\n201\t  res: ServerResponse\r\n202\t): Promise<boolean> {\r\n203\t  const pathname = (req.url ?? \"\").split(\"?\")[0];\r\n204\t  if (pathname !== ENFORCE_PATH) return false;\r\n205\t\r\n206\t  if (req.method !== \"POST\") {\r\n207\t    sendJson(res, 405, { error: \"Method not allowed\" });\r\n208\t    return true;\r\n209\t  }\r\n210\t\r\n211\t  const secret = process.env.SOCKET_INTERNAL_SECRET;\r\n212\t  if (!secret) {\r\n213\t    console.error(\"[enforce] SOCKET_INTERNAL_SECRET ë¯¸ì„¤????enforce ë¹„í™œ???”ì²­ ê±°ë?)\");\r\n214\t    sendJson(res, 503, { error: \"Enforcement not configured\" });\r\n215\t    return true;\r\n216\t  }\r\n217\t\r\n218\t  // body ?˜ì§‘ (byte ?¨ìœ„ size limit ì´ˆê³¼ ??ì¦‰ì‹œ ì¤‘ë‹¨ ??ë©€?°ë°”?´íŠ¸ UTF-8 ?•í™• ì¸¡ì •)\r\n219\t  let raw = \"\";\r\n220\t  let receivedBytes = 0;\r\n221\t  let tooLarge = false;\r\n222\t  for await (const chunk of req) {\r\n223\t    receivedBytes += (chunk as Buffer).length; // chunk ?€ Buffer ??.length ê°€ byte ??    if (receivedBytes > ENFORCE_MAX_BODY_BYTES) {\r\n224\t      tooLarge = true;\r\n225\t      break;\r\n226\t    }\r\n227\t    raw += chunk;\r\n228\t  }\r\n229\t  if (tooLarge) {\r\n230\t    sendJson(res, 413, { error: \"Body too large\" });\r\n231\t    return true;\r\n232\t  }\r\n233\t\r\n234\t  const signature = headerStr(req, ENFORCE_SIGNATURE_HEADER);\r\n235\t  const timestamp = headerStr(req, ENFORCE_TIMESTAMP_HEADER);\r\n236\t  if (!signature || !timestamp) {\r\n237\t    sendJson(res, 401, { error: \"Missing signature\" });\r\n238\t    return true;\r\n239\t  }\r\n240\t  if (!isFreshTimestamp(timestamp, Date.now())) {\r\n241\t    sendJson(res, 401, { error: \"Stale timestamp\" });\r\n242\t    return true;\r\n243\t  }\r\n244\t  if (!verifyEnforceSignature(secret, timestamp, raw, signature)) {\r\n245\t    sendJson(res, 403, { error: \"Invalid signature\" });\r\n246\t    return true;\r\n247\t  }\r\n248\t\r\n249\t  let parsed: unknown;\r\n250\t  try {\r\n251\t    parsed = JSON.parse(raw);\r\n252\t  } catch {\r\n253\t    sendJson(res, 400, { error: \"Invalid JSON\" });\r\n254\t    return true;\r\n255\t  }\r\n256\t  const enforceReq = parseEnforceRequest(parsed);\r\n257\t  if (!enforceReq) {\r\n258\t    sendJson(res, 400, { error: \"Invalid request\" });\r\n259\t    return true;\r\n260\t  }\r\n261\t\r\n262\t  try {\r\n263\t    const ok = await verifyPostcondition(enforceReq);\r\n264\t    if (!ok) {\r\n265\t      sendJson(res, 409, { error: \"Postcondition not met\" });\r\n266\t      return true;\r\n267\t    }\r\n268\t    const affectedSockets = applyEnforcement(io, enforceReq);\r\n269\t    sendJson(res, 200, { enforced: true, affectedSockets });\r\n270\t  } catch (err) {\r\n271\t    console.error(\"[enforce] ì²˜ë¦¬ ?¤ë¥˜:\", err);\r\n272\t    sendJson(res, 500, { error: \"Enforcement failed\" });\r\n273\t  }\r\n274\t  return true;\r\n275\t}\r\n","exit_code":0,"status":"completed"}}
