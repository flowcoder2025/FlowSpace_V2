\t  it(\"connect 시 쿨다운 아니면 join:space 발송\", async () => {\r\n200\t    isSpaceKickedMock.mockReturnValue(false);\r\n201\t    const fake = makeFakeSocket();\r\n202\t    getSocketClientMock.mockResolvedValue(fake);\r\n203\t    renderHook(() => useSocket(baseProps));\r\n204\t    await act(async () => {\r\n205\t      await flush();\r\n206\t    });\r\n207\t\r\n208\t    const connect = onHandler(fake, \"connect\");\r\n209\t    act(() => connect!());\r\n210\t    const emits = joinEmits(fake);\r\n211\t    expect(emits.length).toBe(1);\r\n212\t    expect(emits[0][1]).toMatchObject({ spaceId: \"space-1\", userId: \"user-1\" });\r\n213\t  });\r\n214\t\r\n215\t  it(\"reconnect 시 강퇴 쿨다운 중이면 join:space 자동 재발송 차단\", async () => {\r\n216\t    isSpaceKickedMock.mockReturnValue(true);\r\n217\t    const fake = makeFakeSocket();\r\n218\t    getSocketClientMock.mockResolvedValue(fake);\r\n219\t    renderHook(() => useSocket(baseProps));\r\n220\t    await act(async () => {\r\n221\t      await flush();\r\n222\t    });\r\n223\t\r\n224\t    const reconnect = ioHandler(fake, \"reconnect\");\r\n225\t    expect(reconnect).toBeTypeOf(\"function\");\r\n226\t    act(() => reconnect!());\r\n227\t    expect(joinEmits(fake).length).toBe(0);\r\n228\t  });\r\n229\t});\r\n","exit_code":0,"status":"completed"}}
