isSuperAdmin) {\r\n  75:       return NextResponse.json({ error: \"Forbidden\" }, { status: 403 });\r\n  76:     }\r\n  77:     const actorRole = (self?.role ?? \"OWNER\") as SpaceRole;\r\n  78: \r\n  79:     const body = await request.json();\r\n  80:     const { memberId, action, role } = body as {\r\n  81:       memberId: string;\r\n  82:       action: \"changeRole\" | \"mute\" | \"unmute\" | \"kick\" | \"ban\";\r\n  83:       role?: SpaceRole;\r\n  84:     };\r\n  85: \r\n  86:     if (!memberId || !action) {\r\n  87:       return NextResponse.json({ error: \"memberId and action are required\" }, { status: 400 });\r\n  88:     }\r\n  89: \r\n  90:     const target = await prisma.spaceMember.findUnique({\r\n  91:       where: { id: memberId },\r\n  92:       include: { user: { select: { name: true } } },\r\n  93:     });\r\n  94:     if (!target || target.spaceId !== spaceId) {\r\n  95:       return NextResponse.json({ error: \"Member not found\" }, { status: 404 });\r\n  96:     }\r\n  97: \r\n  98:     // OWNER??УЋТГтЌУЊТВ?УЋТЖЫУЊ?\r\n  99:     if (target.role === \"OWNER\" && !isSuperAdmin) {\r\n 100:       return NextResponse.json({ error: \"Cannot modify the space owner\" }, { status: 403 });\r\n 101:     }\r\n 102: \r\n 103:     // ??тЂТ  УЊТГтУЌТИТЕ: ?ТИУЌТЖХ????тЂТ ???тЌ?ТУЋТГТД???ТУЌХт???ХУЋТЇХ ?ХУЌХОТЌ/УЋТГтЌУЊТВ?УЊТАтЌ??    // (STAFFУЊТАтЌ ?тЂУЊТИтА STAFFУЋТЅ?ban/kick/mute ?ЫУЋХ т УЊТВЦУЌТт УЌТАТЈУЋтЙТЈ)\r\n 104:     if (!canActOn(actorRole, target.role, isSuperAdmin)) {\r\n 105:       return NextResponse.json(\r\n 106:         { error: \"Cannot modify a member of equal or higher role\" },\r\n 107:         { status: 403 }\r\n 108:       );\r\n 109:     }\r\n 110: \r\n 111:     let updatedRestriction: ChatRestriction | undefined;\r\n 112:     let updatedRole: SpaceRole | undefined;\r\n 113:     const actionLabel = action;\r\n 114:     const actorName = session.user.name ?? undefined;\r\n 115: \r\n 116:     switch (action) {\