\n+\n+export interface UseSpaceMembersResult {\n+  /** userId т ManagedMember (ыБыЁ ьЌьЉьыЇ). */\n+  membersByUserId: Map<string, ManagedMember>;\n+  /** эИьЖь ыГИьИь ъЖь role(ьЄыьЗ ъИАьЄ) т stale prop ыь  ьЌьЉ. ыЏИьИъА/ыЏИыАъВЌ ь null. */\n+  actorRole: SpaceRole | null;\n+  /** GET 200(OWNER/STAFF/superAdmin) ьЌыЖ. falseыЉД ъДыІЌ UI ьЈъЙ. */\n+  isAuthorized: boolean;\n+  isLoading: boolean;\n+  /** ьЁь э ьЄыьЗ ьЌьЁАэ. */\n+  refetch: () => void;\n+}\n+\n+interface AdminMemberRow {\n+  id: string;\n+  role: SpaceRole;\n+  restriction: ChatRestrictionValue;\n+  userId: string | null;\n+}\n+\n+/**\n+ * LiveKit identityьь ъДыІЌ ыь userIdыЅМ эДьэыЄ.\n+ * `user-{userId}`ыЇ userIdыЁ ыГИыЄ. `guest-*`/`dev-anon-*`/ъИАэы ъДыІЌ ыь ьы(null).\n+ */\n+export function managedUserIdFromIdentity(identity: string): string | null {\n+  const PREFIX = \"user-\";\n+  if (!identity.startsWith(PREFIX)) return null;\n+  const userId = identity.slice(PREFIX.length);\n+  return userId.length > 0 ? userId : null;\n+}\n+\n+export function useSpaceMembers(\n+  spaceId: string,\n+  currentUserId: string,\n+  enabled: boolean\n+): UseSpaceMembersResult {\n+  const [membersByUserId, setMembersByUserId] = useState<Map<string, ManagedMember>>(\n+    () => new Map()\n+  );\n+  const [actorRole, setActorRole] = useState<SpaceRole | null>(null);\n+  const [isAuthorized, setIsAuthorized] = useState(false);\n+  const [isLoading, setIsLoading] = useState(false);\n+  const [reqTick, setReqTick] = useState(0);\n+\n+  const refetch = useCallback(() => setReqTick((n) => n + 1), []);\n+\n+  useEffect(() => {\n+    // ыЙэьБ/ьыГь ьь т ьДь  ьЄыьЗь эъИА(ыЋэ эЈыьД stale ъДыІЌ ьэыЅМ ыГДь эьЇ ьъВ).\n+    if (!enabled || !spaceId || !currentUserId) {\n+      setMembersByUserId(new Map());\n+      setActorRole(null);\n+      setIsAuthorized(false);\n+      setIsLoading(false);\n+      retur