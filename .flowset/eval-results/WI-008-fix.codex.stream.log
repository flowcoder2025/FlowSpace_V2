     where: { ...scope, status: \"ACTIVE\" },\r\n  39:       include: {\r\n  40:         template: { select: { key: true, name: true } },\r\n  41:         _count: { select: { members: true } },\r\n  42:         members: {\r\n  43:           where: { userId },\r\n  44:           select: { role: true },\r\n  45:           take: 1,\r\n  46:         },\r\n  47:       },\r\n  48:       orderBy: { updatedAt: \"desc\" },\r\n  49:     });\r\n  50: \r\n  51:     const result = spaces.map((s) => ({\r\n  52:       id: s.id,\r\n  53:       name: s.name,\r\n  54:       description: s.description,\r\n  55:       accessType: s.accessType,\r\n  56:       template: s.template,\r\n  57:       maxUsers: s.maxUsers,\r\n  58:       memberCount: s._count.members,\r\n  59:       myRole: s.members[0]?.role || null,\r\n  60:       logoUrl: s.logoUrl,\r\n  61:       primaryColor: s.primaryColor,\r\n  62:       createdAt: s.createdAt,\r\n  63:     }));\r\n  64: \r\n  65:     return NextResponse.json({ spaces: result });\r\n  66:   } catch (error) {\r\n  67:     return NextResponse.json(\r\n  68:       {\r\n  69:         error: \"Failed to fetch spaces\",\r\n  70:         details: error instanceof Error ? error.message : undefined,\r\n  71:       },\r\n  72:       { status: 500 }\r\n  73:     );\r\n  74:   }\r\n  75: }\r\n  76: \r\n  77: /** POST /api/spaces - ê³µê°„ ?ì„± */\r\n  78: export async function POST(request: Request) {\r\n  79:   try {\r\n  80:     const session = await auth();\r\n  81:     if (!session?.user?.id) {\r\n  82:       return NextResponse.json({ error: \"Unauthorized\" }, { status: 401 });\r\n  83:     }\r\n  84: \r\n  85:     // ê³µê°„ ?ì„±?€ ?ˆí¼?´ë“œë¯¼ë§Œ ?ˆìš© (?ì„±??ê³µê°„??OWNER ê¶Œí•œ?€ ?´í›„ ë©¤ë²„ PATCHë¡??„ìž„)\r\n  86:     if (session.user.isSuperAdmin !== true) {\r\n  87:       return NextResponse.json(\r\n  88:         { error: \"Only superAdmin can create spaces\", code: \"SUPER_ADMIN_REQUIRED\" },\r\n  89:         { status: 403 }\r\n  90:       );\r\n