{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'Get-Content -Path src/lib/pagination.test.ts'","aggregated_output":"import { describe, it, expect } from \"vitest\";\r\nimport {\r\n  DEFAULT_PAGE_LIMIT,\r\n  MAX_PAGE_LIMIT,\r\n  parsePageLimit,\r\n  parsePageNumber,\r\n  buildCursorPage,\r\n} from \"./pagination\";\r\n\r\ndescribe(\"parsePageLimit\", () => {\r\n  it(\"null/зүҚе Ұзҡ° ??ж—®еҚҠжҺЈиҮ§?, () => {\r\n    expect(parsePageLimit(null)).toBe(DEFAULT_PAGE_LIMIT);\r\n    expect(parsePageLimit(\"\")).toBe(DEFAULT_PAGE_LIMIT);\r\n  });\r\n\r\n  it(\"?жӣҘе„Ҡ ?жӣҘеһ¬ ??ж”ҙйёҪ?жҗҝ?, () => {\r\n    expect(parsePageLimit(\"10\")).toBe(10);\r\n    expect(parsePageLimit(\"50\")).toBe(50);\r\n    expect(parsePageLimit(\"100\")).toBe(MAX_PAGE_LIMIT);\r\n  });\r\n\r\n  it(\"MAX йҪ‘е ҰиҮЈ ??MAXжҗҝ??е Ёе„Ҡ\", () => {\r\n    expect(parsePageLimit(\"101\")).toBe(MAX_PAGE_LIMIT);\r\n    expect(parsePageLimit(\"100000\")).toBe(MAX_PAGE_LIMIT);\r\n  });\r\n\r\n  it(\"0/?еІҮеһ¬ ??ж—®еҚҠжҺЈиҮ§?, () => {\r\n    expect(parsePageLimit(\"0\")).toBe(DEFAULT_PAGE_LIMIT);\r\n    expect(parsePageLimit(\"-5\")).toBe(DEFAULT_PAGE_LIMIT);\r\n  });\r\n\r\n  it(\"зүҚеӢізҲј??NaN ?зҠҪзҡҪ ?е‘әзү“ ??ж—®еҚҠжҺЈиҮ§?, () => {\r\n    expect(parsePageLimit(\"abc\")).toBe(DEFAULT_PAGE_LIMIT);\r\n    expect(parsePageLimit(\"NaN\")).toBe(DEFAULT_PAGE_LIMIT);\r\n    // parseInt(\"12.9\") === 12 (?еІҮеһ¬???е ЁеҒ”?вӮ¬ JS parseInt ?ж¬–зҖҫ ???е ЁжҜ„)\r\n    expect(parsePageLimit(\"12.9\")).toBe(12);\r\n  });\r\n\r\n  // WI-022: ?жЈҖжҜҺ?йёҪзЎ  ж—®еҚҠжҺЈ ?ж©ғжҫҠжӯҶвӮ¬ ?о„…иөҙ ж°ӨжҢ«гҖҲ???еӢҙжҡ… optional defaultLimit\r\n  describe(\"defaultLimit ?иғізҖҪ (WI-022)\", () => {\r\n    it(\"null/зүҚе Ұзҡ°/?жҢ«е„Ҡж—ғ????еӢІе«ӯ??defaultLimit\", () => {\r\n      expect(parsePageLimit(null, 20)).toBe(20);\r\n      expect(parsePageLimit(\"\", 20)).toBe(20);\r\n      expect(parsePageLimit(\"0\", 20)).toBe(20);\r\n      expect(parsePageLimit(\"-5\", 20)).toBe(20);\r\n      expect(parsePageLimit(\"abc\", 20)).toBe(20);\r\n    });\r\n\r\n    it(\"?зҠҝжҜғ ?жӣҘеһ¬??defaultLimitз“ҝ?ж°Қжҗ“??ж©ҒзҹҠ ж”ҙйёҪ?жҗҝ?, () => {\r\n      expect(parsePageLimit(\"10\", 20)).toBe(10);\r\n      expect(parsePageLimit(\"75\", 20)).toBe(75);\r\n    });\r\n\r\n    it(\"MAX cap?вӮ¬ defaultLimitз“ҝ?ж°Қжҗ“??ж©ҒзҹҠ ?дҫ…жҜ„\", () => {\r\n      expect(parsePageLimit(\"100000\", 20)).toBe(MAX_PAGE_LIMIT);\r\n    });\r\n\r\n    it(\"?иғізҖҪ ж°ҷиғі?????DEFAULT_PAGE_LIMIT (ж—®еҠһгҖҲ ?иғізЁ–ж”өвӮ¬ ж°ҚжҢ«жҰҝ??\", () => {\r\n      expect(parsePageLimit(null)).toBe(DEFAULT_PAGE_LIMIT);\r\n    });\r\n  });\r\n});\r\n\r\ndescribe(\"parsePageNumber (WI-022)\", () => {\r\n  it(\"null/зүҚе Ұзҡ° ??1\", () => {\r\n    expect(parsePageNumber(null)).toBe(1);\r\n    expect(parsePageNumber(\"\")).toBe(1);\r\n  });\r\n\r\n  it(\"?жӣҘе„Ҡ ?жҲ©жҪЈ ?жӣҘеһ¬ ??ж”ҙйёҪ?жҗҝ?, () => {\r\n    expect(parsePageNumber(\"1\")).toBe(1);\r\n    expect(parsePageNumber(\"2\")).toBe(2);\r\n    expect(parsePageNumber(\"999\")).toBe(999);\r\n  });\r\n\r\n  it(\"0/?еІҮеһ¬ ??1 (?еІҮеһ¬ skip ж°ҡв•Ҳ?)\", () => {\r\n    expect(parsePageNumber(\"0\")).toBe(1);\r\n    expect(parsePageNumber(\"-5\")).toBe(1);\r\n  });\r\n\r\n  it(\"зүҚеӢізҲј??NaN ?зҠҪзҡҪ ?е‘әзү“ ??1\", () => {\r\n    expect(parsePageNumber(\"abc\")).toBe(1);\r\n    expect(parsePageNumber(\"NaN\")).toBe(1);\r\n  });\r\n\r\n  it(\"?дҫҶжҡ… ?е—ўжҪ“ (offset ж°©ж—Қжёј???еҠһжҫҠ???о„…иөҙ???ж©ғгҖҲ)\", () => {\r\n    expect(parsePageNumber(\"100000\")).toBe(100000);\r\n  });\r\n\r\n  it(\"?еІҮеһ¬???е ЁеҒ”?вӮ¬ parsePageLimitз“ҝ??ж¬–жҫ• ?ж»ҠР–??(parseInt ?зј„???\", () => {\r\n    expect(parsePageNumber(\"2.9\")).toBe(2);\r\n  });\r\n});\r\n\r\ndescribe(\"buildCursorPage\", () => {\r\n  const make = (n: number) => Array.from({ length: n }, (_, i) => ({ id: `s${i}` }));\r\n\r\n  it(\"????<= limit ??жҜөе Ё?жҜө??ж©ғжҫҠжӯҶвӮ¬(hasMore=false, nextCursor=null)\", () => {\r\n    const rows = make(3);\r\n    const page = buildCursorPage(rows, 5);\r\n    expect(page.items).toHaveLength(3);\r\n    expect(page.hasMore).toBe(false);\r\n    expect(page.nextCursor).toBeNull();\r\n  });\r\n\r\n  it(\"????== limit ??жҜөе Ё?жҜө??ж©ғжҫҠжӯҶвӮ¬(?о„Ҷз§і ?е—ўжҪ“)\", () => {\r\n    const rows = make(5);\r\n    const page = buildCursorPage(rows, 5);\r\n    expect(page.items).toHaveLength(5);\r\n    expect(page.hasMore).toBe(false);\r\n    expect(page.nextCursor).toBeNull();\r\n  });\r\n\r\n  it(\"????== limit + 1 ??hasMore=true, ?о„Ҷз§і 1з“Ҝ??е §е«§, nextCursor=жҜөе Ё?жҜө??иғізЁ–??id\", () => {\r\n    const rows = make(6); // limit 5 + 1\r\n    const page = buildCursorPage(rows, 5);\r\n    expect(page.items).toHaveLength(5);\r\n    expect(page.hasMore).toBe(true);\r\n    expect(page.nextCursor).toBe(\"s4\"); // items[4].id\r\n    expect(page.items.map((r) => r.id)).not.toContain(\"s5\"); // ?о„Ҷз§і ж°ҷйёҪеҗҖж–ј?  });\r\n\r\n  it(\"зүҚ?ж°ҡеҠһжЈҝ ??hasMore=false, nextCursor=null, items=[]\", () => {\r\n    const page = buildCursorPage<{ id: string }>([], 5);\r\n    expect(page.items).toEqual([]);\r\n    expect(page.hasMore).toBe(false);\r\n    expect(page.nextCursor).toBeNull();\r\n  });\r\n});\r\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'Get-Content -Path src/app/api/assets/route.test.ts -TotalCount 260'","aggregated_output":"import { describe, it, expect, vi, beforeEach } from \"vitest\";\r\nimport { NextRequest } from \"next/server\";\r\nimport { buildGetRequest, makeSession, readJson } from \"@/__tests__/helpers/api-route\";\r\n\r\n/** ж¬·жҲЁиҪҰ зӮңиҢ§Оң ?еІҶжҫ•ж°ҷз–ҷеҠҷ(`?k=a&k=b`)жҜі??ж»Қж§ғ?ж©Ғиөҙ ?еӢҙжҡ… raw-URL ?ж—Қз®” зүҚеІҶеҙқ. */\r\nfunction buildRawRequest(query: string): NextRequest {\r\n  return new NextRequest(new URL(`http://localhost/api/assets?${query}`));\r\n}\r\n\r\n// ============================================\r\n// auth()/prisma mock ??vi.hoisted + vi.mock?вӮ¬ ?еІҮжҫ• жҗҝж»Ңж»‘ ?иғіжҫҠ?гӮҚеҜҳ?жҺӘжҫ•\r\n// ?жЈҖжҜҺ??import ?еӢіжЈҺ ???еІҮжҫ•?ж„іеҠҖ жӯҶдҫ…зҲІ ?зҠҫжҹӣ?жҢ«жҡӯ ?ж»Ҡе«ҹ (?ж©ӮеӘ№?гӮӢо”Ў ж¬·жҲ©жҡҖ??ж”өе Ұ?).\r\n// ============================================\r\nconst { mockAuth, mockPrisma } = vi.hoisted(() => ({\r\n  mockAuth: vi.fn(),\r\n  mockPrisma: {\r\n    generatedAsset: { findMany: vi.fn(), count: vi.fn() },\r\n  },\r\n}));\r\n\r\nvi.mock(\"@/lib/auth\", () => ({ auth: mockAuth }));\r\nvi.mock(\"@/lib/prisma\", () => ({ prisma: mockPrisma }));\r\n\r\nimport { GET } from \"./route\";\r\n\r\n/** WI-021 ж°Үв•Үо”ў ?жҲЁе«· з“ҝеә—зҡҪ ??жӯҶжҲ«жҡ• (lean DTO). */\r\nconst LIST_ITEM_KEYS = [\r\n  \"id\",\r\n  \"type\",\r\n  \"name\",\r\n  \"status\",\r\n  \"filePath\",\r\n  \"thumbnailPath\",\r\n  \"createdAt\",\r\n  \"updatedAt\",\r\n] as const;\r\n\r\n/**\r\n * prisma.generatedAsset.findManyиҮ§вӮ¬ ж°ҡж©…ж«Ӯ?ж©Ӯе§… ??fixture.\r\n * ?жҲЁе«·/ select allowlist ?еІ…?жҜі??еӢҙжҡЈ, ?иғізЁ–?ж©Ӯв”җ ???ж©Ӯе§… ж°ҷзј„зҡӯ/?жҺӘ? ?еӢІж‘җ\r\n * (prompt/workflow/comfyuiJobId/userId/metadata/user/fileSize/isShared)жҜі? * ?ж©Ӯеј°?дҫ…жәӮжҗҝ??о„Ҳжҡ”?ж»Ҡе«ҹ ??findMany??mock?жҺӘжҫ• select?вӮ¬ ж°Қжҗ“??ж©ҒзҹҠ ???еӨ“жҪү ж”ҙйёҪ?жҗҝ? * ?еІҶзү‘ж¬ӨиҢ§?жҗҝ? ?жҲЁе«·?ж„іеҠҖ зүҚзҠҫ?ж°…?transform(toPublicAssetListItem)???о„ҮеӮ… ж°ҡв•ҲжҹҺиҮ§вӮ¬ ?гӮҢоңӮ?ж»Ҡе«ҹ.\r\n */\r\nfunction makeAssetListRow(overrides: Record<string, unknown> = {}) {\r\n  return {\r\n    id: \"asset-1\",\r\n    userId: \"owner-1\",\r\n    type: \"CHARACTER\",\r\n    name: \"?еӢіеҒ“\",\r\n    status: \"COMPLETED\",\r\n    filePath: \"/assets/generated/characters/x.png\",\r\n    thumbnailPath: \"/assets/generated/thumbnails/x.png\",\r\n    createdAt: new Date(\"2026-06-22T00:00:00.000Z\"),\r\n    updatedAt: new Date(\"2026-06-22T00:01:00.000Z\"),\r\n    // ???жҲЁе«·/select?ж„іеҠҖ ?ж»Ңж«ў?жЈҖжҡӯ ?ж©Ӯе§… ж°ҷзј„зҡӯ/?жҺӘ? ?еӢІж‘җ (?еІ…? иҮ§вӮ¬??\r\n    prompt: \"secret prompt\",\r\n    workflow: \"character-default\",\r\n    comfyuiJobId: \"comfy-job-xyz\",\r\n    fileSize: 9999,\r\n    isShared: false,\r\n    metadata: {\r\n      width: 1024,\r\n      frameWidth: 128,\r\n      prompt: \"secret prompt in metadata\",\r\n      accessSecret: \"should-never-leak\",\r\n    },\r\n    user: { id: \"owner-1\", name: \"?е¶ҠзҲ¶?? },\r\n    ...overrides,\r\n  };\r\n}\r\n\r\nbeforeEach(() => {\r\n  mockAuth.mockReset();\r\n  mockPrisma.generatedAsset.findMany.mockReset();\r\n  mockPrisma.generatedAsset.count.mockReset();\r\n});\r\n\r\ndescribe(\"GET /api/assets ???иғіоңӮ иҮ§вӮ¬??, () => {\r\n  it(\"ж°ҷиғіжҫ‘жӯғжҝҺжҫҠж°…?401?жҗ“зўғ prismaжҜі?з“ҜжҺӘж‘җжҜҪо„Ү? ?е©Ӣе§…??, async () => {\r\n    mockAuth.mockResolvedValue(makeSession(null));\r\n\r\n    const res = await GET(buildGetRequest(\"/api/assets\"));\r\n\r\n    expect(res.status).toBe(401);\r\n    expect(mockPrisma.generatedAsset.findMany).not.toHaveBeenCalled();\r\n    expect(mockPrisma.generatedAsset.count).not.toHaveBeenCalled();\r\n  });\r\n});\r\n\r\ndescribe(\"GET /api/assets ??owner ж”өеӢұиөҙ (shared ж°ҷиғі???\", () => {\r\n  beforeEach(() => {\r\n    mockAuth.mockResolvedValue(makeSession({ id: \"owner-1\" }));\r\n    mockPrisma.generatedAsset.findMany.mockResolvedValue([makeAssetListRow()]);\r\n    mockPrisma.generatedAsset.count.mockResolvedValue(1);\r\n  });\r\n\r\n  it(\"ж°Өиғіжҫ‘ ?ж„іеҒҳжҜө?иҮҒз»Ҡж®һ?ж»Ҡе«ҹ (where.userId = session.id, isShared ж°ҷз–ҷеҪ«??\", async () => {\r\n    await GET(buildGetRequest(\"/api/assets\"));\r\n\r\n    const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\r\n      where: Record<string, unknown>;\r\n    };\r\n    expect(arg.where.userId).toBe(\"owner-1\");\r\n    expect(arg.where.isShared).toBeUndefined();\r\n  });\r\n\r\n  it(\"иҮ§???оҖҲ?вӮ¬ ?жӣ§жӘҝ??lean з“ҝеә—зҡҪ ??жӯҶжҲ«жҡ•жҜө?ж°ҡж©…ж«Ӯ?ж»Ҡе«ҹ\", async () => {\r\n    const res = await GET(buildGetRequest(\"/api/assets\"));\r\n    const body = await readJson<{ assets: Record<string, unknown>[] }>(res);\r\n\r\n    expect(res.status).toBe(200);\r\n    expect(body.assets).toHaveLength(1);\r\n    expect(Object.keys(body.assets[0]).sort()).toEqual(\r\n      [...LIST_ITEM_KEYS].sort()\r\n    );\r\n  });\r\n\r\n  it(\"ж°ҷзј„зҡӯ/?жҺӘ? ?еӢІж‘җжҜі??иғізЁ–?ж©ғ? ?е©Ӣе§…??(transform ?о„ҮеӮ… ж°ҡв•ҲжҹҺ)\", async () => {\r\n    const res = await GET(buildGetRequest(\"/api/assets\"));\r\n    const body = await readJson<{ assets: Record<string, unknown>[] }>(res);\r\n    const item = body.assets[0];\r\n\r\n    expect(item.prompt).toBeUndefined();\r\n    expect(item.workflow).toBeUndefined();\r\n    expect(item.comfyuiJobId).toBeUndefined();\r\n    expect(item.userId).toBeUndefined();\r\n    expect(item.metadata).toBeUndefined();\r\n    expect(item.user).toBeUndefined();\r\n    expect(item.fileSize).toBeUndefined();\r\n    expect(item.isShared).toBeUndefined();\r\n  });\r\n\r\n  it(\"findMany??ж°ҷзј„зҡӯ/?жҺӘ? ?еӢІж‘җжҜі??зҠҫзЈ®??select?ж©ғ? ?е©Ӣе§…??(зӮңиҢ§Оң ??ж°ҡв•ҲжҹҺ)\", async () => {\r\n    await GET(buildGetRequest(\"/api/assets\"));\r\n\r\n    const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\r\n      select?: Record<string, unknown>;\r\n    };\r\n    expect(arg.select).toBeDefined();\r\n    expect(Object.keys(arg.select!).sort()).toEqual([...LIST_ITEM_KEYS].sort());\r\n    expect(arg.select?.prompt).toBeUndefined();\r\n    expect(arg.select?.workflow).toBeUndefined();\r\n    expect(arg.select?.comfyuiJobId).toBeUndefined();\r\n    expect(arg.select?.metadata).toBeUndefined();\r\n    expect(arg.select?.user).toBeUndefined();\r\n    expect(arg.select?.userId).toBeUndefined();\r\n  });\r\n});\r\n\r\ndescribe(\"GET /api/assets ??shared=true ж”өеӢұиөҙ (?вӮ¬??з“ҝеҘ ж№ў ?ж„іеҒҳ)\", () => {\r\n  beforeEach(() => {\r\n    mockAuth.mockResolvedValue(makeSession({ id: \"viewer-1\" }));\r\n    // ?вӮ¬??other-user) ?еІҮж№ў + isShared:true ?ж„іеҒҳ??ж°ҡж©…ж«Ӯ?ж©Ӯе§… ?дҫҶж«“\r\n    mockPrisma.generatedAsset.findMany.mockResolvedValue([\r\n      makeAssetListRow({\r\n        userId: \"other-user\",\r\n        isShared: true,\r\n        user: { id: \"other-user\", name: \"?вӮ¬?иғіе„©?иҶҳзҖҪ\" },\r\n      }),\r\n    ]);\r\n    mockPrisma.generatedAsset.count.mockResolvedValue(1);\r\n  });\r\n\r\n  it(\"isShared=trueжҗҝ?иҮҒз»Ҡж®һ?ж©Ғзўғ where.userIdжҗҝ?ж°Өиғіжҫ‘ ?ж»Қжҡ…??з“Ҝиғі? ?е©Ӣе§…??, async () => {\r\n    await GET(buildGetRequest(\"/api/assets\", { shared: \"true\" }));\r\n\r\n    const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\r\n      where: Record<string, unknown>;\r\n    };\r\n    expect(arg.where.isShared).toBe(true);\r\n    expect(arg.where.userId).toBeUndefined();\r\n  });\r\n\r\n  it(\"?вӮ¬??з“ҝеҘ ж№ў ?ж„іеҒҳ??lean ?гӮӢоқ‘ ж°ҡж©…ж«Ӯ?ж©Ғзўғ ?еІҮж№ў??ж°ҷзј„зҡӯ ?жӣӨзӮ’жҜі??иғізЁ–?ж©ғ? ?е©Ӣе§…??, async () => {\r\n    const res = await GET(buildGetRequest(\"/api/assets\", { shared: \"true\" }));\r\n    const body = await readJson<{ assets: Record<string, unknown>[] }>(res);\r\n    const item = body.assets[0];\r\n\r\n    expect(Object.keys(item).sort()).toEqual([...LIST_ITEM_KEYS].sort());\r\n    // ?вӮ¬???жҝҺеҠҡ???жӣӨзӮ’ ж°ҷйёҪеҗҖж–ј?(codex consult: shared ж”өеӢұиөҙ user/metadata зүҚеӢІеҗҖж–ј?\r\n    expect(item.user).toBeUndefined();\r\n    expect(item.userId).toBeUndefined();\r\n    expect(item.metadata).toBeUndefined();\r\n    expect(item.prompt).toBeUndefined();\r\n  });\r\n});\r\n\r\ndescribe(\"GET /api/assets ???еӢҙеҠҷ/?ж©ғжҫҠжӯҶвӮ¬?гӮҢжҫҠ???еӢІе«ӯ\", () => {\r\n  beforeEach(() => {\r\n    mockAuth.mockResolvedValue(makeSession({ id: \"owner-1\" }));\r\n    mockPrisma.generatedAsset.findMany.mockResolvedValue([]);\r\n    mockPrisma.generatedAsset.count.mockResolvedValue(0);\r\n  });\r\n\r\n  it(\"type/status ?еӢҙеҠҷжҜі??вӮ¬ж°ҚиғізҖҪжҗҝ?where??ж°ҡж©ғжҰҝ?ж»Ҡе«ҹ\", async () => {\r\n    await GET(\r\n      buildGetRequest(\"/api/assets\", { type: \"character\", status: \"completed\" })\r\n    );\r\n\r\n    const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\r\n      where: Record<string, unknown>;\r\n    };\r\n    expect(arg.where.type).toBe(\"CHARACTER\");\r\n    expect(arg.where.status).toBe(\"COMPLETED\");\r\n  });\r\n\r\n  it(\"page/limitжҗҝ?skip/takeжҜі?з“ҝеӢіеҒҳ?ж»Ҡе«ҹ\", async () => {\r\n    await GET(buildGetRequest(\"/api/assets\", { page: \"2\", limit: \"10\" }));\r\n\r\n    const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\r\n      skip: number;\r\n      take: number;\r\n    };\r\n    expect(arg.skip).toBe(10);\r\n    expect(arg.take).toBe(10);\r\n  });\r\n\r\n  it(\"count??findMany?вӮ¬ ?ж¬–жҫ•??whereжҗҝ??иғізЁ–?ж»Ҡе«ҹ\", async () => {\r\n    await GET(buildGetRequest(\"/api/assets\", { shared: \"true\" }));\r\n\r\n    const findArg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\r\n      where: Record<string, unknown>;\r\n    };\r\n    const countArg = mockPrisma.generatedAsset.count.mock.calls[0][0] as {\r\n      where: Record<string, unknown>;\r\n    };\r\n    expect(countArg.where).toEqual(findArg.where);\r\n  });\r\n\r\n  it(\"pagination ж°…ж—җ??еҠһжҫҠ?еҚҠ? ?жҲЁе«·???о„Ҳжҡ”?ж»Ҡе«ҹ\", async () => {\r\n    mockPrisma.generatedAsset.count.mockResolvedValue(25);\r\n\r\n    const res = await GET(buildGetRequest(\"/api/assets\", { limit: \"10\" }));\r\n    const body = await readJson<{\r\n