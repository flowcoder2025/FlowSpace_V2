{"type":"item.completed","item":{"id":"item_10","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'Get-Content -Path src/lib/pagination.ts'","aggregated_output":"/**\r\n * ?ЛңГ¬ВқВҙГ¬В§вӮ¬?ВӨГ¬ВқВҙ??Г¬ВҝВјГ«ВҰВ¬ ?Е’Г¬вҖ№Вұ + Г«ВівӮ¬??ГӘВіВөГ¬ЕЎВ© ?В¬ГӯВҚВј (?Е“Г¬ЛҶЛң ?ВЁГ¬ЛҶЛң ??Prisma/React Г«В¬ВҙГ¬ВқЛңГ¬ВЎ?.\r\n *\r\n * - `parsePageLimit`/`parsePageNumber`: Г¬ВҝВјГ«ВҰВ¬?ВӨГӯЕ ВёГ«В§?limit/pageГ«ВҘ??ЛҶГ¬В вҖһ???вҖўГ¬ЛҶЛңГ«ВЎ??вҖўГӘВ·Е“??\r\n * - `buildCursorPage`: cursor ?ЛңГ¬ВқВҙГ¬В§вӮ¬?ВӨГ¬ВқВҙ?ЛңГ¬ВқЛң `take: limit + 1` ?ВЁГӯвҖһВҙ\r\n *   (`src/app/api/spaces/[id]/messages/route.ts` ГӘВҙвӮ¬Г«ВЎвӮ¬)??Г¬ВәВЎГ¬Е Вҗ????limitГ«ВіВҙГ«вҖ№ВӨ 1ГӘВұ??? *   ГӘВ°вӮ¬?ВёГ¬ЛңВЁ ?вҖ°Г¬ВқвҖһ ?ЛңГ«ВқВј `hasMore`/`nextCursor`Г«ВҘ??вҖһГ¬В¶Е“?Е“Г«вҖ№ВӨ.\r\n *\r\n * offset ?ЛңГ¬ВқВҙГ¬В§вӮ¬?ВӨГ¬ВқВҙ??`skip`/`take`) ?ВјГ¬ЕЎВ°?ВёГ«Е вҖқ `parsePageNumber`+`parsePageLimit`Г«В§?\r\n * cursor ?ЛңГ¬ВқВҙГ¬В§вӮ¬?ВӨГ¬ВқВҙ???ВјГ¬ЕЎВ°?ВёГ«Е вҖқ `parsePageLimit`+`buildCursorPage`Г«ВҘ??В¬Г¬ЕЎВ©?Е“Г«вҖ№ВӨ.\r\n */\r\n\r\n/** limit Г«ВҜВёГ¬????ВҙГ¬Ж’ВҒГ¬В№???ГӘВёВ°Г«ВіВё ?ЛңГ¬ВқВҙГ¬В§вӮ¬ ?В¬ГӘВёВ° */\r\nexport const DEFAULT_PAGE_LIMIT = 50;\r\n/** ?ВҙГ«ВқВј?ВҙГ¬вҖ“Вё?ВёГӘ? ?вҖқГ¬ВІВӯ ГӘВ°вӮ¬?ВҘГӯвҖўЕ“ Г¬ВөЕ“Г«? ?ЛңГ¬ВқВҙГ¬В§вӮ¬ ?В¬ГӘВёВ° (?вҖһГ¬вҖ”Вӯ Г«ВӘВ©Г«ВЎВқ ??ВЈВј Г«В°В©Г¬?) */\r\nexport const MAX_PAGE_LIMIT = 100;\r\n\r\n/**\r\n * Г¬ВҝВјГ«ВҰВ¬?ВӨГӯЕ ВёГ«В§?`limit` ГӘВ°вҖҷГ¬ВқвҖһ ?ЛҶГ¬В вҖһ???вҖўГ¬ЛҶЛң ?ЛңГ¬ВқВҙГ¬В§вӮ¬ ?В¬ГӘВёВ°Г«ВЎ??вҖўГӘВ·Е“?вҖқГӯвҖўЕ“??\r\n * - null/Г«В№ЛҶГӘВ°вҖҷ/Г«В№вҖһГ¬В вҖў??0 ?ВҙГӯвҖўЛң ??`defaultLimit`\r\n * - MAX_PAGE_LIMIT Г¬ВҙЛҶГӘВіВј ??MAX_PAGE_LIMITГ«ВЎ??ЛҶГ¬Ж’ВҒ(cap)\r\n *\r\n * @param defaultLimit limit Г«ВҜВёГ¬????ВҙГ¬Ж’ВҒГ¬В№???ГӘВёВ°Г«ВіВёГӘВ°??ВјГ¬ЕЎВ°?ВёГ«ВівҖһ ГӘВёВ°Г«ВіВё ?ЛңГ¬ВқВҙГ¬В§вӮ¬ ?В¬ГӘВёВ°Г«ВҘ? *   Г«ВіВҙГ¬ВЎВҙ?ЛңГӘВёВ° ?вҖһГӯвҖўЕ“ ?В ГӯЖ’Вқ ?ВёГ¬ЕҫВҗ, Г«ВҜВёГ¬?????DEFAULT_PAGE_LIMIT).\r\n */\r\nexport function parsePageLimit(\r\n  raw: string | null,\r\n  defaultLimit: number = DEFAULT_PAGE_LIMIT\r\n): number {\r\n  const n = parseInt(raw ?? \"\", 10);\r\n  if (!Number.isFinite(n) || n <= 0) return defaultLimit;\r\n  return Math.min(n, MAX_PAGE_LIMIT);\r\n}\r\n\r\n/**\r\n * Г¬ВҝВјГ«ВҰВ¬?ВӨГӯЕ ВёГ«В§?`page`(1-base offset ?ЛңГ¬ВқВҙГ¬В§вӮ¬ Г«ВІЛҶГӯЛңВё)Г«ВҘ??ЛҶГ¬В вҖһ???вҖҳГ¬ВқЛң ?вҖўГ¬ЛҶЛңГ«ВЎ??вҖўГӘВ·Е“?вҖқГӯвҖўЕ“??\r\n * - null/Г«В№ЛҶГӘВ°вҖҷ/Г«В№вҖһГ¬В вҖў??1 Г«ВҜВёГ«В§Е’ ??1\r\n * - ?ВҒГӯвҖўЕ“ ?вҖ Г¬ВқЕ’ (offset ?ЛңГ¬ВқВҙГ¬В§вӮ¬ Г«ВІвҖқГ¬Е“вҖһ???В°Г¬ВқВҙ???В¬ГӘВёВ°???ЛңГ¬ВЎВҙ)\r\n *\r\n * offset ?ВјГ¬ЕЎВ°?ВёГ¬вҖ”Вҗ??`skip: (page - 1) * limit` ГӘВівҖһГ¬вҖҡВ° ??pageГӘВ°вӮ¬ NaN/0/?Е’Г¬ЛҶЛңГ«В©? * ?Е’Г¬ЛҶЛң skip???ЛңГ¬вҖ“Вҙ PrismaГӘВ°вӮ¬ throw(??00)?ЛңГ«ВҚЛң ГӘВІЖ’Г¬ВқвҖһ Г«В°В©Г¬??Е“Г«вҖ№ВӨ.\r\n */\r\nexport function parsePageNumber(raw: string | null): number {\r\n  const n = parseInt(raw ?? \"\", 10);\r\n  if (!Number.isFinite(n) || n < 1) return 1;\r\n  return n;\r\n}\r\n\r\nexport interface CursorPage<T> {\r\n  items: T[];\r\n  nextCursor: string | null;\r\n  hasMore: boolean;\r\n}\r\n\r\n/**\r\n * `take: limit + 1`Г«ВЎ?Г¬ВЎВ°ГӯЕЎЕ’????Г«В°В°Г¬вҖ”Вҙ???ЛңГ¬ВқВҙГ¬В§вӮ¬Г«ВЎ?Г«ВівӮ¬?ЛңГӯвҖўЕ“??\r\n * ?вҖ°Г¬ВқВҙ limitГ«ВіВҙГ«вҖ№ВӨ Г«В§ЕҪГ¬Е“ВјГ«В©?Г«В§ЛҶГ¬?Г«В§??В¬Г«В¶вҖһ) 1ГӘВұВҙГ¬ВқвҖһ ?ЛңГ«ВқВј?ВҙГӘВіВ  ГӘВ·?Г¬В§ВҒГ¬В вҖһ ?вҖ°Г¬ВқЛң idГ«ВҘ? * ?ВӨГ¬ВқЕ’ cursorГ«ВЎ??В¬Г¬ЕЎВ©?Е“Г«вҖ№ВӨ.\r\n *\r\n * @param rows  limit + 1 Г«В§Е’ГӯВҒВј Г¬ВЎВ°ГӯЕЎЕ’?????вҖўГ«В В¬ ?вҖһГ«ВЈЕ’ ?ВҒГӯЖ’Е“, ГӘВ°??вҖ°Г¬? ГӘВіВ Г¬Е“В  `id` Г«ВіВҙГ¬Е“В )\r\n * @param limit ?ЛңГ¬ВқВҙГ¬В§вӮ¬ ?В¬ГӘВёВ°\r\n */\r\nexport function buildCursorPage<T extends { id: string }>(\r\n  rows: T[],\r\n  limit: number\r\n): CursorPage<T> {\r\n  const hasMore = rows.length > limit;\r\n  const items = hasMore ? rows.slice(0, limit) : rows;\r\n  const nextCursor = hasMore ? items[items.length - 1]?.id ?? null : null;\r\n  return { items, nextCursor, hasMore };\r\n}\r\n","exit_code":0,"status":"completed"}}
