{"type":"item.completed","item":{"id":"item_7","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'Get-Content -Path src/app/api/assets/route.ts'","aggregated_output":"import { NextRequest, NextResponse } from \"next/server\";\r\nimport { AssetType, AssetStatus } from \"@prisma/client\";\r\nimport { auth } from \"@/lib/auth\";\r\nimport { prisma } from \"@/lib/prisma\";\r\nimport { parsePageLimit, parsePageNumber } from \"@/lib/pagination\";\r\nimport { toPublicAssetListItem } from \"@/features/assets\";\r\n\r\n/** limit Г«ВҜВёГ¬?????ГӘВёВ°Г«ВіВё ?ЛңГ¬ВқВҙГ¬В§вӮ¬ ?В¬ГӘВёВ° (WI-022 ?ВҙГ¬В вҖһ ?в„ўГ¬ЕҫвҖҳ Г«ВіВҙГ¬ВЎВҙ). */\r\nconst ASSETS_DEFAULT_LIMIT = 20;\r\n/**\r\n * ?вҖһГӯвҖһВ° enum allowlist ??Prisma ?В°Гӯ???enum?ВҗГ¬вҖһЕ“ ?вҖһГ¬В¶Е“(?ЛңГ«вҖңЕ“Г¬ВҪвҖқГ«вҖқВ© Г«В°В°Г¬вҖ”Вҙ ?Е’ГӯвҖқВј, enum\r\n * Г¬В¶вҖқГӘ? ???ВҗГ«ВҸв„ў ?в„ўГӘВёВ°??. ГӘВ°вҖҷГ¬? Г«ВӘВЁГ«вҖҳВҗ ?вӮ¬Г«В¬ВёГ¬ЕҫВҗ???вҖҰГ«В ВҘ???вҖўГӘВ·Е“??trim+?вӮ¬Г«В¬ВёГ¬ЕҫВҗ)????ГӘВІвӮ¬Г¬ВҰВқГӯвҖўЕ“??\r\n */\r\nconst ASSET_TYPE_VALUES = new Set<string>(Object.values(AssetType));\r\nconst ASSET_STATUS_VALUES = new Set<string>(Object.values(AssetStatus));\r\n\r\n/**\r\n * Г¬ВҝВјГ«ВҰВ¬ enum ?вҖһГӯвҖһВ°Г«ВҘ??вҖўГӘВ·Е“??trim+?вӮ¬Г«В¬ВёГ¬ЕҫВҗ)ГӮВ·ГӘВІвӮ¬Г¬ВҰВқГӯвҖўЕ“??\r\n * Г¬ВӨвҖҳГ«ВіВө ?Е’Г«ВқВјГ«ВҜВёГӯвҖһВ°(`?type=a&type=b`)??ГӘВІвӮ¬Г¬ВҰ??В°ГӯЕЎЕ’Г«ВҘ?Г«В§вҖ°ГӘВёВ° ?вҖһГӯвҖўВҙ `getAll()`Г«ВЎ?Г«В°вҖәГ¬?\r\n * **Г«ВӘВЁГ«вҖңВ  ГӘВ°?*??ГӘВІвӮ¬?В¬ГӯвҖўЕ“??(`get()`?вӮ¬ Г¬ВІ?ГӘВ°вҖҷГ«В§Е’ Г«Вҙ?invalid 2Г«ВІЛҶГ¬В§Вё ГӘВ°вҖҷГ¬ВқВҙ ?ВЁГ«Е вҖқ??.\r\n * - Г«В№?Г«В°В°Г¬вҖ”Вҙ/ГӘВіВөГ«В°Вұ-onlyГ«В§???undefined (?вҖһГӯвҖһВ° Г«ВҜВёГ¬В ВҒ?? trim ??Г«В№вҖһГ«В©Вҙ \"Г«ВҜВёГ¬???ГӘВі??в„ўГ¬ВқВј)\r\n * - ?ЛңГ«вҖҡЛң?ВјГ«ВҸвҖһ allowlist Г«В¶ЛҶГ¬ВқВјГ¬В№???null (?ВёГ¬В¶Е“Г«В¶вӮ¬ГӘВ°вӮ¬ 400 INVALID_FILTERГ«ВЎ?Г¬ВІЛңГ«ВҰВ¬)\r\n * - ?вҖһГ«? ?В ГӯЕЎВЁ ??Г¬ВІ?ГӘВ°?Prisma scalar equality)?ВјГ«ВЎЕ“ ?вҖһГӯвҖһВ°\r\n */\r\nfunction normalizeEnumFilter(\r\n  values: string[],\r\n  allowed: Set<string>\r\n): string | undefined | null {\r\n  const normalized = values\r\n    .map((v) => v.trim().toUpperCase())\r\n    .filter((v) => v.length > 0);\r\n  if (normalized.length === 0) return undefined;\r\n  if (normalized.some((v) => !allowed.has(v))) return null;\r\n  return normalized[0];\r\n}\r\n\r\n/** GET /api/assets - ?ВҗГ¬вҖҰвҖ№ Г«ВӘВ©Г«ВЎВқ (?вҖһГӯвҖһВ°Г«В§? */\r\nexport async function GET(request: NextRequest) {\r\n  try {\r\n    const session = await auth();\r\n    if (!session?.user?.id) {\r\n      return NextResponse.json({ error: \"Unauthorized\" }, { status: 401 });\r\n    }\r\n\r\n    const searchParams = request.nextUrl.searchParams;\r\n    const shared = searchParams.get(\"shared\");\r\n\r\n    // ?вҖҰГ«В ВҘ ГӘВІвӮ¬Г¬ВҰ?WI-022): type/statusГ«ВҘ?AssetType/AssetStatus allowlistГ«ВЎ?ГӘВІвӮ¬Г¬ВҰ?\r\n    // ?ЛңГ«ВӘВ»??enum?вӮ¬ Г¬ВЎВ°Г¬ЕЎВ©??Г«В¬ВҙГ¬вҖ№Е“(?вҖһГ¬ВІВҙ Г«ВӘВ©Г«ВЎВқ ?вҖҳГ«вҖ№Вө)?ЛңГ¬? ?Е ГӘВіВ  400?ВјГ«ВЎЕ“ ГӘВұВ°Г¬В ЛҶ(WI-009 ?вҖўГӯвҖўВ©).\r\n    // getAllГ«ВЎ?Г¬ВӨвҖҳГ«ВіВө ?Е’Г«ВқВјГ«ВҜВёГӯвҖһВ°ГӘВ№Е’Г¬? ?вҖһГ¬ЛҶЛң ГӘВІвӮ¬Г¬ВҰ?Г¬ВӨвҖҳГ«ВіВөГӘВ°?ГӘВІвӮ¬Г¬ВҰ??В°ГӯЕЎЕ’ Г¬В°ВЁГ«вҖ№ВЁ, codex r2).\r\n    const type = normalizeEnumFilter(\r\n      searchParams.getAll(\"type\"),\r\n      ASSET_TYPE_VALUES\r\n    );\r\n    const status = normalizeEnumFilter(\r\n      searchParams.getAll(\"status\"),\r\n      ASSET_STATUS_VALUES\r\n    );\r\n    if (type === null || status === null) {\r\n      return NextResponse.json(\r\n        { error: \"Invalid asset filter\", code: \"INVALID_FILTER\" },\r\n        { status: 400 }\r\n      );\r\n    }\r\n\r\n    // page/limit ?вҖўГӘВ·Е“??WI-022): NaN/0/?Е’Г¬ЛҶЛң ???Е’Г¬ЛҶЛң skip(500) Г«В°В©Г¬?, limit ?ВҒГӯвҖўЕ“ 100.\r\n    const page = parsePageNumber(searchParams.get(\"page\"));\r\n    const limit = parsePageLimit(searchParams.get(\"limit\"), ASSETS_DEFAULT_LIMIT);\r\n\r\n    const where: Record<string, unknown> = {};\r\n\r\n    if (shared === \"true\") {\r\n      // ГӘВіВөГ¬ЕЎВ© ?ВҗГ¬вҖҰвҖ№ Г¬ВЎВ°ГӯЕЎЕ’ (?вҖһГ«В°вҖқ?вӮ¬ ?В ГӯЖ’Вқ ??\r\n      where.isShared = true;\r\n    } else {\r\n      // Г«ВіВёГ¬ВқВё ?ВҗГ¬вҖҰвҖ№Г«В§?Г¬ВЎВ°ГӯЕЎЕ’ (IDOR Г«В°В©Г¬?)\r\n      where.userId = session.user.id;\r\n    }\r\n\r\n    if (type) {\r\n      where.type = type;\r\n    }\r\n    if (status) {\r\n      where.status = status;\r\n    }\r\n\r\n    // ?вҖҳГ«вҖ№Вө allowlist (WI-021): Г«ВӘВ©Г«ВЎВқ?вӮ¬ lean DTOГ«В§?Г«В°ЛңГӯв„ўЛң?Е“Г«вҖ№ВӨ.\r\n    // shared=true Г«В¶вҖһГӘВёВ°??owner ГӘВІЕ’Г¬ВқВҙ???вҖ Г¬ВқВҙ ?вӮ¬??ГӘВіВөГ¬Е“В  ?ВҗГ¬вҖҡВ°??Г«В°ЛңГӯв„ўЛң?ЛңГ«?Г«ВЎ??ЛңГ«ВҸвҖһ??ГӘВіВөГ¬Е“В )\r\n    // prompt/workflow/comfyuiJobId(Г«ВҜВјГӘВ°Вҗ)ГӮВ·metadataГӮВ·user??select?ЛңГ¬? ?Е ГӘВіВ ,\r\n    // toPublicAssetListItemГ«ВЎ??вҖҳГ«вҖ№Вө ??Г¬В§вҖҳГӯвҖўВ©??ГӘВіВ Г¬В вҖў?Е“Г«вҖ№ВӨ(?В¬Г¬ВёВө Г«В°В©Г¬вҖ“Вҙ).\r\n    const [assets, total] = await Promise.all([\r\n      prisma.generatedAsset.findMany({\r\n        where,\r\n        orderBy: { createdAt: \"desc\" },\r\n        skip: (page - 1) * limit,\r\n        take: limit,\r\n        select: {\r\n          id: true,\r\n          type: true,\r\n          name: true,\r\n          status: true,\r\n          filePath: true,\r\n          thumbnailPath: true,\r\n          createdAt: true,\r\n          updatedAt: true,\r\n        },\r\n      }),\r\n      prisma.generatedAsset.count({ where }),\r\n    ]);\r\n\r\n    return NextResponse.json({\r\n      assets: assets.map(toPublicAssetListItem),\r\n      pagination: {\r\n        page,\r\n        limit,\r\n        total,\r\n        totalPages: Math.ceil(total / limit),\r\n      },\r\n    });\r\n  } catch (error) {\r\n    return NextResponse.json(\r\n      {\r\n        error: \"Failed to fetch assets\",\r\n        details: error instanceof Error ? error.message : undefined,\r\n      },\r\n      { status: 500 }\r\n    );\r\n  }\r\n}\r\n","exit_code":0,"status":"completed"}}
