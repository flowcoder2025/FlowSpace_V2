 мӢң DEFAULT_PAGE_LIMIT).\n  */\n-export function parsePageLimit(raw: string | null): number {\n+export function parsePageLimit(\n+  raw: string | null,\n+  defaultLimit: number = DEFAULT_PAGE_LIMIT\n+): number {\n   const n = parseInt(raw ?? \"\", 10);\n-  if (!Number.isFinite(n) || n <= 0) return DEFAULT_PAGE_LIMIT;\n+  if (!Number.isFinite(n) || n <= 0) return defaultLimit;\n   return Math.min(n, MAX_PAGE_LIMIT);\n }\n \n+/**\n+ * мҝјлҰ¬мҠӨнҠёл§Ғ `page`(1-base offset нҺҳмқҙм§Җ лІҲнҳё)лҘј м•Ҳм „н•ң м–‘мқҳ м •мҲҳлЎң м •к·ңнҷ”н•ңлӢӨ.\n+ * - null/л№Ҳк°’/л№„м •мҲҳ/1 лҜёл§Ң вҶ’ 1\n+ * - мғҒн•ң м—ҶмқҢ (offset нҺҳмқҙм§Җ лІ”мң„лҠ” лҚ°мқҙн„° нҒ¬кё°м—җ мқҳмЎҙ)\n+ *\n+ * offset лқјмҡ°нҠём—җм„ң `skip: (page - 1) * limit` кі„мӮ° мӢң pageк°Җ NaN/0/мқҢмҲҳл©ҙ\n+ * мқҢмҲҳ skipмқҙ лҗҳм–ҙ Prismaк°Җ throw(вҶ’500)н•ҳлҚҳ кІғмқ„ л°©м§Җн•ңлӢӨ.\n+ */\n+export function parsePageNumber(raw: string | null): number {\n+  const n = parseInt(raw ?? \"\", 10);\n+  if (!Number.isFinite(n) || n < 1) return 1;\n+  return n;\n+}\n+\n export interface CursorPage<T> {\n   items: T[];\n   nextCursor: string | null;\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_5","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'git diff develop...HEAD -- src/lib/pagination.test.ts'","aggregated_output":"diff --git a/src/lib/pagination.test.ts b/src/lib/pagination.test.ts\nindex 7956789..edeb2ab 100644\n--- a/src/lib/pagination.test.ts\n+++ b/src/lib/pagination.test.ts\n@@ -3,6 +3,7 @@ import {\n   DEFAULT_PAGE_LIMIT,\n   MAX_PAGE_LIMIT,\n   parsePageLimit,\n+  parsePageNumber,\n   buildCursorPage,\n } from \"./pagination\";\n \n@@ -34,6 +35,61 @@ describe(\"parsePageLimit\", () => {\n     // parseInt(\"12.9\") === 12 (мҶҢмҲҳм җ м ҲмӮӯмқҖ JS parseInt лҸҷмһ‘ вҖ” н—Ҳмҡ©)\n     expect(parsePageLimit(\"12.9\")).toBe(12);\n   });\n+\n+  // WI-022: лқјмҡ°нҠёлі„ кё°ліё нҺҳмқҙм§Җ нҒ¬кё° ліҙмЎҙмқ„ мң„н•ң optional defaultLimit\n+  describe(\"defaultLimit мқёмһҗ (WI-022)\", () => {\n+    it(\"null/л№Ҳк°’/мқҙмғҒм№ҳ вҶ’ м „лӢ¬н•ң defaultLimit\", () => {\n+      expect(parsePageLimit(null, 20)).toBe(20);\n+      expect(parsePageLimit(\"\", 20)).toBe(20);\n+      expect(parsePageLimit(\"0\", 20)).toBe(20);\n+      expect(parsePageLimit(\"-5\", 20)).toBe(20);\n+      expect(parsePageLimit(\"abc\", 20)).toBe(20);\n+    });\n+\n+    it(\"мң нҡЁ м •мҲҳлҠ” defaultLimitкіј л¬ҙкҙҖн•ҳкІҢ к·ёлҢҖлЎң\", () => {\n+      expect(parsePageLimit(\"10\", 20)).toBe(10);\n+      expect(parsePageLimit(\"75\", 20)).toBe(75);\n+    });\n+\n+    it(\"MAX capмқҖ defaultLimitкіј л¬ҙкҙҖн•ҳкІҢ м Ғмҡ©\", () => {\n+      expect(parsePageLimit(\"100000\", 20)).toBe(MAX_PAGE_LIMIT);\n+    });\n+\n+    it(\"мқёмһҗ лҜём§Җм • мӢң DEFAULT_PAGE_LIMIT (кё°мЎҙ нҳём¶ңл¶Җ л¬ҙмҳҒн–Ҙ)\", () => {\n+      expect(parsePageLimit(null)).toBe(DEFAULT_PAGE_LIMIT);\n+    });\n+  });\n+});\n+\n+describe(\"parsePageNumber (WI-022)\", () => {\n+  it(\"null/л№Ҳк°’ вҶ’ 1\", () => {\n+    expect(parsePageNumber(null)).toBe(1);\n+    expect(parsePageNumber(\"\")).toBe(1);\n+  });\n+\n+  it(\"м •мғҒ м–‘мқҳ м •мҲҳ вҶ’ к·ёлҢҖлЎң\", () => {\n+    expect(parsePageNumber(\"1\")).toBe(1);\n+    expect(parsePageNumber(\"2\")).toBe(2);\n+    expect(parsePageNumber(\"999\")).toBe(999);\n+  });\n+\n+  it(\"0/мқҢмҲҳ вҶ’ 1 (мқҢмҲҳ skip л°©м§Җ)\", () => {\n+    expect(parsePageNumber(\"0\")).toBe(1);\n+    expect(parsePageNumber(\"-5\")).toBe(1);\n+  });\n+\n+  it(\"л№„м •мҲҳ/NaN мң л°ң мһ…л Ҙ вҶ’ 1\", () => {\n+    expect(parsePageNumber(\"abc\")).toBe(1);\n+    expect(parsePageNumber(\"NaN\")).toBe(1);\n+  });\n+\n+  it(\"мғҒн•ң м—ҶмқҢ (offset лІ”мң„лҠ” лҚ°мқҙн„° нҒ¬кё°м—җ мқҳмЎҙ)\", () => {\n+    expect(parsePageNumber(\"100000\")).toBe(100000);\n+  });\n+\n+  it(\"мҶҢмҲҳм җ м ҲмӮӯмқҖ parsePageLimitкіј лҸҷмқј мӢңл§ЁнӢұ (parseInt мқјкҙҖм„ұ)\", () => {\n+    expect(parsePageNumber(\"2.9\")).toBe(2);\n+  });\n });\n \n describe(\"buildCursorPage\", () => {\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_6","type":"command_execution","command":"\"C:\\\\Windows\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command 'git diff develop...HEAD -- src/app/api/assets/route.test.ts'","aggregated_output":"diff --git a/src/app/api/assets/route.test.ts b/src/app/api/assets/route.test.ts\nindex ae944e5..083f80a 100644\n--- a/src/app/api/assets/route.test.ts\n+++ b/src/app/api/assets/route.test.ts\n@@ -1,6 +1,12 @@\n import { describe, it, expect, vi, beforeEach } from \"vitest\";\n+import { NextRequest } from \"next/server\";\n import { buildGetRequest, makeSession, readJson } from \"@/__tests__/helpers/api-route\";\n \n+/** мӨ‘ліө мҝјлҰ¬ нҢҢлқјлҜён„°(`?k=a&k=b`)лҘј н‘ңнҳ„н•ҳкё° мң„н•ң raw-URL мҡ”мІӯ л№ҢлҚ”. */\n+function buildRawRequest(query: string): NextRequest {\n+  return new NextRequest(new URL(`http://localhost/api/assets?${query}`));\n+}\n+\n // ============================================\n // auth()/prisma mock вҖ” vi.hoisted + vi.mockмқҖ нҢҢмқј лЎңм»¬ нҳёмқҙмҠӨнҢ…мқҙлқј\n // лқјмҡ°нҠё import м „м—җ мқҙ нҢҢмқјм—җм„ң м§Ғм ‘ м„ м–ён•ҙм•ј н•ңлӢӨ (н•ҳлӢҲмҠӨлЎң мӨ‘м•ҷнҷ” л¶Ҳк°Җ).\n@@ -239,6 +245,147 @@ describe(\"GET /api/assets вҖ” н•„н„°/нҺҳмқҙм§Җл„Өмқҙм…ҳ м „лӢ¬\", () => {\n   });\n });\n \n+describe(\"GET /api/assets вҖ” мһ…л Ҙ кІҖмҰқ (WI-022)\", () => {\n+  beforeEach(() => {\n+    mockAuth.mockResolvedValue(makeSession({ id: \"owner-1\" }));\n+    mockPrisma.generatedAsset.findMany.mockResolvedValue([]);\n+    mockPrisma.generatedAsset.count.mockResolvedValue(0);\n+  });\n+\n+  it(\"мһҳлӘ»лҗң type вҶ’ 400 INVALID_FILTER, prisma лҜём ‘к·ј\", async () => {\n+    const res = await GET(buildGetRequest(\"/api/assets\", { type: \"weapon\" }));\n+    const body = await readJson<{ error: string; code: string }>(res);\n+\n+    expect(res.status).toBe(400);\n+    expect(body.code).toBe(\"INVALID_FILTER\");\n+    expect(mockPrisma.generatedAsset.findMany).not.toHaveBeenCalled();\n+    expect(mockPrisma.generatedAsset.count).not.toHaveBeenCalled();\n+  });\n+\n+  it(\"мһҳлӘ»лҗң status вҶ’ 400 INVALID_FILTER, prisma лҜём ‘к·ј\", async () => {\n+    const res = await GET(buildGetRequest(\"/api/assets\", { status: \"compelted\" }));\n+    const body = await readJson<{ code: string }>(res);\n+\n+    expect(res.status).toBe(400);\n+    expect(body.code).toBe(\"INVALID_FILTER\");\n+    expect(mockPrisma.generatedAsset.findMany).not.toHaveBeenCalled();\n+  });\n+\n+  it(\"мҶҢл¬ёмһҗ status=completedлҠ” м •мғҒ нҶөкіјн•ңлӢӨ (asset-loader мҶҢл№„мІҳ л¬ҙнҡҢк·Җ)\", async () => {\n+    const res = await GET(buildGetRequest(\"/api/assets\", { status: \"completed\" }));\n+\n+    expect(res.status).toBe(200);\n+    const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\n+      where: Record<string, unknown>;\n+    };\n+    expect(arg.where.status).toBe(\"COMPLETED\");\n+  });\n+\n+  it(\"лӘЁл“  AssetType enum к°’мқ„ н—Ҳмҡ©н•ңлӢӨ\", async () => {\n+    for (const t of [\"character\", \"tileset\", \"object\", \"map\"]) {\n+      mockPrisma.generatedAsset.findMany.mockClear();\n+      const res = await GET(buildGetRequest(\"/api/assets\", { type: t }));\n+      expect(res.status).toBe(200);\n+      const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\n+        where: Record<string, unknown>;\n+      };\n+      expect(arg.where.type).toBe(t.toUpperCase());\n+    }\n+  });\n+\n+  it(\"м•һл’Ө кіөл°ұмқ„ trim нӣ„ кІҖмҰқн•ңлӢӨ\", async () => {\n+    const res = await GET(\n+      buildGetRequest(\"/api/assets\", { type: \"  character  \" })\n+    );\n+\n+    expect(res.status).toBe(200);\n+    const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\n+      where: Record<string, unknown>;\n+    };\n+    expect(arg.where.type).toBe(\"CHARACTER\");\n+  });\n+\n+  it(\"кіөл°ұ-only к°’мқҖ лҜём§Җм •кіј лҸҷмқј м·Ёкёү(н•„н„° лҜём Ғмҡ©, 400 м•„лӢҳ)\", async () => {\n+    // codex r1: trim нӣ„ л№„л©ҙ л№Ҳк°’мІҳлҹј н•„н„° лҜём Ғмҡ© вҖ” 400мңјлЎң кұ°м Ҳн•ҳм§Җ м•ҠлҠ”лӢӨ.\n+    const res = await GET(buildGetRequest(\"/api/assets\", { type: \"   \" }));\n+\n+    expect(res.status).toBe(200);\n+    const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\n+      where: Record<string, unknown>;\n+    };\n+    expect(arg.where.type).toBeUndefined();\n+  });\n+\n+  it(\"мӨ‘ліө нҢҢлқјлҜён„°мқҳ invalid к°’лҸ„ кІҖмҰқн•ңлӢӨ (getAll м „мҲҳ вҖ” кІҖмҰқ мҡ°нҡҢ м°ЁлӢЁ)\", async () => {\n+    // codex r2: get()мқҖ мІ« к°’л§Ң лҙҗ invalid 2лІҲм§ё к°’мқҙ мҲЁмқҢ вҶ’ getAllлЎң м „мҲҳ кІҖмҰқ.\n+    const resType = await GET(buildRawRequest(\"type=character&type=weapon\"));\n+    expect(resType.status).toBe(400);\n+\n+    const resStatus = await GET(\n+      buildRawRequest(\"status=COMPLETED&status=compelted\")\n+    );\n+    expect(resStatus.status).toBe(400);\n+\n+    expect(mockPrisma.generatedAsset.findMany).not.toHaveBeenCalled();\n+  });\n+\n+  it(\"мӨ‘ліө нҢҢлқјлҜён„°к°Җ лӘЁл‘җ мң нҡЁн•ҳл©ҙ мІ« к°’мңјлЎң н•„н„°н•ңлӢӨ\", async () => {\n+    const res = await GET(buildRawRequest(\"type=character&type=tileset\"));\n+\n+    expect(res.status).toBe(200);\n+    const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\n+      where: Record<string, unknown>;\n+    };\n+    expect(arg.where.type).toBe(\"CHARACTER\");\n+  });\n+\n+  it(\"limit лҜём§Җм • вҶ’ take 20 (кё°мЎҙ default ліҙмЎҙ)\", async () => {\n+    await GET(buildGetRequest(\"/api/assets\"));\n+\n+    const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\n+      take: number;\n+    };\n+    expect(arg.take).toBe(20);\n+  });\n+\n+  it(\"кіјлҢҖ limit вҶ’ 100мңјлЎң cap\", async () => {\n+    await GET(buildGetRequest(\"/api/assets\", { limit: \"100000\" }));\n+\n+    const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\n+      take: number;\n+    };\n+    expect(arg.take).toBe(100);\n+  });\n+\n+  it(\"л№„м •мҲҳ limit вҶ’ 20мңјлЎң м •к·ңнҷ”\", async () => {\n+    await GET(buildGetRequest(\"/api/assets\", { limit: \"abc\" }));\n+\n+    const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\n+      take: number;\n+    };\n+    expect(arg.take).toBe(20);\n+  });\n+\n+  it(\"page=0/мқҢмҲҳ/л№„м •мҲҳ вҶ’ 1лЎң нҒҙлһЁн”„, skipмқҖ мқҢмҲҳк°Җ лҗҳм§Җ м•ҠлҠ”лӢӨ\", async () => {\n+    for (const p of [\"0\", \"-5\", \"abc\"]) {\n+      mockPrisma.generatedAsset.findMany.mockClear();\n+      await GET(buildGetRequest(\"/api/assets\", { page: p, limit: \"10\" }));\n+\n+      const arg = mockPrisma.generatedAsset.findMany.mock.calls[0][0] as {\n+        skip: number;\n+      };\n+      expect(arg.skip).toBe(0);\n+    }\n+  });\n+\n+  it(\"мқ‘лӢө pagination.pageлҠ” м •к·ңнҷ”лҗң pageлҘј л°ҳмҳҒн•ңлӢӨ\", async () => {\n+    const res = await GET(buildGetRequest(\"/api/assets\", { page: \"-3\" }));\n+    const body = await readJson<{ pagination: { page: number } }>(res);\n+\n+    expect(body.pagination.page).toBe(1);\n+  });\n+});\n+\n describe(\"GET /api/assets вҖ” м—җлҹ¬ мІҳлҰ¬\", () => {\n   it(\"prisma мҳҲмҷё мӢң 500 нҸҙл°ұ\", async () => {\n     mockAuth.mockResolvedValue(makeSession({ id: \"owner-1\" }));\n","exit_code":0,"status":"completed"}}
