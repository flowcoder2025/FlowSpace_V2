e(USER_PREFIX.length);\r\n  31:     return userId.length > 0 ? { kind: \"user\", userId } : null;\r\n  32:   }\r\n  33:   if (identity.startsWith(GUEST_PREFIX)) {\r\n  34:     const guestSessionId = identity.slice(GUEST_PREFIX.length);\r\n  35:     return guestSessionId.length > 0\r\n  36:       ? { kind: \"guest\", guestSessionId }\r\n  37:       : null;\r\n  38:   }\r\n  39:   return null;\r\n  40: }\r\n  41: \r\n  42: /** ë§ˆì´???¸ì— ?±ì´ publish?˜ëŠ” source??canPublishSources allowlist êµ¬ì„±??. */\r\n  43: const NON_MIC_PUBLISH_SOURCES: readonly TrackSource[] = [\r\n  44:   TrackSource.CAMERA,\r\n  45:   TrackSource.SCREEN_SHARE,\r\n  46:   TrackSource.SCREEN_SHARE_AUDIO,\r\n  47: ];\r\n  48: \r\n  49: /** ì°¸ê????¸ëž™ ëª©ë¡?ì„œ ë§ˆì´???¸ëž™??ì°¾ëŠ”??sid + ?„ìž¬ muted). ?†ìœ¼ë©?null. */\r\n  50: export function findMicrophoneTrack(\r\n  51:   tracks: ReadonlyArray<{ sid: string; source: TrackSource; muted: boolean }>\r\n  52: ): { sid: string; muted: boolean } | null {\r\n  53:   const mic = tracks.find((t) => t.source === TrackSource.MICROPHONE);\r\n  54:   return mic ? { sid: mic.sid, muted: mic.muted } : null;\r\n  55: }\r\n  56: \r\n  57: /**\r\n  58:  * ?Œì†Œê±???canPublishSources ?¬ê³„??\r\n  59:  * LiveKit ?œë§¨?? `[]`=?„ì²´ ?ˆìš©, non-empty=ëª…ì‹œ allowlist.\r\n  60:  * - ?„ìž¬ `[]`(?„ì²´ ?ˆìš©) ??ë§ˆì´?¬ë§Œ ?œì™¸??ëª…ì‹œ ëª©ë¡?¼ë¡œ ì¢ížŒ??\r\n  61:  * - non-empty ??ë§ˆì´?¬ë§Œ ?„í„°ë§??¤ë¥¸ source ?œí•œ?€ ë³´ì¡´ ??codex risk #1).\r\n  62:  */\r\n  63: export function computePublishSourcesForMute(\r\n  64:   current: readonly TrackSource[]\r\n  65: ): TrackSource[] {\r\n  66:   const base =\r\n  67:     current.length === 0\r\n  68:       ? [...NON_MIC_PUBLISH_SOURCES, TrackSource.MICROPHONE]\r\n  69:       : current;\r\n  70:   return base.filter((s) => s !== TrackSource.MICROPHONE);\r\n  71: }\r\n  72: \r\n  73: /**\r\n  74:  * ?Œì†Œê±??´ì œ ??canPublishSources ?¬ê³„??ê¶Œí•œ ë³µì›ë§???force-unmute ?„ë‹˜).\r\n  75:  * - ?„ìž¬ `[]`(?„ì²´ ?ˆìš©) ??`[]` ? ì?(ë§ˆì´???´ë? ?ˆìš©, idempotent no-op).\r\n  76:  * - non-empty ??ë§ˆì´???†ìœ¼ë©?ì¶”ê?, ?ˆìœ¼ë©?ê·¸ë?ë¡??¤ë¥¸ source ?œí•œ ë³´ì¡´).\r\n  77:  */\r\n  78: export function computePublishSourcesForUnmute(\r\n  79:   current: readonly TrackSource[]\r\n  80: ): TrackSource[] {\r\n  81:   if (current.length === 0) return [];\r\n  82:   return current.includes(TrackSource.MICROPHONE)\r\n  83:     ? [...current]\r\n  84:     : [...current, TrackSource.MICROPHONE];\r\n  85: }\r\n  86: \r\n  87: /**\r\n  88:  * updateParticipant???˜ê¸¸ permission??ë§Œë“ ??\r\n  89:  * ? ï¸ LiveKit permission?€ atomic(\"all desired permissions would need to be set\")?´ë¼\r\n  90:  * **ë¯¸ì—´ê±??„ë“œ??falseë¡?ë¦¬ì…‹?œë‹¤**. ParticipantPermission?ëŠ” canPublishSources ?¸ì—?? * canSubscribe/canPublish/canPublishData/hidden/recorder/canUpdateMetadata/agent/\r\n  91:  * canSubscribeMetrics/canManageAgentSession???ˆìœ¼ë¯€ë¡? ?„ìž¬ permission???ˆìœ¼ë©? * **?„ì²´ë¥?ê·¸ë?ë¡?ë³´ì¡´?˜ê³  canPublishSourcesë§?* ë§ˆì´??add/removeë¡???–´?´ë‹¤\r\n  92:  * (codex risk #1: ?Œì„± ?Œì†Œê±°ê? ?¤ë¥¸ ê¶Œí•œ/?œìž¬ë¥??¤ìˆ˜ë¡??´ì œ?˜ëŠ” ê²?ë°©ì?).\r\n  93:  * ?„ìž¬ permission???†ì„ ?Œë§Œ ? í° ?¼ìš°??grant?€ ?™ì¼??ê¸°ë³¸ê°’ì„ ?©ì„±?œë‹¤.\r\n  94:  */\r\n  95: export function buildModeratedPermission(\r\n  96:   current: Partial<ParticipantPermission> | undefined,\r\n  97:   muted: boolean\r\n  98: ): Partial<ParticipantPermission> {\r\n  99:   const sources = current?.canPublishSources ?? [];\r\n 100:   const canPublishSources = muted\r\n 101:     ? computePublishSourcesForMute(sources)\r\n 102:     : computePublishSourcesForUnmute(sources);\r\n 103:   if (current) {\r\n 104:     return { ...current, canPublishSources };\r\n 105:   }\r\n 106:   return {\r\n 107:     canSubscribe: true,\r\n 108:     canPublish: true,\r\n 109:     canPublishData: true,\r\n 110:     hidden: false,\r\n 111:     canPublishSources,\r\n 112:   };\r\n 113: }\r\n","exit_code":0,"status":"completed"}}
