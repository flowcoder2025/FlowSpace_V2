antName,\r\n 273:       apiKey,\r\n 274:       apiSecret\r\n 275:     );\r\n 276: \r\n 277:     // 6. ? í° ?ì„±\r\n 278:     const token = new AccessToken(apiKey, apiSecret, {\r\n 279:       identity: serverParticipantId,\r\n 280:       name: serverParticipantName,\r\n 281:       ttl: 60 * 60 * 4, // 4 hours\r\n 282:     });\r\n 283: \r\n 284:     token.addGrant({\r\n 285:       room: roomName,\r\n 286:       roomJoin: true,\r\n 287:       canPublish: true,\r\n 288:       canSubscribe: true,\r\n 289:       canPublishData: true,\r\n 290:     });\r\n 291: \r\n 292:     const jwt = await token.toJwt();\r\n 293: \r\n 294:     if (IS_DEV) {\r\n 295:       console.log(\"[LiveKit Token] Token generated for:\", {\r\n 296:         roomName,\r\n 297:         participantId: serverParticipantId,\r\n 298:         participantName: serverParticipantName,\r\n 299:       });\r\n 300:     }\r\n 301: \r\n 302:     return NextResponse.json({\r\n 303:       token: jwt,\r\n 304:       participantId: serverParticipantId,\r\n 305:       participantName: serverParticipantName,\r\n 306:     });\r\n 307:   } catch (error) {\r\n 308:     console.error(\"[LiveKit Token] Error:\", error);\r\n 309:     return NextResponse.json(\r\n 310:       { error: \"Failed to generate token\" },\r\n 311:       { status: 500 }\r\n 312:     );\r\n 313:   }\r\n 314: }\r\n","exit_code":0,"status":"completed"}}
