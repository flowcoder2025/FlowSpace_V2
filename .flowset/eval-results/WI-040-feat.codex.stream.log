=> clearTimeout(timer);\r\n    }\r\n  }, [autoFocus]);\r\n\r\n  // WI-040: ?¸ë? ê·“ì†ë§?prefill ???…ë ¥ì°½ì— `/?‰ë„¤??`??ì±„ìš°ê³?caret???ì— ?ê³  ?¬ì»¤??\r\n  // prefill ê°ì²´??ChatPanel state(?´ë²¤?¸ë§ˆ????refÂ·token++)??unrelated ë¦¬ë Œ?”ì—” ?¬ì‹¤??????\r\n  // setState/focusë¥?rAFë¡?ë¯¸ë¤„ effect ë³¸ë¬¸ ?™ê¸° setState(set-state-in-effect ë¦°íŠ¸)ë¥??¼í•˜ê³?\r\n  // ì¡°ê±´ë¶€ ë§ˆìš´??ì§í›„ ref ?ˆì •????caret???ì— ?”ë‹¤(unmount/?°ì† prefill ??cleanup??ì·¨ì†Œ).\r\n  useEffect(() => {\r\n    if (!prefill) return;\r\n    const raf = requestAnimationFrame(() => {\r\n      setInput(prefill.value);\r\n      setWhisperIdx(-1);\r\n      const el = inputRef.current;\r\n      if (!el) return;\r\n      el.focus();\r\n      el.setSelectionRange(prefill.value.length, prefill.value.length);\r\n    });\r\n    return () => cancelAnimationFrame(raf);\r\n  }, [prefill]);\r\n\r\n\r\n  const handleSend = useCallback(() => {\r\n    const trimmed = input.trim();\r\n    if (trimmed.length === 0) {\r\n      // ë¹??…ë ¥ + Enter ??ë¹„í™œ?±í™”\r\n      onEscape?.();\r\n      return;\r\n    }\r\n    onSend(trimmed);\r\n    setInput(\"\");\r\n    setWhisperIdx(-1);\r\n    // ?„ì†¡ ??ë¹„í™œ?±í™” (?ˆê±°???¨í„´)\r\n    onEscape?.();\r\n  }, [input, onSend, onEscape]);\r\n\r\n  const handleKeyDown = useCallback(\r\n    (e: KeyboardEvent<HTMLInputElement>) => {\r\n      if (e.key === \"Enter\" && !e.shiftKey) {\r\n        e.preventDefault();\r\n        handleSend();\r\n        return;\r\n      }\r\n      if (e.key === \"Escape\") {\r\n        onCancelReply();\r\n        inputRef.current?.blur();\r\n        onEscape?.();\r\n        return;\r\n      }\r\n\r\n      // ê·“ì†ë§??ˆìŠ¤? ë¦¬ ?ìƒ‰ (/ ?œìž‘ ???‘â†“)\r\n      if (whisperHistory.length > 0 && input.startsWith(\"/\")) {\r\n        if (e.key === \"ArrowUp\") {\r\n          e.preventDefault();\r\n          const nextIdx = Math.min(whisperIdx + 1, whisperHistory.length - 1);\r\n          setWhisperIdx(nextIdx);\r\n          setInput(`/$