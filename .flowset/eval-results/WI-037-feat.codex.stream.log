 []);\r\n  39: \r\n  40:   const closeModal = useCallback(() => {\r\n  41:     // 삭제 진행 중에는 닫기/취소 차단(중도 이탈로 인한 혼동·중복요청 방지).\r\n  42:     if (isDeleting) return;\r\n  43:     setIsOpen(false);\r\n  44:     setConfirmInput(\"\");\r\n  45:     setError(null);\r\n  46:   }, [isDeleting]);\r\n  47: \r\n  48:   // ESC로 모달 닫기(dialog 접근성).\r\n  49:   useEffect(() => {\r\n  50:     if (!isOpen) return;\r\n  51:     const handler = (e: KeyboardEvent) => {\r\n  52:       if (e.key === \"Escape\") closeModal();\r\n  53:     };\r\n  54:     document.addEventListener(\"keydown\", handler);\r\n  55:     return () => document.removeEventListener(\"keydown\", handler);\r\n  56:   }, [isOpen, closeModal]);\r\n  57: \r\n  58:   async function handleDelete() {\r\n  59:     if (!canConfirm) return;\r\n  60:     setIsDeleting(true);\r\n  61:     setError(null);\r\n  62:     try {\r\n  63:       const res = await fetch(`/api/spaces/${spaceId}`, { method: \"DELETE\" });\r\n  64:       if (!res.ok) {\r\n  65:         const data = (await res.json().catch(() => ({}))) as { error?: string };\r\n  66:         setError(data.error || COPY.deleteError);\r\n  67:         setIsDeleting(false);\r\n  68:         return;\r\n  69:       }\r\n  70:       // 성공(이미 archived인 멱등 200 포함) → 목록으로 이동.\r\n  71:       // replace로 삭제된 스페이스의 설정 페이지를 뒤로가기 이력에서 제거한다.\r\n  72:       // isDeleting을 리셋하지 않아 네비게이션 동안 버튼이 잠긴 상태를 유지(중복 제출 방지).\r\n  73:       router.replace(\"/my-spaces\");\r\n  74:     } catch {\r\n  75:       setError(COPY.deleteError);\r\n  76:       setIsDeleting(false);\r\n  77:     }\r\n  78:   }\r\n  79: \r\n  80:   return (\r\n  81:     <div className=\"max-w-2xl rounded-lg border border-red-200 bg-red-50/50 p-6\">\r\n  82:       <h2 className=\"text-base font-semibold text-red-700\">{COPY.title}</h2>\r\n  83:       <p className=\"mt-1 text-sm text-ink-soft\">{COPY.description}</p>\r\n  84:       <button\r\n  85:         type=\"button\"\r\n  86:         onClick={openModal}\r\n  87:         className=\"mt-4 rounded-md border border-red-300 bg-white px-4 py-2 text-sm font-medium text-red-700 transition-colors hover:bg-red-100\"\r\n  88:       >\r\n  89:         {COPY.deleteButton}\r\n  90:       </button>\r\n  91: \r\n  92:       {isOpen && (\r\n  93:         <div\r\n  94:           className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4\"\r\n  95:           onClick={closeModal}\r\n  96:         >\r\n  97:           <div\r\n  98:             role=\"dialog\"\r\n  99:             aria-modal=\"true\"\r\n 100:             aria-labelledby=\"delete-space-title\"\r\n 101:             className=\"w-full max-w-md rounded-lg bg-white p-6 shadow-xl\"\r\n 102:             onClick={(e) => e.stopPropagation()}\r\n 103:           >\r\n 104:             <h3 id=\"delete-space-title\" className=\"text-lg font-bold text-ink\">\r\n 105:               {COPY.modalTitle}\r\n 106:             </h3>\r\n 107:             <p className=\"mt-2 text-sm leading-relaxed text-ink-soft\">{COPY.modalWarning}</p>\r\n 108:             <p className=\"mt-4 text-sm text-ink-soft\">{COPY.confirmPrompt}</p>\r\n 109:             <p className=\"mt-1 select-all break-all rounded bg-cream-deep px-3 py-2 font-mono text-sm text-ink\">\r\n 110:               {spaceName}\r\n 111:             </p>\r\n 112:             <input\r\n 113:               type=\"text\"\r\n 114:               value={confirmInput}\r\n 115:               onChange={(e) => setConfirmInput(e.target.value)}\r\n 116:               placeholder={COPY.confirmPlaceholder}\r\n 117:               autoFocus\r\n 118:               disabled={isDeleting}\r\n 119:               aria-label={COPY.confirmPlaceholder}\r\n 120:               className=\"mt-3 w-full rounded-md border border-line px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-300 disabled:opacity-50\"\r\n 121:             />\r\n 122:             {error && <p className=\"mt-2 text-sm text-red-600\">{error}</p>}\r\n 123:             <div className=\"mt-5 flex justify-end gap-2\">\r\n 124:               <button\r\n 125:                 type=\"button\"\r\n 126:                 onClick={closeModal}\r\n 127:                 disabled={isDeleting}\r\n 128:                 className=\"rounded-md border border-line px-4 py-2 text-sm text-ink-soft transition-colors hover:bg-cream-deep disabled:opacity-50\"\r\n 129:               >\r\n 130:                 {COPY.cancel}\r\n 131:               </button>\r\n 132:               <button\r\n 133:                 type=\"button\"\r\n 134:                 onClick={handleDelete}\r\n 135:                 disabled={!canConfirm}\r\n 136:                 className=\"rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-red-500 disabled:cursor-not-allowed disabled:opacity-50\"\r\n 137:               >\r\n 138:                 {isDeleting ? COPY.deleting : COPY.confirm}\r\n 139:               </button>\r\n 140:             </div>\r\n 141:           </div>\r\n 142:         </div>\r\n 143:       )}\r\n 144:     </div>\r\n 145:   );\r\n 146: }\r\n","exit_code":0,"status":"completed"}}
