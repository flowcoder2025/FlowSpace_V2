{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FlowSpace dual-verification review output (codex | evaluator)",
  "type": "object",
  "additionalProperties": false,
  "required": ["reviewer", "schemaVersion", "scores", "weightedTotal", "verdict", "issues"],
  "properties": {
    "reviewer": { "type": "string", "enum": ["codex", "evaluator"] },
    "schemaVersion": { "type": "integer", "enum": [1] },
    "scores": {
      "description": "evaluator 4축 점수(0~10). codex는 null.",
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["completeness", "consistency", "specificity", "actionability"],
          "properties": {
            "completeness": { "type": "number", "minimum": 0, "maximum": 10 },
            "consistency": { "type": "number", "minimum": 0, "maximum": 10 },
            "specificity": { "type": "number", "minimum": 0, "maximum": 10 },
            "actionability": { "type": "number", "minimum": 0, "maximum": 10 }
          }
        }
      ]
    },
    "weightedTotal": {
      "description": "evaluator 가중 총점(0~10). codex는 null.",
      "oneOf": [{ "type": "null" }, { "type": "number", "minimum": 0, "maximum": 10 }]
    },
    "verdict": { "type": "string", "enum": ["PASS", "WARNING", "FAIL"] },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "location", "description", "recommendation", "defer", "deferRationale", "fixNow"],
        "properties": {
          "severity": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
          "location": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "recommendation": { "type": "string" },
          "defer": { "type": "boolean" },
          "deferRationale": { "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }] },
          "fixNow": { "type": "boolean" }
        }
      }
    }
  }
}
