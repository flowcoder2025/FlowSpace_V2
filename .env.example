# ============================================
# Database (Prisma)
# ============================================
# 로컬 PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/flowspace"
DIRECT_URL="postgresql://user:password@localhost:5432/flowspace"
# Supabase 사용 시 (Transaction Pooler → pgbouncer=true 필수)
# DATABASE_URL="postgresql://...@pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://...@pooler.supabase.com:5432/postgres"

# ============================================
# NextAuth
# ============================================
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# ============================================
# OAuth Providers (optional)
# ============================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================
# Socket.io
# ============================================
SOCKET_PORT=3001
NEXT_PUBLIC_SOCKET_PORT=3001
# 프로덕션: 별도 서브도메인 사용 시 (NEXT_PUBLIC_SOCKET_PORT 대신)
# NEXT_PUBLIC_SOCKET_URL=https://v2-socket.flow-coder.com

# 실시간 제재 전파(ban/kick/mute/unmute/changeRole) — Next API → socket 서버 내부 채널 (WI-005)
# SOCKET_INTERNAL_SECRET: enforce 요청 HMAC 서명 키. AUTH_SECRET 과 반드시 분리(강제 추방 권한).
#   openssl rand -base64 32 로 생성. 양쪽(Next, socket 서버)에 동일 값 설정.
# SOCKET_INTERNAL_URL: Next API 가 호출할 socket 서버 base URL. 미설정 시 실시간 반영 생략
#   (DB 만 반영, 재접속 시 join 게이트가 차단). 프로덕션은 반드시 설정.
SOCKET_INTERNAL_SECRET="generate-with-openssl-rand-base64-32"
SOCKET_INTERNAL_URL="http://localhost:3001"

# ============================================
# LiveKit
# ============================================
LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
# NEXT_PUBLIC_SKIP_LIVEKIT_IN_DEV=true  # dev에서 LiveKit 비활성화

# ============================================
# ComfyUI Asset Pipeline
# ============================================
COMFYUI_URL="http://localhost:8001"
COMFYUI_MODE="auto"
# COMFYUI_MODE: auto(기본) | mock(목업) | real(실제 서버)
